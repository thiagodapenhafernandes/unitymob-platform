<% content_for :title, "Configurações da Conta" %>

<%# Ícone no cabeçalho de cada card (título aceita HTML no ax_operational_panel). %>
<% panel_title = ->(icon, text) { safe_join([tag.i(class: "bi #{icon}"), text], " ") } %>

<div class="layout-settings-workspace">
  <div class="tw-mb-4">
    <h1 class="ax-page-title tw-flex tw-items-center tw-gap-2">
      <i class="bi bi-building-gear" style="color: var(--admin-primary);"></i>Configurações da Conta
    </h1>
    <p class="ax-page-subtitle">Tudo que é da conta em um lugar: marca, equipe e permissões, notificações, segurança, auditorias e compliance.</p>
  </div>

  <%# ---- Identidade da conta (único bloco editável — destacado no topo) ---- %>
  <%= ax_operational_panel(eyebrow: "Empresa", title: panel_title.call("bi-building", "Identidade da conta"), class_name: "tw-mb-4") do %>
    <div class="ax-panel-body">
      <div class="tw-grid tw-gap-4 md:tw-grid-cols-2">
        <div>
          <span class="ax-label">Nome de exibição</span>
          <p class="tw-mt-1 tw-mb-1 tw-text-base tw-font-semibold tw-text-ink">
            <%= LayoutSetting.instance.site_name.presence || "Não definido" %>
          </p>
          <p class="ax-field__hint tw-mt-0">
            Aparece no site, nos cartões de apresentação e no <code>{empresa}</code>.
            <% if can?(:manage, :marketing) %>
              Editável em <%= link_to "Identidade e Marca", edit_admin_layout_setting_path, class: "tw-text-primary" %>.
            <% end %>
          </p>
        </div>

        <% if current_admin_user.tenant_owner? %>
          <div>
            <%= form_with url: admin_account_settings_path, method: :patch, class: "tw-flex tw-items-end tw-gap-2 tw-flex-wrap" do %>
              <div class="tw-flex-1 tw-min-w-0">
                <label class="ax-label" for="tenant_name">Nome interno da conta</label>
                <%= text_field_tag "tenant[name]", current_tenant.name, id: "tenant_name", class: "ax-input tw-w-full", maxlength: 80, required: true %>
              </div>
              <button type="submit" class="ax-btn ax-btn--sm ax-btn--primary">Salvar</button>
            <% end %>
            <p class="ax-field__hint">Uso administrativo (relatórios e painel do sistema). Não aparece para clientes.</p>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ---- Cards de navegação ---- %>
  <div class="tw-grid tw-gap-4 lg:tw-grid-cols-2 xl:tw-grid-cols-3">
    <% if can?(:manage, :marketing) %>
      <%= ax_operational_panel(eyebrow: "Marca", title: panel_title.call("bi-palette", "Identidade e Marca")) do %>
        <div class="ax-panel-body">
          <p class="ax-field__hint tw-mt-0">Logotipo, cores e apresentação do sistema e do site.</p>
          <%= link_to edit_admin_layout_setting_path, class: "ax-btn ax-btn--sm" do %>
            <i class="bi bi-palette ax-ico"></i><span>Abrir Identidade e Marca</span>
          <% end %>
        </div>
      <% end %>
    <% end %>

    <% if can?(:view, :corretores) || current_admin_user.tenant_owner? %>
      <%= ax_operational_panel(eyebrow: "Equipe", title: panel_title.call("bi-people", "Equipe & Permissões")) do %>
        <div class="ax-panel-body">
          <p class="ax-field__hint tw-mt-0">Usuários da conta, perfis de acesso e convites externos.</p>
          <div class="tw-flex tw-flex-wrap tw-gap-2">
            <% if can?(:view, :corretores) %>
              <%= link_to admin_admin_users_path, class: "ax-btn ax-btn--sm" do %>
                <i class="bi bi-people ax-ico"></i><span>Usuários</span>
              <% end %>
            <% end %>
            <% if current_admin_user.tenant_owner? %>
              <%= link_to admin_profiles_path, class: "ax-btn ax-btn--sm" do %>
                <i class="bi bi-shield-lock ax-ico"></i><span>Perfis de acesso</span>
              <% end %>
            <% end %>
            <% if can?(:manage, :corretores) %>
              <%= link_to admin_account_memberships_path, class: "ax-btn ax-btn--sm" do %>
                <i class="bi bi-person-plus ax-ico"></i><span>Acessos externos</span>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>

    <% if can?(:manage, :integracoes) %>
      <%= ax_operational_panel(eyebrow: "Canais", title: panel_title.call("bi-bell", "Notificações")) do %>
        <div class="ax-panel-body">
          <p class="ax-field__hint tw-mt-0">Servidor de e-mail (SMTP) desta conta para envios de leads e avisos.</p>
          <div class="tw-flex tw-flex-wrap tw-gap-2">
            <%= link_to edit_admin_email_setting_path, class: "ax-btn ax-btn--sm" do %>
              <i class="bi bi-envelope-at ax-ico"></i><span>Meu SMTP</span>
            <% end %>
          </div>
          <p class="ax-field__hint">Push e transportes globais de notificação são configurados pelo Admin do Sistema.</p>
        </div>
      <% end %>
    <% end %>

    <% if can?(:manage, :access_security) %>
      <%= ax_operational_panel(eyebrow: "Segurança", title: panel_title.call("bi-fingerprint", "Segurança de Acesso")) do %>
        <div class="ax-panel-body">
          <p class="ax-field__hint tw-mt-0">Políticas de sessão, IPs, aparelhos confiáveis e 2FA da equipe.</p>
          <div class="tw-flex tw-flex-wrap tw-gap-2">
            <%= link_to admin_access_security_path, class: "ax-btn ax-btn--sm" do %>
              <i class="bi bi-fingerprint ax-ico"></i><span>Abrir Segurança de Acesso</span>
            <% end %>
            <%= link_to admin_two_factor_settings_path, class: "ax-btn ax-btn--sm" do %>
              <i class="bi bi-shield-lock ax-ico"></i><span>Verificação em duas etapas</span>
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>

    <% if can?(:view, :field_audit) || can?(:view, :access_audit) || can?(:view, :data_export_audit) %>
      <%= ax_operational_panel(eyebrow: "Compliance", title: panel_title.call("bi-clipboard-check", "Auditorias")) do %>
        <div class="ax-panel-body">
          <p class="ax-field__hint tw-mt-0">Trilhas de acesso, campo, apresentações e exportações de dados.</p>
          <div class="tw-flex tw-flex-wrap tw-gap-2">
            <% if can?(:view, :field_audit) %>
              <%= link_to admin_field_audit_logs_path, class: "ax-btn ax-btn--sm" do %>
                <i class="bi bi-shield-lock-fill ax-ico"></i><span>Campo</span>
              <% end %>
            <% end %>
            <% if can?(:view, :access_audit) %>
              <%= link_to admin_access_audit_logs_path, class: "ax-btn ax-btn--sm" do %>
                <i class="bi bi-person-lock ax-ico"></i><span>Acessos</span>
              <% end %>
              <%= link_to admin_presentation_audit_logs_path, class: "ax-btn ax-btn--sm" do %>
                <i class="bi bi-person-badge ax-ico"></i><span>Apresentações WhatsApp</span>
              <% end %>
            <% end %>
            <% if can?(:view, :data_export_audit) %>
              <%= link_to admin_data_export_audit_logs_path, class: "ax-btn ax-btn--sm" do %>
                <i class="bi bi-file-earmark-arrow-down ax-ico"></i><span>Exportações</span>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>

    <% if can?(:view, :whatsapp_campaigns) %>
      <%= ax_operational_panel(eyebrow: "WhatsApp", title: panel_title.call("bi-whatsapp", "Compliance WhatsApp")) do %>
        <div class="ax-panel-body">
          <p class="ax-field__hint tw-mt-0">Contatos importados por CSV e descadastros (opt-out) dos disparos.</p>
          <div class="tw-flex tw-flex-wrap tw-gap-2">
            <%= link_to admin_whatsapp_campaign_recipients_path, class: "ax-btn ax-btn--sm" do %>
              <i class="bi bi-table ax-ico"></i><span>Importados CSV</span>
            <% end %>
            <%= link_to admin_whatsapp_campaign_unsubscribes_path, class: "ax-btn ax-btn--sm" do %>
              <i class="bi bi-person-dash ax-ico"></i><span>Descadastros</span>
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
