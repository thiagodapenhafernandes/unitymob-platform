<div class="integration-workspace ai-integration-workspace">
<%= ax_workspace_heading(
      eyebrow: "Integrações · Conteúdo",
      icon: "stars",
      title: "IA",
      pills: [@openai_connected ? "conectada" : "configuração pendente"],
      subtitle: "Configure o provedor e acompanhe a geração assistida de conteúdo dos imóveis.",
      metrics: [
        { value: number_with_delimiter(@pending_suggestions_count), label: "pendentes" },
        { value: number_with_delimiter(@failed_suggestions_count), label: "falhas" }
      ]
    ) %>

<div class="integration-split-layout">
  <main class="integration-split-layout__main">
    <%= ax_panel(title: "Configuração do provedor", subtitle: "Credencial, modelo e instrução principal.", actions: ax_badge(@openai_connected ? "conectada" : "aguardando token", tone: @openai_connected ? :green : :amber)) do %>
        <%= ax_inline_notice(tone: @openai_connected ? :success : :warning, icon: @openai_connected ? "check-circle" : "exclamation-triangle") do %>
          <span>
            Status:
            <strong><%= @openai_connected ? "Conectado" : "Aguardando token" %></strong>
          </span>
        <% end %>

        <%= form_with url: admin_ai_integration_path, method: :patch, scope: :ai, local: true do |f| %>
          <div class="tw-mb-3">
            <%= f.label :api_key, "Token da OpenAI", class: "ax-label tw-font-semibold" %>
            <%= f.password_field :api_key,
                class: "ax-control",
                autocomplete: "off",
                placeholder: (@openai_connected ? "Token já configurado. Preencha apenas para substituir." : "Cole o token da OpenAI") %>
            <div class="ax-field-hint">Preencha somente para configurar ou substituir a credencial atual.</div>
          </div>

          <div class="tw-mb-3">
            <%= f.label :model, "Modelo", class: "ax-label tw-font-semibold" %>
            <%= f.text_field :model, class: "ax-control", value: @openai_model %>
            <div class="ax-field-hint">Padrão: <code><%= Ai::PropertyContentService::DEFAULT_MODEL %></code>.</div>
          </div>

          <div class="tw-mb-3">
            <%= f.label :property_enrichment_prompt, "Instruções para autopreenchimento e enriquecimento", class: "ax-label tw-font-semibold" %>
            <%= f.text_area :property_enrichment_prompt,
                class: "ax-control font-monospace",
                rows: 18,
                value: @openai_prompt %>
            <div class="ax-field-hint">
              Este texto é a instrução principal usada pela IA. Alterações aqui passam a valer para as próximas sugestões.
            </div>
          </div>

          <%= f.submit "Salvar Configurações", class: "ax-btn ax-btn--primary" %>
        <% end %>
    <% end %>
  </main>

  <aside class="integration-split-layout__aside">
    <%= ax_operational_panel(eyebrow: "Operação", title: "Geração em lote", actions: ax_badge(@batch_status, tone: @batch_status == "failed" ? :red : :blue)) do %>
        <p class="tw-text-sm tw-text-ink-muted">
          O lote gera sugestões de título e descrição para os imóveis, mas não aplica automaticamente. Cada sugestão precisa ser revisada e confirmada na edição do imóvel.
        </p>

        <div class="tw-mb-3">
          <div class="tw-flex tw-justify-between tw-text-sm tw-mb-1">
            <span>Status: <strong><%= @batch_status %></strong></span>
            <span><%= @batch_progress %>%</span>
          </div>
          <%= ax_progress(value: @batch_progress, tone: @batch_status == "failed" ? :red : :blue) %>
          <p class="tw-text-sm tw-text-ink-muted tw-mt-2 tw-mb-0"><%= @batch_message %></p>
          <% if @batch_last_at.present? %>
            <p class="tw-text-sm tw-text-ink-muted tw-mb-0">Última atualização: <%= l(@batch_last_at, format: :short) %></p>
          <% end %>
        </div>

        <%= ax_field_grid do %>
          <div class="ax-span-6">
            <div class="integration-stat-tile">
              <strong><%= number_with_delimiter(@pending_suggestions_count) %></strong>
              <div class="tw-text-sm tw-text-ink-muted">Sugestões pendentes</div>
            </div>
          </div>
          <div class="ax-span-6">
            <div class="integration-stat-tile">
              <strong><%= number_with_delimiter(@failed_suggestions_count) %></strong>
              <div class="tw-text-sm tw-text-ink-muted">Falhas</div>
            </div>
          </div>
        <% end %>

        <%= button_to generate_batch_admin_ai_integration_path,
            method: :post,
            class: "ax-btn ax-btn--ghost tw-w-full",
            data: { turbo_confirm: "Gerar sugestões para todos os imóveis em segundo plano? Nada será aplicado automaticamente." } do %>
          <i class="bi bi-magic ax-ico"></i>Gerar sugestões para todos os imóveis
        <% end %>
    <% end %>

    <%= ax_inline_notice(tone: :info, icon: "info-circle") do %>
      <strong>Fluxo seguro:</strong> a IA apenas sugere. Para alterar título, descrição e SEO do imóvel, abra a edição do imóvel e confirme a sugestão manualmente.
    <% end %>
  </aside>
</div>
</div>
