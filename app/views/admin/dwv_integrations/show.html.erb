<%= ax_workspace_heading(eyebrow: "Integrações · Estoque", icon: "hdd-network", title: "DWV", pills: [@dwv_enabled ? "ativa" : "inativa"], subtitle: "Monitore conexão, sincronização e disponibilidade do estoque de lançamentos.", metrics: [{ value: current_tenant.habitations.where(imovel_dwv: "Sim").count, label: "importados" }], actions: ax_button("Documentação", "https://api.dwvapp.com.br/", variant: :ghost, size: :sm, icon: "box-arrow-up-right", target: "_blank", rel: "noopener")) %>

<%= ax_field_grid do %>
  <div class="ax-span-6">
    <div class="ax-card tw-mb-4">
      <div class="ax-card__header">
        <div class="tw-flex tw-justify-between tw-items-center">
          <h5 class="ax-card__title tw-font-bold"><i class="bi bi-key dwv-integration-title-icon"></i>Configuração de Acesso</h5>
          <span class="ax-badge <%= @dwv_connected ? 'ax-badge--green' : 'ax-badge--gray' %>">
            <%= @dwv_connected ? "Conectado" : "Desconectado" %>
          </span>
        </div>
      </div>
      <div class="ax-card__body">
        <%= form_with url: admin_dwv_integrations_path, method: :patch, scope: :dwv, local: true do |f| %>
          <%= ax_switch_field(label: "Ativar integração DWV", form: f, method: :enabled, checked_value: "true", unchecked_value: "false", class_name: "tw-mb-3", input_html: { checked: @dwv_enabled }) %>

          <div class="tw-mb-3">
            <%= f.label :base_url, "URL base da API", class: "ax-label tw-font-semibold" %>
            <%= f.text_field :base_url, class: "ax-control", value: @dwv_base_url, placeholder: "https://agencies.dwvapp.com.br" %>
            <div class="dwv-integration-help">Use produção (`https://agencies.dwvapp.com.br`) ou sandbox (`https://apisandbox.dwvapp.com.br`).</div>
          </div>

          <div class="tw-mb-3">
            <%= f.label :api_token, "Token da API DWV", class: "ax-label tw-font-semibold" %>
            <%= f.password_field :api_token, class: "ax-control", autocomplete: "off", placeholder: (@dwv_api_token.present? ? "Token já configurado. Preencha apenas para substituir." : "Cole o token fornecido pela DWV") %>
          </div>

          <%= ax_field_grid do %>
            <div class="ax-span-6">
              <%= f.label :sync_limit, "Itens por página", class: "ax-label tw-font-semibold" %>
              <%= f.number_field :sync_limit, class: "ax-control", min: 1, max: 50, value: @dwv_sync_limit %>
            </div>
            <div class="ax-span-6">
              <%= f.label :sync_max_pages, "Máximo de páginas", class: "ax-label tw-font-semibold" %>
              <%= f.number_field :sync_max_pages, class: "ax-control", min: 1, max: 100, value: @dwv_sync_max_pages %>
            </div>
          <% end %>

          <%= ax_field_grid do %>
            <div class="ax-span-6">
              <%= f.label :request_pause_seconds, "Pausa entre requisições (s)", class: "ax-label tw-font-semibold" %>
              <%= f.number_field :request_pause_seconds, class: "ax-control", min: 0.2, max: 2.0, step: 0.05, value: @dwv_request_pause_seconds %>
              <div class="dwv-integration-help">Recomendado: 0.70 para alto desempenho com segurança no limite da API.</div>
            </div>
          <% end %>

          <%= ax_field_grid do %>
            <div class="ax-span-4">
              <%= f.label :poll_processing_interval_ms, "Polling processing (ms)", class: "ax-label tw-font-semibold" %>
              <%= f.number_field :poll_processing_interval_ms, class: "ax-control", min: 1000, max: 30000, step: 500, value: @dwv_poll_processing_interval_ms %>
            </div>
            <div class="ax-span-4">
              <%= f.label :poll_idle_interval_ms, "Polling idle (ms)", class: "ax-label tw-font-semibold" %>
              <%= f.number_field :poll_idle_interval_ms, class: "ax-control", min: 2000, max: 60000, step: 500, value: @dwv_poll_idle_interval_ms %>
            </div>
            <div class="ax-span-4">
              <%= f.label :poll_slow_interval_ms, "Polling final (ms)", class: "ax-label tw-font-semibold" %>
              <%= f.number_field :poll_slow_interval_ms, class: "ax-control", min: 5000, max: 120000, step: 1000, value: @dwv_poll_slow_interval_ms %>
            </div>
          <% end %>

          <div class="tw-flex tw-gap-2">
            <%= f.submit "Salvar Configurações", class: "ax-btn ax-btn--primary" %>
          </div>
        <% end %>
        <div class="tw-mt-2">
          <%= button_to "Testar Conexão", test_connection_admin_dwv_integrations_path, method: :post, class: "ax-btn ax-btn--ghost" %>
        </div>
      </div>
    </div>

    <div class="ax-card">
      <div class="ax-card__header">
        <h5 class="ax-card__title tw-font-bold"><i class="bi bi-arrow-repeat dwv-integration-title-icon dwv-integration-title-icon--info"></i>Controles de Sincronização</h5>
      </div>
      <div class="ax-card__body">
        <%= form_with url: sync_property_admin_dwv_integrations_path, method: :post, local: true, class: "tw-flex tw-items-center tw-gap-2 tw-mb-4" do |f| %>
          <div class="tw-w-full">
            <%= label_tag :property_id, "ID do imóvel na DWV", class: "ax-label tw-font-semibold" %>
            <%= text_field_tag :property_id, nil, class: "ax-control", placeholder: "Ex: 12345" %>
          </div>
          <div>
            <%= f.submit "Sincronizar Imóvel", class: "ax-btn ax-btn--primary" %>
          </div>
        <% end %>

        <div class="tw-flex tw-flex-wrap tw-gap-2">
          <%= button_to "Sincronizar Tudo Agora (Job)", sync_now_admin_dwv_integrations_path, method: :post, class: "ax-btn ax-btn--primary" %>
          <%= button_to "Sincronizar Lote (1 página)", sync_recent_admin_dwv_integrations_path(limit: @dwv_sync_limit), method: :post, class: "ax-btn ax-btn--ghost" %>
          <%= button_to "Desativar Removidos DWV", deactivate_removed_admin_dwv_integrations_path, method: :post, class: "ax-btn ax-btn--danger", data: { confirm: "Isso vai desativar no site imóveis marcados como removidos na DWV. Continuar?" } %>
        </div>
      </div>
    </div>
  </div>

  <div class="ax-span-6">
    <%= turbo_frame_tag "dwv_status_panel",
                        src: status_admin_dwv_integrations_path,
                        loading: "eager",
                        data: {
                          controller: "dwv-sync-status",
                          dwv_sync_status_processing_interval_value: @dwv_poll_processing_interval_ms,
                          dwv_sync_status_idle_interval_value: @dwv_poll_idle_interval_ms,
                          dwv_sync_status_slow_interval_value: @dwv_poll_slow_interval_ms
                        } do %>
      <%= render "status_panel" %>
    <% end %>
  </div>
<% end %>
