                    <%= f.label :codigo_empreendimento, "Pertence ao empreendimento:", class: "form-label small fw-bold mb-1" %>
                    <div class="input-group input-group-sm">
                      <%= f.collection_select :codigo_empreendimento, @developments, :codigo, :nome_empreendimento, { include_blank: true },
                          { class: "form-select form-select-sm",
                            disabled: !can_edit_protected_habitation_fields,
                            data: { controller: "tom-select", placeholder: "Selecione...", habitation_form_target: "developmentSelect", action: "change->habitation-form#developmentChanged" } } %>
                      <% if can_edit_protected_habitation_fields %>
                        <%= link_to new_admin_habitation_path(habitation: { tipo: "Empreendimento" }),
                            class: "btn btn-outline-secondary",
                            title: "Cadastrar novo empreendimento",
                            target: "_blank",
                            rel: "noopener" do %>
                          <i class="bi bi-plus"></i>
                        <% end %>
                      <% end %>
                    </div>
                    <% linked_dev = f.object.empreendimento %>
                    <% if f.object.codigo_empreendimento.present? %>
                      <% if linked_dev.present? %>
                        <div class="form-text text-success extra-small mt-1">
                          <i class="bi bi-check-circle me-1"></i>
                          Vínculo ativo: <strong><%= linked_dev.nome_empreendimento.presence || linked_dev.codigo %></strong>
                        </div>
                      <% else %>
                        <div class="form-text text-danger extra-small mt-1">
                          <i class="bi bi-exclamation-triangle me-1"></i>
                          Código sem empreendimento válido. Ajuste antes de salvar.
                        </div>
                      <% end %>
                    <% else %>
                      <div class="form-text text-muted extra-small mt-1">
                        <i class="bi bi-info-circle me-1"></i>Ao vincular uma unidade, nome do empreendimento e dados do proprietário podem ser ajustados manualmente.
                      </div>
                    <% end %>
                  </div>
                  <div class="col-md-4">
                    <%= f.label :nome_empreendimento,
                                (f.object.tipo == "Empreendimento" ? "Nome do empreendimento:" : "Nome do condomínio:"),
                                class: "form-label small fw-bold mb-1",
                                data: { habitation_form_target: "developmentNameLabel" } %>
                    <%= f.text_field :nome_empreendimento,
                                     class: "form-control form-control-sm",
                                     readonly: !can_edit_protected_habitation_fields || f.object.codigo_empreendimento.present?,
                                     data: {
                                       habitation_form_target: "developmentName",
                                       habitation_duplicate_check_target: "building",
                                       action: "input->habitation-duplicate-check#schedule blur->habitation-duplicate-check#check"
                                     } %>
                    <div class="form-text text-muted extra-small mt-1">
                      <%= f.object.tipo == "Empreendimento" ? "Nome público e interno do cadastro de empreendimento." : "Campo gerenciado automaticamente para unidades vinculadas." %>
                    </div>
                  </div>
                  <div class="col-md-3">
                    <%= f.label :data_entrega, "Data entrega:", class: "form-label small fw-bold mb-1" %>
                    <%= f.date_field :data_entrega, class: "form-control form-control-sm" %>
                  </div>
                </div>

                <div class="row g-2">
                  <% if current_admin_user&.admin? || current_admin_user&.profile&.name == "Administrativo" %>
                    <div class="col-md-5">
                      <%= f.label :proprietor_id, "Proprietário:", class: "form-label small fw-bold mb-1" %>
                      <div class="input-group input-group-sm">
                        <%= f.collection_select :proprietor_id, @proprietors, :id, :name, { include_blank: "Selecione..." }, {
                            class: "form-select form-select-sm",
                            data: { controller: "tom-select", placeholder: "Selecione..." }
                        } %>
                        <%= link_to "#quickProprietorModal",
                            class: "btn btn-outline-secondary",
                            title: "Cadastrar novo proprietário",
                            data: { bs_toggle: "modal", bs_target: "#quickProprietorModal" } do %>
                          <i class="bi bi-plus"></i>
                        <% end %>
                      </div>
                      <div class="form-text text-muted extra-small mt-1">
                        Campo opcional. Pode salvar o imóvel sem proprietário e vincular depois.
                      </div>
                    </div>

                    <div class="col-md-4">
                      <%= f.label :admin_user_id, "Captador responsável:", class: "form-label small fw-bold mb-1" %>
                      <%= f.collection_select :admin_user_id,
                            AdminUser.active.order(:name),
                            :id, :name,
                            { include_blank: "— sem corretor —" },
                            { class: "form-select form-select-sm",
                              data: { controller: "tom-select", placeholder: "Selecione..." } } %>
                      <div class="form-text text-muted extra-small mt-1">
                        Captador principal do imóvel. Pode ser atualizado automaticamente via sync Vista.
                      </div>
                    </div>
                  <% end %>
                  <div class="col-md-3">
                    <%= f.label :perfil_construcao, "Perfil de construção:", class: "form-label small fw-bold mb-1" %>
                    <%= f.select :perfil_construcao, Habitation::CONSTRUCTION_PROFILES, { include_blank: true }, class: "form-select form-select-sm" %>
                  </div>
                </div>
              </div>
            </div>
          </div>

