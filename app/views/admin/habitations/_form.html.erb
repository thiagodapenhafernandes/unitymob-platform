        </div>

        <% if show_vista_document_assets %>
        <div class="col-12">
          <div class="card border-0 shadow-sm">
            <div class="card-body p-3 p-md-4">
              <div class="d-flex flex-column flex-md-row justify-content-between gap-2 mb-3">
                <div>
                  <h6 class="small fw-semibold text-uppercase text-muted mb-1">
                    <i class="bi bi-database-down me-1"></i> Documentos do Vista
                  </h6>
                  <p class="small text-muted mb-0">
                    Arquivos identificados na integração. Estes itens são rastreáveis pela importação e não devem ser removidos manualmente por aqui.
                  </p>
                </div>
                <span class="badge bg-light text-dark border align-self-start">
                  <%= vista_document_assets.size %> arquivo(s)
                </span>
              </div>

              <% if vista_document_assets.any? %>
                <ul class="list-group list-group-flush small">
                  <% vista_document_assets.each do |asset| %>
                    <% attachment = asset.active_storage_attachment %>
                    <% link_target = attachment&.blob&.persisted? ? rails_blob_path(attachment, disposition: "attachment") : asset.source_url %>
                    <% status_label = vista_document_status_labels.fetch(asset.status.to_s, asset.status.to_s.presence || "Desconhecido") %>
                    <li class="list-group-item d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 px-0">
                      <div class="d-flex align-items-start gap-2 flex-grow-1">
                        <i class="bi bi-file-earmark-arrow-down text-primary mt-1"></i>
                        <div class="min-w-0">
                          <% if link_target.present? %>
                            <%= link_to asset.filename,
                                        link_target,
                                        target: "_blank",
                                        rel: "noopener",
                                        class: "text-decoration-none fw-semibold text-break" %>
                          <% else %>
                            <span class="fw-semibold text-break"><%= asset.filename %></span>
                          <% end %>
                          <div class="text-muted">
                            <%= asset.source_path %>
                          </div>
                          <% if asset.error_message.present? %>
                            <div class="text-danger">
                              <%= asset.error_message %>
                            </div>
                          <% end %>
                        </div>
                      </div>
                      <div class="d-flex flex-wrap gap-2 align-items-center">
                        <span class="badge <%= asset.status == "downloaded" ? "bg-success-subtle text-success border border-success-subtle" : "bg-light text-muted border" %>">
                          <%= status_label %>
                        </span>
                        <% if asset.downloaded_at.present? %>
                          <span class="text-muted"><%= l(asset.downloaded_at, format: "%d/%m/%Y %H:%M") %></span>
                        <% end %>
                      </div>
                    </li>
                  <% end %>
                </ul>
              <% else %>
                <p class="small text-muted fst-italic mb-0">Nenhum documento do Vista vinculado a este imóvel.</p>
              <% end %>
            </div>
          </div>
        </div>
        <% end %>
      </div>
