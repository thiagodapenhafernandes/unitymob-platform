<%
  cadastro_categories = {
    "apartamentos" => ["Apartamento", "Cobertura", "Loft", "Studio"],
    "comerciais_industriais" => ["Sala Comercial", "Loja", "Prédio Comercial", "Galpão", "Galpão Industrial", "Área", "Casa comercial", "Condomínio Industrial", "Ponto Comercial", "Salas/Conjuntos"],
    "empreendimento" => ["Empreendimento"],
    "imoveis_residenciais" => ["Casa", "Casa em Condomínio", "Sobrado", "Rural", "Condomínio", "Chácara", "Sítio"],
    "terrenos" => ["Terreno", "Terreno em Condomínio", "Área", "Terreno Comercial", "Terreno Industrial"]
  }
  cadastro_tipo_by_type = {
    "empreendimento" => "Empreendimento",
    "apartamentos" => "Unitário",
    "comerciais_industriais" => "Unitário",
    "imoveis_residenciais" => "Unitário",
    "terrenos" => "Unitário"
  }
  cadastro_type_labels = {
    "apartamentos" => "Apartamentos",
    "comerciais_industriais" => "Comerciais e Industriais",
    "empreendimento" => "Empreendimento",
    "imoveis_residenciais" => "Imóveis Residenciais",
    "terrenos" => "Terrenos"
  }
  inferred_cadastro_type =
    if habitation.tipo == "Empreendimento"
      "empreendimento"
    else
      cadastro_categories.find { |_key, values| values.include?(habitation.categoria) }&.first || "imoveis_residenciais"
    end
  show_development_context = habitation.codigo_empreendimento.present? || habitation.proprietor_id.present? || habitation.tipo == "Empreendimento"
  cadastro_reference_at = habitation.data_cadastro_crm
  updated_reference_at = [habitation.data_atualizacao_crm, habitation.updated_at].compact.max
  development_lookup = @developments.each_with_object({}) do |development, hash|
    hash[development.codigo.to_s] = {
      nome_empreendimento: development.nome_empreendimento.to_s,
      constructor_id: development.constructor_id&.to_s,
      edit_url: edit_admin_habitation_path(development)
    }
  end
  intake_waiting_admin_review = habitation.broker_intake? && habitation.intake_submitted_for_admin_review?
  can_manage_internal_documents = can_manage_internal_documents?
  can_edit_protected_habitation_fields = current_admin_user&.admin? || owns_all_resource?(:imoveis)
  vista_document_assets = Array(@habitation_vista_document_assets)
  show_vista_document_assets = vista_document_assets.any? || habitation.vista_integrated?
  vista_document_status_labels = {
    "pending" => "Pendente de download",
    "downloaded" => "Baixado",
    "failed" => "Falhou",
    "skipped" => "Ignorado"
  }
%>
<div class="habitation-form-ui"
     data-controller="attribute-manager habitation-form habitation-duplicate-check"
     data-attribute-manager-modal-id-value="attributeManagerModal"
     data-habitation-form-categories-by-type-value="<%= json_escape(cadastro_categories.to_json) %>"
     data-habitation-form-tipo-by-type-value="<%= json_escape(cadastro_tipo_by_type.to_json) %>"
     data-habitation-form-developments-value="<%= json_escape(development_lookup.to_json) %>"
     data-habitation-form-error-fields-value="<%= json_escape(habitation.errors.attribute_names.map(&:to_s).uniq.to_json) %>"
     data-habitation-duplicate-check-url-value="<%= check_admin_habitation_duplicate_path %>"
     data-habitation-duplicate-check-ignored-id-value="<%= habitation.id %>">
<%= form_with url: search_by_code_admin_habitations_path, method: :get, local: true, class: "card border-0 shadow-sm mb-3" do %>
  <div class="card-body p-3">
    <div class="row g-2 align-items-end">
      <div class="col-md-4 col-lg-3">
        <label for="admin_habitation_code_search" class="form-label small fw-bold mb-1">Pesquisar por código/referência:</label>
        <div class="input-group input-group-sm">
          <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
          <%= text_field_tag :codigo,
                             nil,
                             id: "admin_habitation_code_search",
                             class: "form-control",
                             placeholder: "Ex.: 54" %>
          <button class="btn btn-primary fw-semibold" type="submit">Abrir</button>
        </div>
      </div>
      <div class="col-md-8 col-lg-9">
        <div class="form-text mb-1">
          Use para abrir rapidamente um imóvel ou empreendimento pelo código.
        </div>
      </div>
    </div>
  </div>
<% end %>

<%= form_with(model: [:admin, habitation], local: true, class: "needs-validation habitation-form-shell", data: { controller: "save-state", action: "submit->save-state#submitting turbo:submit-end->save-state#submitted", habitation_save_options_form: true }) do |f| %>
  <%= hidden_field_tag :save_navigation, "exit", data: { save_state_target: "choice", habitation_save_options_choice: true } %>
  <%= hidden_field_tag :return_to, @return_to_path if @return_to_path.present? %>
  <%
    tab_titles = {
      general: "Visão geral",
      features: "Características",
      infra: "Infraestrutura",
      commercial: "Comercial",
      media: "Mídia",
      seo: "SEO & Controle",
      other: "Outros"
    }

    grouped_errors = Hash.new { |hash, key| hash[key] = [] }

    habitation.errors.each do |error|
      attribute = error.attribute.to_s

      tab_key =
        if attribute.start_with?("address.")
          :general
        elsif %w[
          codigo codigo_dwv categoria status situacao ocupacao_status estado_conservacao tipo
          codigo_empreendimento nome_empreendimento data_entrega proprietor_id perfil_construcao
          bloco andar dormitorios_qtd suites_qtd demi_suites_qtd salas_qtd varandas_qtd banheiros_qtd
          hidromassagem_qtd tipo_vaga vagas_qtd numero_box area_privativa_m2 area_total_m2 area_terreno_m2
          dimensoes_terreno topografia face construtora tipo_fachada descricao_empreendimento andares_qtd
          ano_construcao aptos_andar aptos_edificio elevadores_qtd matricula_imovel zona
          exibir_no_site_flag destaque_web_flag festival_salute_flag lancamento_flag tem_placa_flag
          exclusivo_flag imovel_dwv publicar_imovelweb_2 publicar_netimoveis_2 publicar_lais_ai
          publicar_loft publicar_chaves_na_mao publicar_casa_mineira publicar_imovelweb publicar_viva_real_vrsync
        ].include?(attribute)
          :general
        elsif %w[caracteristica_unica caracteristicas].include?(attribute)
          :features
        elsif %w[infra_estrutura].include?(attribute)
          :infra
        elsif %w[
          valor_venda_formatted valor_locacao_formatted valor_alugado_terceiros_formatted valor_vendido_terceiros_formatted
          valor_condominio_formatted valor_iptu_formatted motivo_suspensao
          valor_por_m2_formatted valor_venda_anterior_formatted valor_locacao_anterior_formatted
          valor_promocional_formatted proprietario proprietario_codigo proprietario_email proprietario_celular
          proprietario_telefone_comercial proprietario_telefone_residencial captador_commission_percentage
          valor_comissao_formatted valor_livre_proprietario_formatted
          broker_commission_percentage salute_rental_management_flag home_corporate_flag home_corporate_position
          observacoes responsavel_reserva key_location key_location_notes observacoes_visitas zelador_nome
          zelador_telefone regiao_foco saldo_devedor_formatted numero_prestacoes aceita_permuta_flag valor_aceito_permuta_formatted
          tipo_veiculo_aceito_permuta ano_minimo_veiculo_aceito_permuta aceita_permuta_veiculo_flag
          aceita_permuta_imovel_flag aceita_permuta_outros_flag permuta_valor_formatted permuta_localizacao
          permuta_dormitorios_qtd permuta_suites_qtd permuta_garagens_qtd
        ].include?(attribute)
          :commercial
        elsif %w[photos ordered_photo_ids ordered_picture_indices videos tour_virtual podcast_url foto_classificacao plantas fotos_empreendimento].include?(attribute)
          :media
        elsif %w[slug meta_title meta_description meta_keywords].include?(attribute)
          :seo
        else
          :other
        end

      grouped_errors[tab_key] << error.full_message
    end

    tab_error_counts = tab_titles.keys.index_with { |key| grouped_errors[key].size }
    tab_title_with_count = lambda do |tab_key|
      count = tab_error_counts[tab_key].to_i
      count.positive? ? "#{tab_titles[tab_key]} (#{count})" : tab_titles[tab_key]
    end
  %>
  <% if habitation.errors.any? %>

    <div class="alert alert-danger shadow-sm border-0 mb-4">
      <h5 class="alert-heading"><i class="bi bi-exclamation-triangle-fill me-2"></i>Ops! Verifique os erros abaixo:</h5>
      <% [:general, :features, :infra, :commercial, :media, :seo, :other].each do |tab_key| %>
        <% messages = grouped_errors[tab_key] %>
        <% next if messages.blank? %>
        <div class="mt-2">
          <strong><%= tab_titles[tab_key] %></strong>
          <ul class="mb-0">
            <% messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- Navigation Tabs -->
  <div class="border-bottom mb-4 habitation-tabs-bar">
    <ul class="nav nav-tabs border-0 gap-3" id="habitationTabs" role="tablist">
      <li class="nav-item" role="presentation">
        <button class="nav-link active border-0 bg-transparent py-2 px-1 fw-bold text-primary border-bottom border-2 border-primary" id="general-tab" data-bs-toggle="tab" data-bs-target="#general" type="button" role="tab" aria-selected="true">
          <i class="bi bi-house-door me-2"></i><%= tab_title_with_count.call(:general) %>
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link border-0 bg-transparent py-2 px-1 text-muted" id="features-tab" data-bs-toggle="tab" data-bs-target="#features" type="button" role="tab" aria-selected="false">
          <i class="bi bi-tags me-2"></i><%= tab_title_with_count.call(:features) %>
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link border-0 bg-transparent py-2 px-1 text-muted" id="infra-tab" data-bs-toggle="tab" data-bs-target="#infra" type="button" role="tab" aria-selected="false">
          <i class="bi bi-building me-2"></i><%= tab_title_with_count.call(:infra) %>
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link border-0 bg-transparent py-2 px-1 text-muted" id="comercial-tab" data-bs-toggle="tab" data-bs-target="#comercial" type="button" role="tab" aria-selected="false">
          <i class="bi bi-briefcase me-2"></i><%= tab_title_with_count.call(:commercial) %>
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link border-0 bg-transparent py-2 px-1 text-muted" id="media-tab" data-bs-toggle="tab" data-bs-target="#media" type="button" role="tab" aria-selected="false">
          <i class="bi bi-images me-2"></i><%= tab_title_with_count.call(:media) %>
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link border-0 bg-transparent py-2 px-1 text-muted" id="documents-tab" data-bs-toggle="tab" data-bs-target="#documents" type="button" role="tab" aria-selected="false">
          <i class="bi bi-folder2 me-2"></i>Documentos
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link border-0 bg-transparent py-2 px-1 text-muted" id="seo-tab" data-bs-toggle="tab" data-bs-target="#seo" type="button" role="tab" aria-selected="false">
          <i class="bi bi-google me-2"></i><%= tab_title_with_count.call(:seo) %>
        </button>
      </li>
    </ul>
  </div>

  <style>
    /* Custom Tab Styles for "Modern UI" */
    #habitationTabs .nav-link {
        font-size: 0.9rem;
        transition: all 0.2s;
        color: #6c757d; /* text-muted */
        border-bottom: 2px solid transparent !important;
    }
    #habitationTabs .nav-link:hover {
        color: var(--bs-primary);
    }
    #habitationTabs .nav-link.active {
        color: var(--bs-primary) !important;
        border-bottom: 2px solid var(--bs-primary) !important;
        font-weight: bold;
    }

    /* Fine-tuning: readable density with softer visual rhythm */
    .habitation-form-ui .card-body {
      line-height: 1.35;
    }
    .habitation-form-ui .form-label {
      font-size: 0.78rem;
      letter-spacing: 0.01em;
      color: #4b5563;
      margin-bottom: 0.2rem !important;
    }
    .habitation-form-ui .form-control-sm,
    .habitation-form-ui .form-select-sm,
    .habitation-form-ui .input-group-sm > .form-control,
    .habitation-form-ui .input-group-sm > .form-select,
    .habitation-form-ui .input-group-sm > .input-group-text {
      font-size: 0.84rem;
    }
    .habitation-form-ui .form-text {
      font-size: 0.72rem;
    }
    .habitation-form-ui .form-section {
      border: 1px solid #e7ecf1;
      border-radius: 0.6rem;
      padding: 0.9rem 1rem;
      margin-bottom: 0.9rem;
      background: #fff;
    }
    .habitation-form-ui .form-section-header {
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: #64748b;
      margin-bottom: 0.7rem;
      border-bottom: 1px solid #edf1f5;
      padding-bottom: 0.45rem;
    }
    .habitation-form-ui .custom-checkbox-card {
      padding: 0.35rem 0.55rem;
      border-radius: 0.45rem;
    }
    .habitation-form-ui .custom-checkbox-card .small,
    .habitation-form-ui .custom-checkbox-card .extra-small {
      font-size: 0.78rem !important;
      font-weight: 500 !important;
      color: #374151;
    }
    .habitation-form-ui .row.g-2 {
      --bs-gutter-y: 0.55rem;
    }
    .habitation-form-ui .row.g-3 {
      --bs-gutter-y: 0.75rem;
    }
    @media (max-width: 768px) {
      .habitation-form-ui .form-section {
        padding: 0.75rem;
      }
      .habitation-form-ui #habitationTabs .nav-link {
        font-size: 0.82rem;
      }
    }
    .habitation-form-ui .habitation-action-bar {
      z-index: 1000;
    }
    .habitation-form-ui .habitation-action-buttons {
      display: flex;
      gap: 0.5rem;
    }
    @media (max-width: 768px) {
      .habitation-form-ui .habitation-action-bar {
      }
      .habitation-form-ui .habitation-action-inner {
        flex-direction: column;
        align-items: stretch !important;
        gap: 0.6rem;
      }
      .habitation-form-ui .habitation-action-buttons {
        width: 100%;
      }
      .habitation-form-ui .habitation-action-buttons .btn {
        flex: 1 1 0;
      }
      .habitation-form-ui .habitation-action-meta {
        text-align: center;
      }
    }
    @media (max-width: 420px) {
      .habitation-form-ui .habitation-action-buttons {
        flex-direction: column;
      }
    }
    .habitation-form-ui .media-photo-tile {
      overflow: hidden;
    }
    .habitation-form-ui .media-gallery-scroll {
      max-height: min(72vh, 760px);
      overflow-y: auto;
      overflow-x: hidden;
      padding-right: 0.25rem;
      scroll-behavior: smooth;
    }
    .habitation-form-ui .media-photo-tile.is-site-hidden img {
      filter: grayscale(1);
      opacity: 0.62;
    }
    .habitation-form-ui .media-photo-tile > .media-photo-overlay {
      inset: 0;
      width: auto;
      height: auto;
      z-index: 2;
      pointer-events: none;
    }
    .habitation-form-ui .media-photo-tile .media-photo-overlay .badge,
    .habitation-form-ui .media-photo-tile .media-photo-feature-button,
    .habitation-form-ui .media-photo-tile .media-photo-drag-handle,
    .habitation-form-ui .media-photo-tile .media-photo-action-button,
    .habitation-form-ui .media-photo-tile .media-photo-site-toggle {
      pointer-events: auto;
    }
    .habitation-form-ui .media-photo-site-toggle {
      align-items: center;
      display: inline-flex;
      gap: 0.25rem;
      line-height: 1;
      min-height: 32px;
    }
    .habitation-form-ui .media-photo-action-button {
      align-items: center;
      display: inline-flex;
      height: 32px;
      justify-content: center;
      line-height: 1;
      min-width: 32px;
      padding: 0;
    }
    .habitation-form-ui .media-photo-feature-button {
      line-height: 1;
    }
    .habitation-form-ui .media-photo-drag-handle {
      cursor: grab;
      line-height: 1;
    }
    .habitation-form-ui .media-photo-drag-handle:active {
      cursor: grabbing;
    }
  </style>

  <!-- Tab Content -->
  <div class="tab-content habitation-tab-content" id="habitationTabsContent">
    
    <!-- Tab: Visão Geral -->
    <div class="tab-pane fade show active" id="general" role="tabpanel" aria-labelledby="general-tab">
      <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-3 p-md-4">
          <div class="form-section mb-3">
            <div class="form-section-header">
              Identificação e sinalizadores
            </div>
            <div class="row g-3 align-items-end mb-2">
              <div class="col-md-2">
                <%= f.label :codigo, "Referência:", class: "form-label fw-bold mb-1" %>
                <%= text_field_tag :codigo_preview,
                                   (f.object.codigo.presence || "Gerado automaticamente"),
                                   class: "form-control form-control-sm bg-light",
                                   readonly: true,
                                   disabled: true %>
              </div>
              <div class="col-md-2">
                <%= f.label :codigo_dwv, "Cód. DWV:", class: "form-label fw-bold mb-1" %>
                <%= text_field_tag :codigo_dwv_preview,
                                   f.object.codigo_dwv.to_s,
                                   class: "form-control form-control-sm bg-light",
                                   readonly: true,
                                   disabled: true %>
              </div>
              <div class="col-md-3">
                <div class="row g-2">
                  <div class="col-6">
                    <label class="form-label small text-muted mb-0">Cadastro:</label>
                    <input type="text" class="form-control form-control-sm bg-light" value="<%= cadastro_reference_at&.strftime("%d/%m/%Y") %>" readonly>
                  </div>
                  <div class="col-6">
                    <label class="form-label small text-muted mb-0">Atualização:</label>
                    <input type="text"
                           class="form-control form-control-sm bg-light"
                           value="<%= updated_reference_at ? "#{time_ago_in_words(updated_reference_at)} atrás" : "" %>"
                           title="<%= updated_reference_at&.strftime("%d/%m/%Y às %H:%M") %>"
                           readonly>
                  </div>
                </div>
              </div>
            </div>
            <div class="row g-2">
              <div class="col-12">
                <div class="d-flex flex-wrap gap-2 pb-1">
                  <label class="custom-checkbox-card">
                    <%= f.check_box :exibir_no_site_flag, class: "form-check-input mt-0", disabled: intake_waiting_admin_review %>
                    <span class="small fw-semibold">Exibir no site</span>
                  </label>
                  <label class="custom-checkbox-card">
                    <%= f.check_box :destaque_web_flag, class: "form-check-input mt-0" %>
                    <span class="small fw-semibold">Destaque Web</span>
                  </label>
                  <label class="custom-checkbox-card">
                    <%= f.check_box :festival_salute_flag, class: "form-check-input mt-0" %>
                    <span class="small fw-semibold">Super Destaque</span>
                  </label>
                  <label class="custom-checkbox-card">
                    <%= f.check_box :lancamento_flag, class: "form-check-input mt-0" %>
                    <span class="small fw-semibold">Lançamento</span>
                  </label>
                  <label class="custom-checkbox-card">
                    <%= f.check_box :tem_placa_flag, class: "form-check-input mt-0" %>
                    <span class="small fw-semibold">Tem Placa</span>
                  </label>
                  <label class="custom-checkbox-card">
                    <%= f.check_box :exclusivo_flag, class: "form-check-input mt-0" %>
                    <span class="small fw-semibold">Exclusivo</span>
                  </label>
                  <label class="custom-checkbox-card">
                    <%= f.check_box :imovel_dwv, { class: "form-check-input mt-0" }, "Sim", "Não" %>
                    <span class="small fw-semibold">Imóvel DWV</span>
                  </label>
                </div>
              </div>
            </div>
          </div>

          <div class="form-section mb-3">
            <div class="form-section-header">
              Definições básicas
            </div>
            <div class="row g-2 mb-0">
              <div class="col-md-3">
                <label class="form-label small fw-bold mb-1">Tipo de cadastro:</label>
                <%= select_tag :ui_cadastro_type,
                    options_for_select(cadastro_type_labels.map { |k, v| [v, k] }, inferred_cadastro_type),
                    class: "form-select form-select-sm",
                    data: {
                      controller: "tom-select",
                      habitation_form_target: "cadastroType",
                      action: "change->habitation-form#cadastroTypeChanged"
                    } %>
                <%= f.hidden_field :tipo, value: (f.object.tipo.presence || cadastro_tipo_by_type[inferred_cadastro_type]), data: { habitation_form_target: "tipo" } %>
              </div>
              <div class="col-md-2">
                <%= f.label :categoria, "Categoria:", class: "form-label small fw-bold mb-1" %>
                <%= f.select :categoria, (@categories.presence || Habitation::CATEGORIES), { include_blank: true },
                    data: {
                      controller: "tom-select",
                      tom_select_create_value: true,
                      placeholder: "Selecione...",
                      habitation_form_target: "category",
                      habitation_duplicate_check_target: "category",
                      action: "change->habitation-duplicate-check#check"
                    },
                    class: "form-select form-select-sm" %>
              </div>
              <div class="col-md-2">
                <%= f.label :status, "Status comercial:", class: "form-label small fw-bold mb-1" %>
                <%= f.select :status, (@status_options.presence || Habitation::STATUS_OPTIONS), { include_blank: true },
                    class: "form-select form-select-sm",
                    data: {
                      controller: "tom-select",
                      placeholder: "Selecione...",
                      habitation_duplicate_check_target: "commercialStatus",
                      action: "change->habitation-duplicate-check#check"
                    } %>
                <%= hidden_field_tag :duplicate_check_comparison,
                                     habitation.duplicate_identity_scope,
                                     data: { habitation_duplicate_check_target: "comparison" } %>
              </div>
              <div class="col-md-4">
                <%= f.label :motivo_suspensao, "Motivo de suspensão:", class: "form-label small fw-bold mb-1" %>
                <%= f.text_field :motivo_suspensao,
                    class: "form-control form-control-sm",
                    placeholder: "Informe quando o status estiver Suspenso" %>
              </div>
              <% if habitation.broker_intake? %>
                <div class="col-md-3">
                  <%= f.label :intake_status, "Status da captação:", class: "form-label small fw-bold mb-1" %>
