            <% linked_development = habitation.empreendimento if habitation.codigo_empreendimento.present? %>
            <% attached_media_photos = habitation.photos.attached? ? habitation.ordered_photos.select { |photo| photo.persisted? && photo.blob&.persisted? } : [] %>
            <% api_media_pictures = habitation.pictures.is_a?(Array) ? habitation.pictures.each_with_index.filter_map { |pic, index|
                 pic_url = pic.is_a?(String) ? pic : (pic.try(:[], "url") || pic.try(:[], "src") || pic.try(:[], "link"))
                 [pic, index, pic_url] if pic_url.present?
               } : [] %>
            <% media_gallery_count =
                 attached_media_photos.size +
                 api_media_pictures.size +
                 ((habitation.use_development_photos? && linked_development.present? && habitation.own_public_image_sources.blank?) ? linked_development.own_public_image_sources.first(12).size : 0) %>
            <div class="d-flex align-items-center justify-content-between gap-3 flex-wrap mb-3">
              <h6 class="small fw-semibold text-uppercase text-muted mb-0">Fotos</h6>
              <% if media_gallery_count.positive? %>
                <button type="button" class="btn btn-outline-primary btn-sm fw-semibold" data-gallery-open>
                  <i class="bi bi-images me-1"></i>
                  Abrir galeria
                </button>
              <% end %>
            </div>
            <% if linked_development.present? %>
              <div class="alert alert-light border d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
                <div>
                  <div class="fw-semibold small mb-1">
                    <i class="bi bi-building me-1 text-primary"></i>
                    Fotos do empreendimento vinculado
                  </div>
                  <div class="text-muted small">
                    Este imóvel está vinculado a <strong><%= linked_development.nome_empreendimento.presence || linked_development.codigo %></strong>.
                    Se não houver fotos próprias, ele pode usar as fotos desse empreendimento.
                  </div>
                </div>
                <div class="form-check form-switch m-0">
                  <%= f.check_box :use_development_photos_flag, class: "form-check-input", role: "switch" %>
                  <%= f.label :use_development_photos_flag, "Usar fotos do empreendimento", class: "form-check-label small fw-semibold" %>
                </div>
              </div>
            <% end %>
            <div class="mb-4 text-center p-5 border border-dashed rounded bg-light">
               <% if can?(:manage, :imoveis) %>
                 <div class="row justify-content-center mb-3">
                   <div class="col-md-4">
                     <%= f.label :foto_classificacao, "Classificação das Fotos:", class: "form-label small fw-bold mb-1" %>
                     <%= f.select :foto_classificacao, Habitation::FOTO_CLASSIFICACAO, { include_blank: "Selecione..." }, class: "form-select form-select-sm" %>
                   </div>
                 </div>
               <% end %>
               <div class="mb-3">
                 <i class="bi bi-images display-4 text-muted"></i>
               </div>
               <h5>Arraste fotos ou clique para selecionar</h5>
               <p class="text-muted small">Fotos adicionadas aqui serão mantidas junto das fotos atuais. Para remover, use a lixeira sobre a imagem.</p>
               <% watermark_available = @property_setting&.watermark_configured? %>
               <div class="d-inline-flex flex-column align-items-center gap-1 mb-3">
                 <label class="form-check d-inline-flex align-items-center gap-2 border rounded px-3 py-2 bg-white shadow-sm mb-0">
                   <%= hidden_field_tag "habitation[apply_photo_watermark]", "0" %>
                   <%= check_box_tag "habitation[apply_photo_watermark]", "1", watermark_available, class: "form-check-input m-0", disabled: !watermark_available %>
                   <span class="small fw-semibold">Aplicar marca d'água nas novas fotos</span>
                 </label>
                 <% unless watermark_available %>
                   <span class="text-muted small">
                     Marca d'água não configurada.
                     <% if current_admin_user&.admin? %>
                       <%= link_to "Configurar", edit_admin_property_setting_path, class: "fw-semibold" %>
                     <% end %>
                   </span>
                 <% end %>
               </div>
               <br>
               <%= f.label :photos, "Selecionar Arquivos", class: "btn btn-primary" %>
               <%= f.file_field :photos, multiple: true, class: "d-none", 
                   id: "habitation_photos",
                   data: { action: "change->photo-upload#preview", photo_upload_target: "input" } %>
               <div class="alert alert-warning small mt-3 mb-0 d-none" data-photo-upload-target="uploadLimitFeedback"></div>
	               <%= f.hidden_field :ordered_photo_ids, data: { photo_upload_target: "orderInput" }, value: attached_media_photos.map(&:id).join(',') %>
	               <%= f.hidden_field :ordered_picture_indices,
	                   data: { photo_upload_target: "apiOrderInput" },
	                   value: api_media_pictures.map { |_pic, index, _url| index }.join(',') %>
	               <%= f.hidden_field :site_hidden_photo_ids,
	                   data: { photo_upload_target: "hiddenPhotoIdsInput" },
	                   value: Array(habitation.site_hidden_photo_ids).map(&:to_i).join(',') %>
	               <%= f.hidden_field :site_hidden_picture_urls,
	                   data: { photo_upload_target: "hiddenPictureUrlsInput" },
	                   value: api_media_pictures.select { |pic, _index, _url| habitation.picture_hidden_from_site?(pic) }.map { |_pic, _index, url| url }.join(',') %>
	               <%= hidden_field_tag "habitation[remove_photo_ids]", "", data: { photo_upload_target: "removePhotoIdsInput" } %>
	               <%= hidden_field_tag "habitation[remove_picture_indices]", "", data: { photo_upload_target: "removePictureIndicesInput" } %>
	            </div>

		            <div class="media-gallery-scroll">
		              <div class="row g-3" data-photo-upload-target="previewContainer">
		                <% if attached_media_photos.any? %>
		                  <% attached_media_photos.each_with_index do |photo, index| %>
		                    <% photo_hidden_from_site = Array(habitation.site_hidden_photo_ids).map(&:to_i).include?(photo.id) %>
		                    <div class="col-6 col-md-3 col-lg-2 draggable-item attached-photo-item" data-id="<%= photo.id %>">
		                      <div class="position-relative ratio ratio-1x1 group-hover media-photo-tile <%= 'is-site-hidden' if photo_hidden_from_site %>" data-site-hidden="<%= photo_hidden_from_site %>">
		                        <%= link_to url_for(photo),
		                            class: "d-block w-100 h-100",
		                            data: { fancybox: "habitation-media-gallery", caption: "Foto ativa #{index + 1} - #{photo.filename}" } do %>
		                          <%= image_tag photo, class: "rounded border w-100 h-100 object-fit-cover" %>
		                        <% end %>
		                        <div class="media-photo-overlay position-absolute d-flex flex-column justify-content-between p-1">
		                          <div class="d-flex justify-content-between align-items-start gap-1">
		                            <span class="badge bg-dark bg-opacity-75 border shadow-sm" data-photo-position-badge>#<%= index + 1 %></span>
		                            <span class="badge bg-light text-dark border shadow-sm">Ativo</span>
		                          </div>
		                          <div class="d-flex justify-content-end">
		                            <button type="button"
		                                    class="media-photo-site-toggle btn btn-sm <%= photo_hidden_from_site ? 'btn-secondary' : 'btn-success' %> border fw-semibold"
		                                    title="<%= photo_hidden_from_site ? 'Foto interna, fora do site' : 'Foto publicada no site' %>"
		                                    data-action="photo-upload#toggleSiteVisibility"
		                                    data-photo-id="<%= photo.id %>">
		                              <i class="bi <%= photo_hidden_from_site ? 'bi-eye-slash' : 'bi-globe2' %>"></i>
		                              <span><%= photo_hidden_from_site ? 'Interna' : 'Site' %></span>
		                            </button>
		                          </div>
		                          <div class="d-flex justify-content-between align-items-end gap-1">
		                            <span data-photo-featured-control>
		                              <% if index.zero? %>
		                                <span class="badge bg-warning text-dark border shadow-sm">
		                                  <i class="bi bi-star-fill me-1"></i>Destaque
		                                </span>
		                              <% else %>
		                                <button type="button"
		                                        class="media-photo-feature-button btn btn-sm btn-warning border py-0 px-1 fw-semibold"
		                                        title="Definir como destaque"
		                                        data-action="photo-upload#setFeatured">
		                                  <i class="bi bi-star"></i>
		                                </button>
		                              <% end %>
		                            </span>
		                            <span class="d-flex align-items-center gap-1">
		                              <button type="button"
		                                      class="btn btn-sm btn-danger border media-photo-action-button"
		                                      title="Remover foto"
		                                      data-action="photo-upload#removeAttached">
		                                <i class="bi bi-trash"></i>
		                              </button>
		                              <button type="button" class="media-photo-drag-handle btn btn-sm btn-light border media-photo-action-button" title="Arrastar foto">
		                                <i class="bi bi-grip-vertical"></i>
		                              </button>
		                            </span>
		                          </div>
		                        </div>
		                      </div>
		                    </div>
		                  <% end %>
		                <% end %>

		                <% if api_media_pictures.any? %>
		                  <% api_media_pictures.each_with_index do |(pic, original_index, pic_url), index| %>
		                    <% display_index = attached_media_photos.size + index %>
		                    <% picture_hidden_from_site = habitation.picture_hidden_from_site?(pic) %>
		                    <div class="col-6 col-md-3 col-lg-2 draggable-item api-picture-item" data-api-index="<%= original_index %>">
		                      <div class="position-relative ratio ratio-1x1 group-hover media-photo-tile <%= 'is-site-hidden' if picture_hidden_from_site %>" data-site-hidden="<%= picture_hidden_from_site %>">
		                        <%= link_to pic_url,
		                            class: "d-block w-100 h-100",
		                            data: { fancybox: "habitation-media-gallery", caption: "Foto API/Vista #{display_index + 1}" } do %>
		                          <%= image_tag pic_url, class: "rounded border w-100 h-100 object-fit-cover opacity-75" %>
		                        <% end %>
		                        <div class="media-photo-overlay position-absolute d-flex flex-column justify-content-between p-1">
		                          <div class="d-flex justify-content-between align-items-start gap-1">
		                            <span class="badge bg-dark bg-opacity-75 border shadow-sm" data-photo-position-badge>#<%= display_index + 1 %></span>
		                            <span class="badge bg-secondary border shadow-sm" title="Vindo da Integração API">API/Vista</span>
		                          </div>
		                          <div class="d-flex justify-content-end">
		                            <button type="button"
		                                    class="media-photo-site-toggle btn btn-sm <%= picture_hidden_from_site ? 'btn-secondary' : 'btn-success' %> border fw-semibold"
		                                    title="<%= picture_hidden_from_site ? 'Foto interna, fora do site' : 'Foto publicada no site' %>"
		                                    data-action="photo-upload#toggleSiteVisibility"
		                                    data-picture-url="<%= pic_url %>">
		                              <i class="bi <%= picture_hidden_from_site ? 'bi-eye-slash' : 'bi-globe2' %>"></i>
		                              <span><%= picture_hidden_from_site ? 'Interna' : 'Site' %></span>
		                            </button>
		                          </div>
		                          <div class="d-flex justify-content-between align-items-end gap-1">
		                            <span data-photo-featured-control>
		                              <% if display_index.zero? %>
		                                <span class="badge bg-warning text-dark border shadow-sm">
		                                  <i class="bi bi-star-fill me-1"></i>Destaque
		                                </span>
		                              <% else %>
		                                <button type="button"
		                                        class="media-photo-feature-button btn btn-sm btn-warning border py-0 px-1 fw-semibold"
		                                        title="Definir como destaque"
		                                        data-action="photo-upload#setFeatured">
		                                  <i class="bi bi-star"></i>
		                                </button>
		                              <% end %>
		                            </span>
		                            <span class="d-flex align-items-center gap-1">
		                              <button type="button"
		                                      class="btn btn-sm btn-danger border media-photo-action-button"
		                                      title="Remover foto da API"
		                                      data-action="photo-upload#removeApiPicture">
		                                <i class="bi bi-trash"></i>
		                              </button>
		                              <button type="button" class="media-photo-drag-handle btn btn-sm btn-light border media-photo-action-button" title="Arrastar foto">
		                                <i class="bi bi-grip-vertical"></i>
		                              </button>
		                            </span>
		                          </div>
		                        </div>
		                      </div>
		                    </div>
		                  <% end %>
		                <% end %>

		                <% if habitation.use_development_photos? && linked_development.present? && habitation.own_public_image_sources.blank? %>
		                  <% linked_development.own_public_image_sources.first(12).each_with_index do |pic, index| %>
		                    <% development_photo_url = public_image_url(pic) %>
		                    <div class="col-6 col-md-3 col-lg-2">
		                      <div class="position-relative ratio ratio-1x1 group-hover media-photo-tile">
		                        <%= link_to development_photo_url,
		                            class: "d-block w-100 h-100",
		                            data: { fancybox: "habitation-media-gallery", caption: "Foto do empreendimento #{index + 1}" } do %>
		                          <%= image_tag development_photo_url, class: "rounded border w-100 h-100 object-fit-cover opacity-75" %>
		                        <% end %>
		                        <div class="media-photo-overlay position-absolute d-flex flex-column justify-content-between p-1">
		                          <div class="d-flex justify-content-between align-items-start gap-1">
		                            <span class="badge bg-dark bg-opacity-75 border shadow-sm">#<%= index + 1 %></span>
		                            <span class="badge bg-info text-dark border shadow-sm" title="Foto herdada do empreendimento">Empreendimento</span>
		                          </div>
		                          <% if index.zero? %>
		                            <div>
		                              <span class="badge bg-warning text-dark border shadow-sm">
		                                <i class="bi bi-star-fill me-1"></i>Destaque
		                              </span>
		                            </div>
		                          <% end %>
		                        </div>
		                      </div>
		                    </div>
		                  <% end %>
			                <% end %>
			              </div>
			            </div>
	       </div>
	       </div>

	       <div class="card border-0 shadow-sm mb-4" data-controller="dynamic-list" data-dynamic-list-param-name-value="habitation[videos][]">
          <div class="card-body p-3 p-md-4">
             <div class="d-flex justify-content-between align-items-center mb-3">
               <h6 class="small fw-semibold text-uppercase text-muted mb-0">Vídeos e tour virtual</h6>
               <button type="button" class="btn btn-sm btn-outline-primary" data-action="dynamic-list#add">
                 <i class="bi bi-plus-lg me-1"></i>Adicionar
               </button>
             </div>
             <div class="mb-3" data-dynamic-list-target="container">
                <% (f.object.videos || []).each do |video_url| %>
                  <div class="input-group mb-2">
                     <input type="text" name="habitation[videos][]" value="<%= video_url %>" class="form-control form-control-sm" placeholder="https://...">
                     <button type="button" class="btn btn-outline-danger" data-action="dynamic-list#remove">
                       <i class="bi bi-trash"></i>
                     </button>
                  </div>
                <% end %>
             </div>
             <div class="mt-4">
                <%= f.label :tour_virtual, "Link Tour Virtual (360)", class: "form-label fw-bold" %>
                <%= f.text_field :tour_virtual, class: "form-control form-control-sm", placeholder: "https://..." %>
             </div>
             <div class="mt-2">
                <%= f.label :podcast_url, "Link do Podcast", class: "form-label fw-bold" %>
                <%= f.text_field :podcast_url, class: "form-control form-control-sm", placeholder: "https://..." %>
             </div>
          </div>
       </div>
    </div>

    <!-- Tab: Documentos (anexos internos) -->
    <div class="tab-pane fade" id="documents" role="tabpanel" aria-labelledby="documents-tab">
      <div class="alert alert-info border-0 small mb-4">
        <i class="bi bi-info-circle me-1"></i>
        Documentos internos do imóvel. Administrador e Administrativo podem anexar/remover; captadores visualizam sem trocar nem apagar.
      </div>

      <div class="row g-3">
        <!-- Fichas de cadastro -->
        <div class="col-lg-6">
          <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-3 p-md-4">
              <h6 class="small fw-semibold text-uppercase text-muted mb-3">
                <i class="bi bi-file-earmark-text me-1"></i> Fichas de Cadastro
              </h6>
              <p class="small text-muted mb-3">
                PDFs ou imagens da ficha física de cadastro do imóvel. Pode anexar vários arquivos.
              </p>

              <% if can_manage_internal_documents %>
                <div class="mb-3">
                  <%= f.label :fichas_cadastro, "Adicionar arquivos", class: "btn btn-outline-primary btn-sm" %>
                  <%= f.file_field :fichas_cadastro, multiple: true, class: "d-none", id: "habitation_fichas_cadastro" %>
                </div>
              <% end %>

              <% if habitation.fichas_cadastro.attached? %>
                <ul class="list-group list-group-flush small">
                  <% habitation.fichas_cadastro.attachments.each do |attachment| %>
                    <% next unless attachment.persisted? && attachment.blob&.persisted? %>
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                      <div class="d-flex align-items-center gap-2 flex-grow-1 text-truncate">
                        <i class="bi bi-paperclip text-muted"></i>
                        <%= link_to attachment.filename.to_s,
                                    rails_blob_path(attachment, disposition: "attachment"),
                                    target: "_blank", rel: "noopener",
                                    class: "text-decoration-none text-truncate" %>
                        <span class="badge bg-light text-muted border ms-1">
                          <%= number_to_human_size(attachment.byte_size) rescue '-' %>
                        </span>
                      </div>
                      <% if habitation.persisted? && can_manage_internal_documents %>
                        <%= button_to purge_attachment_admin_habitation_path(habitation, association: "fichas_cadastro", attachment_id: attachment.id),
                                      method: :delete,
                                      class: "btn btn-sm btn-link text-danger p-0 ms-2",
                                      form: { data: { turbo_confirm: "Remover este arquivo?" } } do %>
                          <i class="bi bi-trash"></i>
                        <% end %>
                      <% end %>
                    </li>
                  <% end %>
                </ul>
              <% else %>
                <p class="small text-muted fst-italic mb-0">Nenhuma ficha anexada.</p>
              <% end %>
            </div>
          </div>
        </div>

        <!-- Autorizações de venda -->
        <div class="col-lg-6">
          <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-3 p-md-4">
              <h6 class="small fw-semibold text-uppercase text-muted mb-3">
                <i class="bi bi-shield-check me-1"></i> Autorizações de Venda
              </h6>
              <p class="small text-muted mb-3">
                Imagens (JPG/PNG) ou PDFs de autorizações assinadas pelo proprietário. Pode anexar várias.
              </p>

              <% if can_manage_internal_documents %>
                <div class="mb-3">
                  <%= f.label :autorizacoes_venda, "Adicionar arquivos", class: "btn btn-outline-primary btn-sm" %>
                  <%= f.file_field :autorizacoes_venda, multiple: true, class: "d-none", id: "habitation_autorizacoes_venda" %>
                </div>
              <% end %>

              <% if habitation.autorizacoes_venda.attached? %>
                <ul class="list-group list-group-flush small">
                  <% habitation.autorizacoes_venda.attachments.each do |attachment| %>
                    <% next unless attachment.persisted? && attachment.blob&.persisted? %>
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                      <div class="d-flex align-items-center gap-2 flex-grow-1 text-truncate">
                        <% if attachment.image? %>
                          <%= image_tag attachment, class: "rounded border", style: "width: 36px; height: 36px; object-fit: cover;" %>
                        <% else %>
                          <i class="bi bi-file-earmark-pdf text-danger fs-5"></i>
                        <% end %>
                        <%= link_to attachment.filename.to_s,
                                    rails_blob_path(attachment, disposition: "attachment"),
                                    target: "_blank", rel: "noopener",
                                    class: "text-decoration-none text-truncate" %>
                        <span class="badge bg-light text-muted border ms-1">
                          <%= number_to_human_size(attachment.byte_size) rescue '-' %>
                        </span>
                      </div>
                      <% if habitation.persisted? && can_manage_internal_documents %>
                        <%= button_to purge_attachment_admin_habitation_path(habitation, association: "autorizacoes_venda", attachment_id: attachment.id),
                                      method: :delete,
                                      class: "btn btn-sm btn-link text-danger p-0 ms-2",
                                      form: { data: { turbo_confirm: "Remover este arquivo?" } } do %>
                          <i class="bi bi-trash"></i>
                        <% end %>
                      <% end %>
                    </li>
                  <% end %>
                </ul>
              <% else %>
                <p class="small text-muted fst-italic mb-0">Nenhuma autorização anexada.</p>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Tab: SEO & Controle -->
    <div class="tab-pane fade" id="seo" role="tabpanel" aria-labelledby="seo-tab">
      <div class="row g-3">
         <div class="col-lg-12">
           <div class="card border-0 shadow-sm mb-4">
             <div class="card-body p-3 p-md-4">
               <h6 class="small fw-semibold text-uppercase text-muted mb-3">Otimização para busca (SEO)</h6>
               <div class="row g-2">
                 <div class="col-md-6">
                    <%= f.label :slug, "URL Amigável (Slug)", class: "form-label small fw-bold mb-1" %>
                    <%= f.text_field :slug, class: "form-control form-control-sm bg-light", readonly: true %>
                 </div>
                 <div class="col-md-6">
                    <%= f.label :meta_title, "Meta Title", class: "form-label small fw-bold mb-1" %>
                    <%= f.text_field :meta_title, class: "form-control form-control-sm" %>
                 </div>
                 <div class="col-12 mt-2">
                    <%= f.label :meta_description, "Meta Description (SEO)", class: "form-label small fw-bold mb-1" %>
                    <%= f.rich_text_area :meta_description, class: "form-control", style: "min-height: 150px;" %>
                 </div>
                 <div class="col-12 mt-2">
                    <%= f.label :meta_keywords, "Palavras-chave (Tags)", class: "form-label small fw-bold mb-1" %>
                    <%= f.text_field :meta_keywords, 
                        class: "form-control form-control-sm",
                        placeholder: "Digite e Enter...",
                        data: { controller: "tom-select", tom_select_tags_value: true } %>
                 </div>
               </div>
             </div>
           </div>
         </div>

         <div class="col-lg-12">
           <div class="alert alert-light border small mb-0">
             Os controles de exibição estão na seção <strong>Identificação e Sinalizadores</strong> para evitar duplicidade.
           </div>
         </div>
      </div>
    </div>
  </div>

  <!-- Sticky Footer Action Bar -->
  <div class="position-sticky bottom-0 bg-white py-3 border-top mt-4 shadow-lg habitation-action-bar">
    <div class="d-flex justify-content-between align-items-center habitation-action-inner">
      <div class="text-muted small habitation-action-meta">
        <% if updated_reference_at %>
          <i class="bi bi-clock-history me-1"></i>
          Atualizado há <%= time_ago_in_words(updated_reference_at) %>
          <span class="d-none d-md-inline">(<%= updated_reference_at.strftime("%d/%m/%Y às %H:%M") %>)</span>
        <% end %>
      </div>
      <div class="habitation-action-buttons">
         <%= link_to "Cancelar", (@return_to_path || admin_habitations_path), class: "btn btn-outline-secondary px-4 px-md-4", data: { save_state_target: "cancelButton" } %>
         <% if can_release_intake_to_broker?(habitation) || (habitation.new_record? && can_complete_admin_intake_review?(habitation)) %>
           <%= f.button type: "submit",
                        name: "release_to_broker_after_save",
                        value: "1",
