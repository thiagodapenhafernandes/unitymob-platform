<%
  cadastro_categories = {
    "apartamentos" => ["Apartamento", "Cobertura", "Loft", "Studio"],
    "comerciais_industriais" => ["Sala Comercial", "Loja", "Prédio Comercial", "Galpão", "Galpão Industrial", "Área", "Casa comercial", "Condomínio Industrial", "Ponto Comercial", "Salas/Conjuntos"],
    "empreendimento" => ["Empreendimento"],
    "imoveis_residenciais" => ["Casa", "Casa em Condomínio", "Sobrado", "Rural", "Condomínio", "Chácara", "Sítio"],
    "terrenos" => ["Terreno", "Terreno em Condomínio", "Área", "Terreno Comercial", "Terreno Industrial"]
  }
  cadastro_tipo_by_type = {
    "empreendimento" => "Empreendimento",
    "apartamentos" => "Unitário",
    "comerciais_industriais" => "Unitário",
    "imoveis_residenciais" => "Unitário",
    "terrenos" => "Unitário"
  }
  cadastro_type_labels = {
    "apartamentos" => "Apartamentos",
    "comerciais_industriais" => "Comerciais e Industriais",
    "empreendimento" => "Empreendimento",
    "imoveis_residenciais" => "Imóveis Residenciais",
    "terrenos" => "Terrenos"
  }
  inferred_cadastro_type =
    if habitation.tipo == "Empreendimento"
      "empreendimento"
    else
      cadastro_categories.find { |_key, values| values.include?(habitation.categoria) }&.first || "imoveis_residenciais"
    end
  show_development_context = habitation.codigo_empreendimento.present? || habitation.proprietor_id.present? || habitation.tipo == "Empreendimento"
  cadastro_reference_at = habitation.data_cadastro_crm
  updated_reference_at = [habitation.data_atualizacao_crm, habitation.updated_at].compact.max
  development_lookup = @developments.each_with_object({}) do |development, hash|
    development_address = development.address
    hash[development.codigo.to_s] = {
      nome_empreendimento: development.nome_empreendimento.presence || development.titulo_anuncio.to_s,
      proprietor_id: development.proprietor_id&.to_s,
      admin_user_id: development.admin_user_id&.to_s,
      data_entrega: development.data_entrega&.iso8601,
      perfil_construcao: development.perfil_construcao.to_s,
      address: {
        tipo_endereco: (development_address&.tipo_endereco.presence || development.tipo_endereco).to_s,
        logradouro: (development_address&.logradouro.presence || development.endereco).to_s,
        numero: (development_address&.numero.presence || development.numero).to_s,
        bairro: (development_address&.bairro.presence || development.bairro).to_s,
        bairro_comercial: (development_address&.bairro_comercial.presence || development.bairro_comercial).to_s,
        cidade: (development_address&.cidade.presence || development.cidade).to_s,
        uf: (development_address&.uf.presence || development.uf).to_s,
        cep: (development_address&.cep.presence || development.cep).to_s
      },
      edit_url: edit_admin_habitation_path(development.id)
    }
  end
  intake_waiting_admin_review = habitation.broker_intake? && habitation.intake_submitted_for_admin_review?
  can_manage_internal_documents = can_manage_internal_documents?
  can_edit_protected_habitation_fields = can_edit_protected_habitation_fields?
  vista_document_assets = Array(@habitation_vista_document_assets)
  show_vista_document_assets = vista_document_assets.any? || habitation.vista_integrated?
  vista_document_status_labels = {
    "pending" => "Pendente de download",
    "downloaded" => "Baixado",
    "failed" => "Falhou",
    "skipped" => "Ignorado"
  }
  tab_titles = {
    general: "Visão geral",
    features: "Características",
    infra: "Infraestrutura",
    commercial: "Comercial",
    media: "Mídia",
    documents: "Documentos",
    seo: "SEO & Controle",
    other: "Outros"
  }
  tab_nav_items = [
    [:general, "house-door", "Identificação, localização, estrutura e valores"],
    [:features, "tags", "Texto público e atributos do imóvel"],
    [:infra, "building", "Edifício, empreendimento e lazer"],
    [:commercial, "briefcase", "Negociação, contatos, portais e operação"],
    [:media, "images", "Fotos, vídeos e tour"],
    [:documents, "folder2", "Fichas e autorizações"],
    [:seo, "google", "Slug, metas e palavras-chave"]
  ]
  grouped_errors = Hash.new { |hash, key| hash[key] = [] }

  habitation.errors.each do |error|
    attribute = error.attribute.to_s

    tab_key =
      if attribute.start_with?("address.")
        :general
      elsif %w[
        codigo codigo_dwv categoria status situacao ocupacao_status estado_conservacao tipo
        proprietor_id admin_user_id motivo_suspensao
        exibir_no_site_flag destaque_web_flag festival_salute_flag lancamento_flag tem_placa_flag
        exclusivo_flag imovel_dwv
        bloco andar dormitorios_qtd suites_qtd demi_suites_qtd salas_qtd varandas_qtd banheiros_qtd
        hidromassagem_qtd tipo_vaga vagas_qtd numero_box area_privativa_m2 area_total_m2 area_terreno_m2
        dimensoes_terreno topografia face
        valor_venda_formatted valor_locacao_formatted valor_alugado_terceiros_formatted valor_vendido_terceiros_formatted
        valor_condominio_formatted valor_iptu_formatted valor_por_m2_formatted valor_venda_anterior_formatted
        valor_locacao_anterior_formatted valor_total_aluguel_cents
        codigo_empreendimento nome_empreendimento data_entrega perfil_construcao
      ].include?(attribute)
        :general
      elsif %w[
        caracteristicas caracteristica_unica titulo_anuncio descricao_web
      ].include?(attribute)
        :features
      elsif %w[
        construtora tipo_fachada descricao_empreendimento andares_qtd ano_construcao aptos_andar
        aptos_edificio elevadores_qtd infra_estrutura
        agenciador
      ].include?(attribute)
        :infra
      elsif %w[
        slug meta_title meta_description meta_keywords
      ].include?(attribute)
        :seo
      elsif %w[
        matricula_imovel zona
        valor_promocional_formatted proprietario proprietario_codigo proprietario_email proprietario_celular
        proprietario_telefone_comercial proprietario_telefone_residencial captador_commission_percentage
        valor_comissao_formatted valor_livre_proprietario_formatted
        broker_commission_percentage salute_rental_management_flag home_corporate_flag home_corporate_position
        observacoes responsavel_reserva key_location key_location_notes observacoes_visitas zelador_nome
        zelador_telefone regiao_foco saldo_devedor_formatted numero_prestacoes aceita_permuta_flag valor_aceito_permuta_formatted
        tipo_veiculo_aceito_permuta ano_minimo_veiculo_aceito_permuta aceita_permuta_veiculo_flag
        aceita_permuta_imovel_flag aceita_permuta_outros_flag permuta_valor_formatted permuta_localizacao
        permuta_dormitorios_qtd permuta_suites_qtd permuta_garagens_qtd
        publicar_imovelweb_2 publicar_netimoveis_2 publicar_lais_ai publicar_loft publicar_chaves_na_mao
        publicar_casa_mineira publicar_imovelweb publicar_viva_real_vrsync tipo_publicacao_imovelweb_2
        mostrar_mapa_imovelweb_2 destaque_chaves_na_mao periodo_locacao_chaves_na_mao modelo_casa_mineira
        tipo_publicacao_imovelweb mostrar_mapa_imovelweb tipo_publicacao_viva_real divulgar_endereco_viva_real
      ].include?(attribute)
        :commercial
      elsif %w[photos ordered_photo_ids ordered_picture_indices videos tour_virtual podcast_url foto_classificacao plantas fotos_empreendimento].include?(attribute)
        :media
      elsif %w[fichas_cadastro autorizacoes_venda].include?(attribute)
        :documents
      else
        :other
      end

    grouped_errors[tab_key] << error.full_message
  end

  tab_error_counts = tab_titles.keys.index_with { |key| grouped_errors[key].size }
  operational_missing_counts = admin_habitation_editor_tab_missing_counts(habitation, property_setting: @property_setting)
  tab_missing_counts = tab_titles.keys.index_with { |key| operational_missing_counts[key].to_i }
  tab_validation_rules = admin_habitation_editor_tab_validation_rules(habitation, property_setting: @property_setting)
  tab_error_badge = lambda do |tab_key|
    count = tab_error_counts[tab_key].to_i
    count.positive? ? tag.span(count, class: "ax-tab-error", title: "#{count} erro(s)") : nil
  end
  source_habitation = defined?(@source_habitation) ? @source_habitation : nil
  suspended_status = Habitation.normalize_status(habitation.status) == "Suspenso"
%>
<div class="habitation-form-ui"
     data-controller="attribute-manager habitation-form habitation-duplicate-check ax-form-hints ax-checkbox-chips"
     data-action="change->ax-checkbox-chips#sync"
     data-attribute-manager-modal-id-value="attributeManagerModal"
     data-habitation-form-categories-by-type-value="<%= json_escape(cadastro_categories.to_json) %>"
     data-habitation-form-tipo-by-type-value="<%= json_escape(cadastro_tipo_by_type.to_json) %>"
     data-habitation-form-developments-value="<%= json_escape(development_lookup.to_json) %>"
     data-habitation-form-error-fields-value="<%= json_escape(habitation.errors.attribute_names.map(&:to_s).uniq.to_json) %>"
     data-habitation-form-validation-rules-value="<%= json_escape(tab_validation_rules.to_json) %>"
     data-habitation-duplicate-check-url-value="<%= check_admin_habitation_duplicate_path %>"
     data-habitation-duplicate-check-ignored-id-value="<%= habitation.id %>">
  <% form_main = capture do %>
<% form_url = habitation.persisted? ? admin_habitation_path(habitation.id) : admin_habitations_path %>
<%= form_with(model: [:admin, habitation], url: form_url, local: true, class: "needs-validation habitation-form-shell habitation-editor-form", html: { id: "admin_habitation_form", novalidate: true }, data: { controller: "save-state", action: "submit->save-state#confirm submit->save-state#submitting", turbo: false }) do |f| %>
  <%= hidden_field_tag :save_navigation, "exit", data: { save_state_target: "choice" } %>
  <%= hidden_field_tag :return_to, @return_to_path if @return_to_path.present? %>
  <%= hidden_field_tag :source_habitation_id, source_habitation.id if source_habitation.present? %>
  <%= hidden_field_tag :intake_mode, "paper" if habitation.new_record? && habitation.broker_intake? %>

  <% action_footer_meta = capture do %>
    <% if updated_reference_at %>
      <i class="bi bi-clock-history ax-ico"></i>
      Atualizado há <%= time_ago_in_words(updated_reference_at) %>
      <span class="tw-hidden md:tw-inline">(<%= updated_reference_at.strftime("%d/%m/%Y às %H:%M") %>)</span>
    <% end %>
  <% end %>

  <%= ax_sticky_action_footer(meta: action_footer_meta, class_name: "habitation-action-bar--top") do %>
    <%= link_to "Cancelar", (@return_to_path || admin_habitations_path), class: "ax-btn", data: { save_state_target: "cancelButton" } %>
    <% if can_release_intake_to_broker?(habitation) || (habitation.new_record? && can_complete_admin_intake_review?(habitation)) %>
      <%= f.button type: "submit",
                   name: "release_to_broker_after_save",
                   value: "1",
                   form: "admin_habitation_form",
                   class: "ax-btn ax-btn--primary",
                   data: { habitation_duplicate_check_target: "submit" } do %>
        <%= habitation.new_record? ? "Enviar para corretor" : "Devolver para captador" %>
      <% end %>
      <%= f.button type: "submit",
                   name: "save_internal_after_save",
                   value: "1",
                   form: "admin_habitation_form",
                   class: "ax-btn",
                   data: { habitation_duplicate_check_target: "submit" } do %>
        Salvar Interno
      <% end %>
    <% end %>
    <%= f.button type: "submit",
                 name: "save_navigation",
                 value: "stay",
                 form: "admin_habitation_form",
                 class: "ax-btn ax-btn--primary",
                 data: { save_state_target: "submitButton", habitation_duplicate_check_target: "submit", save_state_direct: true } do %>
      <span class="ax-btn__spinner" role="status" aria-hidden="true" hidden data-save-state-target="spinner"></span>
      <span data-save-state-target="label">Salvar</span>
    <% end %>
    <%= f.button type: "submit",
                 name: "save_navigation",
                 value: "exit",
                 form: "admin_habitation_form",
                 class: "ax-btn",
                 data: { habitation_duplicate_check_target: "submit", save_state_direct: true } do %>
      Salvar e sair
    <% end %>
  <% end %>

  <div class="habitation-editor-main">
    <section class="habitation-editor-workspace" aria-label="Campos do cadastro">
  <% if source_habitation.present? %>
    <div class="ax-form-origin-note">
      <i class="bi bi-link-45deg"></i>
      <span>
        Este empreendimento será criado a partir da unidade
        <strong>#<%= source_habitation.codigo.presence || source_habitation.id %></strong>
        e a unidade será vinculada automaticamente após salvar.
      </span>
    </div>
  <% end %>
  <% if habitation.new_record? %>
    <% if habitation.broker_intake? %>
      <%= ax_inline_notice(tone: :info, icon: "journal-check", class_name: "habitation-new-mode-notice") do %>
        <strong>Ficha de captação interna.</strong>
        Este cadastro entra no fluxo de captações. Use <strong>Enviar para corretor</strong> para repassar a publicação ao captador ou <strong>Salvar interno</strong> para deixar o imóvel disponível no catálogo sem publicar no site.
        <%= link_to "Cadastrar imóvel direto", new_admin_habitation_path, class: "habitation-new-mode-notice__link" %>
      <% end %>
    <% end %>
  <% end %>
  <% if habitation.errors.any? %>
    <%= ax_error_summary(
          habitation,
          grouped_errors: grouped_errors,
          labels: tab_titles,
          order: [:general, :features, :infra, :commercial, :media, :documents, :seo, :other]
        ) %>
  <% end %>

  <!-- Tab Content -->
  <div class="tab-content habitation-tab-content" id="habitationTabsContent">
    
<%= render "admin/habitations/form_tabs/base",
           f: f,
           habitation: habitation,
           cadastro_reference_at: cadastro_reference_at,
           updated_reference_at: updated_reference_at,
           intake_waiting_admin_review: intake_waiting_admin_review,
           cadastro_type_labels: cadastro_type_labels,
           inferred_cadastro_type: inferred_cadastro_type,
           cadastro_tipo_by_type: cadastro_tipo_by_type,
           suspended_status: suspended_status,
           can_edit_protected_habitation_fields: can_edit_protected_habitation_fields %>

<%= render "admin/habitations/form_tabs/estrutura",
           f: f,
           can_edit_protected_habitation_fields: can_edit_protected_habitation_fields %>

<%= render "admin/habitations/form_tabs/empreendimento",
           f: f,
           habitation: habitation,
           can_edit_protected_habitation_fields: can_edit_protected_habitation_fields %>

<%= render "admin/habitations/form_tabs/comercial",
           f: f,
           habitation: habitation,
           can_edit_protected_habitation_fields: can_edit_protected_habitation_fields %>
<%= render "admin/habitations/form_tabs/publicacao",
           f: f,
           intake_waiting_admin_review: intake_waiting_admin_review,
           can_edit_protected_habitation_fields: can_edit_protected_habitation_fields %>

<%= render "admin/habitations/form_tabs/media", f: f, habitation: habitation %>

<%= render "admin/habitations/form_tabs/documents",
           f: f,
           habitation: habitation,
           show_vista_document_assets: show_vista_document_assets,
           vista_document_assets: vista_document_assets,
           vista_document_status_labels: vista_document_status_labels,
           can_manage_internal_documents: can_manage_internal_documents %>


      </div>
    </section>

  </div>

  <div class="ax-save-modal"
       tabindex="-1"
       role="presentation"
       aria-hidden="true"
       hidden
       data-save-state-target="modal"
       data-action="click->save-state#backdropCancel">
    <div class="ax-save-modal__panel" role="dialog" aria-modal="true" aria-labelledby="habitationSaveOptionsTitle">
      <header class="ax-save-modal__header">
        <h5 id="habitationSaveOptionsTitle">Como deseja salvar?</h5>
        <button type="button" class="ax-icon-btn" aria-label="Fechar" data-action="save-state#cancel">
          <i class="bi bi-x-lg"></i>
        </button>
      </header>
      <div class="ax-save-modal__body">
        <p>
          Escolha se quer continuar editando esta ficha ou voltar para o catálogo depois que o imóvel for salvo.
        </p>
      </div>
      <footer class="ax-save-modal__footer">
        <button type="button" class="ax-btn" data-action="save-state#cancel">
          Cancelar
        </button>
        <button type="button" class="ax-btn" data-action="save-state#submitStay">
          Salvar e permanecer
        </button>
        <button type="button" class="ax-btn ax-btn--primary" autofocus data-action="save-state#submitExit">
          Salvar e sair
        </button>
      </footer>
    </div>
  </div>

  <div class="ax-toast" role="status" aria-live="polite" aria-atomic="true" hidden data-save-state-target="toast">
    <div class="ax-toast__body" data-save-state-target="toastBody"></div>
    <button type="button" class="ax-toast__close" aria-label="Fechar aviso" data-action="save-state#closeToast">
      <i class="bi bi-x-lg"></i>
    </button>
  </div>
<% end %>
  <% end %>

  <%= render "admin/shared/ui/workspace_shell",
             class_name: "habitation-property-editor-main",
             main_class: "habitation-property-main-pane",
             main_label: "Cadastro de imóvel",
             main_body_class: "habitation-property-main-body",
             main: form_main,
             aside_partial: "admin/habitations/editor_aside",
             aside_locals: {
               habitation: habitation,
               tab_nav_items: tab_nav_items,
               tab_titles: tab_titles,
               tab_error_counts: tab_error_counts,
               tab_missing_counts: tab_missing_counts,
               tab_error_badge: tab_error_badge
             },
             aside_first: true,
             aside_class: "habitation-editor-explorer habitation-editor-inspector",
             aside_label: "Editor do imóvel",
             contextbar_class: "habitation-property-middle-contextbar",
             controller: "ax-aside",
             storage_key: "admin-habitation-form-editor-collapsed",
             preload_class: "ax-habitation-editor-collapsed-preload" %>

<% if habitation.persisted? && can_manage_internal_documents %>
  <% [
       ["habitation_fichas_cadastro", :fichas_cadastro],
       ["habitation_autorizacoes_venda", :autorizacoes_venda]
     ].each do |input_id, association| %>
    <%= form_with model: [:admin, habitation],
                  local: true,
                  html: {
                    id: "#{association}_upload_form",
                    class: "ax-hidden-form",
                    multipart: true
                  },
                  data: { controller: "internal-document-upload", turbo: false, internal_document_upload_form: true } do %>
      <%= hidden_field_tag :save_navigation, "stay" %>
      <%= hidden_field_tag :save_anchor, "documents" %>
      <%= hidden_field_tag :document_upload, association %>
      <%= hidden_field_tag :return_to, @return_to_path if @return_to_path.present? %>
      <%= file_field_tag "habitation[#{association}][]",
                         multiple: true,
                         id: input_id,
                         class: "ax-file-upload__input",
                         data: {
                           internal_document_upload_input: true,
                           action: "change->internal-document-upload#upload"
                         } %>
    <% end %>
  <% end %>
<% end %>

<% if habitation.persisted? && can_manage_internal_documents %>
  <% [
       ["fichas_cadastro", habitation.fichas_cadastro.attachments],
       ["autorizacoes_venda", habitation.autorizacoes_venda.attachments]
     ].each do |association, attachments| %>
    <% attachments.each do |attachment| %>
      <% next unless attachment.persisted? && attachment.blob&.persisted? %>
      <%= form_with url: purge_attachment_admin_habitation_path(habitation.id, association: association, attachment_id: attachment.id),
                    method: :delete,
                    local: true,
                    html: {
                      id: "purge_attachment_#{attachment.id}",
                      class: "ax-hidden-form",
                    },
                    data: { turbo: false } do %>
        <%= hidden_field_tag :return_to, @return_to_path if @return_to_path.present? %>
      <% end %>
    <% end %>
  <% end %>
<% end %>

<%= render "admin/shared/attribute_manager_modal", modal_id: "attributeManagerModal" %>

<% quick_proprietor_body = capture do %>
  <div class="ax-quick-modal__error" data-ax-quick-create-target="error" hidden></div>
  <form id="quickProprietorForm"
        action="<%= quick_create_admin_proprietors_path %>"
        method="post"
        class="ax-quick-modal__form"
        data-ax-quick-create-target="form"
        data-action="submit->ax-quick-create#submit">
    <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
    <%= ax_field_grid(columns: 12, gap: :compact, class_name: "ax-quick-modal__grid") do %>
      <div class="ax-span-12">
        <%= ax_field_label(nil, nil, text: "Nome do proprietário", for: "quick_proprietor_name") %>
        <input type="text"
               class="ax-control"
               id="quick_proprietor_name"
               name="proprietor[name]"
               required
               autocomplete="name">
      </div>
      <div class="ax-span-6">
        <%= ax_field_label(nil, nil, text: "Telefone principal", for: "quick_proprietor_phone") %>
        <input type="text"
               class="ax-control"
               id="quick_proprietor_phone"
               name="proprietor[phone_primary]">
      </div>
      <div class="ax-span-6">
        <%= ax_field_label(nil, nil, text: "Celular", for: "quick_proprietor_mobile") %>
        <input type="text"
               class="ax-control"
               id="quick_proprietor_mobile"
               name="proprietor[mobile_phone]">
      </div>
      <div class="ax-span-7">
        <%= ax_field_label(nil, nil, text: "E-mail", for: "quick_proprietor_email") %>
        <input type="email"
               class="ax-control"
               id="quick_proprietor_email"
               name="proprietor[email]">
      </div>
      <div class="ax-span-5">
        <%= ax_field_label(nil, nil, text: "CPF/CNPJ", for: "quick_proprietor_cpf") %>
        <input type="text"
               class="ax-control"
               id="quick_proprietor_cpf"
               name="proprietor[cpf_cnpj]">
      </div>
    <% end %>
  </form>
<% end %>

<% quick_proprietor_footer = capture do %>
  <button type="button" class="ax-btn" data-action="ax-modal#close">Cancelar</button>
  <button type="submit" form="quickProprietorForm" class="ax-btn ax-btn--primary" data-ax-quick-create-target="submit">
    Salvar e selecionar
  </button>
<% end %>

<%= ax_quick_modal(
      id: "quickProprietorModal",
      title: "Novo proprietário",
      footer: quick_proprietor_footer,
      body: quick_proprietor_body,
      data: {
        controller: "ax-quick-create",
        ax_quick_create_select_id_value: "habitation_proprietor_id",
        ax_quick_create_focus_selector_value: "#quick_proprietor_phone"
      }
    ) %>

</div>
