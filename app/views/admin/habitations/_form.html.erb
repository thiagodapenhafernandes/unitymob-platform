<script>
  (() => {
    if (window.saluteHabitationSaveOptionsBound) return;
    window.saluteHabitationSaveOptionsBound = true;

    const submitters = new WeakMap();

    const bootstrapApi = () => window.bootstrap || (typeof bootstrap !== "undefined" ? bootstrap : null);
    const findForm = (element) => element?.closest?.("form[data-habitation-save-options-form='true']");
    const findModal = (form) => form?.querySelector("[data-habitation-save-options-modal='true']");
    const findToast = (form) => form?.querySelector("[data-habitation-save-options-toast='true']");
    const findToastBody = (form) => form?.querySelector("[data-habitation-save-options-toast-body='true']");
    const findChoice = (form) => form?.querySelector("[data-habitation-save-options-choice='true']");

    const showToast = (form, message) => {
      const toast = findToast(form);
      const body = findToastBody(form);
      if (!toast || !body) return;

      body.textContent = message;
      const bootstrapElement = bootstrapApi();

      if (bootstrapElement?.Toast) {
        bootstrapElement.Toast.getOrCreateInstance(toast, { delay: 3500 }).show();
        return;
      }

      toast.classList.add("show");
      window.setTimeout(() => toast.classList.remove("show"), 3500);
    };

    const showModal = (form) => {
      const modal = findModal(form);
      const bootstrapElement = bootstrapApi();

      if (modal && bootstrapElement?.Modal) {
        bootstrapElement.Modal.getOrCreateInstance(modal).show();
        return;
      }

      const choiceInput = findChoice(form);
      if (choiceInput) choiceInput.value = "exit";
      form.dataset.habitationSaveOptionsConfirmed = "true";
      requestSubmit(form);
    };

    const hideModal = (form) => {
      const modal = findModal(form);
      const bootstrapElement = bootstrapApi();
      if (!modal || !bootstrapElement?.Modal) return;

      bootstrapElement.Modal.getOrCreateInstance(modal).hide();
    };

    const requestSubmit = (form) => {
      const submitter = submitters.get(form);
      if (submitter) {
        form.requestSubmit(submitter);
      } else {
        form.requestSubmit();
      }
    };

    const submitWithChoice = (form, choice, message) => {
      const choiceInput = findChoice(form);
      if (choiceInput) choiceInput.value = choice;
      form.dataset.habitationSaveOptionsConfirmed = "true";
      hideModal(form);
      showToast(form, message);
      window.setTimeout(() => requestSubmit(form), 200);
    };

    document.addEventListener("submit", (event) => {
      const form = findForm(event.target);
      if (!form) return;

      if (form.dataset.habitationSaveOptionsConfirmed === "true") {
        form.dataset.habitationSaveOptionsConfirmed = "false";
        return;
      }

      if (event.submitter?.name === "release_to_broker_after_save") return;
      if (event.submitter?.name === "save_internal_after_save") return;
      if (event.submitter?.dataset?.habitationSaveOptionsDirect === "true") return;

      event.preventDefault();
      event.stopImmediatePropagation();
      submitters.set(form, event.submitter);
      showToast(form, "Escolha como deseja concluir o salvamento.");
      showModal(form);
    }, true);

    document.addEventListener("click", (event) => {
      const button = event.target.closest("[data-habitation-save-options-action]");
      const form = findForm(button);
      if (!button || !form) return;

      event.preventDefault();
      const action = button.dataset.habitationSaveOptionsAction;

      if (action === "cancel") {
        hideModal(form);
        showToast(form, "Salvamento cancelado. Nenhuma alteração foi enviada.");
        return;
      }

      if (action === "stay") {
        submitWithChoice(form, "stay", "Salvando e permanecendo na ficha de cadastro...");
        return;
      }

      submitWithChoice(form, "exit", "Salvando e saindo para o catálogo...");
    });
  })();
</script>
<script>
  (() => {
    const form = document.getElementById("quickProprietorForm");
    if (!form) return;

    const modalElement = document.getElementById("quickProprietorModal");
    const errorBox = modalElement?.querySelector("[data-quick-proprietor-error]");
    const submitButton = modalElement?.querySelector('button[form="quickProprietorForm"]');

    const showError = (message) => {
      if (!errorBox) return;
      errorBox.textContent = message;
      errorBox.classList.remove("d-none");
    };

    const clearError = () => {
      if (!errorBox) return;
      errorBox.textContent = "";
      errorBox.classList.add("d-none");
    };

    const selectProprietor = ({ id, name }) => {
      const select = document.getElementById(form.dataset.proprietorSelectId);
      if (!select) return;

      const value = String(id);
      if (!select.querySelector(`option[value="${CSS.escape(value)}"]`)) {
        select.add(new Option(name, value, true, true));
      }

      select.value = value;

      if (select.tomselect) {
        select.tomselect.addOption({ value: value, text: name });
        select.tomselect.setValue(value, true);
      }

      select.dispatchEvent(new Event("change", { bubbles: true }));
    };

    modalElement?.addEventListener("shown.bs.modal", () => {
      clearError();
      form.querySelector("#quick_proprietor_name")?.focus();
    });

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      clearError();
      submitButton?.setAttribute("disabled", "disabled");

      try {
        const response = await fetch(form.action, {
          method: "POST",
          headers: {
            "Accept": "application/json",
            "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]')?.content || ""
          },
          body: new FormData(form)
        });
        const payload = await response.json();

        if (!response.ok) {
          showError((payload.errors || ["Não foi possível salvar o proprietário."]).join(" "));
          return;
        }

        selectProprietor(payload);
        form.reset();
        window.bootstrap?.Modal?.getInstance(modalElement)?.hide();
      } catch (_error) {
        showError("Erro de comunicação ao salvar o proprietário.");
      } finally {
        submitButton?.removeAttribute("disabled");
      }
    });
  })();
</script>
