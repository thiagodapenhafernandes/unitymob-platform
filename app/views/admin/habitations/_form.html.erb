      <div class="d-flex">
        <div class="toast-body" data-save-state-target="toastBody" data-habitation-save-options-toast-body="true"></div>
        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Fechar"></button>
      </div>
