              <div class="col-md-3">
                <%= address_form.label :cidade, "Cidade:", class: "form-label small fw-bold mb-1" %>
                <%= address_form.select :cidade, @cities, { include_blank: true, selected: address_form.object.cidade },
                    data: { controller: "tom-select", tom_select_create_value: true, cep_search_target: "cidade" },
