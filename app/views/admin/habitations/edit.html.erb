<% content_for :submit_text, "Atualizar Imóvel" %>

<% return_path = @return_to_path || admin_habitations_path %>
<% content_for :admin_contextbar_breadcrumb do %>
  <%= link_to "Admin", admin_root_path %>
  <i class="bi bi-chevron-right"></i>
  <%= link_to "Imóveis", admin_habitations_path %>
  <i class="bi bi-chevron-right"></i>
  <strong><%= @habitation.codigo.presence || "Novo cadastro" %></strong>
<% end %>

<% content_for :admin_contextbar_actions do %>
  <%= admin_contextbar_link("Voltar", return_path, icon: "arrow-left") %>
  <%= admin_contextbar_link("Ver no site", habitation_path(@habitation), icon: "box-arrow-up-right", primary: true, target: "_blank", rel: "noopener") if @habitation.persisted? %>
  <button type="button" class="ax-contextbar__button" data-ax-modal-open="#habitationHistoryModal">
    <i class="bi bi-layout-text-window-reverse"></i><span>Central do imóvel</span>
  </button>
  <% if can_destroy_habitation? && @habitation.persisted? %>
    <%= button_to admin_habitation_path(@habitation.id),
        method: :delete,
        class: "ax-contextbar__button ax-contextbar__button--danger",
        form: { class: "tw-m-0" },
        data: { turbo_confirm: "Tem certeza que deseja excluir este imóvel? Esta ação não pode ser desfeita." },
        title: "Excluir imóvel" do %>
      <i class="bi bi-trash"></i><span>Excluir</span>
    <% end %>
  <% end %>
<% end %>

<%= render 'form', habitation: @habitation %>
<%= render 'audit_history_modal', habitation: @habitation %>
