<%= ax_form_section(title: "Proprietário e comissões", eyebrow: "Relacionamento", icon: "person-lines-fill") do %>
  <div class="ax-owner-commission-layout">
    <% if can_view_proprietor_data?(habitation) %>
      <div>
        <%= ax_field_group(title: "Proprietário e contatos") do %>
          <% proprietor_action = capture do %>
            <%= link_to "#quickProprietorModal",
                class: "ax-btn ax-btn--ghost",
                title: "Cadastrar novo proprietário",
                data: {
                  ax_modal_open: "#quickProprietorModal",
                  broker_field_policy_lock: true,
                  field_lock_action: "acao:cadastrar_proprietario"
                } do %>
              <i class="bi bi-plus"></i>
            <% end %>
          <% end %>

          <%= ax_field_grid do %>
            <div class="ax-span-12">
              <%= ax_relationship_select(
                    form: f,
                    method: :proprietor_id,
                    label: "Proprietário",
                    collection: @proprietors,
                    value_method: :id,
                    text_method: :name,
                    select_options: { include_blank: "Selecione..." },
                    html_options: {
                      data: { controller: "tom-select", placeholder: "Selecione...", habitation_form_target: "proprietorSelect" },
                      disabled: !habitation_field_editable?("proprietor_id")
                    },
                    action: proprietor_action,
                    tooltip: "Cadastro único do proprietário. Os contatos exibidos abaixo vêm deste vínculo."
                  ) %>
            </div>
            <div class="ax-span-12">
              <%= ax_field_label(nil, nil, text: "E-mail", for: "habitation_proprietor_email_display") %>
              <%= tag.input type: "text",
                    value: habitation.proprietario_email_display,
                    id: "habitation_proprietor_email_display",
                    class: "ax-control",
                    readonly: true %>
            </div>
            <div class="ax-span-12">
              <%= ax_field_label(nil, nil, text: "Cidade", for: "habitation_proprietor_city_display") %>
              <%= tag.input type: "text",
                    value: habitation.proprietor&.city.presence || habitation.proprietario_cidade,
                    id: "habitation_proprietor_city_display",
                    class: "ax-control",
                    readonly: true %>
            </div>
            <div class="ax-span-12">
              <%= ax_field_label(nil, nil, text: "Celular", for: "habitation_proprietor_mobile_display") %>
              <%= tag.input type: "text",
                    value: Phones::Normalizer.display(habitation.proprietario_telefone),
                    id: "habitation_proprietor_mobile_display",
                    class: "ax-control",
                    readonly: true %>
            </div>
            <div class="ax-span-6">
              <%= ax_field_label(nil, nil, text: "F. Comercial", for: "habitation_proprietor_business_phone_display") %>
              <%= tag.input type: "text",
                    value: Phones::Normalizer.display(habitation.proprietario_telefone_comercial_display),
                    id: "habitation_proprietor_business_phone_display",
                    class: "ax-control",
                    readonly: true %>
            </div>
            <div class="ax-span-6">
              <%= ax_field_label(nil, nil, text: "F. Residencial", for: "habitation_proprietor_residential_phone_display") %>
              <%= tag.input type: "text",
                    value: Phones::Normalizer.display(habitation.proprietario_telefone_residencial_display),
                    id: "habitation_proprietor_residential_phone_display",
                    class: "ax-control",
                    readonly: true %>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
    <div>
      <%= ax_field_group(title: "Comissão e operação") do %>
        <%= ax_field_grid do %>
          <div class="ax-span-6">
            <%= ax_currency_field(form: f, method: :valor_livre_proprietario_formatted, label: "Proprietário (livre)", data: { controller: "mask", mask_type_value: "currency" }) %>
          </div>
          <div class="ax-span-6">
            <%= ax_currency_field(form: f, method: :valor_comissao_formatted, label: "Valor da comissão", data: { controller: "mask", mask_type_value: "currency" }) %>
          </div>
          <div class="ax-span-6">
            <%= ax_number_field(form: f, method: :captador_commission_percentage, label: "Comissão captador (%)", min: 0, max: 100, step: 0.01, placeholder: "0,00") %>
          </div>
          <div class="ax-span-6">
            <%= ax_number_field(form: f, method: :broker_commission_percentage, label: "Comissão corretor (%)", min: 0, max: 100, step: 0.01, placeholder: "0,00") %>
          </div>
          <div class="ax-span-12 ax-field-align-end">
            <%= ax_toggle_chip(f, :salute_rental_management_flag, label: "Administração de locação", class_name: "ax-toggle-chip--full") %>
          </div>
          <div class="ax-span-12"
               data-controller="conditional-reveal"
               data-conditional-reveal-kind-value="checkbox">
            <%= ax_field_grid do %>
              <div class="ax-span-5 ax-field-align-end">
                <%= ax_toggle_chip(
                      f,
                      :home_corporate_flag,
                      label: "Vitrine Corporate",
                      class_name: "ax-toggle-chip--full",
                      input_data: {
                        conditional_reveal_target: "trigger",
                        action: "change->conditional-reveal#sync"
                      }
                    ) %>
              </div>
              <div class="ax-span-7 ax-reactive-inactive-hint"
                   data-conditional-reveal-target="inactiveHint"
                   <%= "hidden" if f.object.home_corporate_flag? %>>
                Ative para definir a posição do imóvel na vitrine Corporate.
              </div>
              <div class="ax-span-4 ax-reactive-context ax-reactive-context--inline"
                   data-conditional-reveal-target="panel"
                   <%= "hidden" unless f.object.home_corporate_flag? %>>
                <%= ax_number_field(
                      form: f,
                      method: :home_corporate_position,
                      label: "Posição na Home",
                      min: 1,
                      max: 20,
                      placeholder: "1, 2, 3...",
                      disabled: !f.object.home_corporate_flag?,
                      required: f.object.home_corporate_flag?,
                      data: { conditional_required: true }
                    ) %>
              </div>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
