<!-- Tab: Comercial -->
<div class="tab-pane fade" id="comercial" role="tabpanel" aria-labelledby="comercial-tab" data-controller="habitation-brokers">
  <div class="ax-form-workspace ax-commercial-workspace">
    <div class="ax-commercial-columns">
      <div class="ax-commercial-column ax-commercial-column--main">
        <%= render "admin/habitations/form_tabs/comercial/condicoes", f: f %>
        <%= render "admin/habitations/form_tabs/comercial/atendimento", f: f %>
        <%= render "admin/habitations/form_tabs/comercial/permuta", f: f %>
      </div>
      <div class="ax-commercial-column ax-commercial-column--side">
        <%= render "admin/habitations/form_tabs/comercial/proprietario_comissao",
                   f: f,
                   habitation: habitation,
                   can_edit_protected_habitation_fields: can_edit_protected_habitation_fields %>
        <%= render "admin/habitations/form_tabs/comercial/responsaveis", f: f %>
        <%= render "admin/habitations/form_tabs/shared/portal_publicacao", f: f %>
      </div>
    </div>
  </div>
</div>
