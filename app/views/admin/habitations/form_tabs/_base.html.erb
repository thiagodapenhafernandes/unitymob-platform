<!-- Tab: Visão Geral -->
<div class="tab-pane fade show active" id="general" role="tabpanel" aria-labelledby="general-tab">
  <div class="ax-form-workspace">
    <%= render "admin/habitations/form_tabs/base/identificacao",
               f: f,
               cadastro_reference_at: cadastro_reference_at,
               updated_reference_at: updated_reference_at,
               intake_waiting_admin_review: intake_waiting_admin_review %>

    <%= render "admin/habitations/form_tabs/base/classificacao",
               f: f,
               habitation: habitation,
               cadastro_type_labels: cadastro_type_labels,
               inferred_cadastro_type: inferred_cadastro_type,
               cadastro_tipo_by_type: cadastro_tipo_by_type,
               suspended_status: suspended_status %>

    <%= render "admin/habitations/form_tabs/base/relacionamentos",
               f: f,
               habitation: habitation,
               show_development_context: show_development_context,
               can_edit_protected_habitation_fields: can_edit_protected_habitation_fields %>

    <%= render "admin/habitations/form_tabs/base/localizacao",
               f: f,
               can_edit_protected_habitation_fields: can_edit_protected_habitation_fields %>
  </div>
</div>
