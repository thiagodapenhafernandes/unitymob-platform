<%= ax_form_section(title: "Endereço e localização", eyebrow: "Localização", icon: "geo-alt") do %>
  <%= f.fields_for :address do |address_form| %>
    <div data-controller="cep-search">
      <%= ax_field_grid(columns: 12, gap: :compact) do %>
        <div class="ax-span-2">
          <%= ax_select_field(
                form: address_form,
                method: :tipo_endereco,
                label: "Endereço",
                choices: Habitation::STREET_TYPES,
                select_options: { include_blank: true },
                html_options: {
                  disabled: !habitation_field_editable?("tipo_endereco"),
                  data: { controller: "tom-select", placeholder: "Selecione...", cep_search_target: "tipo", habitation_form_target: "streetTypeSelect" }
                }
              ) %>
        </div>

        <div class="ax-span-4">
          <%= ax_text_field(
                form: address_form,
                method: :logradouro,
                label: "Logradouro",
                placeholder: "Rua, Av...",
                readonly: !habitation_field_editable?("logradouro"),
                data: {
                  cep_search_target: "logradouro",
                  habitation_form_target: "street",
                  habitation_duplicate_check_target: "street",
                  action: "input->habitation-duplicate-check#schedule blur->habitation-duplicate-check#check"
                }
              ) %>
        </div>

        <div class="ax-span-1">
          <%= ax_text_field(
                form: address_form,
                method: :numero,
                label: "Nº",
                readonly: !habitation_field_editable?("numero"),
                data: {
                  cep_search_target: "numero",
                  habitation_form_target: "streetNumber",
                  habitation_duplicate_check_target: "number",
                  action: "input->habitation-duplicate-check#schedule blur->habitation-duplicate-check#check"
                }
              ) %>
        </div>

        <div class="ax-span-2">
          <%= ax_text_field(
                form: address_form,
                method: :complemento,
                label: "Compl.",
                readonly: !habitation_field_editable?("complemento"),
                data: {
                  cep_search_target: "complemento",
                  habitation_duplicate_check_target: "complement",
                  action: "input->habitation-duplicate-check#schedule blur->habitation-duplicate-check#check"
                }
              ) %>
        </div>

        <div class="ax-span-1">
          <%= ax_select_field(
                form: address_form,
                method: :uf,
                label: "UF",
                choices: Habitation::UF_OPTIONS,
                select_options: { include_blank: true },
                html_options: {
                  disabled: !habitation_field_editable?("uf"),
                  data: { controller: "tom-select", placeholder: "UF", cep_search_target: "uf", habitation_form_target: "stateSelect" }
                }
              ) %>
        </div>

        <div class="ax-span-2">
          <%= ax_field_label(address_form, :cep, text: "CEP") %>
          <% cep_action = capture do %>
            <button class="ax-btn ax-btn--primary" type="button"
                    data-action="cep-search#search"
                    data-broker-field-policy-lock
                    data-field-lock-action="acao:buscar_cep"
                    <%= "disabled" unless habitation_field_editable?("cep") && habitation_field_editable?("acao:buscar_cep") %>>
              <i class="bi bi-search"></i>
            </button>
          <% end %>
          <%= ax_input_group(action: cep_action) do %>
            <%= address_form.text_field :cep,
                class: "ax-control",
                readonly: !habitation_field_editable?("cep"),
                data: {
                  controller: "mask",
                  mask_type_value: "cep",
                  cep_search_target: "cep",
                  habitation_form_target: "zipCode",
                  action: "blur->cep-search#search"
                } %>
          <% end %>
        </div>

        <div class="ax-span-3">
          <%= ax_select_field(
                form: address_form,
                method: :bairro,
                label: "Bairro",
                choices: @neighborhoods,
                select_options: { include_blank: true, selected: address_form.object.bairro },
                html_options: {
                  disabled: !habitation_field_editable?("bairro"),
                  data: { controller: "tom-select", tom_select_create_value: true, cep_search_target: "bairro", habitation_form_target: "neighborhoodSelect" }
                }
              ) %>
        </div>

        <div class="ax-span-2">
          <%= ax_select_field(
                form: address_form,
                method: :bairro_comercial,
                label: "Bairro comercial",
                choices: (@commercial_neighborhoods || []),
                select_options: { include_blank: true, selected: address_form.object.bairro_comercial },
                html_options: {
                  disabled: !habitation_field_editable?("bairro_comercial"),
                  data: { controller: "tom-select", tom_select_create_value: true, habitation_form_target: "commercialNeighborhoodSelect" }
                }
              ) %>
        </div>

        <div class="ax-span-3">
          <%= ax_select_field(
                form: address_form,
                method: :cidade,
                label: "Cidade",
                choices: @cities,
                select_options: { include_blank: true, selected: address_form.object.cidade },
                html_options: {
                  disabled: !habitation_field_editable?("cidade"),
                  data: { controller: "tom-select", tom_select_create_value: true, cep_search_target: "cidade", habitation_form_target: "citySelect" }
                }
              ) %>
        </div>

        <div class="ax-span-1">
          <%= ax_text_field(
                form: f,
                method: :bloco,
                label: "Bloco",
                readonly: !habitation_field_editable?("bloco"),
                data: {
                  habitation_duplicate_check_target: "unit",
                  action: "input->habitation-duplicate-check#schedule blur->habitation-duplicate-check#check"
                }
              ) %>
        </div>

        <div class="ax-span-12">
          <% selected_imediacoes = case address_form.object.imediacoes
             when String then address_form.object.imediacoes.split(/[,\n;]+/)
             else Array(address_form.object.imediacoes)
             end.flatten.compact.map(&:to_s).map(&:strip).reject(&:blank?).uniq %>
          <% imediacoes_options = (@imediacoes_options.to_a + selected_imediacoes).uniq %>
          <%= ax_multiselect_field(
                form: address_form,
                method: :imediacoes,
                label: "Imediações:",
                choices: imediacoes_options,
                selected: selected_imediacoes,
                id: "address-imediacoes-tags",
                # Card #1: "Imediações" é a ÚNICA parte do endereço que o corretor
                # pode editar — por isso não segue can_edit_protected aqui.
                disabled: false,
                placeholder: "Selecione ou digite...",
                manager: {
                  title: "Gerenciar Imediações",
                  aria_label: "Gerenciar Imediações",
                  modal_title: "Gerenciar Imediações",
                  context: "habitation",
                  category: "imediacoes",
                  field_lock_action: "acao:gerenciar_imediacoes",
                  field_name: "habitation[address_attributes][imediacoes][]",
                  modal_id: "attributeManagerModal"
                }
              ) %>
        </div>

        <div class="ax-span-12" data-habitation-duplicate-check-target="status"></div>
      <% end %>
    </div>
  <% end %>

  <div class="tw-mt-3 tw-pt-3 tw-border-t tw-border-line-soft">
    <div class="tw-flex tw-items-center tw-justify-between tw-gap-3 tw-mb-2">
      <div>
        <p class="ax-label tw-mb-0">Exibição no site</p>
        <p class="form-text tw-mb-0">Controle a precisão do mapa e a exposição da vista da rua somente para este imóvel.</p>
      </div>
      <%= ax_badge("Privacidade", tone: :blue, dot: true) %>
    </div>

    <%= ax_field_grid(columns: 12, gap: :compact) do %>
      <div class="ax-span-6">
        <%= ax_select_field(
              form: f,
              method: :public_map_display_mode,
              label: "Localização pública",
              choices: Habitation::PUBLIC_MAP_DISPLAY_MODES.map { |value, label| [label, value] },
              select_options: { selected: f.object.public_map_display_mode },
              html_options: { disabled: !habitation_field_editable?("public_map_display_mode") }
            ) %>
      </div>
      <div class="ax-span-6">
        <%= ax_select_field(
              form: f,
              method: :public_street_view_mode,
              label: "Vista da rua",
              choices: Habitation::PUBLIC_STREET_VIEW_MODES.map { |value, label| [label, value] },
              select_options: { selected: f.object.public_street_view_mode },
              html_options: { disabled: !habitation_field_editable?("public_street_view_mode") }
            ) %>
      </div>
    <% end %>

    <%= ax_inline_notice(tone: :warning, icon: "shield-exclamation", class_name: "tw-mt-2") do %>
      <span>Localização exata e vista da rua devem ser liberadas apenas quando houver autorização para divulgar o endereço.</span>
    <% end %>
  </div>
<% end %>
