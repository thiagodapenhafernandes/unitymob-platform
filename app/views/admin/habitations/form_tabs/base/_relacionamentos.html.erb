<%# O vínculo de empreendimento mora na aba Empreendimento
    (form_tabs/empreendimento/_vinculo). Aqui ficam os vínculos da unidade. %>
<% if can_export_proprietor_data? %>
  <%= ax_form_section(title: "Responsável pelo cadastro", eyebrow: "Cadastro", icon: "person-vcard") do %>
    <%= ax_field_grid(columns: 12, gap: :compact) do %>
      <div class="ax-span-6">
        <%= ax_relationship_select(
              form: f,
              method: :admin_user_id,
              label: "Captador responsável",
              collection: @brokers || [],
              value_method: :id,
              text_method: :name,
              select_options: { include_blank: "— sem corretor —" },
              html_options: {
                data: { controller: "tom-select", placeholder: "Selecione...", habitation_form_target: "captadorSelect" }
              },
              tooltip: "Captador principal responsável pelo imóvel."
            ) %>
      </div>
    <% end %>
  <% end %>
<% end %>
