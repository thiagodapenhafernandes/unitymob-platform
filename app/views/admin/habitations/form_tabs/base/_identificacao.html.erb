<%= ax_form_section(title: "Identificação e sinalizadores", eyebrow: "Base") do %>
  <div class="ax-info-badge-grid ax-info-badge-grid--section">
    <%= ax_info_badge(label: "Referência", value: f.object.codigo.presence || "Gerado automaticamente") %>
    <%= ax_info_badge(label: "Cód. DWV", value: f.object.codigo_dwv.presence || "Não informado") %>
    <%= ax_info_badge(label: "Cadastro", value: cadastro_reference_at ? cadastro_reference_at.strftime("%d/%m/%Y") : "Sem data") %>
    <%= ax_info_badge(
          label: "Atualização",
          value: updated_reference_at ? "#{time_ago_in_words(updated_reference_at)} atrás" : "Sem data",
          tooltip: updated_reference_at&.strftime("%d/%m/%Y às %H:%M")
        ) %>
  </div>

  <div class="ax-toggle-group">
    <%= ax_toggle_chip(f, :exibir_no_site_flag, label: "Site", disabled: intake_waiting_admin_review) %>
    <%= ax_toggle_chip(f, :destaque_web_flag, label: "Destaque") %>
    <%= ax_toggle_chip(f, :festival_salute_flag, label: "Super destaque") %>
    <%= ax_toggle_chip(f, :lancamento_flag, label: "Lançamento") %>
    <%= ax_toggle_chip(f, :tem_placa_flag, label: "Placa") %>
    <%= ax_toggle_chip(f, :exclusivo_flag, label: "Exclusivo") %>
    <%= ax_toggle_chip(f, :imovel_dwv, label: "Imóvel DWV", checked_value: "Sim", unchecked_value: "Não") %>
  </div>
<% end %>
