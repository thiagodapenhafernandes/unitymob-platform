<div class="tab-pane fade" id="documents" role="tabpanel" aria-labelledby="documents-tab">
  <% can_upload_fichas = can_manage_internal_documents && habitation_field_editable?("fichas_cadastro") %>
  <% can_upload_autorizacoes = can_manage_internal_documents && habitation_field_editable?("autorizacoes_venda") %>
  <% can_remove_fichas = can_manage_internal_documents && habitation_field_editable?("acao:remover_fichas_cadastro") %>
  <% can_remove_autorizacoes = can_manage_internal_documents && habitation_field_editable?("acao:remover_autorizacoes_venda") %>
  <div class="ax-form-workspace">
    <%= ax_form_section(
          title: "Documentos internos",
          eyebrow: "Anexos",
          icon: "folder2-open",
          tooltip: "Administrador e Administrativo podem anexar/remover documentos. Captadores visualizam sem trocar nem apagar."
        ) do %>
      <%= ax_field_grid(columns: 12, gap: :compact, class_name: "ax-field-grid--spaced") do %>
        <div class="ax-span-6">
          <%= ax_field_group(
                title: "Fichas de cadastro",
                token: "#{habitation.fichas_cadastro.attachments.size} arquivo(s)",
                class_name: "ax-field-group--panel",
                tooltip: "PDFs ou imagens da ficha física de cadastro do imóvel."
              ) do %>
            <% if can_upload_fichas %>
              <div class="ax-upload-control">
                <% if habitation.persisted? %>
                  <%= ax_file_upload_button(
                        label: "Adicionar arquivos",
                        input_id: "habitation_fichas_cadastro",
                        label_data: { internal_document_upload_label: true }
                      ) %>
                <% else %>
                  <%= ax_file_upload_button(
                        form: f,
                        method: :fichas_cadastro,
                        label: "Adicionar arquivos",
                        input_id: "habitation_fichas_cadastro"
                      ) %>
                <% end %>
                <div class="ax-upload-status" hidden data-internal-document-upload-status="habitation_fichas_cadastro"></div>
              </div>
            <% end %>

            <% if habitation.fichas_cadastro.attached? %>
              <ul class="ax-file-list">
                <% habitation.fichas_cadastro.attachments.each do |attachment| %>
                  <% next unless attachment.persisted? && attachment.blob&.persisted? %>
                  <% attachment_actions = capture do %>
                    <% if habitation.persisted? && can_remove_fichas %>
                      <%= ax_confirm_submit(
                            form_id: "purge_attachment_#{attachment.id}",
                            message: "Remover este arquivo?",
                            confirm_label: "Remover"
                          ) do %>
                        <%= button_tag type: "button",
                                       class: "ax-btn ax-btn--ghost ax-btn--sm ax-text-danger",
                                       title: "Remover arquivo",
                                       form: "purge_attachment_#{attachment.id}",
                                       data: { action: "click->ax-confirm-submit#request" } do %>
                          <i class="bi bi-trash"></i>
                        <% end %>
                      <% end %>
                    <% end %>
                  <% end %>
                  <%= ax_attachment_item(
                        attachment:,
                        url: rails_blob_path(attachment, disposition: "attachment"),
                        meta: number_to_human_size(attachment.byte_size),
                        actions: attachment_actions
                      ) %>
                <% end %>
              </ul>
            <% else %>
              <%= ax_empty_state(
                    title: "Nenhuma ficha anexada",
                    description: "Anexe PDFs ou imagens da ficha física quando houver.",
                    icon: "file-earmark-text"
                  ) %>
            <% end %>
          <% end %>
        </div>

        <div class="ax-span-6">
          <%= ax_field_group(
                title: "Autorizações de venda",
                token: "#{habitation.autorizacoes_venda.attachments.size} arquivo(s)",
                class_name: "ax-field-group--panel",
                tooltip: "Imagens ou PDFs de autorizações assinadas pelo proprietário."
              ) do %>
            <% if can_upload_autorizacoes %>
              <div class="ax-upload-control">
                <% if habitation.persisted? %>
                  <%= ax_file_upload_button(
                        label: "Adicionar arquivos",
                        input_id: "habitation_autorizacoes_venda",
                        label_data: { internal_document_upload_label: true }
                      ) %>
                <% else %>
                  <%= ax_file_upload_button(
                        form: f,
                        method: :autorizacoes_venda,
                        label: "Adicionar arquivos",
                        input_id: "habitation_autorizacoes_venda"
                      ) %>
                <% end %>
                <div class="ax-upload-status" hidden data-internal-document-upload-status="habitation_autorizacoes_venda"></div>
              </div>
            <% end %>

            <% if habitation.autorizacoes_venda.attached? %>
              <ul class="ax-file-list">
                <% habitation.autorizacoes_venda.attachments.each do |attachment| %>
                  <% next unless attachment.persisted? && attachment.blob&.persisted? %>
                  <% attachment_actions = capture do %>
                    <% if habitation.persisted? && can_remove_autorizacoes %>
                      <%= ax_confirm_submit(
                            form_id: "purge_attachment_#{attachment.id}",
                            message: "Remover este arquivo?",
                            confirm_label: "Remover"
                          ) do %>
                        <%= button_tag type: "button",
                                       class: "ax-btn ax-btn--ghost ax-btn--sm ax-text-danger",
                                       title: "Remover arquivo",
                                       form: "purge_attachment_#{attachment.id}",
                                       data: { action: "click->ax-confirm-submit#request" } do %>
                          <i class="bi bi-trash"></i>
                        <% end %>
                      <% end %>
                    <% end %>
                  <% end %>
                  <%= ax_attachment_item(
                        attachment:,
                        url: rails_blob_path(attachment, disposition: "attachment"),
                        meta: number_to_human_size(attachment.byte_size),
                        image_preview: true,
                        actions: attachment_actions
                      ) %>
                <% end %>
              </ul>
            <% else %>
              <%= ax_empty_state(
                    title: "Nenhuma autorização anexada",
                    description: "Anexe autorizações assinadas quando houver.",
                    icon: "shield-check"
                  ) %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
