<%= turbo_frame_tag dom_id(habitation, :ai_content_preview) do %>
  <div class="border rounded p-3 mb-3 bg-light" data-controller="ai-preview">
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-2">
      <div>
        <h6 class="fw-bold mb-1"><i class="bi bi-stars text-primary me-1"></i>IA para título e descrição</h6>
      </div>
      <%= link_to generate_ai_preview_admin_habitation_path(habitation),
          class: "btn btn-sm btn-outline-primary",
          data: {
            turbo_method: :post,
            turbo_frame: dom_id(habitation, :ai_content_preview),
            action: "click->ai-preview#loading",
            ai_preview_loading_text: "Gerando..."
          } do %>
        <i class="bi bi-magic me-1"></i>Gerar prévia
      <% end %>
    </div>

    <% if local_assigns[:message].present? %>
      <div class="alert alert-<%= local_assigns[:message_type].presence || "info" %> small py-2 mb-3">
        <%= message %>
      </div>
    <% end %>

    <% if local_assigns[:failed_suggestion]&.error_message.present? %>
      <div class="alert alert-warning small py-2 mb-3">
        Última falha da IA: <%= failed_suggestion.error_message %>
      </div>
    <% end %>

    <% if suggestion.present? %>
      <div class="card border-0 shadow-sm">
        <div class="card-body p-3">
          <div class="mb-3">
            <div class="small text-muted fw-semibold text-uppercase mb-1">Título sugerido</div>
            <div class="fw-bold text-dark"><%= suggestion.generated_title %></div>
          </div>

          <div class="mb-3">
            <div class="small text-muted fw-semibold text-uppercase mb-1">Descrição sugerida</div>
            <div class="small text-dark" style="white-space: pre-line;"><%= suggestion.generated_description %></div>
          </div>

          <% if suggestion.seo_keywords_list.any? %>
            <div class="mb-3">
              <div class="small text-muted fw-semibold text-uppercase mb-1">Palavras-chave SEO sugeridas</div>
              <div class="d-flex flex-wrap gap-1">
                <% suggestion.seo_keywords_list.each do |keyword| %>
                  <span class="badge bg-primary bg-opacity-10 text-primary border"><%= keyword %></span>
                <% end %>
              </div>
            </div>
          <% end %>

          <div class="d-flex justify-content-end gap-2 flex-wrap">
            <%= link_to format_ai_suggestion_admin_habitation_path(habitation, suggestion_id: suggestion.id),
                class: "btn btn-sm btn-outline-secondary",
                data: {
                  turbo_method: :patch,
                  turbo_frame: dom_id(habitation, :ai_content_preview),
                  action: "click->ai-preview#loading",
                  ai_preview_loading_text: "Formatando..."
                } do %>
              <i class="bi bi-text-paragraph me-1"></i>Formatar texto
            <% end %>
            <%= link_to apply_ai_suggestion_admin_habitation_path(habitation, suggestion_id: suggestion.id),
                class: "btn btn-sm btn-success",
                data: {
                  turbo_method: :patch,
                  turbo_frame: dom_id(habitation, :ai_content_preview),
                  turbo_confirm: "Aplicar esta sugestão ao título, descrição e SEO do imóvel?",
                  action: "click->ai-preview#loading",
                  ai_preview_loading_text: "Aplicando..."
                } do %>
              <i class="bi bi-check2-circle me-1"></i>Aplicar sugestão
            <% end %>
          </div>
        </div>
      </div>
    <% else %>
      <div class="alert alert-info small mb-0">
        Nenhuma prévia pendente para este imóvel. Clique em <strong>Gerar prévia</strong> para revisar antes de aplicar.
      </div>
    <% end %>
  </div>
<% end %>
