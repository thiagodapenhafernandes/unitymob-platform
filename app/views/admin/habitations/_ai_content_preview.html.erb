<%= turbo_frame_tag dom_id(habitation, :ai_content_preview) do %>
  <% show_button = local_assigns.fetch(:show_button, true) %>
  <% has_content = local_assigns[:message].present? ||
                   local_assigns[:failed_suggestion]&.error_message.present? ||
                   suggestion.present? ||
                   show_button %>
  <% if has_content %>
    <div class="ax-ai-preview" data-controller="ai-preview">
    <% if show_button %>
      <div class="ax-ai-preview__header">
        <h6 class="ax-ai-preview__title">
          <i class="bi bi-stars ax-ai-preview__title-icon" aria-hidden="true"></i>
          <span>IA para título e descrição</span>
        </h6>
        <%= link_to generate_ai_preview_admin_habitation_path(habitation.id),
            class: "ax-btn ax-btn--ghost ax-btn--sm",
            data: {
              turbo_frame: dom_id(habitation, :ai_content_preview),
              action: "click->ai-preview#submit",
              ai_preview_method: "POST",
              ai_preview_loading_text: "Gerando..."
            } do %>
          <i class="bi bi-magic" aria-hidden="true"></i>
          <span>Gerar prévia</span>
        <% end %>
      </div>
    <% end %>

    <% if local_assigns[:message].present? %>
      <% message_tone = { "success" => :success, "warning" => :warning, "danger" => :danger, "info" => :neutral }.fetch(local_assigns[:message_type].to_s, :neutral) %>
      <%= ax_inline_notice(tone: message_tone, icon: "info-circle", body: message) %>
    <% end %>

    <% if local_assigns[:failed_suggestion]&.error_message.present? %>
      <%= ax_inline_notice(tone: :warning, icon: "exclamation-triangle", body: "Última falha da IA: #{failed_suggestion.error_message}") %>
    <% end %>

    <% if suggestion.present? %>
      <div class="ax-ai-preview__result">
        <div class="ax-ai-preview__content">
          <div class="ax-ai-preview__block">
            <div class="ax-ai-preview__label">Título sugerido</div>
            <div class="ax-ai-preview__text ax-ai-preview__text--strong"><%= suggestion.generated_title %></div>
          </div>

          <div class="ax-ai-preview__block">
            <div class="ax-ai-preview__label">Descrição sugerida</div>
            <div class="ax-ai-preview__description"><%= suggestion.generated_description %></div>
          </div>

          <% if suggestion.seo_keywords_list.any? %>
            <div class="ax-ai-preview__block">
              <div class="ax-ai-preview__label">Palavras-chave SEO sugeridas</div>
              <div class="ax-ai-preview__keywords">
                <% suggestion.seo_keywords_list.each do |keyword| %>
                  <span class="ax-ai-preview__keyword"><%= keyword %></span>
                <% end %>
              </div>
            </div>
          <% end %>

          <div class="ax-ai-preview__actions">
            <%= link_to format_ai_suggestion_admin_habitation_path(habitation.id, suggestion_id: suggestion.id),
                class: "ax-btn ax-btn--ghost ax-btn--sm",
                data: {
                  turbo_frame: dom_id(habitation, :ai_content_preview),
                  action: "click->ai-preview#submit",
                  ai_preview_method: "PATCH",
                  ai_preview_loading_text: "Formatando..."
                } do %>
              <i class="bi bi-text-paragraph" aria-hidden="true"></i>
              <span>Formatar texto</span>
            <% end %>
            <%= link_to apply_ai_suggestion_admin_habitation_path(habitation.id, suggestion_id: suggestion.id),
                class: "ax-btn ax-btn--primary ax-btn--sm",
                data: {
                  turbo_frame: dom_id(habitation, :ai_content_preview),
                  action: "click->ai-preview#submit",
                  ai_preview_method: "PATCH",
                  ai_preview_confirm_message: "Aplicar esta sugestão ao título, descrição e SEO do imóvel?",
                  ai_preview_loading_text: "Aplicando..."
                } do %>
              <i class="bi bi-check2-circle" aria-hidden="true"></i>
              <span>Aplicar sugestão</span>
            <% end %>
          </div>
        </div>
      </div>
    <% elsif show_button %>
      <%= ax_inline_notice(tone: :neutral,
                           icon: "info-circle",
                           body: "Nenhuma prévia pendente para este imóvel. Clique em Gerar prévia para revisar antes de aplicar.") %>
    <% end %>
    </div>
  <% end %>
<% end %>
