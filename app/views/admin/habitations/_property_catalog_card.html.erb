<%
  card_return_to_path = "#{@return_to_path || request.fullpath}#habitation_#{imovel.id}"
  card_return_params = admin_habitation_flat_return_params(card_return_to_path)
  details_path = admin_habitation_path_with_query(admin_habitation_path(imovel.id), card_return_params)
  edit_path = admin_habitation_path_with_query(edit_admin_habitation_path(imovel.id), card_return_params) if admin_can_edit_habitation?(imovel)
  media_modal_path = admin_habitation_path_with_query(modal_admin_habitation_media_path(imovel), card_return_params) if admin_can_manage_habitation_media?(imovel)
  catalog_card_path = admin_habitation_catalog_card_path(imovel, ownership_scope: @ownership_scope, intake_review: @intake_review, return_to: card_return_to_path)
  image_urls = catalog_property_image_urls(imovel)
  total_image_count = catalog_property_image_count(imovel)
  preview_image_count = catalog_property_image_preview_count(imovel, total_count: total_image_count)
  image_url = image_urls.first
  fallback_image_urls = image_urls.drop(1)
  display_title = imovel.display_title
  catalog_title = admin_habitation_catalog_card_title(imovel)
  development_name = admin_habitation_catalog_development_name(imovel)
  catalog_heading_subject = development_name.presence || imovel.categoria.presence || imovel.tipo.presence || catalog_title
  catalog_heading = ["REF: #{imovel.codigo}", catalog_heading_subject].compact_blank.join(" · ")
  has_photo = image_urls.any? || imovel.has_any_photo?
  publication_channels = admin_habitation_publication_channels(imovel)
  captador_name = imovel.primary_captador_name
  captador_label = captador_name.presence || "Não informado"
  data_referencia = [imovel.data_atualizacao_crm, imovel.updated_at].compact.max || Time.current
  seconds_since_update = [Time.current - data_referencia, 0].max
  days_since_update = (seconds_since_update / 1.day).to_i
  compact_update_label = if seconds_since_update < 1.hour
                           "#{[(seconds_since_update / 1.minute).floor, 1].max}min"
                         elsif seconds_since_update < 1.day
                           "#{(seconds_since_update / 1.hour).floor}h"
                         elsif days_since_update < 30
                           "#{days_since_update}d"
                         elsif days_since_update < 365
                           "#{(days_since_update / 30).floor}m"
                         else
                           "#{(days_since_update / 365).floor}a"
                         end
  full_update_label = "Atualizado há #{time_ago_in_words(data_referencia)}"
  update_state = if days_since_update <= 30
                   "is-fresh"
                 elsif days_since_update <= 60
                   "is-attention"
                 else
                   "is-stale"
                 end
  price_label = if imovel.valor_venda_cents.to_i.positive?
                  number_to_currency(imovel.valor_venda_cents / 100.0)
                elsif imovel.valor_locacao_cents.to_i.positive?
                  "#{number_to_currency(imovel.valor_locacao_cents / 100.0)}/mes"
                else
                  "Sob consulta"
                end
  costs = [
    ["Cond.", imovel.valor_condominio_cents.to_i.positive? ? number_to_currency(imovel.valor_condominio_cents / 100.0) : "R$ 0"],
    ["IPTU", imovel.valor_iptu_cents.to_i.positive? ? number_to_currency(imovel.valor_iptu_cents / 100.0) : "R$ 0"]
  ]
  pending_intake_status = admin_habitation_pending_intake_status(imovel, intake_review: @intake_review)
%>

<article id="habitation_<%= imovel.id %>"
         class="ax-property-card ax-property-card--catalog <%= 'is-muted property-card--inactive' if imovel.inactive_for_admin_card? %>"
         data-controller="clickable-card"
         data-clickable-card-url-value="<%= catalog_card_path %>">
  <div class="ax-property-card__media"
       data-controller="fancybox-gallery"
       data-fancybox-gallery-source-url-value="<%= gallery_admin_habitation_path(imovel) %>">
    <% if image_url.present? %>
      <%= link_to image_url,
                  class: "ax-property-card__media-link",
                  data: {
                    controller: "stop-propagation",
                    action: "click->stop-propagation#stop",
                    fancybox: "admin-property-card-#{imovel.id}",
                    caption: display_title
                  } do %>
        <%= image_tag image_url,
                      alt: display_title,
                      loading: "lazy",
                      data: {
                        controller: "image-fallback",
                        action: "error->image-fallback#hide",
                        image_fallback_container_selector_value: ".ax-property-card__media",
                        image_fallback_fallback_urls_value: fallback_image_urls
                      } %>
      <% end %>
      <% fallback_image_urls.each_with_index do |gallery_image_url, gallery_index| %>
        <%= link_to "#{display_title} - Foto #{gallery_index + 2}",
                    gallery_image_url,
                    class: "visually-hidden",
                    data: {
                      fancybox: "admin-property-card-#{imovel.id}",
                      caption: "#{display_title} - Foto #{gallery_index + 2}"
                    },
                    tabindex: "-1",
                    aria: { hidden: "true" } %>
      <% end %>
    <% else %>
      <div class="ax-property-card__empty-media">
        <i class="bi bi-image"></i>
      </div>
    <% end %>

    <% if bulk_actions_allowed %>
      <label class="ax-property-select" title="Selecionar imóvel" data-controller="stop-propagation" data-action="click->stop-propagation#stop">
        <input type="checkbox"
               data-bulk-publish-target="item"
               data-id="<%= imovel.id %>"
               data-action="change->bulk-publish#toggleOne"
               aria-label="Selecionar imóvel <%= imovel.codigo %>">
      </label>
    <% end %>

    <div class="ax-property-card__top-badges">
      <span class="ax-property-badge ax-property-badge--status"><%= imovel.status.presence || "Sem status" %></span>
      <% if imovel.destaque_web_flag %>
        <span class="ax-property-badge ax-property-badge--warning" title="Destaque Web"><i class="bi bi-star-fill"></i></span>
      <% end %>
      <% if !has_photo %>
        <span class="ax-property-badge ax-property-badge--danger">Sem fotos</span>
      <% elsif publication_channels.blank? %>
        <span class="ax-property-badge ax-property-badge--danger">Fora site</span>
      <% end %>
    </div>

    <div class="ax-property-card__media-badges">
      <%= render "admin/shared/ui/photo_count_badge",
                 total_count: total_image_count,
                 preview_count: preview_image_count %>
      <span class="ax-property-update <%= update_state %>" title="<%= full_update_label %>">
        <i class="bi bi-clock-history"></i>
        <%= compact_update_label %>
      </span>
    </div>
  </div>

  <div class="ax-property-card__body">
    <header class="ax-property-card__head">
      <div class="ax-property-card__title-stack">
        <%= link_to catalog_heading,
                    catalog_card_path,
                    class: "ax-property-card__title" %>
        <div class="ax-property-card__identity">
          <span class="ax-property-chip ax-property-card__identity-status <%= admin_habitation_status_chip_class(imovel.status) %>"><%= imovel.status.presence || "Status" %></span>
          <span class="ax-property-chip ax-property-card__identity-category"><%= imovel.categoria.presence || "Sem categoria" %></span>
          <% if pending_intake_status.present? %>
            <span class="ax-property-chip <%= pending_intake_status[:class_name] %>"><%= pending_intake_status[:label] %></span>
          <% end %>
          <% if imovel.dwv_property? %>
            <span class="ax-property-chip ax-property-chip--dark" title="<%= imovel.codigo_dwv.present? ? "Código DWV: #{imovel.codigo_dwv}" : "Imóvel sincronizado via DWV" %>">DWV</span>
          <% end %>
        </div>
      </div>

      <%= render "admin/habitations/property_catalog_actions",
                 imovel: imovel,
                 details_path: details_path,
                 edit_path: edit_path,
                 media_modal_path: media_modal_path %>
    </header>

    <div class="ax-property-card__meta">
      <span>
        <i class="bi bi-geo-alt"></i>
        <%= [imovel.endereco, imovel.numero].compact_blank.join(", ") %>
        <% address_unit_label = admin_habitation_address_unit_label(imovel) %>
        <% if address_unit_label.present? %>
          <strong><%= address_unit_label %></strong>
        <% end %>
        <%= " - #{[imovel.cidade, imovel.uf].compact_blank.join('/')}" if imovel.cidade.present? || imovel.uf.present? %>
      </span>
      <% if development_name.present? %>
        <span><i class="bi bi-building"></i> Empreendimento: <strong><%= development_name %></strong></span>
      <% end %>
      <span><i class="bi bi-person-badge"></i> Captador: <strong><%= captador_label %></strong></span>
    </div>

    <div class="ax-property-card__features" aria-label="Características do imóvel">
      <span><i class="bi bi-door-closed"></i> <strong><%= imovel.dormitorios_qtd.to_i %></strong> Dorm.</span>
      <span><i class="bi bi-key"></i> <strong><%= imovel.suites_qtd.to_i %></strong> Suítes</span>
      <span><i class="bi bi-car-front"></i> <strong><%= imovel.vagas_qtd.to_i %></strong> Vagas</span>
      <span><i class="bi bi-arrows-angle-expand"></i> <strong><%= number_with_precision(imovel.area_privativa_m2.to_f, precision: 1, separator: ",", delimiter: ".") %></strong> m²</span>
    </div>

    <footer class="ax-property-card__footer">
      <div class="ax-property-price">
        <span>Valor do imóvel</span>
        <div class="ax-property-price__value-row">
          <strong><%= price_label %></strong>
          <% if imovel.preco_atualizado_em.present? %>
            <span class="ax-property-price__updated" title="Preço atualizado em <%= l(imovel.preco_atualizado_em, format: :long) rescue imovel.preco_atualizado_em.strftime('%d/%m/%Y') %>">
              <i class="bi bi-tag-fill" aria-hidden="true"></i>
              Preço atualizado há <%= time_ago_in_words(imovel.preco_atualizado_em) %>
            </span>
          <% end %>
        </div>
      </div>
      <div class="ax-property-costs">
        <% costs.each do |label, value| %>
          <span>
            <small><%= label %></small>
            <strong><%= value %></strong>
          </span>
        <% end %>
      </div>
    </footer>
  </div>
</article>
