<% content_for :submit_text, "Criar Imóvel" %>
<% return_path = @return_to_path || admin_habitations_path %>
<% new_habitation_label = @habitation.empreendimento? ? "Novo empreendimento" : "Novo imóvel" %>

<% content_for :admin_contextbar_breadcrumb do %>
  <%= link_to "Admin", admin_root_path %>
  <i class="bi bi-chevron-right"></i>
  <%= link_to "Imóveis", admin_habitations_path %>
  <i class="bi bi-chevron-right"></i>
  <strong><%= new_habitation_label %></strong>
<% end %>

<% content_for :admin_contextbar_actions do %>
  <%= admin_contextbar_link("Voltar", return_path, icon: "arrow-left") %>
<% end %>

<%= render 'form', habitation: @habitation %>
