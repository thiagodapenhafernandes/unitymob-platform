<%
  habitation = local_assigns.fetch(:habitation)
  tab_nav_items = local_assigns.fetch(:tab_nav_items)
  tab_titles = local_assigns.fetch(:tab_titles)
  tab_error_counts = local_assigns.fetch(:tab_error_counts)
  tab_missing_counts = local_assigns.fetch(:tab_missing_counts)
  tab_error_badge = local_assigns.fetch(:tab_error_badge)
  tab_error_count = ->(tab_key) { tab_error_counts[tab_key].to_i }
  tab_missing_count = ->(tab_key) { tab_missing_counts[tab_key].to_i }
  tab_pending_count = lambda do |tab_key|
    [tab_error_count.call(tab_key), tab_missing_count.call(tab_key)].max
  end
  tab_missing_badge = lambda do |tab_key|
    count = tab_missing_count.call(tab_key)
    count.positive? ? tag.span(count, class: "ax-tab-missing", title: "#{count} validação(ões) faltante(s)") : nil
  end
  tab_indicator_tone = lambda do |tab_key|
    tab_pending_count.call(tab_key).positive? ? :pending : :success
  end
  completed_tabs_count = tab_nav_items.count { |(tab_key, _icon, _description)| tab_indicator_tone.call(tab_key) == :success }
  progress_percent = ((completed_tabs_count.to_f / tab_nav_items.size) * 100).round

  editor_rail_body = capture do
%>
  <nav class="ax-aside-rail-nav habitation-editor-rail-nav"
       aria-label="Seções do cadastro recolhidas"
       data-controller="ax-tabs"
       data-ax-tabs-panel-selector-value="#habitationTabsContent">
    <% tab_nav_items.each_with_index do |(tab_key, icon, description), index| %>
      <% tab_dom_id = tab_key == :commercial ? "comercial" : tab_key.to_s %>
      <button class="ax-aside-rail-nav__item habitation-editor-rail-nav__item <%= 'active' if index.zero? %>"
              type="button"
              data-habitation-form-tab-rail-status="<%= tab_key %>"
              data-ax-tabs-target="tab"
              data-ax-tabs-target-param="#<%= tab_dom_id %>"
              data-action="click->ax-tabs#select"
              aria-label="<%= tab_titles[tab_key] %> - <%= description %>"
              aria-selected="<%= index.zero? ? 'true' : 'false' %>"
              title="<%= tab_titles[tab_key] %>">
        <i class="bi bi-<%= icon %>" aria-hidden="true"></i>
        <% if tab_error_count.call(tab_key).positive? %>
          <%= tab_error_badge.call(tab_key) %>
        <% else %>
          <%= tab_missing_badge.call(tab_key) %>
        <% end %>
      </button>
    <% end %>
  </nav>
<% end %>

<%= ax_aside_panel(
      title: "Editor do imóvel",
      token: "#{tab_nav_items.size} áreas",
      rail_label: "Abrir Editor do imóvel",
      rail_icon: "layout-sidebar-inset-reverse",
      collapse_label: "Recolher Editor do imóvel",
      rail_class: "habitation-editor-inspector-rail",
      rail_body: editor_rail_body,
      panel_class: "habitation-editor-inspector-panel",
      header_class: "habitation-editor-panel-head",
      actions_class: "habitation-editor-panel-head__actions",
      toggle_class: "habitation-editor-panel-head__toggle"
    ) do %>
  <div class="habitation-editor-progress" aria-label="Progresso do cadastro">
    <div class="habitation-editor-progress__head">
      <span>Progresso</span>
      <strong data-habitation-form-progress-count><%= completed_tabs_count %>/<%= tab_nav_items.size %></strong>
    </div>
    <div class="habitation-editor-progress__bar" aria-hidden="true">
      <i style="width:<%= progress_percent %>%" data-habitation-form-progress-bar></i>
    </div>
  </div>
  <nav class="ax-form-tabs habitation-tabs-bar"
       aria-label="Seções do cadastro"
       data-controller="ax-tabs"
       data-ax-tabs-panel-selector-value="#habitationTabsContent">
    <ul class="ax-form-tabs__list" id="habitationTabs" role="tablist">
      <% tab_nav_items.each_with_index do |(tab_key, icon, description), index| %>
        <% active = index.zero? %>
        <% tab_dom_id = tab_key == :commercial ? "comercial" : tab_key.to_s %>
        <li class="nav-item" role="presentation">
          <button class="ax-form-tabs__item <%= 'active' if active %>"
                  id="<%= tab_dom_id %>-tab"
                  data-ax-tabs-target="tab"
                  data-ax-tabs-target-param="#<%= tab_dom_id %>"
                  data-action="click->ax-tabs#select"
                  type="button"
                  role="tab"
                  aria-controls="<%= tab_dom_id %>"
                  aria-selected="<%= active ? 'true' : 'false' %>">
            <span class="ax-form-tabs__icon"><i class="bi bi-<%= icon %>"></i></span>
            <span class="ax-form-tabs__copy">
              <strong><%= tab_titles[tab_key] %></strong>
              <span class="ax-form-tabs__description"><%= description %></span>
            </span>
            <span class="habitation-tabs-bar__status" data-habitation-form-tab-status="<%= tab_key %>">
              <% tone = tab_indicator_tone.call(tab_key) %>
              <% if tab_error_count.call(tab_key).positive? %>
                <%= tab_error_badge.call(tab_key) %>
              <% elsif tab_missing_count.call(tab_key).positive? %>
                <%= tab_missing_badge.call(tab_key) %>
              <% elsif tone == :success %>
                <i class="bi bi-check-circle-fill habitation-tabs-bar__ind habitation-tabs-bar__ind--success" title="Completo" aria-hidden="true"></i>
              <% else %>
                <span class="habitation-tabs-bar__ind--neutral" title="Vazio" aria-hidden="true"></span>
              <% end %>
            </span>
          </button>
        </li>
      <% end %>
    </ul>
  </nav>
<% end %>
