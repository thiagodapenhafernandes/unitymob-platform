     data-controller="ax-modal media-modal"
     data-ax-modal-target="overlay"
     data-media-modal-target="overlay"
     data-action="click->ax-modal#backdropClose">
  <div class="ax-media-modal__panel"
       role="dialog"
       aria-modal="true"
       aria-label="Organizador de mídia do imóvel"
       data-media-modal-target="panel">
