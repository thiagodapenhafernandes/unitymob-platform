    <% if current_admin_user&.admin? %>
      <%= link_to admin_proprietors_path, class: "btn btn-outline-primary d-flex align-items-center justify-content-center bg-white fw-semibold" do %>
        <i class="bi bi-person-vcard me-2"></i><span class="d-none d-sm-inline">Proprietários</span>
      <% end %>
    <% end %>
    <% if current_admin_user&.admin? || current_admin_user&.profile&.name == "Administrativo" %>
      <button type="button" class="btn btn-white border d-flex align-items-center justify-content-center bg-white" data-bs-toggle="modal" data-bs-target="#habitationsExportModal">
        <i class="bi bi-download me-2"></i><span>Exportar</span>
      </button>
    <% end %>
    <%= link_to new_admin_habitation_path, class: "btn btn-primary d-flex align-items-center justify-content-center fw-bold shadow-sm" do %>
      <i class="bi bi-plus-lg me-2"></i><span>Novo Imóvel</span>
    <% end %>
  </div>
</div>

<%
  array_filter_keys = %w[dorms suites vagas banheiros]
  extra_filter_keys = %w[
    logradouro numero cep cidade bairro bairro_comercial promotion_status accepts_exchange key_location salute_rental_management min_price max_price
    foto_classificacao
    amenities
    permuta_vehicle permuta_property permuta_others permuta_min_value permuta_location
    permuta_min_dorms permuta_min_suites permuta_min_garagens
    situacao face ocupacao_status estado_conservacao area_total_min area_total_max area_privativa_min area_privativa_max
    destaque_web festival_salute exibir_no_site_salute tem_placa exclusivo empreendimento_codigo corretor_id proprietor_id regiao_foco
    publicar_imovelweb_2 publicar_lais_ai
    publicar_chaves_na_mao publicar_casa_mineira publicar_imovelweb publicar_viva_real_vrsync
    captacao_inicio captacao_fim somente_com_imagens somente_sem_imagens somente_dwv
  ] + array_filter_keys
  active_extra_filters_count = extra_filter_keys.count do |key|
    value = params[key]
    value.is_a?(Array) ? value.reject(&:blank?).any? : value.present?
  end
  extras_open = true
  vista_advanced_keys = %w[
    situacao face ocupacao_status estado_conservacao area_total_min area_total_max area_privativa_min area_privativa_max
    destaque_web festival_salute exibir_no_site_salute tem_placa exclusivo banheiros dorms suites vagas
    foto_classificacao
    amenities
    publicar_imovelweb_2 publicar_lais_ai
    publicar_chaves_na_mao publicar_casa_mineira publicar_imovelweb publicar_viva_real_vrsync
    empreendimento_codigo corretor_id proprietor_id permuta_vehicle permuta_property permuta_others permuta_min_value
    permuta_location permuta_min_dorms permuta_min_suites permuta_min_garagens regiao_foco
    captacao_inicio captacao_fim somente_com_imagens somente_sem_imagens somente_dwv
  ]
  vista_advanced_open = vista_advanced_keys.any? do |key|
    value = params[key]
    value.is_a?(Array) ? value.reject(&:blank?).any? : value.present?
  end
  clear_extras_params = request.query_parameters.except(*extra_filter_keys, "page")
%>

<div class="habitations-master-detail-layout">
  <aside class="habitations-detail-pane" aria-label="Filtros do catálogo">
<div class="card shadow-sm mb-4 border-0 habitations-filter-card habitations-filter-workspace" data-controller="collapse">
  <%= form_with url: admin_habitations_path, method: :get, local: true do |f| %>
    <div class="filter-sticky-toolbar">
      <button class="btn btn-success fw-semibold" type="submit">
        <i class="bi bi-search me-2"></i>Pesquisar
      </button>
      <%= link_to admin_habitations_path, class: "btn btn-link text-muted text-decoration-none fw-semibold px-2" do %>
        <i class="bi bi-eraser me-1"></i>Limpar
      <% end %>
      <button class="btn btn-light border ms-auto filter-collapse-button <%= extras_open ? '' : 'collapsed' %>"
              type="button"
              data-action="click->collapse#toggle"
              data-collapse-target="button"
              aria-expanded="<%= extras_open %>"
              title="Abrir ou recolher filtros detalhados">
        <% if active_extra_filters_count.positive? %>
          <span class="filter-active-counter me-1"><%= active_extra_filters_count %></span>
        <% end %>
        <i class="bi bi-chevron-left"></i>
      </button>
    </div>

  <div class="card-body habitations-filter-master">
      <%= hidden_field_tag :sort, params[:sort] if params[:sort].present? %>
      <%= hidden_field_tag :direction, params[:direction] if params[:direction].present? %>
      <%= hidden_field_tag :scope, params[:scope] if params[:scope].present? %>
      <%= hidden_field_tag :ownership, @ownership_scope if @ownership_scope.present? %>
      <%= hidden_field_tag :intake_review, @intake_review if @intake_review.present? %>

      <div class="filter-master-layout">
        <div class="filter-pane filter-pane-primary">
          <div class="filter-pane-heading">
            <span class="filter-pane-kicker">Busca</span>
            <strong>Localizar imóvel</strong>
          </div>
          <label class="form-label small fw-bold text-muted text-uppercase">Palavra-chave</label>
          <div class="input-group filter-search-input">
            <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
            <%= f.text_field :q, value: params[:q], class: "form-control border-start-0", placeholder: "Código, empreendimento, endereço..." %>
          </div>
        </div>

        <div class="filter-pane filter-pane-secondary">
          <div class="filter-pane-heading">
            <span class="filter-pane-kicker">Recorte</span>
            <strong>Tipo e status</strong>
          </div>
          <div class="filter-inline-fields">
            <div>
              <label class="form-label small fw-bold text-muted text-uppercase">Status</label>
              <%= f.select :status, @filter_statuses, { include_blank: "Todos", selected: params[:status] }, class: "form-select" %>
            </div>
            <div>
              <label class="form-label small fw-bold text-muted text-uppercase">Categoria</label>
              <%= f.select :categoria, @filter_categories, { include_blank: "Todas", selected: params[:categoria] }, class: "form-select" %>
            </div>
          </div>
        </div>

        <div class="filter-compact-hint">
          <span>Extras</span>
          <span><%= active_extra_filters_count.positive? ? "#{active_extra_filters_count} ativos" : "Nenhum ativo" %></span>
        </div>
      </div>
  </div>

  <div class="collapse <%= extras_open ? 'show' : '' %> border-top filter-detail-collapse" data-collapse-target="content">
    <div class="card-body bg-white habitations-filter-detail">
      <div class="d-flex justify-content-between align-items-center gap-3 mb-3">
        <div>
          <span class="filter-pane-kicker">Detalhamento</span>
          <h6 class="mb-0 fw-bold text-primary">
            <i class="bi bi-funnel me-2"></i>Refinar catálogo
          </h6>
        </div>
        <%= link_to "Limpar extras", admin_habitations_path(clear_extras_params), class: "btn btn-link text-decoration-none text-muted fw-semibold small p-0" %>
      </div>

        <div class="filter-detail-grid">
          <section class="filter-detail-section">
            <div class="filter-detail-section__title">Localização</div>
            <div class="filter-location-grid">
              <div class="wide">
                <label class="form-label small fw-bold text-muted text-uppercase">Rua</label>
                <%= f.text_field :logradouro, value: params[:logradouro], class: "form-control", placeholder: "Ex: Avenida Brasil" %>
              </div>
              <div>
                <label class="form-label small fw-bold text-muted text-uppercase">Número</label>
                <%= f.text_field :numero, value: params[:numero], class: "form-control", placeholder: "123" %>
              </div>
              <div>
                <label class="form-label small fw-bold text-muted text-uppercase">CEP</label>
                <%= f.text_field :cep, value: params[:cep], class: "form-control", placeholder: "88330-590" %>
              </div>
              <div>
                <label class="form-label small fw-bold text-muted text-uppercase">Cidade</label>
                <%= f.select :cidade, @filter_cities, { include_blank: "Todas", selected: params[:cidade] }, class: "form-select" %>
              </div>
              <div>
                <label class="form-label small fw-bold text-muted text-uppercase">Bairro</label>
                <%= f.text_field :bairro, value: params[:bairro], class: "form-control", placeholder: "Centro" %>
              </div>
              <div class="wide">
                <label class="form-label small fw-bold text-muted text-uppercase">Bairro comercial</label>
                <%= f.select :bairro_comercial,
                             @filter_bairros_comerciais,
                             { include_blank: "Todos", selected: params[:bairro_comercial] },
                             {
                               class: "form-select",
                               data: {
                                 controller: "tom-select",
                                 tom_select_create_value: true,
                                 placeholder: "Ex: Barra"
                               }
                             } %>
              </div>
            </div>
          </section>

          <section class="filter-detail-section">
            <div class="filter-detail-section__title">Negócio</div>
            <div class="filter-business-grid">
              <div>
                <label class="form-label small fw-bold text-muted text-uppercase">Situação</label>
                <%= f.select :situacao, @filter_situacoes, { include_blank: "Todas", selected: params[:situacao] }, class: "form-select" %>
              </div>
              <div>
                <label class="form-label small fw-bold text-muted text-uppercase">Preço reduzido</label>
                <%= f.select :promotion_status,
                             [["Com preço reduzido", "with_promo"], ["Sem preço reduzido", "without_promo"]],
                             { include_blank: "Todos", selected: params[:promotion_status] },
                             class: "form-select" %>
              </div>
              <div>
                <label class="form-label small fw-bold text-muted text-uppercase">Aceita permuta</label>
                <%= f.select :accepts_exchange,
                             [["Sim", "1"], ["Não", "0"]],
                             { include_blank: "Todos", selected: params[:accepts_exchange] },
                             class: "form-select" %>
              </div>
              <div>
                <label class="form-label small fw-bold text-muted text-uppercase">Chaves</label>
                <%= f.select :key_location, @filter_key_locations, { include_blank: "Todos", selected: params[:key_location] }, class: "form-select" %>
              </div>
              <div>
                <label class="form-label small fw-bold text-muted text-uppercase">Adm. locação</label>
                <%= f.select :salute_rental_management,
                             [["Sim", "1"], ["Não", "0"]],
                             { include_blank: "Todos", selected: params[:salute_rental_management] },
                             class: "form-select" %>
              </div>
              <div class="wide">
                <label class="form-label small fw-bold text-muted text-uppercase">Preço</label>
                <div class="filter-price-pair">
                  <div class="input-group">
                    <span class="input-group-text bg-white">R$</span>
                    <%= f.text_field :min_price, value: params[:min_price], class: "form-control money-mask", placeholder: "Mín." %>
                  </div>
                  <div class="input-group">
                    <span class="input-group-text bg-white">R$</span>
                    <%= f.text_field :max_price, value: params[:max_price], class: "form-control money-mask", placeholder: "Máx." %>
                  </div>
                </div>
              </div>
            </div>
          </section>

          <section class="filter-detail-section filter-detail-section-dates">
            <div class="filter-detail-section__title">Datas</div>
            <div class="filter-date-grid">
              <div>
                <label class="form-label small fw-bold text-muted text-uppercase">Cadastro de</label>
                <%= f.date_field :captacao_inicio, value: params[:captacao_inicio], class: "form-control" %>
              </div>
              <div>
                <label class="form-label small fw-bold text-muted text-uppercase">Cadastro até</label>
                <%= f.date_field :captacao_fim, value: params[:captacao_fim], class: "form-control" %>
              </div>
              <div>
                <label class="form-label small fw-bold text-muted text-uppercase">Atualiz. de</label>
                <%= f.date_field :atualizacao_inicio, value: params[:atualizacao_inicio], class: "form-control" %>
              </div>
              <div>
                <label class="form-label small fw-bold text-muted text-uppercase">Atualiz. até</label>
                <%= f.date_field :atualizacao_fim, value: params[:atualizacao_fim], class: "form-control" %>
              </div>
            </div>
          </section>
        </div>

        <details class="mt-4 border rounded-3 bg-light-subtle" <%= "open" if vista_advanced_open %>>
          <summary class="px-3 py-2 fw-bold text-primary" style="cursor: pointer;">
            <i class="bi bi-grid-3x3-gap me-2"></i>Filtro avançado
          </summary>
          <div class="p-3 border-top rounded-bottom-3 filter-advanced-body">
            <div class="border rounded-3 p-3 mb-3">
              <h6 class="fw-bold text-secondary mb-3">Localização</h6>
              <div class="row g-3">
                <div class="col-md-3">
                  <label class="form-label small fw-bold text-muted text-uppercase">Empreendimento</label>
                  <%= f.select :empreendimento_codigo,
                               @filter_empreendimentos,
                               { include_blank: "Todos", selected: params[:empreendimento_codigo] },
                               {
                                 class: "form-select",
                                 data: {
                                   controller: "tom-select",
                                   tom_select_create_value: false,
                                   tom_select_options_value: { placeholder: "Selecione empreendimento" }
                                 }
                               } %>
                </div>
                <% if current_admin_user&.admin? || current_admin_user&.profile&.name == "Administrativo" %>
                  <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Corretor</label>
                    <%= f.select :corretor_id,
                                 @filter_brokers,
                                 { include_blank: "Todos", selected: params[:corretor_id] },
                                 {
                                   class: "form-select",
                                   data: {
                                     controller: "tom-select",
                                     tom_select_create_value: false,
                                     tom_select_options_value: { placeholder: "Selecione corretor" }
                                   }
                                 } %>
                  </div>
                  <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Proprietário</label>
                    <%= f.select :proprietor_id,
                                 @filter_proprietors,
                                 { include_blank: "Todas", selected: params[:proprietor_id] },
                                 {
                                   class: "form-select",
                                   data: {
                                     controller: "tom-select",
                                     tom_select_create_value: false,
                                     tom_select_options_value: { placeholder: "Selecione proprietário" }
                                   }
                                 } %>
                  </div>
                <% end %>
              </div>
            </div>

            <div class="border rounded-3 p-3 mb-3">
              <h6 class="fw-bold text-secondary mb-3">Características</h6>
              <div class="row g-3">
                <div class="col-md-3">
                  <label class="form-label small fw-bold text-muted text-uppercase">Face</label>
                  <%= f.select :face, @filter_faces, { include_blank: "Todas", selected: params[:face] }, class: "form-select" %>
                </div>
                <div class="col-md-3">
                  <label class="form-label small fw-bold text-muted text-uppercase">Ocupação</label>
                  <%= f.select :ocupacao_status, @filter_ocupacao_statuses, { include_blank: "Todas", selected: params[:ocupacao_status] }, class: "form-select" %>
                </div>
                <div class="col-md-3">
                  <label class="form-label small fw-bold text-muted text-uppercase">Conservação</label>
                  <%= f.select :estado_conservacao, @filter_estado_conservacoes, { include_blank: "Todas", selected: params[:estado_conservacao] }, class: "form-select" %>
                </div>
                <div class="col-md-3">
                  <label class="form-label small fw-bold text-muted text-uppercase">Região foco?</label>
                  <%= f.select :regiao_foco, @filter_regioes_foco, { include_blank: "Todas", selected: params[:regiao_foco] }, class: "form-select" %>
                </div>
                <div class="col-md-3">
                  <label class="form-label small fw-bold text-muted text-uppercase">Banheiros (exato)</label>
                  <%= f.select :banheiros,
                               options_for_select((1..8).map { |n| [n.to_s, n] }, @banheiros),
                               {},
                               {
                                 multiple: true,
                                 class: "form-select filter-multi-compact",
                                 data: {
                                   controller: "tom-select",
                                   tom_select_create_value: false,
                                   tom_select_options_value: { placeholder: "Selecione banheiros" }
                                 }
                               } %>
                </div>

                <div class="col-md-3">
                  <label class="form-label small fw-bold text-muted text-uppercase">Dormitórios (exato)</label>
                  <%= f.select :dorms,
                               options_for_select((1..8).map { |n| [n.to_s, n] }, @dorms),
                               {},
                               {
                                 multiple: true,
                                 class: "form-select filter-multi-compact",
                                 data: {
                                   controller: "tom-select",
                                   tom_select_create_value: false,
                                   tom_select_options_value: { placeholder: "Selecione dormitórios" }
                                 }
                               } %>
                </div>
                <div class="col-md-3">
                  <label class="form-label small fw-bold text-muted text-uppercase">Suítes (exato)</label>
                  <%= f.select :suites,
                               options_for_select((1..8).map { |n| [n.to_s, n] }, @suites),
                               {},
                               {
                                 multiple: true,
                                 class: "form-select filter-multi-compact",
                                 data: {
                                   controller: "tom-select",
                                   tom_select_create_value: false,
                                   tom_select_options_value: { placeholder: "Selecione suítes" }
                                 }
                               } %>
                </div>
                <div class="col-md-3">
                  <label class="form-label small fw-bold text-muted text-uppercase">Vagas (exato)</label>
                  <%= f.select :vagas,
                               options_for_select((1..8).map { |n| [n.to_s, n] }, @vagas),
                               {},
                               {
                                 multiple: true,
                                 class: "form-select filter-multi-compact",
                                 data: {
                                   controller: "tom-select",
                                   tom_select_create_value: false,
                                   tom_select_options_value: { placeholder: "Selecione vagas" }
                                 }
                               } %>
                </div>
                <div class="col-md-3">
                  <label class="form-label small fw-bold text-muted text-uppercase">Área Total mín. (m²)</label>
                  <%= f.number_field :area_total_min, value: params[:area_total_min], class: "form-control", step: "0.01", min: "0" %>
                </div>
                <div class="col-md-3">
                  <label class="form-label small fw-bold text-muted text-uppercase">Área Total máx. (m²)</label>
                  <%= f.number_field :area_total_max, value: params[:area_total_max], class: "form-control", step: "0.01", min: "0" %>
                </div>
                <div class="col-md-3">
                  <label class="form-label small fw-bold text-muted text-uppercase">Área Privativa mín. (m²)</label>
                  <%= f.number_field :area_privativa_min, value: params[:area_privativa_min], class: "form-control", step: "0.01", min: "0" %>
                </div>
                <div class="col-md-3">
                  <label class="form-label small fw-bold text-muted text-uppercase">Área Privativa máx. (m²)</label>
                  <%= f.number_field :area_privativa_max, value: params[:area_privativa_max], class: "form-control", step: "0.01", min: "0" %>
                </div>
              </div>
            </div>

            <div class="border rounded-3 p-3 mb-3">
              <h6 class="fw-bold text-secondary mb-3">Destaques</h6>
              <div class="row g-3">
                <div class="col-md-3">
                  <label class="form-label small fw-bold text-muted text-uppercase">Destaque Web</label>
                  <%= f.select :destaque_web,
                               [["Sim", "1"], ["Não", "0"]],
                               { include_blank: "Todos", selected: params[:destaque_web] },
                               class: "form-select" %>
                </div>
                <div class="col-md-3">
                  <label class="form-label small fw-bold text-muted text-uppercase">Super Destaque</label>
                  <%= f.select :festival_salute,
                               [["Sim", "1"], ["Não", "0"]],
                               { include_blank: "Todos", selected: params[:festival_salute] },
                               class: "form-select" %>
                </div>
                <div class="col-md-3">
                  <label class="form-label small fw-bold text-muted text-uppercase">Exibir no site Salute</label>
                  <%= f.select :exibir_no_site_salute,
                               [["Sim", "1"], ["Não", "0"]],
                               { include_blank: "Todos", selected: params[:exibir_no_site_salute] },
                               class: "form-select" %>
                </div>
              </div>
            </div>

            <div class="border rounded-3 p-3 mb-3">
              <h6 class="fw-bold text-secondary mb-3">Outros critérios</h6>
              <div class="row g-3">
                <div class="col-md-3">
                  <div class="form-check">
                    <%= check_box_tag :somente_com_imagens, "1", params[:somente_com_imagens] == "1", class: "form-check-input", id: "somente_com_imagens_filter" %>
                    <%= label_tag :somente_com_imagens_filter, "Somente com imagens", class: "form-check-label" %>
                  </div>
                </div>
                <div class="col-md-3">
                  <div class="form-check">
                    <%= check_box_tag :somente_sem_imagens, "1", params[:somente_sem_imagens] == "1", class: "form-check-input", id: "somente_sem_imagens_filter" %>
                    <%= label_tag :somente_sem_imagens_filter, "Somente sem imagens", class: "form-check-label" %>
                  </div>
                </div>
                <div class="col-md-3">
                  <div class="form-check">
                    <%= check_box_tag :tem_placa, "1", params[:tem_placa] == "1", class: "form-check-input", id: "tem_placa_filter_outros" %>
                    <%= label_tag :tem_placa_filter_outros, "Tem Placa", class: "form-check-label" %>
                  </div>
                </div>
                <div class="col-md-3">
                  <div class="form-check">
                    <%= check_box_tag :exclusivo, "1", params[:exclusivo] == "1", class: "form-check-input", id: "exclusivo_filter_outros" %>
                    <%= label_tag :exclusivo_filter_outros, "Exclusivo", class: "form-check-label" %>
                  </div>
                </div>
                <div class="col-md-3">
                  <div class="form-check">
                    <%= check_box_tag :somente_dwv, "1", params[:somente_dwv] == "1", class: "form-check-input", id: "somente_dwv_filter" %>
                    <%= label_tag :somente_dwv_filter, "Somente imóveis do DWV", class: "form-check-label" %>
                  </div>
                </div>
              </div>
              <div class="row g-3 mt-1">
                <div class="col-12">
                  <label class="form-label small fw-bold text-muted text-uppercase mb-2">Publicado com fotos</label>
                  <% selected_foto_classificacoes = Array(params[:foto_classificacao]).map(&:to_s) %>
                  <div class="d-flex flex-wrap gap-3">
                    <% ["Profissionais", "Boas", "Aceitáveis", "Não tem fotos"].each do |opcao| %>
                      <div class="form-check">
                        <%= check_box_tag "foto_classificacao[]", opcao, selected_foto_classificacoes.include?(opcao), class: "form-check-input", id: "foto_classificacao_#{opcao.parameterize}" %>
