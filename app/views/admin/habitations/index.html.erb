  <div class="mb-3 d-flex flex-wrap gap-2">
    <% active_filter_chips.each do |chip| %>
      <span class="badge rounded-pill text-bg-light border px-3 py-2 fw-semibold"><%= chip %></span>
    <% end %>
  </div>
<% end %>

<!-- Property Cards List -->
<div class="row g-3">
