    }

    body.ax-habitations-workspace .habitations-sort-menu .habitations-workspace-heading__tool {
      width: 100%;
    }

    body.ax-habitations-workspace .habitations-workspace-heading__tool,
    body.ax-habitations-workspace .habitations-view-toggle__item {
      min-height: 34px;
      font-size: .72rem;
    }

    body.ax-habitations-workspace .habitations-inspector-rail {
      position: fixed !important;
      inset: auto auto calc(14px + env(safe-area-inset-bottom, 0px)) 50% !important;
      z-index: 1250 !important;
      display: inline-flex !important;
      align-items: center !important;
      justify-content: center !important;
      width: auto !important;
      max-width: calc(100vw - 28px) !important;
      min-width: 112px !important;
      height: 40px !important;
      min-height: 0 !important;
      padding: 0 13px !important;
      border: 1px solid color-mix(in srgb, var(--admin-primary, #365f8f) 78%, #fff) !important;
      border-radius: 999px !important;
      background: var(--admin-primary, #365f8f) !important;
      color: #fff !important;
      box-shadow: 0 8px 20px rgba(15, 23, 42, .22) !important;
      opacity: 1 !important;
      pointer-events: auto !important;
      transform: translateX(-50%) !important;
    }

    body.ax-habitations-workspace .habitations-inspector-rail .ax-aside-rail__content {
      writing-mode: horizontal-tb !important;
      text-orientation: mixed !important;
      color: #fff !important;
      font-size: .74rem !important;
      letter-spacing: 0 !important;
      text-transform: none !important;
    }

    body.ax-habitations-workspace .habitations-inspector-rail .ax-aside-rail__content i {
      color: inherit !important;
    }

    body.ax-habitations-workspace .habitations-inspector {
      position: fixed !important;
      inset: 0 !important;
      width: 100vw !important;
      height: 100dvh !important;
      max-height: none !important;
      z-index: 1260 !important;
      border: 0 !important;
      border-radius: 0 !important;
      background: #fff !important;
      opacity: 1 !important;
      pointer-events: auto !important;
      transform: translateY(0) !important;
      transition: transform 220ms var(--ax-motion-ease, cubic-bezier(.2,.8,.2,1)), opacity 160ms ease !important;
    }

    html.ax-inspector-collapsed-preload body.ax-habitations-workspace .habitations-inspector,
    body.ax-habitations-workspace .habitations-master-detail-layout.is-inspector-collapsed .habitations-inspector {
      opacity: 0 !important;
      pointer-events: none !important;
      transform: translateY(100%) !important;
    }

    body.ax-habitations-workspace .habitations-inspector__header {
      min-height: calc(var(--ax-contextbar-h) + env(safe-area-inset-top, 0px));
      height: auto;
      padding-top: env(safe-area-inset-top, 0px);
