<script>
  (function() {
    if (window.__saluteCatalogToolbarScrollBound) {
      requestAnimationFrame(window.__saluteCatalogToolbarScrollBound.refresh);
      return;
    }

    var fixedTop = 64;
    var fixAtScrollY = 0;

    function toolbarElement() {
      return document.querySelector(".filter-sticky-toolbar");
    }

    function shouldRun() {
      return document.body.classList.contains("admin-drawer-catalog-layout") && window.matchMedia("(max-width: 767.98px)").matches;
    }

    function measureFixPoint() {
      var toolbar = toolbarElement();
      if (!toolbar) return;

      var wasFixed = toolbar.classList.contains("is-filter-toolbar-fixed");
      toolbar.classList.remove("is-filter-toolbar-fixed");
      fixAtScrollY = Math.max(0, window.scrollY + toolbar.getBoundingClientRect().top - fixedTop);
      if (wasFixed) toolbar.classList.add("is-filter-toolbar-fixed");
    }

    function syncToolbarFixedState() {
      var toolbar = toolbarElement();
      if (!toolbar) return;

      if (!shouldRun()) {
        toolbar.classList.remove("is-filter-toolbar-fixed");
        return;
      }

      toolbar.classList.toggle("is-filter-toolbar-fixed", window.scrollY >= fixAtScrollY);
    }

    function refreshToolbarScrollState() {
      measureFixPoint();
      syncToolbarFixedState();
    }

    window.__saluteCatalogToolbarScrollBound = {
      refresh: refreshToolbarScrollState,
      sync: syncToolbarFixedState
    };
    document.addEventListener("turbo:load", refreshToolbarScrollState);
    document.addEventListener("DOMContentLoaded", refreshToolbarScrollState);
    window.addEventListener("scroll", syncToolbarFixedState, { passive: true });
    window.addEventListener("resize", refreshToolbarScrollState, { passive: true });
    window.addEventListener("orientationchange", refreshToolbarScrollState, { passive: true });
    requestAnimationFrame(refreshToolbarScrollState);
  })();
</script>

