  <section class="habitations-master-pane" aria-label="Catálogo de imóveis">

<!-- Quick Scopes (Pills) -->
<%
  ownership_base_params = request.query_parameters.except("ownership", "intake_review", "page")
  mine_active = @ownership_scope == "mine" && @intake_review.blank?
  all_active = @ownership_scope == "all" && @intake_review.blank?
  pending_review_active = @intake_review == "pending"
%>
<div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
  <div class="btn-group ownership-toggle" role="group" aria-label="Escopo dos imóveis">
    <%= link_to admin_habitations_path(ownership_base_params.merge(ownership: "mine")), class: "btn btn-sm #{mine_active ? 'btn-primary' : 'btn-white bg-white border text-muted'} fw-semibold" do %>
      <i class="bi bi-person-check me-1"></i> Meus imóveis
    <% end %>
    <%= link_to admin_habitations_path(ownership_base_params.merge(ownership: "all")), class: "btn btn-sm #{all_active ? 'btn-primary' : 'btn-white bg-white border text-muted'} fw-semibold" do %>
      <i class="bi bi-collection me-1"></i> Todos
    <% end %>
    <%= link_to admin_habitations_path(ownership_base_params.merge(ownership: "all", intake_review: "pending")), class: "btn btn-sm #{pending_review_active ? 'btn-primary' : 'btn-white bg-white border text-muted'} fw-semibold" do %>
      <i class="bi bi-clipboard-check me-1"></i> Pendente de revisão
    <% end %>
  </div>
  <% if mine_active %>
    <span class="small text-muted">Mostrando imóveis vinculados ao corretor logado.</span>
  <% elsif pending_review_active %>
    <span class="small text-muted">Captações em revisão ou aguardando aceite do corretor responsável.</span>
  <% end %>
</div>

<div class="habitations-scopes d-flex flex-wrap gap-2 mb-4">
  <% 
    scopes = [
      { key: 'destaque_web', label: 'Destaque Web', icon: 'star-fill' },
      { key: 'super_destaque', label: 'Super Destaque', icon: 'stars' },
      { key: 'oportunidade', label: 'Oportunidade', icon: 'lightning-fill' },
      { key: 'frente_mar', label: 'Frente Mar', icon: 'building' },
      { key: 'lancamento', label: 'Lançamento', icon: 'rocket-takeoff' },
      { key: 'na_planta', label: 'Na Planta', icon: 'rulers' },
      { key: 'mobiliado', label: 'Mobiliado', icon: 'sofa' },
      { key: 'sacada', label: 'Sacada', icon: 'layout-sidebar' },
      { key: 'dependencia_empregada', label: 'Dependência', icon: 'door-closed' },
      { key: 'cozinha_gourmet_churrasqueira', label: 'Cozinha gourmet', icon: 'fire' },
      { key: 'sol_manha', label: 'Sol manhã', icon: 'sunrise' },
      { key: 'sol_tarde', label: 'Sol tarde', icon: 'sunset' },
      { key: 'sol_dia_todo', label: 'Sol dia todo', icon: 'sun' },
      { key: 'decorado', label: 'Decorado', icon: 'palette' }
    ]
  %>
  <% scopes.each do |scope| %>
    <%= link_to admin_habitations_path(request.query_parameters.except("page").merge(scope: scope[:key])), class: "btn btn-sm rounded-pill fw-semibold px-3 py-2 #{params[:scope] == scope[:key] ? 'btn-primary shadow-sm' : 'btn-white bg-white border text-muted shadow-sm hover-shadow'}" do %>
       <i class="bi bi-<%= scope[:icon] %> me-1"></i> <%= scope[:label] %>
    <% end %>
  <% end %>
  <% if params[:scope].present? %>
    <%= link_to admin_habitations_path(request.query_parameters.except("scope", "page")), class: "btn btn-sm btn-link text-muted text-decoration-none d-flex align-items-center" do %>
      <i class="bi bi-x-lg me-1"></i>
    <% end %>
  <% end %>
</div>

<div class="modal fade" id="habitationsExportModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content border-0 shadow">
      <div class="modal-header">
        <h5 class="modal-title fw-semibold">
          <i class="bi bi-download me-2"></i>Exportação de <%= @filtered_count %> imóveis
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
      </div>
      <%= form_with url: export_admin_habitations_path, method: :get, local: true do %>
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label small fw-bold">Formatação dos dados</label>
            <%= select_tag :data_format,
                           options_for_select([["CSV (;)", "csv_semicolon"], ["CSV (,)", "csv_comma"]], "csv_semicolon"),
                           class: "form-select" %>
          </div>

          <% request.query_parameters.except("fields", "data_format").each do |key, value| %>
            <% if value.is_a?(Array) %>
              <% value.each do |entry| %>
                <%= hidden_field_tag "#{key}[]", entry %>
              <% end %>
            <% else %>
              <%= hidden_field_tag key, value %>
            <% end %>
          <% end %>

          <div class="border rounded-3 overflow-hidden">
            <div class="px-3 py-2 bg-light fw-semibold">Selecione os campos para exportação</div>
            <div style="max-height: 340px; overflow-y: auto;">
              <% @export_fields.each do |field_key, field_label| %>
                <% next if !(current_admin_user&.admin? || current_admin_user&.profile&.name == "Administrativo") && field_key == "proprietario" %>
                <label class="d-flex align-items-center gap-2 px-3 py-2 border-bottom small">
                  <%= check_box_tag "fields[]", field_key, @default_export_fields.include?(field_key), class: "form-check-input mt-0" %>
                  <span><%= field_label %></span>
                </label>
              <% end %>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-primary px-4">Exportar</button>
        </div>
      <% end %>
    </div>
  </div>
</div>

<% bulk_actions_allowed = can?(:manage, :imoveis) && current_admin_user&.admin? %>

<% filters_json = request.query_parameters.except("page").to_json.html_safe if bulk_actions_allowed %>

<div class="habitations-results-shell" <% if bulk_actions_allowed %>data-controller="bulk-publish"
     data-bulk-publish-url-value="<%= bulk_publish_admin_habitations_path %>"
     data-bulk-publish-csrf-value="<%= form_authenticity_token %>"
     data-bulk-publish-filtered-total-value="<%= @filtered_count %>"
     data-bulk-publish-filters-json-value='<%= filters_json %>'<% end %>>

<% if bulk_actions_allowed %>
<!-- Floating bulk action toolbar -->
<div data-bulk-publish-target="toolbar"
     class="bulk-publish-toolbar d-none position-sticky top-0 bg-white border rounded-3 shadow-sm px-3 py-2 mb-3 d-flex align-items-center justify-content-between"
     style="z-index: 1020;">
  <div class="d-flex align-items-center gap-2">
    <i class="bi bi-check2-square text-success"></i>
    <span class="fw-semibold"><span data-bulk-publish-target="count">0</span> imóvel(is) selecionado(s)</span>
  </div>
  <div class="d-flex align-items-center gap-2">
    <button type="button" class="btn btn-sm btn-outline-secondary" data-action="click->bulk-publish#clearSelection">
      Limpar
    </button>
    <button type="button" class="btn btn-sm btn-success" data-action="click->bulk-publish#openModal">
      <i class="bi bi-megaphone me-1"></i> Divulgar
    </button>
  </div>
</div>

<% end %>

<!-- Results Header -->
<div class="habitations-results-header d-flex justify-content-between align-items-center mb-3">
  <div class="d-flex align-items-center gap-2 flex-wrap">
    <% if bulk_actions_allowed %>
      <div class="form-check mb-0">
        <input type="checkbox" class="form-check-input"
               id="bulkPublishMaster"
               data-bulk-publish-target="master"
               data-action="change->bulk-publish#toggleAll">
        <label class="form-check-label small fw-bold text-muted text-uppercase" for="bulkPublishMaster">
          Selecionar todos
        </label>
      </div>
    <% end %>
    <span class="small text-muted fw-semibold">
      <span class="text-dark fw-bold"><%= @habitations.count %></span> de <%= Habitation.count %>
    </span>
    <% if params[:q].present? || params[:status].present? || params[:categoria].present? || params[:scope].present? || @ownership_scope == "mine" || @intake_review.present? || active_extra_filters_count.positive? %>
      <span class="badge bg-warning-subtle text-warning border">Filtrando</span>
    <% end %>
  </div>
  <div class="habitations-results-actions d-flex align-items-center gap-3">

    <div class="dropdown" data-controller="dropdown">
      <button class="btn btn-white btn-sm border dropdown-toggle text-muted"
              type="button"
              data-action="click->dropdown#toggle"
              aria-expanded="false">
        <i class="bi bi-printer me-1"></i> Impressão
      </button>
      <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0"
          data-dropdown-target="menu"
          style="right: 0; left: auto; min-width: 320px;">
        <% printable_params = request.query_parameters.except("report_type", "page") %>
        <% @report_types.to_h.each do |report_key, report_label| %>
          <li>
            <%= form_with url: print_admin_habitations_path, method: :get, local: true, html: { target: "_blank", class: "m-0" } do %>
              <%= hidden_field_tag :report_type, report_key %>
              <%= hidden_field_tag :full_print, "1" %>
              <% printable_params.each do |key, value| %>
                <% if value.is_a?(Array) %>
                  <% value.each do |entry| %>
                    <%= hidden_field_tag "#{key}[]", entry %>
                  <% end %>
                <% else %>
                  <%= hidden_field_tag key, value %>
                <% end %>
              <% end %>
              <button type="submit" class="dropdown-item small"><%= report_label %></button>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
    
    <%
      current_sort_key = sort_options.key?(params[:sort].to_s) ? params[:sort].to_s : "data_cadastro_crm"
      current_sort_label = sort_options[current_sort_key][:label]
      next_sort_direction = sort_direction == "asc" ? "desc" : "asc"
    %>
    <div class="d-flex align-items-center gap-1">
      <div class="dropdown" data-controller="dropdown">
        <button class="btn btn-white btn-sm border dropdown-toggle text-muted d-flex align-items-center"
                type="button"
                data-action="click->dropdown#toggle"
                aria-expanded="false">
          <i class="bi bi-sort-down me-1"></i>
          <span>Ordenar: <strong class="text-dark"><%= current_sort_label %></strong></span>
        </button>
        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0"
            data-dropdown-target="menu"
            style="right: 0; left: auto; min-width: 240px;">
          <% sort_options.each do |sort_key, sort_config| %>
            <% active_sort = current_sort_key == sort_key %>
            <li>
              <%= link_to admin_habitations_path(request.query_parameters.except("page").merge(sort: sort_key, direction: sort_config[:default_direction])),
                          class: "dropdown-item small d-flex align-items-center gap-2 #{active_sort ? 'active' : ''}" do %>
                <i class="bi <%= active_sort ? 'bi-check-lg' : 'bi-dot' %>"></i>
                <span><%= sort_config[:label] %></span>
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>
      <%= link_to admin_habitations_path(request.query_parameters.except("page").merge(sort: current_sort_key, direction: next_sort_direction)),
                  class: "btn btn-white btn-sm border text-muted",
                  title: sort_direction == "asc" ? "Ordenar decrescente" : "Ordenar crescente" do %>
        <i class="bi bi-sort-<%= sort_direction == "asc" ? "up" : "down" %>"></i>
      <% end %>
    </div>
  </div>
</div>

