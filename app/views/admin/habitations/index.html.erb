    body.ax-habitations-workspace .habitations-inspector > .ax-aside-panel__body,
    body.ax-habitations-workspace .habitations-inspector__form {
      height: calc(100dvh - var(--ax-contextbar-h) - env(safe-area-inset-top, 0px)) !important;
      max-height: none !important;
      overflow-y: auto !important;
      overscroll-behavior: contain;
    }
  }
</style>

<%
  active_extra_filters_count = active_extra_filters_count()
  extras_open = true
  vista_advanced_keys = %w[
    situacao face ocupacao_status estado_conservacao area_total_min area_total_max area_privativa_min area_privativa_max
    destaque_web festival_salute exibir_no_site_salute tem_placa exclusivo banheiros dorms suites vagas
    foto_classificacao
    amenities
    publicar_imovelweb_2 publicar_lais_ai
    publicar_chaves_na_mao publicar_casa_mineira publicar_imovelweb publicar_viva_real_vrsync
    empreendimento_codigo corretor_id proprietor_id permuta_vehicle permuta_property permuta_others permuta_min_value
    permuta_location permuta_min_dorms permuta_min_suites permuta_min_garagens regiao_foco
    captacao_inicio captacao_fim somente_com_imagens somente_sem_imagens somente_dwv
  ]
  vista_advanced_open = vista_advanced_keys.any? do |key|
    value = params[key]
    value.is_a?(Array) ? value.reject(&:blank?).any? : value.present?
  end
  clear_extras_params = clear_extra_filter_params
  total_habitations_count = Habitation.count
  bulk_actions_allowed = can_bulk_publish_habitations?
  filters_json = request.query_parameters.except("page").to_json.html_safe if bulk_actions_allowed
  current_sort_key = sort_options.key?(params[:sort].to_s) ? params[:sort].to_s : "data_cadastro_crm"
  current_sort_label = sort_options[current_sort_key][:label]
  next_sort_direction = sort_direction == "asc" ? "desc" : "asc"
  printable_params = request.query_parameters.except("report_type", "page")
  property_view_mode = params[:visualizacao].to_s == "tabela" ? "tabela" : "cards"
  property_view_params = request.query_parameters.except("page", "visualizacao")
  page_size_params = request.query_parameters.except("page")
  current_per_page = @per_page.to_i.positive? ? @per_page.to_i : @habitations.per_page.to_i
  page_size_options = @page_size_options.presence || [10, 20]
  filtering_active = params[:codigo].present? ||
                     params[:q].present? ||
                     params[:status].present? ||
                     params[:categoria].present? ||
                     params[:scope].present? ||
                     @ownership_scope == "mine" ||
                     @intake_review.present? ||
                     active_extra_filters_count.positive?
%>

<% catalog_aside = capture do %>
  <%= content_tag(
        "turbo-frame",
        render("admin/habitations/filter_inspector_loading", active_extra_filters_count: active_extra_filters_count),
        id: "admin_habitations_filter_inspector",
        src: filter_inspector_admin_habitations_path(request.query_parameters.except("page")),
        loading: "eager",
        target: "_top"
      ) %>
<% end %>

<% catalog_main = capture do %>
    <div class="habitations-master-content" <% if bulk_actions_allowed %>data-controller="bulk-publish"
         data-bulk-publish-url-value="<%= bulk_publish_admin_habitations_path %>"
         data-bulk-publish-csrf-value="<%= form_authenticity_token %>"
         data-bulk-publish-filtered-total-value="<%= @filtered_count %>"
         data-bulk-publish-filters-json-value='<%= filters_json %>'<% end %>>
<div class="habitations-workspace-heading">
  <div class="habitations-workspace-heading__main">
    <div class="habitations-workspace-heading__eyebrow">
      <i class="bi bi-building"></i>
      <span>Catálogo operacional</span>
    </div>
    <div class="habitations-workspace-heading__title-row">
      <h1>Imóveis</h1>
      <span class="habitations-workspace-heading__scope"><%= @ownership_scope == "mine" ? "Meus imóveis" : "Todos" %></span>
      <% if filtering_active %>
        <span class="habitations-workspace-heading__scope">Filtros ativos</span>
      <% end %>
    </div>
    <p>Portfólio com filtros em contexto, seleção em massa e publicação operacional.</p>
  </div>

  <div class="habitations-workspace-heading__side">
    <div class="habitations-workspace-heading__meta" aria-label="Resumo do catálogo">
      <span><strong><%= number_with_delimiter(@filtered_count) %></strong> filtrados</span>
      <span><strong><%= number_with_delimiter(total_habitations_count) %></strong> total</span>
      <div class="habitations-page-size dropdown" data-controller="ax-dropdown">
        <span><strong><%= @habitations.size %></strong> nesta página</span>
        <button class="habitations-page-size__button"
                type="button"
                data-ax-dropdown-target="trigger"
                data-action="click->ax-dropdown#toggle"
                aria-expanded="false"
                title="Itens por página"
                aria-label="Selecionar itens por página">
          <i class="bi bi-gear"></i>
        </button>
        <ul class="dropdown-menu dropdown-menu-end habitations-command-menu habitations-command-menu--page-size"
            data-ax-dropdown-target="menu"
            hidden
            style="right: 0; left: auto;">
          <li class="habitations-command-menu__header">
            <span>Itens por página</span>
            <small><%= current_per_page %> atual</small>
          </li>
          <% page_size_options.each do |option| %>
            <li>
              <%= link_to admin_habitations_path(page_size_params.merge(per_page: option)),
                          class: "habitations-command-menu__item #{current_per_page == option ? 'is-active' : ''}" do %>
                <span class="habitations-command-menu__item-icon"><i class="bi bi-list-ol"></i></span>
                <span class="habitations-command-menu__item-label"><%= option %> imóveis</span>
                <% if current_per_page == option %>
                  <span class="habitations-command-menu__item-status"><i class="bi bi-check2"></i></span>
                <% end %>
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>
    </div>

    <div class="habitations-workspace-heading__toolbar" aria-label="Ações do catálogo">
      <button type="button"
              class="habitations-workspace-heading__tool habitations-mobile-filter-button"
              data-action="ax-aside#toggle"
              data-ax-aside-target="toggle"
              aria-expanded="false"
              aria-label="Abrir filtros">
        <i class="bi bi-funnel"></i>
        <span>Filtros</span>
        <% if active_extra_filters_count.positive? %>
          <strong><%= active_extra_filters_count %></strong>
        <% elsif filtering_active %>
          <strong>ativo</strong>
        <% end %>
      </button>

      <div class="habitations-view-toggle" aria-label="Visualização da listagem">
        <%= link_to admin_habitations_path(property_view_params.merge(visualizacao: "cards")),
                    class: "habitations-view-toggle__item #{property_view_mode == 'cards' ? 'is-active' : ''}",
                    title: "Visualizar em cards" do %>
          <i class="bi bi-view-stacked"></i>
          <span>Cards</span>
        <% end %>
        <%= link_to admin_habitations_path(property_view_params.merge(visualizacao: "tabela")),
                    class: "habitations-view-toggle__item #{property_view_mode == 'tabela' ? 'is-active' : ''}",
                    title: "Visualizar em tabela" do %>
          <i class="bi bi-table"></i>
          <span>Tabela</span>
        <% end %>
        <% if property_view_mode == "tabela" %>
          <button type="button"
                  class="habitations-view-toggle__item habitations-view-toggle__gear"
                  data-ax-modal-open="#habitationColumnsModal"
                  title="Escolher colunas exibidas"
                  aria-label="Escolher colunas exibidas">
            <i class="bi bi-gear"></i>
          </button>
        <% end %>
      </div>

      <div class="dropdown habitations-print-menu" data-controller="ax-dropdown">
        <button class="habitations-workspace-heading__tool dropdown-toggle"
                type="button"
                data-ax-dropdown-target="trigger"
                data-action="click->ax-dropdown#toggle"
                aria-expanded="false">
          <i class="bi bi-printer"></i> Impressão
        </button>
        <ul class="dropdown-menu dropdown-menu-end habitations-command-menu habitations-command-menu--print"
            data-ax-dropdown-target="menu"
            hidden
            style="right: 0; left: auto;">
          <li class="habitations-command-menu__header">
            <span>Modelos de impressão</span>
            <small><%= @report_types.to_h.size %> opções</small>
          </li>
          <% @report_types.to_h.each do |report_key, report_label| %>
            <li>
              <%= link_to print_admin_habitations_path(printable_params.merge(report_type: report_key, full_print: "1")),
                          class: "habitations-command-menu__item",
                          target: "_blank",
                          rel: "noopener",
                          data: { turbo: false } do %>
                  <span class="habitations-command-menu__item-icon"><i class="bi bi-file-earmark-text"></i></span>
                  <span class="habitations-command-menu__item-label"><%= report_label %></span>
                  <span class="habitations-command-menu__item-status"><i class="bi bi-arrow-up-right-square"></i></span>
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>

      <div class="dropdown habitations-sort-menu" data-controller="ax-dropdown">
        <button class="habitations-workspace-heading__tool dropdown-toggle"
                type="button"
                data-ax-dropdown-target="trigger"
                data-action="click->ax-dropdown#toggle"
                aria-expanded="false">
          <i class="bi bi-sort-down"></i>
          <span>Ordenar: <strong><%= current_sort_label %></strong></span>
        </button>
        <ul class="dropdown-menu dropdown-menu-end habitations-command-menu habitations-command-menu--sort"
            data-ax-dropdown-target="menu"
            hidden
            style="right: 0; left: auto;">
          <li class="habitations-command-menu__header">
            <span>Ordenar por</span>
            <small><%= sort_direction == "asc" ? "asc" : "desc" %></small>
          </li>
          <% sort_options.each do |sort_key, sort_config| %>
            <% active_sort = current_sort_key == sort_key %>
            <li>
              <%= link_to admin_habitations_path(request.query_parameters.except("page").merge(sort: sort_key, direction: sort_config[:default_direction])),
                          class: "habitations-command-menu__item #{active_sort ? 'is-active' : ''}" do %>
                <span class="habitations-command-menu__item-icon <%= active_sort ? '' : 'is-empty' %>">
                  <% if active_sort %>
                    <i class="bi bi-check2"></i>
                  <% end %>
                </span>
                <span class="habitations-command-menu__item-label"><%= sort_config[:label] %></span>
                <span class="habitations-command-menu__item-status"><%= active_sort ? "Atual" : "" %></span>
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>

      <%= link_to admin_habitations_path(request.query_parameters.except("page").merge(sort: current_sort_key, direction: next_sort_direction)),
                  class: "habitations-workspace-heading__tool habitations-workspace-heading__tool--icon",
                  title: sort_direction == "asc" ? "Ordenar decrescente" : "Ordenar crescente" do %>
        <i class="bi bi-sort-<%= sort_direction == "asc" ? "up" : "down" %>"></i>
      <% end %>
    </div>
  </div>
</div>

<!-- Quick Scopes (Pills) -->
<%
  ownership_base_params = request.query_parameters.except("ownership", "intake_review", "page")
  mine_active = @ownership_scope == "mine" && @intake_review.blank?
  all_active = @ownership_scope == "all" && @intake_review.blank?
  pending_review_active = @intake_review == "pending"
%>
<div class="habitations-workspace-scopebar">
  <div class="habitations-view-toggle habitations-view-toggle--scope" role="group" aria-label="Escopo dos imóveis">
    <%= link_to admin_habitations_path(ownership_base_params.merge(ownership: "mine")), class: "habitations-view-toggle__item #{mine_active ? 'is-active' : ''}" do %>
      <i class="bi bi-person-check"></i>
      <span>Meus imóveis</span>
    <% end %>
    <%# Catálogo: todos podem navegar todos os imóveis (curadoria). %>
    <%= link_to admin_habitations_path(ownership_base_params.merge(ownership: "all")), class: "habitations-view-toggle__item #{all_active ? 'is-active' : ''}" do %>
      <i class="bi bi-collection"></i>
      <span>Todos</span>
    <% end %>
    <%# "Pendente de revisão" é curadoria de intake (admin) — só para escopo total. %>
    <% if owns_all_resource?(:imoveis) %>
      <%= link_to admin_habitations_path(ownership_base_params.merge(ownership: "all", intake_review: "pending")), class: "habitations-view-toggle__item #{pending_review_active ? 'is-active' : ''}" do %>
        <i class="bi bi-clipboard-check"></i>
        <span>Pendente de revisão</span>
      <% end %>
    <% end %>
  </div>

  <div class="habitations-mobile-sort-controls" aria-label="Ordenação da listagem">
    <div class="dropdown habitations-sort-menu" data-controller="ax-dropdown">
      <button class="habitations-workspace-heading__tool dropdown-toggle"
              type="button"
              data-ax-dropdown-target="trigger"
              data-action="click->ax-dropdown#toggle"
              aria-expanded="false">
        <i class="bi bi-sort-down"></i>
        <span>Ordenar: <strong><%= current_sort_label %></strong></span>
      </button>
      <ul class="dropdown-menu dropdown-menu-end habitations-command-menu habitations-command-menu--sort"
          data-ax-dropdown-target="menu"
          hidden
          style="right: 0; left: auto;">
        <li class="habitations-command-menu__header">
          <span>Ordenar por</span>
          <small><%= sort_direction == "asc" ? "asc" : "desc" %></small>
        </li>
        <% sort_options.each do |sort_key, sort_config| %>
          <% active_sort = current_sort_key == sort_key %>
          <li>
            <%= link_to admin_habitations_path(request.query_parameters.except("page").merge(sort: sort_key, direction: sort_config[:default_direction])),
                        class: "habitations-command-menu__item #{active_sort ? 'is-active' : ''}" do %>
              <span class="habitations-command-menu__item-icon <%= active_sort ? '' : 'is-empty' %>">
                <% if active_sort %>
                  <i class="bi bi-check2"></i>
                <% end %>
              </span>
              <span class="habitations-command-menu__item-label"><%= sort_config[:label] %></span>
              <span class="habitations-command-menu__item-status"><%= active_sort ? "Atual" : "" %></span>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>

    <%= link_to admin_habitations_path(request.query_parameters.except("page").merge(sort: current_sort_key, direction: next_sort_direction)),
                class: "habitations-workspace-heading__tool habitations-workspace-heading__tool--icon",
                title: sort_direction == "asc" ? "Ordenar decrescente" : "Ordenar crescente" do %>
      <i class="bi bi-sort-<%= sort_direction == "asc" ? "up" : "down" %>"></i>
    <% end %>
  </div>

  <%= ax_team_toggle(:imoveis) %>

  <% if bulk_actions_allowed %>
    <div class="habitations-workspace-bulkline" aria-label="Seleção em massa">
      <label class="habitations-workspace-heading__select-all" for="bulkPublishMaster">
        <input type="checkbox"
               id="bulkPublishMaster"
               data-bulk-publish-target="master"
               data-action="change->bulk-publish#toggleAll">
        <span>Selecionar filtrados</span>
      </label>

      <div data-bulk-publish-target="toolbar" class="habitations-workspace-selection" hidden>
        <span class="habitations-workspace-selection__count">
          <i class="bi bi-check2-square"></i>
          <span><span data-bulk-publish-target="count">0</span> selecionado(s)</span>
        </span>
        <button type="button" class="habitations-workspace-selection__button" data-action="click->bulk-publish#clearSelection">
          Limpar
        </button>
        <button type="button" class="habitations-workspace-selection__button habitations-workspace-selection__button--primary" data-action="click->bulk-publish#openModal">
          <i class="bi bi-megaphone"></i> Divulgar
        </button>
      </div>
    </div>
  <% end %>
</div>

<div class="habitations-scope-strip habitations-scopes">
  <%
    scopes = [
      { key: 'destaque_web', label: 'Destaque Web', icon: 'star-fill' },
      { key: 'super_destaque', label: 'Super Destaque', icon: 'stars' },
