<%# CSS do catálogo extraído para app/assets/stylesheets/admin/habitations_catalog.css (asset cacheável) %>
<%= stylesheet_link_tag "admin/habitations_catalog", media: "all" %>

<%
  active_extra_filters_count = active_extra_filters_count()
  extras_open = true
  advanced_filter_keys = %w[
    situacao face ocupacao_status estado_conservacao area_total_min area_total_max area_privativa_min area_privativa_max
    destaque_web festival_salute exibir_no_site_salute tem_placa exclusivo banheiros dorms suites vagas
    foto_classificacao
    amenities
    publicar_imovelweb_2 publicar_lais_ai
    publicar_chaves_na_mao publicar_casa_mineira publicar_imovelweb publicar_viva_real_vrsync
    empreendimento_codigo corretor_id proprietor_id permuta_vehicle permuta_property permuta_others permuta_min_value
    permuta_location permuta_min_dorms permuta_min_suites permuta_min_garagens regiao_foco
    captacao_inicio captacao_fim somente_com_imagens somente_sem_imagens somente_dwv
  ]
  advanced_filters_open = advanced_filter_keys.any? do |key|
    value = params[key]
    value.is_a?(Array) ? value.reject(&:blank?).any? : value.present?
  end
  clear_extras_params = clear_extra_filter_params
  total_habitations_count = current_tenant.habitations.count
  bulk_actions_allowed = can_bulk_publish_habitations?
  filters_json = request.query_parameters.except("page").to_json.html_safe if bulk_actions_allowed
  current_sort_key = sort_options.key?(params[:sort].to_s) ? params[:sort].to_s : "data_cadastro_crm"
  current_sort_label = sort_options[current_sort_key][:label]
  next_sort_direction = sort_direction == "asc" ? "desc" : "asc"
  printable_params = request.query_parameters.except("report_type", "page")
  property_view_mode = params[:visualizacao].to_s == "tabela" ? "tabela" : "cards"
  property_view_params = request.query_parameters.except("page", "visualizacao")
  page_size_params = request.query_parameters.except("page")
  current_per_page = @per_page.to_i.positive? ? @per_page.to_i : @habitations.per_page.to_i
  page_size_options = @page_size_options.presence || [10, 20]
  catalog_controller_names = ["catalog-anchor-scroll"]
  catalog_controller_names << "bulk-publish" if bulk_actions_allowed
  filtering_active = params[:codigo].present? ||
                     params[:q].present? ||
                     params[:status].present? ||
                     params[:categoria].present? ||
                     params[:scope].present? ||
                     @intake_review.present? ||
                     active_extra_filters_count.positive?
%>

<% catalog_aside = capture do %>
  <%= content_tag(
        "turbo-frame",
        render("admin/habitations/filter_inspector_loading", active_extra_filters_count: active_extra_filters_count),
        id: "admin_habitations_filter_inspector",
        src: filter_inspector_admin_habitations_path(request.query_parameters.except("page")),
        loading: "eager",
        target: "_top"
      ) %>
<% end %>

<% catalog_main = capture do %>
    <div class="habitations-master-content" data-controller="<%= catalog_controller_names.join(" ") %>" <% if bulk_actions_allowed %>
         data-bulk-publish-url-value="<%= bulk_publish_admin_habitations_path %>"
         data-bulk-publish-csrf-value="<%= form_authenticity_token %>"
         data-bulk-publish-filtered-total-value="<%= @filtered_count %>"
         data-bulk-publish-filters-json-value='<%= filters_json %>'<% end %>>
<div class="habitations-workspace-heading">
  <div class="habitations-workspace-heading__main">
    <div class="habitations-workspace-heading__eyebrow">
      <i class="bi bi-building"></i>
      <span>Catálogo operacional</span>
    </div>
    <div class="habitations-workspace-heading__title-row">
      <h1>Imóveis</h1>
      <span class="habitations-workspace-heading__scope"><%= @intake_review == "pending" ? "Pendente de revisão" : "Todos" %></span>
      <% if filtering_active %>
        <span class="habitations-workspace-heading__scope">Filtros ativos</span>
      <% end %>
    </div>
    <p>Portfólio com filtros em contexto, seleção em massa e publicação operacional.</p>
  </div>

  <div class="habitations-workspace-heading__side">
    <div class="habitations-workspace-heading__meta" aria-label="Resumo do catálogo">
      <span><strong><%= number_with_delimiter(@filtered_count) %></strong> filtrados</span>
      <span><strong><%= number_with_delimiter(total_habitations_count) %></strong> total</span>
      <div class="habitations-page-size dropdown" data-controller="ax-dropdown">
        <span><strong><%= @habitations.size %></strong> nesta página</span>
        <button class="habitations-page-size__button"
                type="button"
                data-ax-dropdown-target="trigger"
                data-action="click->ax-dropdown#toggle"
                aria-expanded="false"
                title="Itens por página"
                aria-label="Selecionar itens por página">
          <i class="bi bi-gear"></i>
        </button>
        <ul class="dropdown-menu dropdown-menu-end habitations-command-menu habitations-command-menu--page-size"
            data-ax-dropdown-target="menu"
            hidden
            style="right: 0; left: auto;">
          <li class="habitations-command-menu__header">
            <span>Itens por página</span>
            <small><%= current_per_page %> atual</small>
          </li>
          <% page_size_options.each do |option| %>
            <li>
              <%= link_to admin_habitations_path(page_size_params.merge(per_page: option)),
                          class: "habitations-command-menu__item #{current_per_page == option ? 'is-active' : ''}" do %>
                <span class="habitations-command-menu__item-icon"><i class="bi bi-list-ol"></i></span>
                <span class="habitations-command-menu__item-label"><%= option %> imóveis</span>
                <% if current_per_page == option %>
                  <span class="habitations-command-menu__item-status"><i class="bi bi-check2"></i></span>
                <% end %>
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>
    </div>

    <div class="habitations-workspace-heading__toolbar" aria-label="Ações do catálogo">
      <button type="button"
              class="habitations-workspace-heading__tool habitations-mobile-filter-button"
              data-action="ax-aside#toggle"
              data-ax-aside-target="toggle"
              aria-expanded="false"
              aria-label="Abrir filtros">
        <i class="bi bi-funnel"></i>
        <span>Filtros</span>
        <% if active_extra_filters_count.positive? %>
          <strong><%= active_extra_filters_count %></strong>
        <% elsif filtering_active %>
          <strong>ativo</strong>
        <% end %>
      </button>

      <div class="habitations-view-toggle" aria-label="Visualização da listagem">
        <%= link_to admin_habitations_path(property_view_params.merge(visualizacao: "cards")),
                    class: "habitations-view-toggle__item #{property_view_mode == 'cards' ? 'is-active' : ''}",
                    title: "Visualizar em cards" do %>
          <i class="bi bi-view-stacked"></i>
          <span>Cards</span>
        <% end %>
        <%= link_to admin_habitations_path(property_view_params.merge(visualizacao: "tabela")),
                    class: "habitations-view-toggle__item #{property_view_mode == 'tabela' ? 'is-active' : ''}",
                    title: "Visualizar em tabela" do %>
          <i class="bi bi-table"></i>
          <span>Tabela</span>
        <% end %>
        <% if property_view_mode == "tabela" %>
          <button type="button"
                  class="habitations-view-toggle__item habitations-view-toggle__gear"
                  data-ax-modal-open="#habitationColumnsModal"
                  title="Escolher colunas exibidas"
                  aria-label="Escolher colunas exibidas">
            <i class="bi bi-gear"></i>
          </button>
        <% end %>
      </div>

      <div class="dropdown habitations-print-menu" data-controller="ax-dropdown">
        <button class="habitations-workspace-heading__tool dropdown-toggle"
                type="button"
                data-ax-dropdown-target="trigger"
                data-action="click->ax-dropdown#toggle"
                aria-expanded="false">
          <i class="bi bi-printer"></i> Impressão
        </button>
        <ul class="dropdown-menu dropdown-menu-end habitations-command-menu habitations-command-menu--print"
            data-ax-dropdown-target="menu"
            hidden
            style="right: 0; left: auto;">
          <li class="habitations-command-menu__header">
            <span>Modelos de impressão</span>
            <small><%= @report_types.to_h.size %> opções</small>
          </li>
          <% @report_types.to_h.each do |report_key, report_label| %>
            <li>
              <%= link_to print_admin_habitations_path(printable_params.merge(report_type: report_key, full_print: "1")),
                          class: "habitations-command-menu__item",
                          target: "_blank",
                          rel: "noopener",
                          data: { turbo: false } do %>
                  <span class="habitations-command-menu__item-icon"><i class="bi bi-file-earmark-text"></i></span>
                  <span class="habitations-command-menu__item-label"><%= report_label %></span>
                  <span class="habitations-command-menu__item-status"><i class="bi bi-arrow-up-right-square"></i></span>
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>

      <div class="dropdown habitations-sort-menu" data-controller="ax-dropdown">
        <button class="habitations-workspace-heading__tool dropdown-toggle"
                type="button"
                data-ax-dropdown-target="trigger"
                data-action="click->ax-dropdown#toggle"
                aria-expanded="false">
          <i class="bi bi-sort-down"></i>
          <span>Ordenar: <strong><%= current_sort_label %></strong></span>
        </button>
        <ul class="dropdown-menu dropdown-menu-end habitations-command-menu habitations-command-menu--sort"
            data-ax-dropdown-target="menu"
            hidden
            style="right: 0; left: auto;">
          <li class="habitations-command-menu__header">
            <span>Ordenar por</span>
            <small><%= sort_direction == "asc" ? "asc" : "desc" %></small>
          </li>
          <% sort_options.each do |sort_key, sort_config| %>
            <% active_sort = current_sort_key == sort_key %>
            <li>
              <%= link_to admin_habitations_path(request.query_parameters.except("page").merge(sort: sort_key, direction: sort_config[:default_direction])),
                          class: "habitations-command-menu__item #{active_sort ? 'is-active' : ''}" do %>
                <span class="habitations-command-menu__item-icon <%= active_sort ? '' : 'is-empty' %>">
                  <% if active_sort %>
                    <i class="bi bi-check2"></i>
                  <% end %>
                </span>
                <span class="habitations-command-menu__item-label"><%= sort_config[:label] %></span>
                <span class="habitations-command-menu__item-status"><%= active_sort ? "Atual" : "" %></span>
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>

      <%= link_to admin_habitations_path(request.query_parameters.except("page").merge(sort: current_sort_key, direction: next_sort_direction)),
                  class: "habitations-workspace-heading__tool habitations-workspace-heading__tool--icon",
                  title: sort_direction == "asc" ? "Ordenar decrescente" : "Ordenar crescente" do %>
        <i class="bi bi-sort-<%= sort_direction == "asc" ? "up" : "down" %>"></i>
      <% end %>
    </div>
  </div>
</div>

<!-- Quick Scopes (Pills) -->
<%
  ownership_base_params = request.query_parameters.except("ownership", "intake_review", "page")
  all_active = @ownership_scope == "all" && @intake_review.blank?
  pending_review_active = @intake_review == "pending"
%>
<div class="habitations-workspace-scopebar">
  <div class="habitations-view-toggle habitations-view-toggle--scope" role="group" aria-label="Escopo dos imóveis">
    <%# Catálogo: todos podem navegar todos os imóveis (curadoria). %>
    <%= link_to admin_habitations_path(ownership_base_params.merge(ownership: "all", intake_review: "all")), class: "habitations-view-toggle__item #{all_active ? 'is-active' : ''}" do %>
      <i class="bi bi-collection"></i>
      <span>Todos</span>
    <% end %>
    <%# "Pendente de revisão" é curadoria de intake (admin) — só para escopo total. %>
    <% if owns_all_resource?(:imoveis) %>
      <%= link_to admin_habitations_path(ownership_base_params.merge(ownership: "all", intake_review: "pending")), class: "habitations-view-toggle__item #{pending_review_active ? 'is-active' : ''}" do %>
        <i class="bi bi-clipboard-check"></i>
        <span>Pendente de revisão</span>
      <% end %>
    <% end %>
  </div>

  <div class="habitations-mobile-sort-controls" aria-label="Ordenação da listagem">
    <div class="dropdown habitations-sort-menu" data-controller="ax-dropdown">
      <button class="habitations-workspace-heading__tool dropdown-toggle"
              type="button"
              data-ax-dropdown-target="trigger"
              data-action="click->ax-dropdown#toggle"
              aria-expanded="false">
        <i class="bi bi-sort-down"></i>
        <span>Ordenar: <strong><%= current_sort_label %></strong></span>
      </button>
      <ul class="dropdown-menu dropdown-menu-end habitations-command-menu habitations-command-menu--sort"
          data-ax-dropdown-target="menu"
          hidden
          style="right: 0; left: auto;">
        <li class="habitations-command-menu__header">
          <span>Ordenar por</span>
          <small><%= sort_direction == "asc" ? "asc" : "desc" %></small>
        </li>
        <% sort_options.each do |sort_key, sort_config| %>
          <% active_sort = current_sort_key == sort_key %>
          <li>
            <%= link_to admin_habitations_path(request.query_parameters.except("page").merge(sort: sort_key, direction: sort_config[:default_direction])),
                        class: "habitations-command-menu__item #{active_sort ? 'is-active' : ''}" do %>
              <span class="habitations-command-menu__item-icon <%= active_sort ? '' : 'is-empty' %>">
                <% if active_sort %>
                  <i class="bi bi-check2"></i>
                <% end %>
              </span>
              <span class="habitations-command-menu__item-label"><%= sort_config[:label] %></span>
              <span class="habitations-command-menu__item-status"><%= active_sort ? "Atual" : "" %></span>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>

    <%= link_to admin_habitations_path(request.query_parameters.except("page").merge(sort: current_sort_key, direction: next_sort_direction)),
                class: "habitations-workspace-heading__tool habitations-workspace-heading__tool--icon",
                title: sort_direction == "asc" ? "Ordenar decrescente" : "Ordenar crescente" do %>
      <i class="bi bi-sort-<%= sort_direction == "asc" ? "up" : "down" %>"></i>
    <% end %>
  </div>

  <%= ax_team_toggle(:imoveis) %>

  <% if bulk_actions_allowed %>
    <div class="habitations-workspace-bulkline" aria-label="Seleção em massa">
      <label class="habitations-workspace-heading__select-all" for="bulkPublishMaster">
        <input type="checkbox"
               id="bulkPublishMaster"
               data-bulk-publish-target="master"
               data-action="change->bulk-publish#toggleAll">
        <span>Selecionar filtrados</span>
      </label>

      <div data-bulk-publish-target="toolbar" class="habitations-workspace-selection" hidden>
        <span class="habitations-workspace-selection__count">
          <i class="bi bi-check2-square"></i>
          <span><span data-bulk-publish-target="count">0</span> selecionado(s)</span>
        </span>
        <button type="button" class="habitations-workspace-selection__button" data-action="click->bulk-publish#clearSelection">
          Limpar
        </button>
        <button type="button" class="habitations-workspace-selection__button habitations-workspace-selection__button--primary" data-action="click->bulk-publish#openModal">
          <i class="bi bi-megaphone"></i> Divulgar
        </button>
      </div>
    </div>
  <% end %>
</div>

<%# Modal de Exportação — ax-modal + exportação assíncrona (progresso + histórico). %>
<div class="ax-quick-modal ax-quick-modal--lg" id="habitationsExportModal" tabindex="-1" role="presentation" hidden
     aria-labelledby="habitationsExportModalLabel" aria-hidden="true"
     data-controller="ax-modal habitation-export"
     data-habitation-export-list-url-value="<%= exports_admin_habitations_path %>"
     data-admin-navigation-ignore="true"
     data-ax-modal-target="overlay" data-action="click->ax-modal#backdropClose">
  <div class="ax-quick-modal__panel" role="dialog" aria-modal="true" aria-labelledby="habitationsExportModalLabel">
    <header class="ax-quick-modal__header">
      <h5 class="ax-quick-modal__title" id="habitationsExportModalLabel">
        <i class="bi bi-download"></i> Exportação de <%= @filtered_count %> imóveis
      </h5>
      <button type="button" class="ax-icon-btn" data-action="ax-modal#close" aria-label="Fechar"><i class="bi bi-x-lg"></i></button>
    </header>
    <%# Histórico das últimas exportações — FORA do <form> de exportação (o button_to de
        excluir é um <form>; aninhar quebra o submit/CSRF). Renderizado no servidor (sem JS);
        o controller habitation-export atualiza/poll este bloco quando o JS está ativo. %>
    <div class="ax-quick-modal__body" style="padding-bottom:0">
      <div data-habitation-export-target="list" class="tw-mb-1">
        <% if @recent_exports.present? %>
          <div class="ax-label tw-mb-1">Exportações recentes</div>
          <% @recent_exports.each do |e| %>
            <div class="tw-flex tw-items-center tw-gap-2 tw-py-2" style="border-bottom:1px solid #e7ebf2">
              <i class="bi bi-filetype-csv" style="color:#16a34a"></i>
              <div class="tw-flex-1" style="min-width:0">
                <div class="tw-text-sm tw-font-semibold" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= e.filename %></div>
                <div class="tw-text-xs tw-text-ink-muted"><%= e.record_count %> imóveis · <%= e.created_at.strftime("%d/%m %H:%M") %></div>
              </div>
              <% if e.completed? %>
                <span class="ax-badge ax-badge--green ax-badge--dot">Pronto</span>
                <%= link_to download_export_admin_habitations_path(export_id: e.id),
                            class: "ax-icon-btn",
                            title: "Baixar",
                            download: e.filename,
                            data: { controller: "ax-async-download", action: "ax-async-download#download", turbo: false, admin_navigation_ignore: true, ax_async_download_accept_value: "text/csv,*/*" } do %><i class="bi bi-download"></i><% end %>
              <% elsif e.failed? %>
                <span class="ax-badge ax-badge--red ax-badge--dot">Falhou</span>
              <% else %>
                <span class="ax-badge ax-badge--amber ax-badge--dot"><%= e.progress %>%</span>
              <% end %>
              <%= button_to destroy_export_admin_habitations_path(export_id: e.id), method: :delete, class: "ax-icon-btn", form_class: "tw-inline-flex", title: "Excluir", data: { turbo_confirm: "Excluir esta exportação?" } do %><i class="bi bi-x-lg"></i><% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>

    <%= form_with url: export_admin_habitations_path, method: :post, local: true,
                  html: { data: { turbo: false, admin_navigation_ignore: true, habitation_export_target: "form", action: "submit->habitation-export#submit" } } do %>
      <div class="ax-quick-modal__body" style="padding-top:0">
        <%# Progresso da geração assíncrona %>
        <div data-habitation-export-target="progress" class="tw-mb-3" hidden>
          <div class="tw-flex tw-items-center tw-gap-2 tw-mb-1">
            <i class="bi bi-arrow-repeat" style="color:var(--admin-primary)"></i>
            <span class="tw-text-sm tw-font-semibold" data-habitation-export-target="progressLabel">Gerando o CSV…</span>
          </div>
          <div class="ax-progress"><i data-habitation-export-target="progressBar" style="width:0%"></i></div>
        </div>

        <div class="tw-mb-3">
          <label class="ax-label">Formatação dos dados</label>
          <%= select_tag :data_format,
                         options_for_select([["CSV (;)", "csv_semicolon"], ["CSV (,)", "csv_comma"]], "csv_semicolon"),
                         class: "ax-control" %>
        </div>

        <% request.query_parameters.except("fields", "data_format").each do |key, value| %>
          <% if value.is_a?(Array) %>
            <% value.each do |entry| %>
              <%= hidden_field_tag "#{key}[]", entry %>
            <% end %>
          <% else %>
            <%= hidden_field_tag key, value %>
          <% end %>
        <% end %>

        <div class="tw-border tw-rounded-lg" style="overflow:hidden">
          <div class="tw-py-2 tw-font-semibold" style="padding:8px 12px;background:#f6f8fb">Selecione os campos para exportação</div>
          <div style="max-height:340px;overflow-y:auto">
            <% @export_fields.each do |field_key, field_label| %>
              <% next if !can_export_proprietor_data? && field_key == "proprietario" %>
              <label class="tw-flex tw-items-center tw-gap-2 tw-py-2 tw-border-b tw-text-sm" style="padding-left:12px;padding-right:12px">
                <%= check_box_tag "fields[]", field_key, @default_export_fields.include?(field_key) %>
                <span><%= field_label %></span>
              </label>
            <% end %>
          </div>
        </div>
      </div>
      <footer class="ax-quick-modal__footer">
        <button type="button" class="ax-btn ax-btn--ghost" data-action="ax-modal#close">Fechar</button>
        <button type="submit" class="ax-btn ax-btn--primary" data-habitation-export-target="submit">Exportar</button>
      </footer>
    <% end %>
  </div>
</div>

<div class="habitations-results-shell">
<%
  active_filter_chips = []
  active_filter_chips << "Código: #{params[:codigo]}" if params[:codigo].present?
  active_filter_chips << "Busca: #{params[:q]}" if params[:q].present?
  selected_status_chips = Array(params[:status]).flatten.map(&:to_s).map(&:strip).reject(&:blank?)
  active_filter_chips << "Status: #{selected_status_chips.join(', ')}" if selected_status_chips.any?
  active_filter_chips << "Categoria: #{params[:categoria]}" if params[:categoria].present?
  active_filter_chips << "Rua: #{params[:logradouro]}" if params[:logradouro].present?
  active_filter_chips << "Número: #{params[:numero]}" if params[:numero].present?
  active_filter_chips << "CEP: #{params[:cep]}" if params[:cep].present?
  active_filter_chips << "Cidade: #{params[:cidade]}" if params[:cidade].present?
  selected_bairro_chips = Array(params[:bairro]).flatten.map(&:to_s).map(&:strip).reject(&:blank?)
  active_filter_chips << "Bairro: #{selected_bairro_chips.join(', ')}" if selected_bairro_chips.any?
  active_filter_chips << "Bairro comercial: #{params[:bairro_comercial]}" if params[:bairro_comercial].present?
  active_filter_chips << "Situação: #{params[:situacao]}" if params[:situacao].present?
  active_filter_chips << "Preço reduzido: Sim" if params[:promotion_status] == "with_promo"
  active_filter_chips << "Preço reduzido: Não" if params[:promotion_status] == "without_promo"
  active_filter_chips << "Chaves: #{params[:key_location]}" if params[:key_location].present?
  active_filter_chips << "Adm. locação: Sim" if params[:salute_rental_management] == "1"
  active_filter_chips << "Adm. locação: Não" if params[:salute_rental_management] == "0"
  active_filter_chips << "Preço mín.: R$ #{params[:min_price]}" if params[:min_price].present?
  active_filter_chips << "Preço máx.: R$ #{params[:max_price]}" if params[:max_price].present?
  active_filter_chips << "Face: #{params[:face]}" if params[:face].present?
  active_filter_chips << "Ocupação: #{params[:ocupacao_status]}" if params[:ocupacao_status].present?
  active_filter_chips << "Conservação: #{params[:estado_conservacao]}" if params[:estado_conservacao].present?
  Array(params[:banheiros]).reject(&:blank?).each { |value| active_filter_chips << "Banheiros: #{value}" }
  Array(params[:dorms]).reject(&:blank?).each { |value| active_filter_chips << "Dormitórios: #{value}" }
  Array(params[:suites]).reject(&:blank?).each { |value| active_filter_chips << "Suítes: #{value}" }
  Array(params[:vagas]).reject(&:blank?).each { |value| active_filter_chips << "Vagas: #{value}" }
  active_filter_chips << "Área total mín.: #{params[:area_total_min]}" if params[:area_total_min].present?
  active_filter_chips << "Área total máx.: #{params[:area_total_max]}" if params[:area_total_max].present?
  active_filter_chips << "Área privativa mín.: #{params[:area_privativa_min]}" if params[:area_privativa_min].present?
  active_filter_chips << "Área privativa máx.: #{params[:area_privativa_max]}" if params[:area_privativa_max].present?
  active_filter_chips << "Somente com imagens" if params[:somente_com_imagens] == "1"
  active_filter_chips << "Somente sem imagens" if params[:somente_sem_imagens] == "1"
  active_filter_chips << "Somente imóveis do DWV" if params[:somente_dwv] == "1"
  active_filter_chips << "Destaque Web: Sim" if params[:destaque_web] == "1"
  active_filter_chips << "Destaque Web: Não" if params[:destaque_web] == "0"
  active_filter_chips << "Super Destaque: Sim" if params[:festival_salute] == "1"
  active_filter_chips << "Super Destaque: Não" if params[:festival_salute] == "0"
  active_filter_chips << "Exibir no site: Sim" if params[:exibir_no_site_salute] == "1"
  active_filter_chips << "Exibir no site: Não" if params[:exibir_no_site_salute] == "0"
  active_filter_chips << "Portal: Imovelweb 2" if params[:publicar_imovelweb_2] == "1"
  active_filter_chips << "Portal: Lais Ai" if params[:publicar_lais_ai] == "1"
  active_filter_chips << "Portal: Chaves Na Mao" if params[:publicar_chaves_na_mao] == "1"
  active_filter_chips << "Portal: Casa Mineira" if params[:publicar_casa_mineira] == "1"
  active_filter_chips << "Portal: Imovelweb" if params[:publicar_imovelweb] == "1"
  active_filter_chips << "Portal: Viva Real VRSync" if params[:publicar_viva_real_vrsync] == "1"
  Array(params[:foto_classificacao]).reject(&:blank?).each do |fc|
    active_filter_chips << "Foto: #{fc}"
  end
  Array(params[:amenities]).reject(&:blank?).each do |amenity|
    active_filter_chips << "Item: #{amenity}"
  end
  active_filter_chips << "Tem Placa" if params[:tem_placa] == "1"
  active_filter_chips << "Exclusivo" if params[:exclusivo] == "1"
  active_filter_chips << "Permuta: Sim" if params[:accepts_exchange] == "1"
  active_filter_chips << "Permuta: Não" if params[:accepts_exchange] == "0"
  active_filter_chips << "Permuta veículo: Sim" if params[:permuta_vehicle] == "1"
  active_filter_chips << "Permuta imóvel: Sim" if params[:permuta_property] == "1"
  active_filter_chips << "Permuta outros: Sim" if params[:permuta_others] == "1"
  active_filter_chips << "Valor mín. permuta: R$ #{params[:permuta_min_value]}" if params[:permuta_min_value].present?
  active_filter_chips << "Localização permuta: #{params[:permuta_location]}" if params[:permuta_location].present?
  active_filter_chips << "Dorms permuta ≥ #{params[:permuta_min_dorms]}" if params[:permuta_min_dorms].present?
  active_filter_chips << "Suítes permuta ≥ #{params[:permuta_min_suites]}" if params[:permuta_min_suites].present?
  active_filter_chips << "Garagens permuta ≥ #{params[:permuta_min_garagens]}" if params[:permuta_min_garagens].present?
  active_filter_chips << "Empreendimento: #{admin_habitation_development_filter_label(params[:empreendimento_codigo])}" if params[:empreendimento_codigo].present?
  active_filter_chips << "Corretor: #{params[:corretor_id]}" if params[:corretor_id].present?
  active_filter_chips << "Proprietário: #{params[:proprietor_id]}" if can_export_proprietor_data? && params[:proprietor_id].present?
  active_filter_chips << "Região foco?: #{params[:regiao_foco]}" if params[:regiao_foco].present?
  active_filter_chips << "Pendente de revisão" if @intake_review == "pending"
  active_filter_chips << "Captação de: #{params[:captacao_inicio]}" if params[:captacao_inicio].present?
  active_filter_chips << "Captação até: #{params[:captacao_fim]}" if params[:captacao_fim].present?
  active_filter_chips << "Atualiz. de: #{params[:atualizacao_inicio]}" if params[:atualizacao_inicio].present?
  active_filter_chips << "Atualiz. até: #{params[:atualizacao_fim]}" if params[:atualizacao_fim].present?
  active_filter_chips << "Escopo: #{params[:scope]}" if params[:scope].present?
%>

<div class="habitations-results-list">
  <p class="habitations-mobile-catalog-summary" aria-label="Resumo do catálogo">
    <span><strong><%= number_with_delimiter(total_habitations_count) %></strong> total</span>
    <span><strong><%= number_with_delimiter(@filtered_count) %></strong> filtrados</span>
  </p>

<% if active_filter_chips.any? %>
  <div class="habitations-active-filter-chips tw-mb-3 tw-flex tw-flex-wrap tw-gap-2">
    <% active_filter_chips.each do |chip| %>
      <%= ax_badge(chip, tone: :gray) %>
    <% end %>
  </div>
<% end %>

<% if @habitations.any? %>
  <% if property_view_mode == "tabela" %>
    <%
      habitation_table_columns = [
        (["select", "Seleção"] if bulk_actions_allowed),
        ["property", "Imóvel"],
        ["location", "Localização"],
        ["price", "Valor"],
        ["costs", "Custos"],
        ["updated", "Atualização"],
        ["actions", "Ações"]
      ].compact
    %>
    <div data-controller="ax-table-columns"
         data-ax-table-columns-storage-key-value="admin-habitations-columns:<%= current_admin_user&.id %>">
      <%= render "admin/habitations/property_catalog_table",
                 habitations: @habitations,
                 bulk_actions_allowed: bulk_actions_allowed %>

      <%= ax_quick_modal(id: "habitationColumnsModal", title: "Colunas da tabela", size: :sm) do %>
        <p class="ax-columns-picker__hint">Escolha quais colunas aparecem na tabela. A preferência fica salva neste navegador.</p>
        <ul class="ax-columns-picker">
          <% habitation_table_columns.each do |key, label| %>
            <li class="ax-columns-picker__row">
              <input type="checkbox"
                     id="habcol_<%= key %>"
                     class="ax-columns-picker__check"
                     data-ax-table-columns-target="toggle"
                     data-column-key="<%= key %>"
                     data-action="change->ax-table-columns#toggle"
                     checked>
              <label for="habcol_<%= key %>" class="ax-columns-picker__label"><%= label %></label>
            </li>
          <% end %>
        </ul>
      <% end %>
    </div>
  <% else %>
    <div class="ax-property-list ax-property-list--cards">
      <% @habitations.each do |imovel| %>
        <%= render "admin/habitations/property_catalog_card",
                   imovel: imovel,
                   bulk_actions_allowed: bulk_actions_allowed %>
      <% end %>
    </div>
  <% end %>
<% else %>
  <div class="ax-property-empty">
    <div class="ax-property-empty__icon"><i class="bi bi-search"></i></div>
    <h5>Nenhum imóvel encontrado</h5>
    <p>Tente ajustar seus filtros ou buscar por outro termo.</p>
    <%= link_to "Limpar filtros", admin_habitations_path(ownership: "all", clear_filters: "1"), class: "ax-btn" %>
  </div>
<% end %>

<%= ax_pagination @habitations, params: request.query_parameters %>
</div>

<!-- Bulk Publish Modal -->
<div class="ax-quick-modal ax-quick-modal--md" id="bulkPublishModal" tabindex="-1" role="presentation" hidden aria-hidden="true"
     data-controller="ax-modal" data-ax-modal-target="overlay" data-action="click->ax-modal#backdropClose"
     data-bulk-publish-target="modal"
     data-bulk-publish-eligibility-url-value="<%= bulk_publish_eligibility_admin_habitations_path %>">
  <div class="ax-quick-modal__panel" role="dialog" aria-modal="true">
    <header class="ax-quick-modal__header">
      <h5 class="ax-quick-modal__title tw-flex tw-items-center tw-gap-2">
        <i class="bi bi-megaphone-fill" style="color:#16a34a"></i>
        Divulgação de <span data-bulk-publish-target="modalCount">0</span> Imóveis
      </h5>
      <button type="button" class="ax-icon-btn" data-action="ax-modal#close" aria-label="Fechar"><i class="bi bi-x-lg"></i></button>
    </header>
    <div class="ax-quick-modal__body">
      <form id="bulkPublishForm" data-bulk-publish-target="form">
        <!-- Canal (single-select) -->
        <div class="tw-mb-3">
          <label class="ax-label tw-font-semibold">Selecione o canal de divulgação.</label>
          <select name="channel" class="ax-control"
                  data-bulk-publish-target="channelSelect"
                  data-action="change->bulk-publish#onChannelChange">
            <option value="">Selecione</option>
            <option value="site">Site da Imobiliária</option>
            <option value="lais_ai">Lais Ai</option>
            <option value="chaves_na_mao">Chaves Na Mão</option>
            <option value="casa_mineira">Casa Mineira</option>
            <option value="imovelweb">Imovelweb</option>
            <option value="imovelweb_2">Imovelweb 2</option>
            <option value="viva_real_vrsync">Viva Real VRSync</option>
          </select>
        </div>

        <!-- Ação -->
        <div class="tw-mb-3">
          <div class="tw-flex tw-gap-3 tw-items-center">
            <label class="tw-flex tw-items-center tw-gap-2" for="bulkActionPublish">
              <input type="radio" name="action_type" value="publicar" id="bulkActionPublish" checked
                     data-bulk-publish-target="actionRadio"
                     data-action="change->bulk-publish#onActionChange">
              <span>Publicar</span>
            </label>
            <label class="tw-flex tw-items-center tw-gap-2 tw-font-semibold" style="color:#16a34a" for="bulkActionUnpublish">
              <input type="radio" name="action_type" value="despublicar" id="bulkActionUnpublish"
                     data-bulk-publish-target="actionRadio"
                     data-action="change->bulk-publish#onActionChange">
              <span>Despublicar</span>
            </label>
          </div>
        </div>

        <!-- Sub-opções específicas do canal (só visíveis quando canal tem opções E ação=publicar) -->
        <div class="tw-mb-3" data-bulk-publish-target="channelOptionsWrapper" hidden>
          <!-- Chaves Na Mão -->
          <div class="channel-options-block tw-border tw-rounded-lg" style="padding:8px" data-channel="chaves_na_mao" hidden>
            <div class="tw-text-sm tw-font-semibold tw-text-ink-muted tw-mb-1">Destaque</div>
            <div class="tw-flex tw-flex-wrap tw-gap-3 tw-mb-2">
              <% Habitation::CHAVES_NA_MAO_DESTAQUE_OPTIONS.each do |(label, val)| %>
                <label class="tw-flex tw-items-center tw-gap-2" for="bulk_chaves_destaque_<%= val %>">
                  <input type="radio" name="channel_options[chaves_na_mao][destaque_chaves_na_mao]" value="<%= val %>" id="bulk_chaves_destaque_<%= val %>">
                  <span class="tw-text-sm"><%= label %></span>
                </label>
              <% end %>
            </div>
            <div class="tw-text-sm tw-font-semibold tw-text-ink-muted tw-mb-1">Período Locação</div>
            <div class="tw-flex tw-flex-wrap tw-gap-3">
              <% Habitation::CHAVES_NA_MAO_PERIODO_LOCACAO_OPTIONS.each do |(label, val)| %>
                <label class="tw-flex tw-items-center tw-gap-2" for="bulk_chaves_periodo_<%= val %>">
                  <input type="radio" name="channel_options[chaves_na_mao][periodo_locacao_chaves_na_mao]" value="<%= val %>" id="bulk_chaves_periodo_<%= val %>">
                  <span class="tw-text-sm"><%= label %></span>
                </label>
              <% end %>
            </div>
          </div>

          <!-- Casa Mineira -->
          <div class="channel-options-block tw-border tw-rounded-lg" style="padding:8px" data-channel="casa_mineira" hidden>
            <div class="tw-text-sm tw-font-semibold tw-text-ink-muted tw-mb-1">Modelo</div>
            <div class="tw-flex tw-flex-wrap tw-gap-3">
              <% Habitation::CASA_MINEIRA_MODELO_OPTIONS.each do |(label, val)| %>
                <label class="tw-flex tw-items-center tw-gap-2" for="bulk_casa_modelo_<%= val %>">
                  <input type="radio" name="channel_options[casa_mineira][modelo_casa_mineira]" value="<%= val %>" id="bulk_casa_modelo_<%= val %>">
                  <span class="tw-text-sm"><%= label %></span>
                </label>
              <% end %>
            </div>
          </div>

          <!-- Imovelweb -->
          <div class="channel-options-block tw-border tw-rounded-lg" style="padding:8px" data-channel="imovelweb" hidden>
            <div class="tw-text-sm tw-font-semibold tw-text-ink-muted tw-mb-1">Tipo Publicação</div>
            <div class="tw-flex tw-flex-wrap tw-gap-3 tw-mb-2">
              <% Habitation::IMOVELWEB_TIPO_PUBLICACAO_OPTIONS.each do |(label, val)| %>
                <label class="tw-flex tw-items-center tw-gap-2" for="bulk_iw_tipo_<%= val %>">
                  <input type="radio" name="channel_options[imovelweb][tipo_publicacao_imovelweb]" value="<%= val %>" id="bulk_iw_tipo_<%= val %>">
                  <span class="tw-text-sm"><%= label %></span>
                </label>
              <% end %>
            </div>
            <div class="tw-text-sm tw-font-semibold tw-text-ink-muted tw-mb-1">Mostrar Mapa</div>
            <div class="tw-flex tw-flex-wrap tw-gap-3">
              <% Habitation::IMOVELWEB_MOSTRAR_MAPA_OPTIONS.each do |(label, val)| %>
                <label class="tw-flex tw-items-center tw-gap-2" for="bulk_iw_mapa_<%= val %>">
                  <input type="radio" name="channel_options[imovelweb][mostrar_mapa_imovelweb]" value="<%= val %>" id="bulk_iw_mapa_<%= val %>">
                  <span class="tw-text-sm"><%= label %></span>
                </label>
              <% end %>
            </div>
          </div>

          <!-- Imovelweb 2 -->
          <div class="channel-options-block tw-border tw-rounded-lg" style="padding:8px" data-channel="imovelweb_2" hidden>
            <div class="tw-text-sm tw-font-semibold tw-text-ink-muted tw-mb-1">Tipo Publicação</div>
            <div class="tw-flex tw-flex-wrap tw-gap-3 tw-mb-2">
              <% Habitation::IMOVELWEB_TIPO_PUBLICACAO_OPTIONS.each do |(label, val)| %>
                <label class="tw-flex tw-items-center tw-gap-2" for="bulk_iw2_tipo_<%= val %>">
                  <input type="radio" name="channel_options[imovelweb_2][tipo_publicacao_imovelweb_2]" value="<%= val %>" id="bulk_iw2_tipo_<%= val %>">
                  <span class="tw-text-sm"><%= label %></span>
                </label>
              <% end %>
            </div>
            <div class="tw-text-sm tw-font-semibold tw-text-ink-muted tw-mb-1">Mostrar Mapa</div>
            <div class="tw-flex tw-flex-wrap tw-gap-3">
              <% Habitation::IMOVELWEB_MOSTRAR_MAPA_OPTIONS.each do |(label, val)| %>
                <label class="tw-flex tw-items-center tw-gap-2" for="bulk_iw2_mapa_<%= val %>">
                  <input type="radio" name="channel_options[imovelweb_2][mostrar_mapa_imovelweb_2]" value="<%= val %>" id="bulk_iw2_mapa_<%= val %>">
                  <span class="tw-text-sm"><%= label %></span>
                </label>
              <% end %>
            </div>
          </div>

          <!-- Viva Real VRSync -->
          <div class="channel-options-block tw-border tw-rounded-lg" style="padding:8px" data-channel="viva_real_vrsync" hidden>
            <div class="tw-text-sm tw-font-semibold tw-text-ink-muted tw-mb-1">Tipo Publicação</div>
            <div class="tw-flex tw-flex-wrap tw-gap-3 tw-mb-2">
              <% Habitation::VIVA_REAL_TIPO_PUBLICACAO_OPTIONS.each do |(label, val)| %>
                <label class="tw-flex tw-items-center tw-gap-2" for="bulk_vr_tipo_<%= val %>">
                  <input type="radio" name="channel_options[viva_real_vrsync][tipo_publicacao_viva_real]" value="<%= val %>" id="bulk_vr_tipo_<%= val %>">
                  <span class="tw-text-sm"><%= label %></span>
                </label>
              <% end %>
            </div>
            <div class="tw-text-sm tw-font-semibold tw-text-ink-muted tw-mb-1">Divulgar Endereço</div>
            <div class="tw-flex tw-flex-wrap tw-gap-3">
              <% Habitation::VIVA_REAL_DIVULGAR_ENDERECO_OPTIONS.each do |(label, val)| %>
                <label class="tw-flex tw-items-center tw-gap-2" for="bulk_vr_endereco_<%= val %>">
                  <input type="radio" name="channel_options[viva_real_vrsync][divulgar_endereco_viva_real]" value="<%= val %>" id="bulk_vr_endereco_<%= val %>">
                  <span class="tw-text-sm"><%= label %></span>
                </label>
              <% end %>
            </div>
          </div>
        </div>

        <!-- Contador de elegibilidade -->
        <div class="tw-rounded-lg tw-text-sm tw-text-ink-muted" style="background:#f6f8fb;padding:12px">
          Você selecionou <strong style="color:#1f2733" data-bulk-publish-target="eligTotal">0</strong> imóveis.<br>
          Em <strong style="color:#1f2733" data-bulk-publish-target="eligCount">—</strong> você pode atualizar as opções de divulgação.
          <i class="bi bi-question-circle-fill tw-text-ink-muted" data-controller="ax-tooltip" data-ax-tooltip-text-value="Quantos dos imóveis selecionados realmente serão afetados pela ação escolhida." title="Quantos dos imóveis selecionados realmente serão afetados pela ação escolhida."></i>
        </div>
      </form>
    </div>
    <footer class="ax-quick-modal__footer">
      <button type="button" class="ax-btn ax-btn--ghost" data-action="ax-modal#close">Cancelar</button>
      <button type="button" class="ax-btn ax-btn--primary" data-action="click->bulk-publish#submit">
        Confirmar
      </button>
    </footer>
  </div>
</div>

</div><!-- /.habitations-results-shell -->
    </div><!-- /.habitations-master-content -->
<% end %>

