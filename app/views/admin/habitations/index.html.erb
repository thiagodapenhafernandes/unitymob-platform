                      </div>
                    </div>
                    <div class="col-md-6">
                      <div class="form-check">
                        <%= check_box_tag :publicar_chaves_na_mao, "1", params[:publicar_chaves_na_mao] == "1", class: "form-check-input", id: "publicar_chaves_na_mao_filter" %>
                        <%= label_tag :publicar_chaves_na_mao_filter, "Publicar Chaves Na Mao", class: "form-check-label" %>
                      </div>
                      <div class="form-check">
                        <%= check_box_tag :publicar_casa_mineira, "1", params[:publicar_casa_mineira] == "1", class: "form-check-input", id: "publicar_casa_mineira_filter" %>
                        <%= label_tag :publicar_casa_mineira_filter, "Publicar Casa Mineira", class: "form-check-label" %>
                      </div>
                      <div class="form-check">
                        <%= check_box_tag :publicar_imovelweb, "1", params[:publicar_imovelweb] == "1", class: "form-check-input", id: "publicar_imovelweb_filter" %>
                        <%= label_tag :publicar_imovelweb_filter, "Publicar Imovelweb", class: "form-check-label" %>
                      </div>
                      <div class="form-check">
                        <%= check_box_tag :publicar_viva_real_vrsync, "1", params[:publicar_viva_real_vrsync] == "1", class: "form-check-input", id: "publicar_viva_real_vrsync_filter" %>
                        <%= label_tag :publicar_viva_real_vrsync_filter, "Publicar Viva Real VRSync", class: "form-check-label" %>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="border rounded-3 p-3 mb-3">
              <h6 class="fw-bold text-secondary mb-3">Permuta</h6>
              <div class="row g-3">
                <div class="col-md-3">
                  <div class="form-check mt-4">
                    <%= check_box_tag :permuta_vehicle, "1", params[:permuta_vehicle] == "1", class: "form-check-input", id: "permuta_vehicle_filter" %>
                    <%= label_tag :permuta_vehicle_filter, "Aceita permuta veículo", class: "form-check-label" %>
                  </div>
                </div>
                <div class="col-md-3">
                  <div class="form-check mt-4">
                    <%= check_box_tag :permuta_property, "1", params[:permuta_property] == "1", class: "form-check-input", id: "permuta_property_filter" %>
                    <%= label_tag :permuta_property_filter, "Aceita permuta imóvel", class: "form-check-label" %>
                  </div>
                </div>
                <div class="col-md-3">
                  <div class="form-check mt-4">
                    <%= check_box_tag :permuta_others, "1", params[:permuta_others] == "1", class: "form-check-input", id: "permuta_others_filter" %>
                    <%= label_tag :permuta_others_filter, "Aceita permuta outros", class: "form-check-label" %>
                  </div>
                </div>
                <div class="col-md-3">
                  <label class="form-label small fw-bold text-muted text-uppercase">Valor mín. permuta</label>
                  <div class="input-group">
                    <span class="input-group-text bg-white">R$</span>
                    <%= f.text_field :permuta_min_value, value: params[:permuta_min_value], class: "form-control money-mask", placeholder: "0,00" %>
                  </div>
                </div>

                <div class="col-md-6">
                  <label class="form-label small fw-bold text-muted text-uppercase">Localização permuta</label>
                  <%= f.text_field :permuta_location, value: params[:permuta_location], class: "form-control", placeholder: "Cidade, bairro ou região" %>
                </div>
                <div class="col-md-2">
                  <label class="form-label small fw-bold text-muted text-uppercase">Dormit. mín.</label>
                  <%= f.number_field :permuta_min_dorms, value: params[:permuta_min_dorms], class: "form-control", min: 0 %>
                </div>
                <div class="col-md-2">
                  <label class="form-label small fw-bold text-muted text-uppercase">Suítes mín.</label>
                  <%= f.number_field :permuta_min_suites, value: params[:permuta_min_suites], class: "form-control", min: 0 %>
                </div>
                <div class="col-md-2">
                  <label class="form-label small fw-bold text-muted text-uppercase">Garagens mín.</label>
                  <%= f.number_field :permuta_min_garagens, value: params[:permuta_min_garagens], class: "form-control", min: 0 %>
                </div>
              </div>
            </div>

          </div>
        </details>

    </div>
  </div>
  <% end %>
</div>
