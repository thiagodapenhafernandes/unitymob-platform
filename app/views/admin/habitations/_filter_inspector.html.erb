<%
  filter_active_count = lambda do |keys|
    keys.count do |key|
      value = params[key]
      value.is_a?(Array) ? value.reject(&:blank?).any? : value.present?
    end
  end

  data_filter_keys = %w[codigo empreendimento_codigo corretor_id status categoria min_price max_price]
  location_filter_keys = %w[logradouro numero cep cidade bairro bairro_comercial]
  business_filter_keys = %w[situacao promotion_status accepts_exchange key_location salute_rental_management]
  people_filter_keys = %w[proprietor_id]
  feature_filter_keys = %w[face ocupacao_status estado_conservacao regiao_foco banheiros dorms suites vagas area_total_min area_total_max area_privativa_min area_privativa_max]
  amenity_filter_keys = %w[amenities]
  media_filter_keys = %w[destaque_web festival_salute exibir_no_site_salute tem_placa exclusivo somente_com_imagens somente_sem_imagens somente_dwv foto_classificacao publicar_imovelweb_2 publicar_lais_ai publicar_chaves_na_mao publicar_casa_mineira publicar_imovelweb publicar_viva_real_vrsync]
  exchange_filter_keys = %w[permuta_vehicle permuta_property permuta_others permuta_min_value permuta_location permuta_min_dorms permuta_min_suites permuta_min_garagens]
  date_filter_keys = %w[captacao_inicio captacao_fim atualizacao_inicio atualizacao_fim]
  quick_filter_count = filter_active_count.call(%w[q]) + (params[:scope].present? ? 1 : 0)
  quick_filters = [
    { key: "destaque_web", label: "Destaque Web", icon: "star-fill" },
    { key: "super_destaque", label: "Super Destaque", icon: "stars" },
    { key: "oportunidade", label: "Oportunidade", icon: "lightning-fill" },
    { key: "frente_mar", label: "Frente Mar", icon: "building" },
    { key: "lancamento", label: "Lançamento", icon: "rocket-takeoff" },
    { key: "na_planta", label: "Na Planta", icon: "rulers" },
    { key: "mobiliado", label: "Mobiliado", icon: "sofa" },
    { key: "sacada", label: "Sacada", icon: "layout-sidebar" },
    { key: "dependencia_empregada", label: "Dependência", icon: "door-closed" },
    { key: "cozinha_gourmet_churrasqueira", label: "Cozinha gourmet", icon: "fire" },
    { key: "sol_manha", label: "Sol manhã", icon: "sunrise" },
    { key: "sol_tarde", label: "Sol tarde", icon: "sunset" },
    { key: "sol_dia_todo", label: "Sol dia todo", icon: "sun" },
    { key: "decorado", label: "Decorado", icon: "palette" }
  ]

  data_count = filter_active_count.call(data_filter_keys)
  location_count = filter_active_count.call(location_filter_keys)
  business_count = filter_active_count.call(business_filter_keys)
  people_count = filter_active_count.call(people_filter_keys)
  feature_count = filter_active_count.call(feature_filter_keys)
  amenity_count = filter_active_count.call(amenity_filter_keys)
  media_count = filter_active_count.call(media_filter_keys)
  exchange_count = filter_active_count.call(exchange_filter_keys)
  date_count = filter_active_count.call(date_filter_keys)

  selected_foto_classificacoes = Array(params[:foto_classificacao]).map(&:to_s)
  selected_amenities = Array(params[:amenities]).map(&:to_s)
  selected_bairros = Array(params[:bairro]).flatten.map(&:to_s).map(&:strip).reject(&:blank?)
  amenity_options = @filter_amenity_options.presence || Admin::HabitationsController::AMENITY_FILTER_OPTIONS
%>

<%= ax_aside_panel(
      title: "Filtros do catálogo",
      token: (active_extra_filters_count.positive? ? "#{active_extra_filters_count} filtros" : nil),
      rail_label: "Abrir filtros do catálogo",
      rail_icon: "funnel",
      collapse_icon: "x-lg",
      collapse_label: "Recolher filtros do catálogo",
      class_name: "habitations-inspector-shell",
      rail_class: "habitations-inspector-rail",
      panel_class: "habitations-inspector",
      header_class: "habitations-inspector__header"
    ) do %>

  <%= form_with url: admin_habitations_path,
                method: :get,
                local: true,
                class: "habitations-inspector__form",
                autocomplete: "off",
                data: { turbo_frame: "_top", action: "submit->ax-aside#collapse" } do |f| %>
    <%= hidden_field_tag :sort, params[:sort] if params[:sort].present? %>
    <%= hidden_field_tag :direction, params[:direction] if params[:direction].present? %>
    <%= hidden_field_tag :scope, params[:scope] if params[:scope].present? %>
    <%= hidden_field_tag :ownership, @ownership_scope if @ownership_scope.present? %>
    <%= hidden_field_tag :intake_review, @intake_review if @intake_review.present? %>

    <div class="habitations-inspector__actions">
      <button class="ax-btn ax-btn--primary" type="submit">
        <i class="bi bi-search"></i> Aplicar filtros
      </button>
      <%= link_to admin_habitations_path(ownership: "all"),
                  class: "ax-btn",
                  data: { turbo_frame: "_top", action: "click->ax-aside#collapse" } do %>
        <i class="bi bi-eraser"></i> Limpar
      <% end %>
    </div>

    <%= ax_filter_section(title: "Filtros rápidos", icon: "stars", count: quick_filter_count, open: params[:q].present?) do %>
      <div class="habitations-inspector-keyword">
        <%= ax_field_label(nil, nil, text: "Palavra-chave") %>
        <%= ax_input_group(prefix: ax_icon("search", class_name: "ax-text-muted")) do %>
          <div class="ax-clearable-control ax-clearable-control--group-item" data-controller="ax-clear-field">
            <%= f.text_field :q,
                             value: params[:q],
                             class: "ax-control",
                             placeholder: "Empreendimento, endereço, bairro...",
                             autocomplete: "off",
                             data: { ax_clear_field_target: "control", action: "input->ax-clear-field#update change->ax-clear-field#update" } %>
            <button class="ax-clearable-control__button"
                    type="button"
                    title="Limpar campo"
                    aria-label="Limpar Palavra-chave"
                    data-ax-clear-field-target="button"
                    data-action="click->ax-clear-field#clear"
                    hidden>
              <i class="bi bi-x"></i>
            </button>
          </div>
        <% end %>
      </div>

      <div class="habitations-scope-strip habitations-scope-strip--inspector habitations-scopes">
        <% quick_filters.each do |quick_filter| %>
          <%= link_to admin_habitations_path(request.query_parameters.except("page").merge(scope: quick_filter[:key])),
                      class: "habitations-scope-chip #{params[:scope] == quick_filter[:key] ? 'is-active' : ''}",
                      data: { turbo_frame: "_top" } do %>
            <i class="bi bi-<%= quick_filter[:icon] %>"></i> <%= quick_filter[:label] %>
          <% end %>
        <% end %>

        <% if params[:scope].present? %>
          <%= link_to admin_habitations_path(request.query_parameters.except("scope", "page")),
                      class: "habitations-scope-chip",
                      data: { turbo_frame: "_top" } do %>
            <i class="bi bi-x-lg"></i> Limpar rápido
          <% end %>
        <% end %>
      </div>
    <% end %>

    <%= ax_filter_section(title: "Dados", icon: "database", count: data_count, open: true) do %>
      <%= ax_field_grid columns: 2, gap: :compact, class_name: "ax-filter-section__grid habitations-catalog-data-grid" do %>
        <div class="ax-span-2">
          <%= ax_field_label(nil, nil,
                text: "Código / Referência",
                for: "admin_habitation_catalog_code_search") %>
          <%= ax_input_group(prefix: "#") do %>
            <div class="ax-clearable-control ax-clearable-control--group-item" data-controller="ax-clear-field">
              <%= f.text_field :codigo,
                               value: params[:codigo],
                               id: "admin_habitation_catalog_code_search",
                               class: "ax-control",
                               placeholder: "Ex.: 8615",
                               autocomplete: "off",
                               data: { ax_clear_field_target: "control", action: "input->ax-clear-field#update change->ax-clear-field#update" } %>
              <button class="ax-clearable-control__button"
                      type="button"
                      title="Limpar campo"
                      aria-label="Limpar Código"
                      data-ax-clear-field-target="button"
                      data-action="click->ax-clear-field#clear"
                      hidden>
                <i class="bi bi-x"></i>
              </button>
            </div>
          <% end %>
        </div>
        <div class="ax-span-2">
          <%= ax_autocomplete_select_field(clearable: true, form: f,
                                           method: :empreendimento_codigo,
                                           label: "Empreendimento",
                                           choices: @filter_empreendimentos,
                                           select_options: { include_blank: "Todos", selected: params[:empreendimento_codigo] },
                                           placeholder: "Selecione empreendimento") %>
        </div>
        <% if can_filter_by_broker? %>
          <div class="ax-span-2">
            <%= ax_autocomplete_select_field(clearable: true, form: f,
                                             method: :corretor_id,
                                             label: "Corretor",
                                             choices: @filter_brokers,
                                             select_options: { include_blank: "Todos", selected: params[:corretor_id] },
                                             placeholder: "Selecione corretor") %>
          </div>
        <% end %>
        <div class="ax-span-2 habitations-catalog-data-divider">
          <span>Recorte</span>
          <strong>Tipo e status</strong>
        </div>
        <div class="ax-span-2">
          <%= ax_autocomplete_select_field(clearable: true, form: f, method: :status, label: "Status", choices: @filter_statuses, select_options: { include_blank: "Todos", selected: params[:status] }, placeholder: "Todos") %>
        </div>
        <div class="ax-span-2">
          <%= ax_autocomplete_select_field(clearable: true, form: f, method: :categoria, label: "Categoria", choices: @filter_categories, select_options: { include_blank: "Todas", selected: params[:categoria] }, placeholder: "Todas") %>
        </div>
        <div class="ax-span-2">
          <%= ax_field_label(nil, nil, text: "Valor") %>
          <div class="habitations-catalog-price-stack">
            <%= ax_input_group(prefix: "R$") do %>
              <div class="ax-clearable-control ax-clearable-control--group-item" data-controller="ax-clear-field">
                <%= f.text_field :min_price,
                                 value: params[:min_price],
                                 class: "ax-control money-mask",
                                 placeholder: "Mín.",
                                 autocomplete: "off",
                                 inputmode: "numeric",
                                 pattern: "[0-9.]*",
                                 data: { controller: "currency-mask", ax_clear_field_target: "control", action: "input->currency-mask#format input->ax-clear-field#update change->ax-clear-field#update" } %>
                <button class="ax-clearable-control__button"
                        type="button"
                        title="Limpar campo"
                        aria-label="Limpar valor mínimo"
                        data-ax-clear-field-target="button"
                        data-action="click->ax-clear-field#clear"
                        hidden>
                  <i class="bi bi-x"></i>
                </button>
              </div>
            <% end %>
            <%= ax_input_group(prefix: "R$") do %>
              <div class="ax-clearable-control ax-clearable-control--group-item" data-controller="ax-clear-field">
                <%= f.text_field :max_price,
                                 value: params[:max_price],
                                 class: "ax-control money-mask",
                                 placeholder: "Máx.",
                                 autocomplete: "off",
                                 inputmode: "numeric",
                                 pattern: "[0-9.]*",
                                 data: { controller: "currency-mask", ax_clear_field_target: "control", action: "input->currency-mask#format input->ax-clear-field#update change->ax-clear-field#update" } %>
                <button class="ax-clearable-control__button"
                        type="button"
                        title="Limpar campo"
                        aria-label="Limpar valor máximo"
                        data-ax-clear-field-target="button"
                        data-action="click->ax-clear-field#clear"
                        hidden>
                  <i class="bi bi-x"></i>
                </button>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>

    <%= ax_filter_section(title: "Localização", icon: "geo-alt", count: location_count, open: location_count.positive?) do %>
      <%= ax_field_grid columns: 2, gap: :compact, class_name: "ax-filter-section__grid" do %>
        <div class="ax-span-2">
          <%= ax_autocomplete_select_field(clearable: true, form: f, method: :cidade, label: "Cidade", choices: @filter_cities, select_options: { include_blank: "Todas", selected: params[:cidade] }, placeholder: "Todas") %>
        </div>
        <div class="ax-span-2">
          <%= ax_autocomplete_select_field(clearable: true, form: f,
                                           method: :bairro,
                                           label: "Bairro",
                                           choices: options_for_select(@filter_bairros, selected_bairros),
                                           select_options: {},
                                           multiple: true,
                                           placeholder: "Bairros",
                                           html_options: { class: "filter-multi-wrap" }) %>
        </div>
        <div class="ax-span-2">
          <%= ax_autocomplete_select_field(clearable: true, form: f,
                                           method: :bairro_comercial,
                                           label: "Bairro comercial",
                                           choices: @filter_bairros_comerciais,
                                           select_options: { include_blank: "Todos", selected: params[:bairro_comercial] },
                                           placeholder: "Ex: Barra") %>
        </div>
        <div class="ax-span-2">
          <%= ax_text_field(clearable: true, form: f, method: :logradouro, label: "Rua", value: params[:logradouro], placeholder: "Ex: Avenida Brasil") %>
        </div>
        <div>
          <%= ax_text_field(clearable: true, form: f, method: :numero, label: "Número", value: params[:numero], placeholder: "123") %>
        </div>
        <div>
          <%= ax_text_field(clearable: true, form: f, method: :cep, label: "CEP", value: params[:cep], placeholder: "88330-590") %>
        </div>
      <% end %>
    <% end %>

    <%= ax_filter_section(title: "Negócio", icon: "cash-coin", count: business_count, open: business_count.positive?) do %>
      <%= ax_field_grid columns: 2, gap: :compact, class_name: "ax-filter-section__grid" do %>
        <div>
          <%= ax_autocomplete_select_field(clearable: true, form: f, method: :situacao, label: "Situação", choices: @filter_situacoes, select_options: { include_blank: "Todas", selected: params[:situacao] }, placeholder: "Todas") %>
        </div>
        <div>
          <%= ax_autocomplete_select_field(clearable: true, form: f,
                                           method: :promotion_status,
                                           label: "Preço reduzido",
                                           choices: [["Com preço reduzido", "with_promo"], ["Sem preço reduzido", "without_promo"]],
                                           select_options: { include_blank: "Todos", selected: params[:promotion_status] },
                                           placeholder: "Todos") %>
        </div>
        <div>
          <%= ax_autocomplete_select_field(clearable: true, form: f, method: :accepts_exchange, label: "Aceita permuta", choices: [["Sim", "1"], ["Não", "0"]], select_options: { include_blank: "Todos", selected: params[:accepts_exchange] }, placeholder: "Todos") %>
        </div>
        <div>
          <%= ax_autocomplete_select_field(clearable: true, form: f, method: :key_location, label: "Chaves", choices: @filter_key_locations, select_options: { include_blank: "Todos", selected: params[:key_location] }, placeholder: "Todos") %>
        </div>
        <div>
          <%= ax_autocomplete_select_field(clearable: true, form: f, method: :salute_rental_management, label: "Adm. locação", choices: [["Sim", "1"], ["Não", "0"]], select_options: { include_blank: "Todos", selected: params[:salute_rental_management] }, placeholder: "Todos") %>
        </div>
      <% end %>
    <% end %>

    <% if can_filter_by_proprietor? %>
      <%= ax_filter_section(title: "Responsáveis", icon: "people", count: people_count, open: people_count.positive?) do %>
        <%= ax_field_grid columns: 2, gap: :compact, class_name: "ax-filter-section__grid" do %>
          <div class="ax-span-2">
            <%= ax_autocomplete_select_field(clearable: true, form: f,
                                             method: :proprietor_id,
                                             label: "Proprietário",
                                             choices: @filter_proprietors,
                                             select_options: { include_blank: "Todos", selected: params[:proprietor_id] },
                                             placeholder: "Digite nome, telefone ou CPF",
                                             url: proprietor_options_admin_habitations_path,
                                             search_param: "q",
                                             min_length: 2,
                                             tom_select_options: { maxOptions: 20 }) %>
          </div>
        <% end %>
      <% end %>
    <% end %>

    <%= ax_filter_section(title: "Características", icon: "sliders", count: feature_count, open: feature_count.positive?) do %>
      <%= ax_field_grid columns: 2, gap: :compact, class_name: "ax-filter-section__grid" do %>
        <div>
          <%= ax_autocomplete_select_field(clearable: true, form: f, method: :face, label: "Face", choices: @filter_faces, select_options: { include_blank: "Todas", selected: params[:face] }, placeholder: "Todas") %>
        </div>
        <div>
          <%= ax_autocomplete_select_field(clearable: true, form: f, method: :ocupacao_status, label: "Ocupação", choices: @filter_ocupacao_statuses, select_options: { include_blank: "Todas", selected: params[:ocupacao_status] }, placeholder: "Todas") %>
        </div>
        <div>
          <%= ax_autocomplete_select_field(clearable: true, form: f, method: :estado_conservacao, label: "Conservação", choices: @filter_estado_conservacoes, select_options: { include_blank: "Todas", selected: params[:estado_conservacao] }, placeholder: "Todas") %>
        </div>
        <div>
          <%= ax_autocomplete_select_field(clearable: true, form: f, method: :regiao_foco, label: "Região foco", choices: @filter_regioes_foco, select_options: { include_blank: "Todas", selected: params[:regiao_foco] }, placeholder: "Todas") %>
        </div>
        <div>
          <%= ax_autocomplete_select_field(clearable: true, form: f, method: :banheiros, label: "Banheiros", choices: options_for_select((1..8).map { |n| [n.to_s, n] }, @banheiros), select_options: {}, multiple: true, placeholder: "Banheiros", html_options: { class: "filter-multi-compact" }) %>
        </div>
        <div>
          <%= ax_autocomplete_select_field(clearable: true, form: f, method: :dorms, label: "Dormitórios", choices: options_for_select((1..8).map { |n| [n.to_s, n] }, @dorms), select_options: {}, multiple: true, placeholder: "Dormitórios", html_options: { class: "filter-multi-compact" }) %>
        </div>
        <div>
          <%= ax_autocomplete_select_field(clearable: true, form: f, method: :suites, label: "Suítes", choices: options_for_select((1..8).map { |n| [n.to_s, n] }, @suites), select_options: {}, multiple: true, placeholder: "Suítes", html_options: { class: "filter-multi-compact" }) %>
        </div>
        <div>
          <%= ax_autocomplete_select_field(clearable: true, form: f, method: :vagas, label: "Vagas", choices: options_for_select((1..8).map { |n| [n.to_s, n] }, @vagas), select_options: {}, multiple: true, placeholder: "Vagas", html_options: { class: "filter-multi-compact" }) %>
        </div>
        <div>
          <%= ax_number_field(clearable: true, form: f, method: :area_total_min, label: "Área total mín.", value: params[:area_total_min], step: "0.01", min: "0") %>
        </div>
        <div>
          <%= ax_number_field(clearable: true, form: f, method: :area_total_max, label: "Área total máx.", value: params[:area_total_max], step: "0.01", min: "0") %>
        </div>
        <div>
          <%= ax_number_field(clearable: true, form: f, method: :area_privativa_min, label: "Privativa mín.", value: params[:area_privativa_min], step: "0.01", min: "0") %>
        </div>
        <div>
          <%= ax_number_field(clearable: true, form: f, method: :area_privativa_max, label: "Privativa máx.", value: params[:area_privativa_max], step: "0.01", min: "0") %>
        </div>
      <% end %>
    <% end %>

    <%= ax_filter_section(title: "Características internas e lazer", icon: "stars", count: amenity_count, open: amenity_count.positive?) do %>
      <div class="ax-filter-checks">
        <% amenity_options.each_with_index do |opcao, idx| %>
          <%= ax_filter_check(name: "amenities[]", value: opcao, checked: selected_amenities.include?(opcao), label: opcao, id: "amenity_filter_#{idx}") %>
        <% end %>
      </div>
    <% end %>

    <%= ax_filter_section(title: "Imagens e portais", icon: "images", count: media_count, open: media_count.positive?) do %>
      <%= ax_field_grid columns: 2, gap: :compact, class_name: "ax-filter-section__grid" do %>
        <div>
          <%= ax_autocomplete_select_field(clearable: true, form: f, method: :destaque_web, label: "Destaque Web", choices: [["Sim", "1"], ["Não", "0"]], select_options: { include_blank: "Todos", selected: params[:destaque_web] }, placeholder: "Todos") %>
        </div>
        <div>
          <%= ax_autocomplete_select_field(clearable: true, form: f, method: :festival_salute, label: "Super Destaque", choices: [["Sim", "1"], ["Não", "0"]], select_options: { include_blank: "Todos", selected: params[:festival_salute] }, placeholder: "Todos") %>
        </div>
        <div class="ax-span-2">
          <%= ax_autocomplete_select_field(clearable: true, form: f, method: :exibir_no_site_salute, label: "Exibir no site", choices: [["Sim", "1"], ["Não", "0"]], select_options: { include_blank: "Todos", selected: params[:exibir_no_site_salute] }, placeholder: "Todos") %>
        </div>
        <div class="ax-span-2 ax-filter-checks">
          <%= ax_filter_check(name: :somente_com_imagens, checked: params[:somente_com_imagens] == "1", label: "Somente com imagens", id: "somente_com_imagens_filter") %>
          <%= ax_filter_check(name: :somente_sem_imagens, checked: params[:somente_sem_imagens] == "1", label: "Somente sem imagens", id: "somente_sem_imagens_filter") %>
          <%= ax_filter_check(name: :somente_dwv, checked: params[:somente_dwv] == "1", label: "Somente DWV", id: "somente_dwv_filter") %>
          <%= ax_filter_check(name: :tem_placa, checked: params[:tem_placa] == "1", label: "Tem placa", id: "tem_placa_filter_outros") %>
          <%= ax_filter_check(name: :exclusivo, checked: params[:exclusivo] == "1", label: "Exclusivo", id: "exclusivo_filter_outros") %>
        </div>
        <div class="ax-span-2">
          <%= ax_field_label(nil, nil, text: "Publicado com fotos") %>
          <div class="ax-filter-checks">
            <% ["Profissionais", "Boas", "Aceitáveis", "Não tem fotos"].each do |opcao| %>
              <%= ax_filter_check(name: "foto_classificacao[]", value: opcao, checked: selected_foto_classificacoes.include?(opcao), label: opcao, id: "foto_classificacao_#{opcao.parameterize}") %>
            <% end %>
          </div>
        </div>
        <div class="ax-span-2">
          <%= ax_field_label(nil, nil, text: "Publicação em portais") %>
          <div class="ax-filter-checks">
            <% [
              [:publicar_imovelweb_2, "Publicar Imovelweb 2"],
              [:publicar_lais_ai, "Publicar Lais Ai"],
              [:publicar_chaves_na_mao, "Publicar Chaves Na Mao"],
              [:publicar_casa_mineira, "Publicar Casa Mineira"],
              [:publicar_imovelweb, "Publicar Imovelweb"],
              [:publicar_viva_real_vrsync, "Publicar Viva Real VRSync"]
            ].each do |field, label| %>
              <%= ax_filter_check(name: field, checked: params[field] == "1", label:, id: "#{field}_filter") %>
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>

    <%= ax_filter_section(title: "Permuta", icon: "arrow-left-right", count: exchange_count, open: exchange_count.positive?) do %>
      <%= ax_field_grid columns: 2, gap: :compact, class_name: "ax-filter-section__grid" do %>
        <div class="ax-span-2 ax-filter-checks">
          <%= ax_filter_check(name: :permuta_vehicle, checked: params[:permuta_vehicle] == "1", label: "Aceita veículo", id: "permuta_vehicle_filter") %>
          <%= ax_filter_check(name: :permuta_property, checked: params[:permuta_property] == "1", label: "Aceita imóvel", id: "permuta_property_filter") %>
          <%= ax_filter_check(name: :permuta_others, checked: params[:permuta_others] == "1", label: "Aceita outros", id: "permuta_others_filter") %>
        </div>
        <div class="ax-span-2">
          <%= ax_field_label(nil, nil, text: "Valor mín. permuta") %>
          <%= ax_input_group(prefix: "R$") do %>
            <div class="ax-clearable-control ax-clearable-control--group-item" data-controller="ax-clear-field">
              <%= f.text_field :permuta_min_value,
                               value: params[:permuta_min_value],
                               class: "ax-control money-mask",
                               placeholder: "0,00",
                               autocomplete: "off",
                               data: { ax_clear_field_target: "control", action: "input->ax-clear-field#update change->ax-clear-field#update" } %>
              <button class="ax-clearable-control__button"
                      type="button"
                      title="Limpar campo"
                      aria-label="Limpar valor mínimo de permuta"
                      data-ax-clear-field-target="button"
                      data-action="click->ax-clear-field#clear"
                      hidden>
                <i class="bi bi-x"></i>
              </button>
            </div>
          <% end %>
        </div>
        <div class="ax-span-2">
          <%= ax_text_field(clearable: true, form: f, method: :permuta_location, label: "Localização permuta", value: params[:permuta_location], placeholder: "Cidade, bairro ou região") %>
        </div>
        <div>
          <%= ax_number_field(clearable: true, form: f, method: :permuta_min_dorms, label: "Dormit. mín.", value: params[:permuta_min_dorms], min: 0) %>
        </div>
        <div>
          <%= ax_number_field(clearable: true, form: f, method: :permuta_min_suites, label: "Suítes mín.", value: params[:permuta_min_suites], min: 0) %>
        </div>
        <div class="ax-span-2">
          <%= ax_number_field(clearable: true, form: f, method: :permuta_min_garagens, label: "Garagens mín.", value: params[:permuta_min_garagens], min: 0) %>
        </div>
      <% end %>
    <% end %>

    <%= ax_filter_section(title: "Datas", icon: "calendar3", count: date_count, open: date_count.positive?) do %>
      <%= ax_field_grid columns: 2, gap: :compact, class_name: "ax-filter-section__grid" do %>
        <div>
          <%= ax_date_field(clearable: true, form: f, method: :captacao_inicio, label: "Cadastro de", value: params[:captacao_inicio]) %>
        </div>
        <div>
          <%= ax_date_field(clearable: true, form: f, method: :captacao_fim, label: "Cadastro até", value: params[:captacao_fim]) %>
        </div>
        <div>
          <%= ax_date_field(clearable: true, form: f, method: :atualizacao_inicio, label: "Atualiz. de", value: params[:atualizacao_inicio]) %>
        </div>
        <div>
          <%= ax_date_field(clearable: true, form: f, method: :atualizacao_fim, label: "Atualiz. até", value: params[:atualizacao_fim]) %>
        </div>
      <% end %>
    <% end %>

    <% if active_extra_filters_count.positive? %>
      <%= link_to admin_habitations_path(clear_extras_params), class: "ax-btn ax-btn--ghost ax-btn--block" do %>
        <i class="bi bi-x-circle"></i> Limpar filtros avançados
      <% end %>
    <% end %>
  <% end %>
<% end %>
