<% audit_modal_body = capture do %>
  <p class="habitation-audit-sub">
    Código <%= habitation.codigo %> · informações carregadas sob demanda
  </p>

  <nav class="habitation-audit-tabs" aria-label="Áreas da central do imóvel">
    <button type="button" class="habitation-audit-tab active"
            data-property-operational-hub-target="tab"
            data-property-operational-hub-tab-param="overview"
            data-action="property-operational-hub#select" aria-selected="true">
      Visão geral
    </button>
    <button type="button" class="habitation-audit-tab"
            data-property-operational-hub-target="tab"
            data-property-operational-hub-tab-param="changes"
            data-action="property-operational-hub#select" aria-selected="false">
      Alterações
    </button>
    <button type="button" class="habitation-audit-tab"
            data-property-operational-hub-target="tab"
            data-property-operational-hub-tab-param="publication"
            data-action="property-operational-hub#select" aria-selected="false">
      Publicação
    </button>
    <button type="button" class="habitation-audit-tab"
            data-property-operational-hub-target="tab"
            data-property-operational-hub-tab-param="intake"
            data-action="property-operational-hub#select" aria-selected="false">
      Captação
    </button>
  </nav>

  <div class="tab-content habitation-audit-content" data-property-operational-hub-target="content" aria-live="polite">
    <div class="habitation-hub-loading"><i class="bi bi-arrow-repeat"></i> Selecione uma aba para carregar.</div>
  </div>
<% end %>

<%= ax_quick_modal(
      id: "habitationHistoryModal",
      title: "Central do imóvel",
      size: :lg,
      class_name: "habitation-audit-modal",
      data: {
        controller: "property-operational-hub",
        action: "ax-modal:opened->property-operational-hub#open",
        property_operational_hub_url_value: operational_hub_admin_habitation_path(habitation)
      },
      body: audit_modal_body
    ) %>

<style>
  .habitation-audit-modal { z-index: 3000; }
  .habitation-audit-modal .ax-quick-modal__panel {
    width: min(860px, calc(100vw - 32px));
    max-height: min(740px, calc(100vh - 88px));
  }
  .habitation-audit-modal .ax-quick-modal__body { padding: 0; }

  .habitation-audit-sub {
    margin: 0;
    padding: 12px 16px;
    color: var(--ab-muted, #657386);
    font-size: 12.5px;
    border-bottom: 1px solid var(--ab-line-soft, #e7ebf2);
  }

  .habitation-audit-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 10px 16px;
    border-bottom: 1px solid var(--ab-line, #d8dee8);
    background: var(--ab-panel-soft, #f4f7fb);
    position: sticky;
    top: 0;
    z-index: 2;
  }

  .habitation-audit-tab {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border: 1px solid var(--ab-line, #d8dee8);
    border-radius: 8px;
    background: #fff;
    color: var(--ab-muted, #657386);
    font-size: 12.5px;
    font-weight: 700;
    line-height: 1;
    cursor: pointer;
    transition: border-color .12s ease, color .12s ease, background .12s ease;
  }

  .habitation-audit-tab:hover {
    border-color: var(--ab-field-hover, #b8c5d6);
    color: var(--ab-ink, #202a37);
  }

  .habitation-audit-tab.active {
    border-color: color-mix(in srgb, var(--admin-primary) 40%, #d8dee8);
    background: var(--admin-primary);
    color: #fff;
  }

  .habitation-audit-tab__count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 20px;
    height: 18px;
    padding: 0 6px;
    border-radius: 999px;
    background: var(--ab-panel-header, #eef2f7);
    color: var(--ab-muted, #657386);
    font-size: 11px;
    font-weight: 800;
  }

  .habitation-audit-tab.active .habitation-audit-tab__count {
    background: rgba(255, 255, 255, .22);
    color: #fff;
  }

  .habitation-audit-content { padding: 16px; }
  .habitation-hub-loading { display: flex; align-items: center; justify-content: center; gap: 8px; min-height: 180px; color: var(--ab-muted, #657386); font-size: 12.5px; }
  .habitation-hub-loading i { animation: habitation-hub-spin .8s linear infinite; }
  .habitation-hub-error { display: grid; place-items: center; gap: 8px; min-height: 180px; color: var(--ab-muted, #657386); font-size: 12.5px; text-align: center; }
  @keyframes habitation-hub-spin { to { transform: rotate(360deg); } }

  .habitation-operational-overview { display: grid; gap: 12px; }
  .habitation-operational-kpis { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 8px; }
  .habitation-operational-kpis article { min-width: 0; padding: 10px 12px; border: 1px solid var(--ab-line-soft, #e7ebf2); border-radius: 8px; background: #fff; }
  .habitation-operational-kpis span { display: block; color: var(--ab-muted, #657386); font-size: 10.5px; font-weight: 800; text-transform: uppercase; }
  .habitation-operational-kpis strong { display: block; margin-top: 3px; overflow: hidden; color: var(--ab-ink, #202a37); font-size: 13px; text-overflow: ellipsis; white-space: nowrap; }
  .habitation-operational-grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: 8px; }
  .habitation-operational-panel { padding: 10px 12px; border: 1px solid var(--ab-line-soft, #e7ebf2); border-radius: 8px; background: var(--ab-panel-soft, #f4f7fb); }
  .habitation-operational-panel header { display: flex; align-items: center; gap: 7px; color: var(--ab-ink, #202a37); font-size: 12px; }
  .habitation-operational-panel header span { margin-left: auto; }
  .habitation-operational-panel ul { margin: 8px 0 0; padding-left: 18px; color: var(--ab-muted, #657386); font-size: 12px; }
  .habitation-operational-panel li.is-danger { color: var(--admin-danger, #b42318); font-weight: 700; }
  .habitation-operational-panel p { margin: 8px 0 0; color: var(--ab-muted, #657386); font-size: 12px; }
  .habitation-publication-overview { display: grid; gap: 12px; }
  .habitation-publication-summary { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 8px; }
  .habitation-publication-summary article { padding: 10px 12px; border: 1px solid var(--ab-line-soft, #e7ebf2); border-radius: 8px; background: #fff; }
  .habitation-publication-summary span { display: block; color: var(--ab-muted, #657386); font-size: 10.5px; font-weight: 800; text-transform: uppercase; }
  .habitation-publication-summary strong { display: block; margin-top: 3px; font-size: 13px; }
  .habitation-publication-channels { display: flex; flex-wrap: wrap; gap: 6px; }
  .habitation-publication-channel { display: inline-flex; align-items: center; gap: 5px; padding: 5px 8px; border: 1px solid var(--ab-line, #d8dee8); border-radius: 999px; color: var(--ab-muted, #657386); font-size: 11.5px; }
  .habitation-publication-channel.is-active { border-color: #86c5a3; background: #edf8f2; color: #167548; font-weight: 700; }
  .habitation-publication-conflicts { padding: 8px 10px; border: 1px solid #f1b6b0; border-radius: 8px; background: #fff2f0; color: #9f2d24; font-size: 12px; }
  .habitation-publication-conflicts p { margin: 0; }
  .habitation-publication-conflicts i { margin-right: 6px; }
  .habitation-publication-history h4 { margin: 0 0 8px; font-size: 12px; text-transform: uppercase; }

  @media (max-width: 720px) {
    .habitation-operational-kpis { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .habitation-operational-grid { grid-template-columns: 1fr; }
    .habitation-publication-summary { grid-template-columns: 1fr; }
  }

  /* Garante o toggle dos panes mesmo sem o JS do Bootstrap. */
  .habitation-audit-modal .tab-content > .tab-pane { display: none; }
  .habitation-audit-modal .tab-content > .tab-pane.active { display: block; }

  /* Timeline compacta, agrupada por data (identidade DS). */
  .ax-tl-day {
    display: flex;
    align-items: center;
    gap: 6px;
    margin: 16px 0 10px;
    color: var(--ab-muted, #657386);
    font-size: 11.5px;
    font-weight: 800;
    letter-spacing: .02em;
    text-transform: uppercase;
  }
  .ax-tl-day:first-child { margin-top: 0; }

  .ax-tl {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin: 0 0 4px 7px;
    padding-left: 18px;
    border-left: 2px solid var(--ab-line-soft, #e7ebf2);
  }

  .ax-tl-item { position: relative; }

  .ax-tl-node {
    position: absolute;
    left: -27px;
    top: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 999px;
    border: 2px solid var(--admin-primary, #365f8f);
    background: #fff;
    color: var(--admin-primary, #365f8f);
    font-size: 8px;
  }

  .ax-tl-card {
    border: 1px solid var(--ab-line-soft, #e7ebf2);
    border-radius: 8px;
    padding: 8px 10px;
    background: #fff;
  }

  .ax-tl-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 8px;
  }
  .ax-tl-title { font-size: 13px; font-weight: 700; color: var(--ab-ink, #202a37); }
  .ax-tl-time { flex: 0 0 auto; font-size: 11.5px; color: var(--ab-muted, #657386); }

  .ax-tl-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    margin-top: 2px;
    font-size: 11.5px;
    color: var(--ab-muted, #657386);
  }
  .ax-tl-actor { font-weight: 700; color: var(--ab-ink, #202a37); }
  .ax-tl-source {
    padding: 1px 7px;
    border: 1px solid var(--ab-line, #d8dee8);
    border-radius: 999px;
    font-size: 10.5px;
    font-weight: 700;
  }

  .ax-tl-changes {
    list-style: none;
    margin: 8px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .ax-tl-changes li {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px 8px;
    border-radius: 6px;
    background: var(--ab-panel-soft, #f4f7fb);
    font-size: 12px;
  }
  .ax-tl-changes li i { flex: 0 0 auto; color: var(--ab-muted, #9aa6b6); font-size: 11px; }
  .ax-tl-field { flex: 0 0 auto; font-weight: 700; color: var(--ab-ink, #202a37); }
  .ax-tl-before,
  .ax-tl-after {
    min-width: 0;
    max-width: 42%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .ax-tl-before { color: var(--ab-muted, #657386); }
  .ax-tl-after { color: var(--ab-ink, #202a37); font-weight: 600; }

  .habitation-audit-empty {
    border: 1px dashed var(--ab-field-border, #cfd8e5);
    border-radius: .85rem;
    padding: 1.5rem;
    text-align: center;
    color: var(--ab-muted, #657386);
    background: var(--ab-panel-soft, #f8fafc);
  }
  .habitation-audit-detail-list {
    margin: .75rem 0 0;
    padding-left: 1rem;
    color: var(--ab-ink, #202a37);
  }
  .habitation-audit-detail-list li {
    margin-bottom: .25rem;
    white-space: pre-wrap;
    word-break: break-word;
  }
</style>
