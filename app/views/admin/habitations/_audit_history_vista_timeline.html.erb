<div class="tab-pane fade <%= "show active" if active %>" id="<%= tab_id %>" role="tabpanel">
  <% if entries.any? %>
    <div class="habitation-audit-timeline">
      <% entries.each do |entry| %>
        <div class="habitation-audit-item">
          <div class="d-flex justify-content-between gap-3 flex-wrap">
            <div>
              <div class="habitation-audit-title"><%= entry[:title] %></div>
              <div class="habitation-audit-meta">
                <% if entry[:at].present? %>
                  <%= l(entry[:at], format: "%d/%m/%Y às %H:%M") %>
                <% else %>
                  Data não informada
                <% end %>
                · <span class="badge bg-light text-dark border"><%= entry[:type] %></span>
                <% if entry[:actor].present? %>
                  · <%= entry[:actor] %>
                <% end %>
              </div>
              <% if entry[:source_table].present? || entry[:source_key].present? %>
                <div class="habitation-audit-meta mt-1">
                  Origem: <%= [entry[:source_table], entry[:source_key]].compact_blank.join(" · ") %>
                </div>
              <% end %>
            </div>
          </div>

          <% if entry[:details].present? %>
            <ul class="habitation-audit-detail-list small">
              <% entry[:details].each do |detail| %>
                <li><%= detail %></li>
              <% end %>
            </ul>
          <% else %>
            <div class="text-muted small mt-2">Registro do Vista sem detalhe adicional.</div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="habitation-audit-empty">
      <i class="bi bi-database d-block fs-3 mb-2"></i>
      Nenhum histórico do Vista encontrado para este imóvel ainda.
    </div>
  <% end %>
</div>
