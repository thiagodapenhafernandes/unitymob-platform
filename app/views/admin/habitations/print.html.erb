<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title><%= @report_title %></title>
  <style>
    @page { size: A4 portrait; margin: 10mm; }
    body { margin: 0; background: #e5e7eb; font-family: Arial, Helvetica, sans-serif; color: #111; }
    .toolbar { display: flex; justify-content: space-between; align-items: center; padding: 14px 24px; background: #f5f5f5; border-bottom: 1px solid #d3d3d3; }
    .toolbar h1 { margin: 0; font-size: 34px; font-weight: 700; }
    .toolbar .meta { font-size: 18px; color: #444; }
    .pager { display: flex; align-items: center; gap: 10px; }
    .pager a, .pager span { text-decoration: none; color: #111; border: 1px solid #c8c8c8; background: white; padding: 6px 10px; border-radius: 4px; font-size: 13px; }
    .pager .disabled { opacity: .4; pointer-events: none; }
    .pager .page-label { border: none; background: transparent; padding: 0; }
    .print-btn { border: 1px solid #c8c8c8; background: #fff; color: #111; border-radius: 4px; padding: 6px 10px; font-size: 13px; cursor: pointer; }
    .print-btn:hover { background: #f0f0f0; }
    .notice { margin: 14px auto; max-width: 1100px; background: #d9f1fb; border: 1px solid #9ecfe6; color: #2c5870; padding: 10px 14px; font-size: 14px; }

    .paper-wrap { max-width: 1100px; margin: 0 auto 20px; }
    .paper { background: white; border: 1px solid #bdbdbd; padding: 22px 24px; }
    .paper + .paper { margin-top: 12px; }
    .page-break { page-break-after: always; break-after: page; }
    .report-header { display: flex; justify-content: space-between; margin-bottom: 14px; }
    .report-header .title { font-size: 36px; font-weight: 700; margin: 0; }
    .report-header .brand { font-size: 16px; font-weight: 700; text-transform: uppercase; margin-top: 2px; }
    .report-header .sub { font-size: 12px; color: #555; }

    table { width: 100%; border-collapse: collapse; font-size: 12px; table-layout: fixed; }
    thead th { text-align: left; font-weight: 700; border-bottom: 1px solid #444; padding: 4px 3px; line-height: 1.2; }
    tbody td { border-bottom: 1px solid #ddd; padding: 3px; vertical-align: top; line-height: 1.2; }
    tfoot td { border-top: 1px solid #444; padding: 6px 4px; font-weight: 700; background: #f6f6f6; }

    .right { text-align: right; }
    .center { text-align: center; }
    .broker-group { margin-bottom: 16px; }
    .broker-name { font-weight: 700; margin: 8px 0 4px; }
    .footer-url { margin-top: 16px; font-size: 12px; color: #666; text-align: center; }

    @media print {
      body { background: white; }
      .toolbar, .notice { display: none; }
      .paper-wrap { max-width: 100%; margin: 0; }
      .paper { border: none; padding: 0; }
      .paper, .broker-group, table, tr, td, th { break-inside: avoid; page-break-inside: avoid; }
      .page-break { display: block; height: 0; page-break-after: always; break-after: page; }
      .footer-url { display: none; }
    }
  </style>
</head>
<body>
  <% paginated_report = %w[property_list property_list_with_m2 property_list_by_broker].include?(@report_type) %>
  <% full_print_mode = @full_print_mode != false %>

  <div class="toolbar">
    <div>
      <h1>Imprimir: <span class="meta"><%= @report_title %></span></h1>
      <div class="meta">Gerado em <%= l(@report_generated_at, format: :short) %></div>
    </div>

    <div class="pager">
      <button type="button" class="print-btn" onclick="window.print()">
        🖨 Imprimir
      </button>
    </div>

    <% if paginated_report && !full_print_mode %>
      <div class="pager">
        <% previous_page = @report_page.to_i - 1 %>
        <% next_page = @report_page.to_i + 1 %>
        <% base_params = request.query_parameters.except("page") %>

        <% if previous_page >= 1 %>
          <%= link_to "←", url_for(params: base_params.merge(page: previous_page)), class: "" %>
        <% else %>
          <span class="disabled">←</span>
        <% end %>

        <span class="page-label"><%= @report_page %> de <%= @report_total_pages %></span>

        <% if next_page <= @report_total_pages.to_i %>
          <%= link_to "→", url_for(params: base_params.merge(page: next_page)), class: "" %>
        <% else %>
          <span class="disabled">→</span>
        <% end %>
      </div>
    <% end %>
  </div>

  <% if @report_limited_to_max_pages %>
    <div class="notice">
      Exibição limitada a <strong><%= Admin::HabitationsController::REPORT_MAX_PAGES %> páginas</strong>.
      Para listagem completa, aplique filtros adicionais ou exporte os dados.
    </div>
  <% end %>

  <div class="paper-wrap">
    <div class="paper">
      <div class="report-header">
        <div>
          <p class="title"><%= @report_title.upcase %></p>
        </div>
        <div>
          <div class="brand"><%= (@layout_setting&.site_name.presence || "Salute Imoveis").upcase %></div>
          <div class="sub">Página <%= @report_page || 1 %></div>
        </div>
      </div>

      <% if @report_type == "sale_rent_total_values" %>
        <table>
          <thead>
            <tr>
              <th>Tipo</th>
              <th class="center">Unid</th>
              <th class="right">Venda (R$)</th>
              <th class="right">Aluguel (R$)</th>
            </tr>
          </thead>
          <tbody>
            <% @summary_rows.each do |row| %>
              <tr>
                <td><%= row[:category] %></td>
                <td class="center"><%= row[:total_units] %></td>
                <td class="right"><%= number_to_currency(row[:sale_total], unit: "", separator: ",", delimiter: ".") %></td>
                <td class="right"><%= number_to_currency(row[:rent_total], unit: "", separator: ",", delimiter: ".") %></td>
              </tr>
            <% end %>
          </tbody>
          <tfoot>
            <tr>
              <td>Total de imóveis</td>
              <td class="center"><%= @summary_totals[:units] %></td>
              <td class="right"><%= number_to_currency(@summary_totals[:sale_total], unit: "", separator: ",", delimiter: ".") %></td>
              <td class="right"><%= number_to_currency(@summary_totals[:rent_total], unit: "", separator: ",", delimiter: ".") %></td>
            </tr>
          </tfoot>
        </table>

      <% elsif @report_type == "property_list" %>
        <% pages = @report_pages_data.presence || [@habitations] %>
        <% pages.each_with_index do |records, page_index| %>
          <table>
            <thead>
              <tr>
                <th>Referência</th>
                <th>Categoria</th>
                <th>Endereço</th>
                <th>Bairro</th>
                <th class="right">Área total</th>
                <th class="right">Área Priv.</th>
                <th class="center">Dorm(s)</th>
                <th class="center">Suíte(s)</th>
                <th class="center">Vaga(s)</th>
                <th class="right">Venda</th>
                <th class="right">Aluguel</th>
              </tr>
            </thead>
            <tbody>
              <% records.each do |habitation| %>
                <tr>
                  <td><%= habitation.codigo %></td>
                  <td><%= habitation.categoria %></td>
                  <td><%= [habitation.logradouro || habitation.endereco, habitation.numero].compact.join(" nº ") %></td>
                  <td><%= habitation.bairro %></td>
                  <td class="right"><%= number_with_precision(habitation.area_total_m2.to_f, precision: 2, separator: ",", delimiter: ".") %></td>
                  <td class="right"><%= number_with_precision(habitation.area_privativa_m2.to_f, precision: 2, separator: ",", delimiter: ".") %></td>
                  <td class="center"><%= habitation.dormitorios_qtd.to_i %></td>
                  <td class="center"><%= habitation.suites_qtd.to_i %></td>
                  <td class="center"><%= habitation.vagas_qtd.to_i %></td>
                  <td class="right"><%= habitation.valor_venda_formatted %></td>
                  <td class="right"><%= habitation.valor_locacao_formatted %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
          <% if page_index < pages.size - 1 %><div class="page-break"></div><% end %>
        <% end %>

      <% elsif @report_type == "property_list_with_m2" %>
        <% pages = @report_pages_data.presence || [@habitations] %>
        <% pages.each_with_index do |records, page_index| %>
          <table>
            <thead>
              <tr>
                <th>Referência</th>
                <th>Categoria</th>
                <th>Cidade</th>
                <th>Bairro</th>
                <th class="right">Área total</th>
                <th class="right">Área Priv.</th>
                <th class="right">Venda</th>
                <th class="right">R$ m² Venda</th>
                <th class="right">Aluguel</th>
                <th class="right">R$ m² Aluguel</th>
              </tr>
            </thead>
            <tbody>
              <% records.each do |habitation| %>
                <% area_for_calc = habitation.area_privativa_m2.to_f.positive? ? habitation.area_privativa_m2.to_f : habitation.area_total_m2.to_f %>
                <% sale_m2 = area_for_calc.positive? ? (habitation.valor_venda_cents.to_i / 100.0) / area_for_calc : 0 %>
                <% rent_m2 = area_for_calc.positive? ? (habitation.valor_locacao_cents.to_i / 100.0) / area_for_calc : 0 %>
                <tr>
                  <td><%= habitation.codigo %></td>
                  <td><%= habitation.categoria %></td>
                  <td><%= habitation.cidade %></td>
                  <td><%= habitation.bairro %></td>
                  <td class="right"><%= number_with_precision(habitation.area_total_m2.to_f, precision: 2, separator: ",", delimiter: ".") %></td>
                  <td class="right"><%= number_with_precision(habitation.area_privativa_m2.to_f, precision: 2, separator: ",", delimiter: ".") %></td>
                  <td class="right"><%= habitation.valor_venda_formatted %></td>
                  <td class="right"><%= number_to_currency(sale_m2, unit: "", separator: ",", delimiter: ".") %></td>
                  <td class="right"><%= habitation.valor_locacao_formatted %></td>
                  <td class="right"><%= number_to_currency(rent_m2, unit: "", separator: ",", delimiter: ".") %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
          <% if page_index < pages.size - 1 %><div class="page-break"></div><% end %>
        <% end %>

      <% elsif @report_type == "property_list_by_broker" %>
        <% pages = @report_pages_data.presence || [@habitations] %>
        <% pages.each_with_index do |records, page_index| %>
          <% grouped = records.group_by { |h| h.corretor_nome.to_s.strip.presence || "Sem corretor" } %>
          <% grouped.each do |broker_name, broker_habitations| %>
            <div class="broker-group">
              <div class="broker-name">Nome: <%= broker_name %></div>
              <table>
                <thead>
                  <tr>
                    <th>Ref.</th>
                    <th>Empreendimento</th>
                    <th>Nome Proprietário</th>
                    <th>Telefone</th>
                    <th>E-mail</th>
                    <th class="right">Área Priv.</th>
                    <th class="right">Venda</th>
                    <th class="right">Aluguel</th>
                  </tr>
                </thead>
                <tbody>
                  <% broker_habitations.each do |habitation| %>
                    <% proprietor_visible = can_view_proprietor_data?(habitation) %>
                    <tr>
                      <td><%= habitation.codigo %></td>
                      <td><%= habitation.nome_empreendimento.presence || habitation.display_title %></td>
                      <td><%= proprietor_visible ? (habitation.proprietor&.name.presence || habitation.proprietario) : "Captador: #{habitation.admin_user&.name || habitation.corretor_nome}" %></td>
                      <td><%= proprietor_visible ? (habitation.proprietor&.mobile_phone.presence || habitation.proprietor&.business_phone.presence || habitation.proprietor&.residential_phone.presence || habitation.proprietario_celular) : "Restrito" %></td>
                      <td><%= proprietor_visible ? (habitation.proprietor&.email.presence || habitation.proprietario_email) : "Restrito" %></td>
                      <td class="right"><%= number_with_precision(habitation.area_privativa_m2.to_f, precision: 2, separator: ",", delimiter: ".") %></td>
                      <td class="right"><%= habitation.valor_venda_formatted %></td>
                      <td class="right"><%= habitation.valor_locacao_formatted %></td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% end %>
          <% if page_index < pages.size - 1 %><div class="page-break"></div><% end %>
        <% end %>

      <% elsif @report_type == "property_count_by_broker" %>
        <table>
          <thead>
            <tr>
              <th>Nome</th>
              <th class="right">Total</th>
            </tr>
          </thead>
          <tbody>
            <% @broker_rows.each do |broker_name, total| %>
              <tr>
                <td><%= broker_name %></td>
                <td class="right"><%= total %></td>
              </tr>
            <% end %>
          </tbody>
          <tfoot>
            <tr>
              <td>Total geral de imóveis:</td>
              <td class="right"><%= @broker_rows.values.sum %></td>
            </tr>
          </tfoot>
        </table>

      <% else %>
        <% pages = @report_pages_data.presence || [@habitations] %>
        <% pages.each_with_index do |records, page_index| %>
          <table>
            <thead>
              <tr>
                <th>Referência</th>
                <th>Imóvel</th>
                <th>Status</th>
                <th>Categoria</th>
                <th>Cidade/Bairro</th>
                <th class="right">Venda</th>
                <th class="right">Locação</th>
              </tr>
            </thead>
            <tbody>
              <% records.each do |habitation| %>
                <tr>
                  <td><%= habitation.codigo %></td>
                  <td><%= habitation.display_title %></td>
                  <td><%= habitation.status %></td>
                  <td><%= habitation.categoria %></td>
                  <td><%= [habitation.cidade, habitation.bairro].compact.join(" - ") %></td>
                  <td class="right"><%= habitation.valor_venda_formatted %></td>
                  <td class="right"><%= habitation.valor_locacao_formatted %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
          <% if page_index < pages.size - 1 %><div class="page-break"></div><% end %>
        <% end %>
      <% end %>

      <div class="footer-url">https://saluteimoveis.com</div>
    </div>
  </div>
</body>
</html>
