<div class="tab-pane fade <%= "show active" if active %>" id="<%= tab_id %>" role="tabpanel">
  <% visible_logs = logs.filter_map { |log| summaries = log.change_summaries; [log, summaries] if summaries.any? } %>
  <% if visible_logs.any? %>
    <div class="habitation-audit-timeline">
      <% visible_logs.each do |log, summaries| %>
        <div class="habitation-audit-item">
          <div class="d-flex justify-content-between gap-3 flex-wrap">
            <div>
              <div class="habitation-audit-title"><%= log.title %></div>
              <div class="habitation-audit-meta">
                <%= l(log.created_at, format: "%d/%m/%Y às %H:%M") %>
                · <span class="badge bg-light text-dark border"><%= log.source_label %></span>
                <% if log.ip.present? %>
                  · IP <%= log.ip %>
                <% end %>
              </div>
            </div>
          </div>

          <div class="mt-3 d-grid gap-2">
            <% summaries.each do |change| %>
              <div class="habitation-audit-change">
                <div class="fw-semibold text-dark mb-1"><%= change[:label] %></div>
                <div class="row g-2 small">
                  <div class="col-md-6">
                    <div class="text-muted fw-semibold">Antes</div>
                    <span class="habitation-audit-value"><%= change[:before] %></span>
                  </div>
                  <div class="col-md-6">
                    <div class="text-muted fw-semibold">Depois</div>
                    <span class="habitation-audit-value"><%= change[:after] %></span>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="habitation-audit-empty">
      <i class="bi bi-clock-history d-block fs-3 mb-2"></i>
      Nenhum histórico registrado para esta aba ainda.
    </div>
  <% end %>
</div>
