<div class="tab-pane fade <%= "show active" if active %>" id="<%= tab_id %>" role="tabpanel">
  <% visible_logs = logs.filter_map { |log| summaries = log.change_summaries; [log, summaries] if summaries.any? } %>
  <% if visible_logs.any? %>
    <% visible_logs.group_by { |log, _| log.created_at.to_date }.each do |day, day_logs| %>
      <div class="ax-tl-day">
        <i class="bi bi-calendar3" aria-hidden="true"></i>
        <span><%= l(day, format: "%d/%m/%Y") %></span>
      </div>

      <div class="ax-tl">
        <% day_logs.each do |log, summaries| %>
          <% system_actor = log.actor_name == "Sistema" %>
          <article class="ax-tl-item">
            <span class="ax-tl-node">
              <i class="bi bi-<%= system_actor ? "arrow-repeat" : "pencil" %>" aria-hidden="true"></i>
            </span>
            <div class="ax-tl-card">
              <header class="ax-tl-head">
                <strong class="ax-tl-title"><%= log.title %></strong>
                <span class="ax-tl-time"><%= l(log.created_at, format: "%H:%M") %></span>
              </header>
              <div class="ax-tl-meta">
                <span class="ax-tl-actor"><%= log.actor_name %></span>
                <span class="ax-tl-source"><%= log.source_label %></span>
                <% if log.ip.present? %><span>IP <%= log.ip %></span><% end %>
              </div>
              <ul class="ax-tl-changes">
                <% summaries.each do |change| %>
                  <li>
                    <span class="ax-tl-field"><%= change[:label] %></span>
                    <span class="ax-tl-before" title="<%= change[:before] %>"><%= change[:before].presence || "vazio" %></span>
                    <i class="bi bi-arrow-right" aria-hidden="true"></i>
                    <span class="ax-tl-after" title="<%= change[:after] %>"><%= change[:after].presence || "vazio" %></span>
                  </li>
                <% end %>
              </ul>
            </div>
          </article>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <div class="habitation-audit-empty">
      <i class="bi bi-clock-history d-block fs-3 mb-2"></i>
      Nenhum histórico registrado para esta aba ainda.
    </div>
  <% end %>
</div>
