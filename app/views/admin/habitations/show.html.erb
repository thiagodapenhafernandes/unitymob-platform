<style>
  .habitation-show-page {
    display: grid;
    gap: 1rem;
  }

  .habitation-show-header,
  .habitation-show-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    box-shadow: 0 1px 3px rgba(15, 23, 42, 0.06);
  }

  .habitation-show-header {
    padding: 1rem 1.25rem;
  }

  .habitation-show-title {
    color: #0f172a;
    font-size: 1.3rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .habitation-show-meta {
    color: #64748b;
    font-size: .85rem;
    font-weight: 600;
  }

  .habitation-show-card {
    padding: 1.25rem;
  }

  .habitation-show-section-title {
    color: #64748b;
    font-size: .75rem;
    font-weight: 800;
    letter-spacing: .08em;
    margin-bottom: .75rem;
    text-transform: uppercase;
  }

  .habitation-show-field {
    border-bottom: 1px solid #eef2f7;
    padding: .55rem 0;
  }

  .habitation-show-label {
    color: #64748b;
    font-size: .74rem;
    font-weight: 800;
    margin-bottom: .1rem;
    text-transform: uppercase;
  }

  .habitation-show-value {
    color: #111827;
    font-size: .96rem;
    font-weight: 600;
    overflow-wrap: anywhere;
  }

  .habitation-show-muted {
    color: #64748b;
    font-size: .9rem;
    font-weight: 500;
  }

  .habitation-show-photo {
    aspect-ratio: 16 / 10;
    background: #f8fafc;
    border-radius: 12px;
    object-fit: cover;
    width: 100%;
  }

  .habitation-show-gallery-thumb {
    aspect-ratio: 1 / 1;
    background: #f8fafc;
    border-radius: 10px;
    object-fit: cover;
    width: 100%;
  }

  .habitation-show-badge-list {
    display: flex;
    flex-wrap: wrap;
    gap: .5rem;
  }

  .habitation-show-document {
    border: 1px solid #eef2f7;
    border-radius: 10px;
    padding: .75rem;
  }

  @media (max-width: 767.98px) {
    .habitation-show-header,
    .habitation-show-card {
      border-radius: 10px;
      padding: 1rem;
    }

    .habitation-show-title {
      font-size: 1.08rem;
    }

    .habitation-show-actions {
      width: 100%;
    }

    .habitation-show-actions .btn {
      flex: 1 1 auto;
    }
  }
</style>

<%
  linked_development = @habitation.empreendimento if @habitation.codigo_empreendimento.present?
  address_parts = [@habitation.endereco, @habitation.numero, @habitation.complemento.presence && "Apto. #{@habitation.complemento}", @habitation.bairro, @habitation.cidade, @habitation.uf].compact_blank
  description = @habitation.display_description

  money = lambda do |cents|
    cents.to_i.positive? ? number_to_currency(cents.to_i / 100.0) : nil
  end

  yes_no = lambda do |value|
    value.nil? ? nil : (value ? "Sim" : "Não")
  end

  show_value = lambda do |value|
    case value
    when Array
      value.compact_blank.join(", ")
    when Hash
      value.values.compact_blank.join(", ")
    when ActiveSupport::TimeWithZone, Time
      l(value, format: :short)
    when Date
      l(value)
    else
      value
    end.presence || "Não informado"
  end

  external_link = lambda do |url|
    normalized_url = url.to_s.strip
    next if normalized_url.blank?

    normalized_url.match?(/\Ahttps?:\/\//i) ? normalized_url : "https://#{normalized_url}"
  end

  feature_names = show_value.call(@habitation.caracteristicas) == "Não informado" ? [] : show_value.call(@habitation.caracteristicas).split(", ")
  infrastructure_names = show_value.call(@habitation.infra_estrutura) == "Não informado" ? [] : show_value.call(@habitation.infra_estrutura).split(", ")
  unique_feature_names = show_value.call(@habitation.caracteristica_unica) == "Não informado" ? [] : show_value.call(@habitation.caracteristica_unica).split(", ")

  attached_photo_sources = @habitation.photos.attached? ? @habitation.ordered_photos.select { |photo| photo.persisted? && photo.blob&.persisted? }.map.with_index { |photo, index|
    {
      url: url_for(photo),
      thumb: url_for(photo),
      caption: "Foto #{index + 1} - #{photo.filename}",
      badge: "Ativo"
    }
  } : []

  api_photo_sources = @habitation.pictures.is_a?(Array) ? @habitation.pictures.each_with_index.filter_map { |pic, index|
    pic_url = pic.is_a?(String) ? pic : (pic.try(:[], "url") || pic.try(:[], "src") || pic.try(:[], "link") || pic.try(:[], "url_pequena"))
    next if pic_url.blank?

    {
      url: pic_url,
      thumb: pic_url,
      caption: "Foto API/Vista #{index + 1}",
      badge: "API/Vista"
    }
  } : []

  development_photo_sources = if @habitation.use_development_photos? && linked_development.present? && attached_photo_sources.blank? && api_photo_sources.blank?
    linked_development.own_public_image_sources.first(24).filter_map.with_index do |source, index|
      photo_url = public_image_url(source)
      next if photo_url.blank?

      {
        url: photo_url,
        thumb: photo_url,
        caption: "Foto do empreendimento #{index + 1}",
        badge: "Empreendimento"
      }
    end
  else
    []
  end

  photo_sources = attached_photo_sources + api_photo_sources + development_photo_sources
  primary_photo = photo_sources.first

  summary_fields = [
    ["Referência", @habitation.codigo],
    ["Tipo", @habitation.tipo],
    ["Categoria", @habitation.categoria],
    ["Modalidade", @habitation.status],
    ["Empreendimento", @habitation.nome_empreendimento],
    ["Ocupação", @habitation.ocupacao_status]
  ]

  address_fields = [
    ["Logradouro", @habitation.endereco],
    ["Número", @habitation.numero],
    ["Complemento", @habitation.complemento],
    ["Bairro", @habitation.bairro],
    ["Cidade", @habitation.cidade],
    ["UF", @habitation.uf],
    ["CEP", @habitation.cep]
  ]

  feature_fields = [
    ["Dormitórios", @habitation.dormitorios_qtd],
    ["Suítes", @habitation.suites_qtd],
    ["Banheiros", @habitation.banheiros_qtd],
    ["Vagas", @habitation.vagas_qtd],
    ["Área privativa", @habitation.area_privativa_m2.present? ? "#{@habitation.area_privativa_m2} m²" : nil],
    ["Área total", @habitation.area_total_m2.present? ? "#{@habitation.area_total_m2} m²" : nil],
    ["Face", @habitation.face]
  ]

  value_fields = [
    ["Venda", money.call(@habitation.valor_venda_cents)],
    ["Locação", money.call(@habitation.valor_locacao_cents)],
    ["Total aluguel", money.call(@habitation.valor_total_aluguel_cents)],
    ["Condomínio", money.call(@habitation.valor_condominio_cents)],
    ["IPTU", money.call(@habitation.valor_iptu_cents)],
    ["Aceita financiamento", yes_no.call(@habitation.aceita_financiamento_flag)],
    ["Aceita permuta", yes_no.call(@habitation.aceita_permuta_flag)]
  ]

  public_flags = [
    ["Mobiliado", @habitation.mobiliado_flag],
    ["Decorado", @habitation.decorado_flag],
    ["Piscina", @habitation.piscina_flag],
    ["Lavabo", @habitation.lavabo_flag],
    ["Quadra mar", @habitation.quadra_mar_flag],
    ["Vista frente mar", @habitation.vista_frente_mar_flag],
    ["Frente mar Av. Atlântica", @habitation.frente_mar_avenida_atlantica_flag]
  ].select { |_label, value| value.present? && value != false }

  media_links = [
    ["Tour virtual", @habitation.tour_virtual],
    ["Podcast", @habitation.podcast_url],
    *@habitation.videos.to_a.compact_blank.map.with_index { |url, index| ["Vídeo #{index + 1}", url] },
    *@habitation.plantas.to_a.compact_blank.map.with_index { |url, index| ["Planta #{index + 1}", url] }
  ].filter_map do |label, url|
    link = external_link.call(url)
    [label, link] if link.present?
  end

  summary_fields = summary_fields.select { |_label, value| value.present? }
  address_fields = address_fields.select { |_label, value| value.present? }
  feature_fields = feature_fields.select { |_label, value| value.present? }
  value_fields = value_fields.select { |_label, value| value.present? }
%>

<div class="habitation-show-page">
  <div class="habitation-show-header d-flex justify-content-between align-items-start gap-3 flex-wrap">
    <div class="flex-grow-1" style="min-width: 0;">
      <div class="habitation-show-meta">
        <i class="bi bi-hash"></i><%= @habitation.codigo %>
        <% if @habitation.status.present? %>
          · <span class="badge bg-light text-dark border fw-normal"><%= @habitation.status %></span>
        <% end %>
        <% if @habitation.categoria.present? %>
          · <span><%= @habitation.categoria %></span>
        <% end %>
      </div>
      <div class="habitation-show-title mt-1">
        <%= @habitation.titulo_anuncio.presence || @habitation.display_title || "Detalhes do imóvel" %>
      </div>
      <% if address_parts.any? %>
        <div class="habitation-show-meta mt-2">
          <i class="bi bi-geo-alt"></i>
          <%= address_parts.join(" · ") %>
        </div>
      <% end %>
    </div>

    <div class="habitation-show-actions d-flex gap-2 flex-wrap">
      <%= link_to (@return_to_path || admin_habitations_path), class: "btn btn-outline-secondary btn-sm" do %>
        <i class="bi bi-arrow-left"></i><span class="ms-1">Voltar</span>
      <% end %>
      <% if can_edit_habitation?(@habitation) %>
        <%= link_to edit_admin_habitation_path(@habitation, return_to: @return_to_path), class: "btn btn-primary btn-sm" do %>
          <i class="bi bi-pencil-square"></i><span class="ms-1">Editar cadastro</span>
        <% end %>
      <% end %>
      <%= link_to habitation_path(@habitation), target: "_blank", rel: "noopener", class: "btn btn-outline-primary btn-sm" do %>
        <i class="bi bi-box-arrow-up-right"></i><span class="ms-1">Ver no site</span>
      <% end %>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-12 col-xl-5">
      <div class="habitation-show-card h-100" data-controller="fancybox-gallery">
        <% if primary_photo.present? %>
          <%= link_to primary_photo[:url], data: { fancybox: "admin-habitation-show-gallery", caption: primary_photo[:caption] } do %>
            <%= image_tag primary_photo[:thumb], class: "habitation-show-photo mb-3", alt: primary_photo[:caption] %>
          <% end %>
        <% else %>
          <div class="habitation-show-photo mb-3 d-flex align-items-center justify-content-center text-muted">
            <i class="bi bi-image display-4 opacity-25"></i>
          </div>
        <% end %>

        <div class="d-flex align-items-center justify-content-between gap-2 mb-3">
          <div class="habitation-show-section-title mb-0">Fotos</div>
          <% if photo_sources.any? %>
            <button type="button" class="btn btn-outline-primary btn-sm fw-semibold" data-gallery-open>
              <i class="bi bi-images me-1"></i>Abrir galeria
            </button>
          <% end %>
        </div>

        <% if photo_sources.any? %>
          <div class="row g-2">
            <% photo_sources.drop(1).each do |photo| %>
              <div class="col-4">
                <%= link_to photo[:url], class: "d-block position-relative", data: { fancybox: "admin-habitation-show-gallery", caption: photo[:caption] } do %>
                  <%= image_tag photo[:thumb], class: "habitation-show-gallery-thumb", alt: photo[:caption] %>
                  <span class="position-absolute top-0 start-0 badge bg-dark bg-opacity-75 m-1"><%= photo[:badge] %></span>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="habitation-show-muted mb-0">Nenhuma foto cadastrada.</p>
        <% end %>
      </div>
    </div>

    <div class="col-12 col-xl-7">
      <div class="habitation-show-card h-100">
        <div class="habitation-show-section-title">Informações principais</div>
        <div class="row">
          <% summary_fields.each do |label, value| %>
            <div class="col-sm-6 habitation-show-field">
              <div class="habitation-show-label"><%= label %></div>
              <div class="habitation-show-value"><%= show_value.call(value) %></div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-12">
      <div class="habitation-show-card">
        <div class="habitation-show-section-title">Valores</div>
        <div class="row">
          <% value_fields.each do |label, value| %>
            <div class="col-sm-6 col-lg-3 habitation-show-field">
              <div class="habitation-show-label"><%= label %></div>
              <div class="habitation-show-value"><%= show_value.call(value) %></div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-12">
      <div class="habitation-show-card">
        <div class="habitation-show-section-title">Endereço</div>
        <div class="row">
          <% address_fields.each do |label, value| %>
            <div class="col-sm-6 col-lg-3 habitation-show-field">
              <div class="habitation-show-label"><%= label %></div>
              <div class="habitation-show-value"><%= show_value.call(value) %></div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-12">
      <div class="habitation-show-card">
        <div class="habitation-show-section-title">Características</div>
        <div class="row">
          <% feature_fields.each do |label, value| %>
            <div class="col-sm-6 col-lg-3 habitation-show-field">
              <div class="habitation-show-label"><%= label %></div>
              <div class="habitation-show-value"><%= show_value.call(value) %></div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <% if media_links.any? %>
      <div class="col-12">
      <div class="habitation-show-card">
        <div class="habitation-show-section-title">Mídia complementar</div>
          <div class="row g-2">
            <% media_links.each do |label, url| %>
              <div class="col-md-6 col-xl-4">
                <%= link_to url, target: "_blank", rel: "noopener", class: "habitation-show-document text-decoration-none d-flex align-items-center justify-content-between gap-2" do %>
                  <span class="fw-semibold text-dark text-truncate"><i class="bi bi-play-circle me-1 text-primary"></i><%= label %></span>
                  <i class="bi bi-box-arrow-up-right text-muted"></i>
                <% end %>
              </div>
            <% end %>
          </div>
      </div>
      </div>
    <% end %>

    <% if description.present? %>
      <div class="col-12">
        <div class="habitation-show-card">
          <div class="habitation-show-section-title">Descrição</div>
          <div class="text-muted"><%= formatted_habitation_description(description) %></div>
        </div>
      </div>
    <% end %>

    <% if feature_names.any? || infrastructure_names.any? || unique_feature_names.any? || public_flags.any? %>
      <div class="col-12">
        <div class="habitation-show-card">
          <div class="habitation-show-section-title">Itens do imóvel</div>
          <div class="habitation-show-badge-list">
            <% (feature_names + infrastructure_names + unique_feature_names).compact_blank.uniq.each do |name| %>
              <span class="badge rounded-pill bg-light text-dark border px-3 py-2"><%= name %></span>
            <% end %>
            <% public_flags.each do |label, value| %>
              <span class="badge rounded-pill bg-light text-dark border px-3 py-2">
                <%= label %><%= value.is_a?(Integer) ? ": #{value}" : "" %>
              </span>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
