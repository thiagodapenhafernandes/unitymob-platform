<%
  linked_development = @habitation.empreendimento if @habitation.codigo_empreendimento.present?
  title = @habitation.titulo_anuncio.presence || @habitation.display_title || "Detalhes do imóvel"
  return_path = @return_to_path.presence || admin_habitations_path
  address_parts = [@habitation.endereco, @habitation.numero, admin_habitation_address_unit_label(@habitation), @habitation.bairro, @habitation.cidade, @habitation.uf].compact_blank
  description = @habitation.display_description

  money = lambda do |cents|
    cents.to_i.positive? ? number_to_currency(cents.to_i / 100.0) : nil
  end

  yes_no = lambda do |value|
    value.nil? ? nil : (value ? "Sim" : "Não")
  end

  show_value = lambda do |value|
    case value
    when Array
      value.compact_blank.join(", ")
    when Hash
      value.values.compact_blank.join(", ")
    when ActiveSupport::TimeWithZone, Time
      l(value, format: :short)
    when Date
      l(value)
    else
      value
    end.presence || "Não informado"
  end

  rich_text_value = lambda do |value|
    ActionView::Base.full_sanitizer.sanitize(value.to_s).squish.presence
  end

  array_value = lambda do |value|
    rendered = show_value.call(value)
    rendered == "Não informado" ? [] : rendered.split(", ").compact_blank
  end

  external_link = lambda do |url|
    normalized_url = url.to_s.strip
    next if normalized_url.blank?

    normalized_url.match?(/\Ahttps?:\/\//i) ? normalized_url : "https://#{normalized_url}"
  end

  status_badge_class = case @habitation.status.to_s.parameterize
                       when /venda/
                         "ax-badge--blue"
                       when /aluguel|alugado|locacao/
                         "ax-badge--green"
                       when /pendente|revisao|suspenso/
                         "ax-badge--amber"
                       else
                         "ax-badge--gray"
                       end

  feature_names = array_value.call(@habitation.caracteristicas)
  infrastructure_names = array_value.call(@habitation.infra_estrutura)
  unique_feature_names = array_value.call(@habitation.caracteristica_unica)

  attached_photo_sources = @habitation.photos.attached? ? @habitation.ordered_photos.select { |photo| photo.persisted? && photo.blob&.persisted? }.filter_map.with_index { |photo, index|
    photo_url = public_image_url({ attachment: photo })
    next if photo_url.blank?

    {
      url: photo_url,
      thumb: photo_url,
      caption: "Foto #{index + 1} - #{photo.filename}",
      badge: "Ativo"
    }
  } : []

  dwv_photo_sources = if @habitation.dwv_property?
    Habitations::MediaGallery.new(@habitation).api_media_pictures.filter_map.with_index do |(_picture, _original_index, photo_url), index|
      next if photo_url.blank?

      {
        url: photo_url,
        thumb: photo_url,
        caption: "Foto DWV #{index + 1}",
        badge: "DWV"
      }
    end
  else
    []
  end

  development_photo_sources = if @habitation.use_development_photos? && linked_development.present? && attached_photo_sources.blank? && dwv_photo_sources.blank?
    development_gallery = Habitations::MediaGallery.new(linked_development)
    local_development_sources = development_gallery.attached_media_photos.map { |photo| { attachment: photo } }
    dwv_development_sources = development_gallery.api_media_pictures.map { |_picture, _original_index, photo_url| photo_url }

    (local_development_sources + dwv_development_sources).first(24).filter_map.with_index do |source, index|
      photo_url = source.is_a?(Hash) ? public_image_url(source) : source
      next if photo_url.blank?

      {
        url: photo_url,
        thumb: photo_url,
        caption: "Foto do empreendimento #{index + 1}",
        badge: "Empreendimento"
      }
    end
  else
    []
  end

  photo_sources = attached_photo_sources + dwv_photo_sources + development_photo_sources
  primary_photo = photo_sources.first

  sale_price = money.call(@habitation.valor_venda_cents)
  rent_price = money.call(@habitation.valor_locacao_cents)
  total_rent_price = money.call(@habitation.valor_total_aluguel_cents)
  has_sale_discount = @habitation.sale_discount?
  has_rent_discount = @habitation.rent_discount?
  previous_sale_price = has_sale_discount ? money.call(@habitation.valor_venda_anterior_cents) : nil
  previous_rent_price = has_rent_discount ? money.call(@habitation.valor_locacao_anterior_cents) : nil
  previous_price = previous_sale_price || previous_rent_price
  current_price_cents = has_sale_discount ? @habitation.valor_venda_cents : @habitation.valor_locacao_cents
  previous_price_cents = has_sale_discount ? @habitation.valor_venda_anterior_cents : @habitation.valor_locacao_anterior_cents
  discount_percent = if previous_price_cents.to_i.positive? && current_price_cents.to_i.positive?
                       (((previous_price_cents.to_i - current_price_cents.to_i).to_f / previous_price_cents.to_i) * 100).round(1)
                     end
  discount_label = discount_percent.present? ? number_with_precision(discount_percent, precision: 1, strip_insignificant_zeros: true) : nil
  reduction_label = if has_sale_discount && discount_label.present?
                      "#{discount_label}% abaixo do valor anterior"
                    elsif has_rent_discount && discount_label.present?
                      "Locação com preço reduzido · #{discount_label}% de desconto"
                    end
  main_price = sale_price || (has_rent_discount && rent_price.present? ? "#{rent_price}/mês" : nil) || total_rent_price || (rent_price.present? ? "#{rent_price}/mês" : nil) || "Sob consulta"
  price_context = if sale_price.present?
                    "Venda"
                  elsif total_rent_price.present?
                    "Pacote locação"
                  elsif rent_price.present?
                    "Locação"
                  else
                    "Valor sob consulta"
                  end

  last_update_at = [@habitation.data_atualizacao_crm, @habitation.updated_at].compact.max
  updated_label = last_update_at.present? ? "Atualizado #{time_ago_in_words(last_update_at)} atrás" : "Atualização não informada"

  quick_stats = [
    ["Dorm.", @habitation.dormitorios_qtd, "bi-door-open"],
    ["Suítes", @habitation.suites_qtd, "bi-key"],
    ["Banheiros", @habitation.banheiros_qtd, "bi-droplet"],
    ["Vagas", @habitation.vagas_qtd, "bi-car-front"],
    ["Área priv.", @habitation.area_privativa_m2.present? ? "#{@habitation.area_privativa_m2} m²" : nil, "bi-arrows-angle-expand"],
    ["Área total", @habitation.area_total_m2.present? ? "#{@habitation.area_total_m2} m²" : nil, "bi-aspect-ratio"]
  ].select { |_label, value, _icon| value.present? }

  summary_fields = [
    ["Referência", @habitation.codigo],
    ["Cód. DWV", @habitation.codigo_dwv],
    ["Tipo", @habitation.tipo],
    ["Categoria", @habitation.categoria],
    ["Modalidade", @habitation.status],
    ["Situação", @habitation.situacao],
    ["Status da captação", @habitation.intake_status],
    ["Motivo de suspensão", @habitation.motivo_suspensao],
    ["Captador", @habitation.primary_captador_name],
    ["Empreendimento", @habitation.nome_empreendimento],
    ["Ocupação", @habitation.ocupacao_status],
    ["Estado", @habitation.estado_conservacao],
    ["Cadastro", @habitation.data_cadastro_crm],
    ["Atualização", @habitation.data_atualizacao_crm]
  ].select { |_label, value| value.present? }

  address_fields = [
    ["Tipo endereço", @habitation.tipo_endereco],
    ["Logradouro", @habitation.endereco],
    ["Número", @habitation.numero],
    ["Complemento", @habitation.complemento],
    ["Bairro", @habitation.bairro],
    ["Bairro comercial", @habitation.bairro_comercial],
    ["Cidade", @habitation.cidade],
    ["UF", @habitation.uf],
    ["CEP", @habitation.cep],
    ["Bloco", @habitation.bloco],
    ["Imediações", @habitation.imediacoes]
  ].select { |_label, value| value.present? }

  feature_fields = [
    ["Dormitórios", @habitation.dormitorios_qtd],
    ["Suítes", @habitation.suites_qtd],
    ["Demi-suítes", @habitation.demi_suites_qtd],
    ["Salas", @habitation.salas_qtd],
    ["Banheiros", @habitation.banheiros_qtd],
    ["Vagas", @habitation.vagas_qtd],
    ["Andar", @habitation.andar],
    ["Varandas", @habitation.varandas_qtd],
    ["Hidromassagem", @habitation.hidromassagem_qtd],
    ["Tipo de vaga", @habitation.tipo_vaga],
    ["Box", @habitation.numero_box],
    ["Área privativa", @habitation.area_privativa_m2.present? ? "#{@habitation.area_privativa_m2} m²" : nil],
    ["Área total", @habitation.area_total_m2.present? ? "#{@habitation.area_total_m2} m²" : nil],
    ["Área terreno", @habitation.area_terreno_m2.present? ? "#{@habitation.area_terreno_m2} m²" : nil],
    ["Dimensões terreno", @habitation.dimensoes_terreno],
    ["Topografia", @habitation.topografia],
    ["Face", @habitation.face]
  ].select { |_label, value| value.present? }

  value_fields = [
    ["Venda", sale_price],
    ["Venda anterior", previous_sale_price],
    ["Locação", rent_price],
    ["Locação anterior", previous_rent_price],
    ["Total aluguel", total_rent_price],
    ["Condomínio", money.call(@habitation.valor_condominio_cents)],
    ["IPTU", money.call(@habitation.valor_iptu_cents)],
    ["Aceita parcelamento", yes_no.call(@habitation.aceita_parcelamento_flag)],
    ["Parcelas", @habitation.aceita_parcelamento_flag? && @habitation.numero_prestacoes.present? ? "#{@habitation.numero_prestacoes}x" : nil],
    ["Aceita permuta", yes_no.call(@habitation.aceita_permuta_flag)],
    ["Com Adm", yes_no.call(@habitation.salute_rental_management_flag)]
  ].select { |_label, value| value.present? }

  commercial_fields = [
    ["Nº de matrícula", @habitation.matricula_imovel],
    ["Zona", @habitation.zona],
    ["Inscrição imobiliária", @habitation.inscricao_imobiliaria],
    ["Valor promocional", money.call(@habitation.valor_promocional_cents)],
    ["Condições de negociação", @habitation.condicoes_negociacao]
  ].select { |_label, value| value.present? }

  attendance_fields = [
    ["Responsável por reserva", @habitation.responsavel_reserva],
    ["Onde estão as chaves", @habitation.key_location],
    ["Detalhe das chaves", @habitation.key_location_notes],
    ["Senha da portaria", @habitation.senha_portaria],
    ["Senha do imóvel/apartamento", @habitation.senha_imovel],
    ["Observações para visitas", @habitation.observacoes_visitas],
    ["Zelador", @habitation.zelador_nome],
    ["Telefone do zelador", format_phone(@habitation.zelador_telefone)],
    ["Região foco", @habitation.regiao_foco],
    ["Saldo devedor", money.call(@habitation.saldo_devedor_cents)]
  ].select { |_label, value| value.present? }

  exchange_fields = [["Aceita permuta", yes_no.call(@habitation.aceita_permuta_flag)]]
  if @habitation.aceita_permuta_flag?
    exchange_fields << ["Valor total da permuta", money.call(@habitation.valor_aceito_permuta_cents)]
    if @habitation.aceita_permuta_veiculo_flag?
      exchange_fields.concat([
        ["Aceita veículo", "Sim"],
        ["Valor do veículo", money.call(@habitation.permuta_veiculo_valor_cents)],
        ["Tipo de veículo aceito", @habitation.tipo_veiculo_aceito_permuta],
        ["Ano mínimo veículo", @habitation.ano_minimo_veiculo_aceito_permuta]
      ])
    end
    if @habitation.aceita_permuta_imovel_flag?
      exchange_fields.concat([
        ["Aceita imóvel", "Sim"],
        ["Valor do imóvel aceito", money.call(@habitation.permuta_valor_cents)],
        ["Localização do imóvel aceito", @habitation.permuta_localizacao],
        ["Dormitórios do imóvel aceito", @habitation.permuta_dormitorios_qtd],
        ["Suítes do imóvel aceito", @habitation.permuta_suites_qtd],
        ["Garagens do imóvel aceito", @habitation.permuta_garagens_qtd]
      ])
    end
    if @habitation.aceita_permuta_outros_flag?
      exchange_fields.concat([
        ["Aceita outros", "Sim"],
        ["Valor dos outros itens", money.call(@habitation.permuta_outros_valor_cents)],
        ["Descrição dos outros itens", @habitation.permuta_outros_descricao]
      ])
    end
  end
  exchange_fields.select! { |_label, value| value.present? }

  building_fields = [
    ["Administradora do condomínio", @habitation.agenciador],
    ["Construtora", @habitation.construtora],
    ["Perfil de construção", @habitation.perfil_construcao],
    ["Tipo de fachada", @habitation.tipo_fachada],
    ["Data entrega", @habitation.data_entrega],
    ["Nº de andares", @habitation.andares_qtd.to_i.positive? ? @habitation.andares_qtd : nil],
    ["Ano construção", @habitation.ano_construcao.to_i.positive? ? @habitation.ano_construcao : nil],
    ["Elevadores", @habitation.elevadores_qtd.to_i.positive? ? @habitation.elevadores_qtd : nil],
    ["Imóveis / andar", @habitation.aptos_andar.to_i.positive? ? @habitation.aptos_andar : nil],
    ["Total imóveis", @habitation.aptos_edificio.to_i.positive? ? @habitation.aptos_edificio : nil],
    ["Descrição do empreendimento", rich_text_value.call(@habitation.descricao_empreendimento)]
  ].select { |_label, value| value.present? }

  seo_fields = [
    ["URL amigável", @habitation.slug],
    ["Meta title", @habitation.meta_title],
    ["Meta description", rich_text_value.call(@habitation.meta_description)],
    ["Palavras-chave", @habitation.meta_keywords]
  ].select { |_label, value| value.present? }

  publication_fields = [
    ["Site público", yes_no.call(@habitation.exibir_no_site_flag)],
    ["Destaque web", yes_no.call(@habitation.destaque_web_flag)],
    ["Super destaque", yes_no.call(@habitation.festival_salute_flag)],
    ["Lançamento", yes_no.call(@habitation.lancamento_flag)],
    ["Tem placa", yes_no.call(@habitation.tem_placa_flag)],
    ["Exclusivo", yes_no.call(@habitation.exclusivo_flag)],
    ["Imóvel DWV", @habitation.imovel_dwv],
    ["Zapimóveis", yes_no.call(@habitation.publicar_zapimoveis)],
    ["Imovelweb", yes_no.call(@habitation.publicar_imovelweb)],
    ["Tipo publicação Imovelweb", @habitation.tipo_publicacao_imovelweb],
    ["Mostrar mapa Imovelweb", @habitation.mostrar_mapa_imovelweb],
    ["Imovelweb 2", yes_no.call(@habitation.publicar_imovelweb_2)],
    ["Tipo publicação Imovelweb 2", @habitation.tipo_publicacao_imovelweb_2],
    ["Mostrar mapa Imovelweb 2", @habitation.mostrar_mapa_imovelweb_2],
    ["Viva Real VRSync", yes_no.call(@habitation.publicar_viva_real_vrsync)],
    ["Tipo publicação Viva Real", @habitation.tipo_publicacao_viva_real],
    ["Divulgar endereço Viva Real", @habitation.divulgar_endereco_viva_real],
    ["Loft", yes_no.call(@habitation.publicar_loft)],
    ["Netimóveis 2", yes_no.call(@habitation.publicar_netimoveis_2)],
    ["Lais AI", yes_no.call(@habitation.publicar_lais_ai)],
    ["Chaves na Mão", yes_no.call(@habitation.publicar_chaves_na_mao)],
    ["Destaque Chaves na Mão", @habitation.destaque_chaves_na_mao],
    ["Período locação Chaves na Mão", @habitation.periodo_locacao_chaves_na_mao],
    ["Casa Mineira", yes_no.call(@habitation.publicar_casa_mineira)],
    ["Modelo Casa Mineira", @habitation.modelo_casa_mineira]
  ].select { |_label, value| value.present? }

  owner_fields = if can_view_habitation_show_sensitive_data?(@habitation)
    [
      ["Proprietário", @habitation.proprietario],
      ["E-mail", @habitation.proprietario_email],
      ["Celular", format_phone(@habitation.proprietario_celular)],
      ["F. Comercial", format_phone(@habitation.proprietario_telefone_comercial)],
      ["F. Residencial", format_phone(@habitation.proprietario_telefone_residencial)]
    ].select { |_label, value| value.present? }
  else
    []
  end

  commission_fields = if can_view_habitation_show_sensitive_data?(@habitation)
    [
      ["Comissão captador (%)", @habitation.captador_commission_percentage],
      ["Comissão corretor (%)", @habitation.broker_commission_percentage],
      ["Administração de locação", yes_no.call(@habitation.salute_rental_management_flag)],
      ["Vitrine Corporate", yes_no.call(@habitation.home_corporate_flag)],
      ["Posição na Home", @habitation.home_corporate_position]
    ].select { |_label, value| value.present? }
  else
    []
  end

  broker_assignment_fields = @habitation.broker_assignments.includes(:admin_user).filter_map do |assignment|
    next if assignment.marked_for_destruction?

    role_label = assignment.role.to_s.presence
    broker_name = assignment.admin_user&.name
    commission_label = [assignment.commission_type, assignment.commission_value].compact_blank.join(": ")
    value = [broker_name, commission_label].compact_blank.join(" · ")
    [role_label || "Responsável", value] if value.present?
  end

  internal_document_groups = if can_view_habitation_show_sensitive_data?(@habitation)
    [
      ["Fichas de cadastro", @habitation.fichas_cadastro.attachments],
      ["Autorizações de venda", @habitation.autorizacoes_venda.attachments]
    ].filter_map do |label, attachments|
      persisted_attachments = attachments.select { |attachment| attachment.persisted? && attachment.blob&.persisted? }
      [label, persisted_attachments] if persisted_attachments.any?
    end
  else
    []
  end

  public_flags = [
    ["Mobiliado", @habitation.mobiliado_flag],
    ["Decorado", @habitation.decorado_flag],
    ["Piscina", @habitation.piscina_flag],
    ["Lavabo", @habitation.lavabo_flag],
    ["Quadra mar", @habitation.quadra_mar_flag],
    ["Vista frente mar", @habitation.vista_frente_mar_flag],
    ["Frente mar Av. Atlântica", @habitation.frente_mar_avenida_atlantica_flag]
  ].select { |_label, value| value.present? && value != false }

  internal_note_fields = if can_view_habitation_show_sensitive_data?(@habitation)
    [
      ["Observações internas", @habitation.observacoes],
      ["Descrição interna", @habitation.descricao_interna]
    ].select { |_label, value| value.present? }
  else
    []
  end

  media_links = [
    ["Tour virtual", @habitation.tour_virtual, "bi-badge-vr"],
    ["Podcast", @habitation.podcast_url, "bi-soundwave"],
    *@habitation.videos.to_a.compact_blank.map.with_index { |url, index| ["Vídeo #{index + 1}", url, "bi-play-circle"] },
    *@habitation.plantas.to_a.compact_blank.map.with_index { |url, index| ["Planta #{index + 1}", url, "bi-file-earmark-image"] }
  ].filter_map do |label, url, icon|
    link = external_link.call(url)
    [label, link, icon] if link.present?
  end

  description_section_class = media_links.any? && description.present? ? "ax-property-show-bottom__body--wide" : "ax-property-show-bottom__body--description-only"
  item_names = (feature_names + infrastructure_names + unique_feature_names).compact_blank.uniq
  operational_panels = [
    { eyebrow: "Comercial", title: "Condições e negociação", fields: commercial_fields },
    { eyebrow: "Atendimento", title: "Chaves e visitas", fields: attendance_fields },
    { eyebrow: "Permuta", title: "Condição especial", fields: exchange_fields },
    { eyebrow: "Empreendimento", title: "Edifício e capacidade", fields: building_fields },
    { eyebrow: "Proprietário", title: "Contatos", fields: owner_fields },
    { eyebrow: "Comissão", title: "Operação", fields: commission_fields },
    { eyebrow: "Responsáveis", title: "Agenciamento", fields: broker_assignment_fields },
    { eyebrow: "Comercial", title: "Observações internas", fields: internal_note_fields }
  ].select { |panel| panel[:fields].present? }
  has_document_panel = internal_document_groups.any?
%>

<% content_for :admin_contextbar_breadcrumb do %>
  <%= link_to "Admin", admin_root_path %>
  <i class="bi bi-chevron-right"></i>
  <%= link_to "Imóveis", return_path %>
  <i class="bi bi-chevron-right"></i>
  <strong>REF <%= @habitation.codigo %></strong>
<% end %>

<div class="ax-property-show">
  <section class="ax-property-hero-panel ax-property-show-hero">
    <div class="ax-property-hero-panel__content">
      <div class="ax-property-show-hero__meta">
        <span><i class="bi bi-hash"></i><%= @habitation.codigo %></span>
        <% if @habitation.status.present? %>
          <span class="ax-badge <%= status_badge_class %>"><%= @habitation.status %></span>
        <% end %>
        <% if @habitation.categoria.present? %>
          <span><%= @habitation.categoria %></span>
        <% end %>
      </div>

      <div class="ax-property-show-hero__row">
        <div class="ax-property-show-hero__title">
          <h1><%= title %></h1>
          <% if address_parts.any? %>
            <p><i class="bi bi-geo-alt"></i><%= address_parts.join(" · ") %></p>
          <% end %>
        </div>

        <%= render "admin/habitations/captador_card", habitation: @habitation, compact: true, class_name: "ax-captador-card--hero" %>

        <div class="ax-property-show-actions">
          <%= link_to safe_join([tag.i(class: "bi bi-arrow-left ax-ico"), tag.span("Voltar")]), return_path, class: "ax-btn ax-btn--sm" %>
          <% if can_edit_habitation?(@habitation) %>
            <%= link_to safe_join([tag.i(class: "bi bi-pencil-square ax-ico"), tag.span("Editar")]), admin_habitation_path_with_query(edit_admin_habitation_path(@habitation.id), admin_habitation_flat_return_params(@return_to_path)), class: "ax-btn ax-btn--primary ax-btn--sm" %>
          <% end %>
          <%= link_to safe_join([tag.i(class: "bi bi-box-arrow-up-right ax-ico"), tag.span("Ver no site")]), habitation_path(@habitation), target: "_blank", rel: "noopener", class: "ax-btn ax-btn--sm" %>
        </div>
      </div>
    </div>
  </section>

  <section class="ax-property-show-grid">
    <div class="ax-card ax-property-gallery" data-controller="fancybox-gallery">
      <% if primary_photo.present? %>
        <%= link_to safe_join([
              image_tag(primary_photo[:thumb], class: "ax-property-gallery__hero", alt: primary_photo[:caption]),
              tag.span(safe_join([tag.i(class: "bi bi-clock"), updated_label]), class: "ax-property-gallery__status")
            ]), primary_photo[:url], class: "ax-property-gallery__hero-link", data: { fancybox: "admin-habitation-show-gallery", caption: primary_photo[:caption], thumb_src: primary_photo[:thumb] } %>
      <% else %>
        <div class="ax-property-gallery__hero ax-property-gallery__empty">
          <i class="bi bi-image"></i>
          <span>Sem foto principal</span>
        </div>
      <% end %>

      <div class="ax-property-gallery__head">
        <div>
          <strong>Galeria</strong>
          <span><%= pluralize(photo_sources.size, "foto", "fotos") %></span>
        </div>
        <% if photo_sources.any? %>
          <button type="button" class="ax-btn ax-btn--sm" data-gallery-open>
            <i class="bi bi-images ax-ico"></i><span>Abrir galeria</span>
          </button>
        <% end %>
      </div>

      <% if photo_sources.any? %>
        <% if photo_sources.many? %>
          <div class="ax-property-gallery__hidden-links" aria-hidden="true">
            <% photo_sources.drop(1).each do |photo| %>
              <%= link_to photo[:caption], photo[:url], data: { fancybox: "admin-habitation-show-gallery", caption: photo[:caption], thumb_src: photo[:thumb] }, tabindex: "-1" %>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <div class="ax-property-gallery__notice">Nenhuma foto cadastrada para este imóvel.</div>
      <% end %>
    </div>

    <div class="ax-property-show-stack">
      <% summary_panel_body = capture do %>
        <div class="ax-property-record-panel__body">
          <div class="ax-property-show-price <%= 'ax-property-show-price--discounted' if previous_price.present? %>">
            <span>Valor do imóvel</span>
            <% if previous_price.present? %>
              <em class="ax-property-show-price__previous">De <s><%= previous_price %></s></em>
            <% end %>
            <strong><%= main_price %></strong>
            <% if reduction_label.present? %>
              <small class="ax-property-show-price__discount"><i class="bi bi-arrow-down-right"></i><%= reduction_label %></small>
            <% end %>
            <% if sale_price.present? && total_rent_price.present? %>
              <small>Locação: <%= total_rent_price %></small>
            <% elsif sale_price.present? && rent_price.present? %>
              <small>Locação: <%= rent_price %>/mês</small>
            <% end %>
          </div>

          <% if quick_stats.any? %>
            <div class="ax-property-stat-row">
              <% quick_stats.each do |label, value, icon| %>
                <div class="ax-property-stat">
                  <i class="bi <%= icon %>"></i>
                  <strong><%= show_value.call(value) %></strong>
                  <span><%= label %></span>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>

        <div class="ax-property-record-sections">
          <section class="ax-property-record-section">
            <div class="ax-property-record-section__head">
              <span>Dados principais</span>
              <strong>Ficha operacional</strong>
            </div>
            <div class="ax-property-data-grid ax-property-data-grid--compact">
              <% summary_fields.each do |label, value| %>
                <div class="ax-property-data-cell">
                  <span><%= label %></span>
                  <strong><%= show_value.call(value) %></strong>
                </div>
              <% end %>
            </div>
          </section>

          <% if value_fields.any? %>
            <section class="ax-property-record-section">
              <div class="ax-property-record-section__head">
                <span>Valores</span>
                <strong>Negociação</strong>
              </div>
              <div class="ax-property-data-grid ax-property-data-grid--compact">
                <% value_fields.each do |label, value| %>
                  <div class="ax-property-data-cell">
                    <span><%= label %></span>
                    <strong><%= show_value.call(value) %></strong>
                  </div>
                <% end %>
              </div>
            </section>
          <% end %>
        </div>
      <% end %>
      <%= ax_operational_panel(
            eyebrow: "Registro operacional",
            title: "Resumo do imóvel",
            class_name: "ax-property-summary ax-property-record-panel",
            actions: safe_join([
              tag.span(@habitation.tipo.presence || "Unitário", class: "ax-badge ax-badge--gray"),
              tag.span(price_context, class: "ax-badge #{status_badge_class}")
            ]),
            body: summary_panel_body
          ) %>
    </div>
  </section>

  <section class="ax-property-show-bottom__body">
    <% if address_fields.any? %>
      <% address_panel_body = capture do %>
        <div class="ax-property-data-grid">
          <% address_fields.each do |label, value| %>
            <div class="ax-property-data-cell">
              <span><%= label %></span>
              <strong><%= show_value.call(value) %></strong>
            </div>
          <% end %>
        </div>
      <% end %>
      <%= ax_operational_panel(eyebrow: "Endereço", title: "Localização", class_name: "ax-property-detail-panel", body: address_panel_body) %>
    <% end %>

    <% if feature_fields.any? %>
      <% features_panel_body = capture do %>
        <div class="ax-property-data-grid">
          <% feature_fields.each do |label, value| %>
            <div class="ax-property-data-cell">
              <span><%= label %></span>
              <strong><%= show_value.call(value) %></strong>
            </div>
          <% end %>
        </div>
      <% end %>
      <%= ax_operational_panel(eyebrow: "Características", title: "Estrutura", class_name: "ax-property-detail-panel", body: features_panel_body) %>
    <% end %>
  </section>

  <% operational_panels.each_slice(2) do |panel_pair| %>
    <section class="ax-property-show-bottom__body">
      <% panel_pair.each do |panel| %>
        <% panel_body = capture do %>
          <div class="ax-property-data-grid">
            <% panel[:fields].each do |label, value| %>
              <div class="ax-property-data-cell">
                <span><%= label %></span>
                <strong><%= show_value.call(value) %></strong>
              </div>
            <% end %>
          </div>
        <% end %>
        <%= ax_operational_panel(
              eyebrow: panel[:eyebrow],
              title: panel[:title],
              class_name: "ax-property-detail-panel",
              body: panel_body
            ) %>
      <% end %>
    </section>
  <% end %>

  <% if has_document_panel %>
    <section class="ax-property-show-bottom__body ax-property-show-bottom__body--wide">
      <% document_panel_body = capture do %>
        <% if internal_document_groups.any? %>
          <% internal_document_groups.each do |group_label, attachments| %>
            <div class="ax-field-group ax-field-group--panel">
              <div class="ax-property-record-section__head">
                <span><%= group_label %></span>
                <strong><%= pluralize(attachments.size, "arquivo", "arquivos") %></strong>
              </div>
              <ul class="ax-file-list">
                <% attachments.each do |attachment| %>
                  <%= ax_attachment_item(
                        attachment:,
                        url: rails_blob_path(attachment, disposition: "attachment"),
                        meta: number_to_human_size(attachment.byte_size)
                      ) %>
                <% end %>
              </ul>
            </div>
          <% end %>
        <% end %>

      <% end %>
      <%= ax_operational_panel(
            eyebrow: "Documentos",
            title: "Anexos internos e integração",
            class_name: "ax-property-detail-panel",
            body: document_panel_body
          ) %>
    </section>
  <% end %>

  <section class="ax-property-show-bottom__body <%= description_section_class %>">
    <% if description.present? %>
      <% description_panel_body = capture do %>
        <div class="ax-property-description"><%= formatted_habitation_description(description) %></div>
      <% end %>
      <%= ax_operational_panel(eyebrow: "Descrição", title: "Texto público", class_name: "ax-property-show-description-card", body: description_panel_body) %>
    <% end %>

    <% if media_links.any? %>
      <% media_panel_body = capture do %>
        <div class="ax-property-link-list">
          <% media_links.each do |label, url, icon| %>
            <%= link_to safe_join([
                  tag.span(safe_join([tag.i(class: "bi #{icon}"), label])),
                  tag.i(class: "bi bi-box-arrow-up-right")
                ]), url, target: "_blank", rel: "noopener", class: "ax-property-link-row" %>
          <% end %>
        </div>
      <% end %>
      <%= ax_operational_panel(eyebrow: "Mídia complementar", title: "Links", class_name: "ax-property-detail-panel", body: media_panel_body) %>
    <% end %>
  </section>

  <% if item_names.any? || public_flags.any? %>
    <% items_panel_body = capture do %>
      <div class="ax-property-chip-list">
        <% item_names.each do |name| %>
          <span class="ax-badge ax-badge--gray"><%= name %></span>
        <% end %>
        <% public_flags.each do |label, value| %>
          <span class="ax-badge ax-badge--blue">
            <%= label %><%= value.is_a?(Integer) ? ": #{value}" : "" %>
          </span>
        <% end %>
      </div>
    <% end %>
    <%= ax_operational_panel(
          eyebrow: "Itens do imóvel",
          title: "Diferenciais e infraestrutura",
          class_name: "ax-property-detail-panel",
          actions: tag.span("#{item_names.size + public_flags.size} itens", class: "ax-badge ax-badge--gray"),
          body: items_panel_body
        ) %>
  <% end %>
</div>
