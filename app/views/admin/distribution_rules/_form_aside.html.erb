<%
  distribution_rule_action_label = lambda do |text, tooltip|
    safe_join([
      text,
      tag.span(
        tag.i(class: "bi bi-info-circle", aria: { hidden: true }),
        class: "ax-field-label__info distribution-rule-action-tooltip",
        role: "img",
        aria: { label: "Ajuda: #{text}" },
        data: {
          controller: "ax-tooltip",
          ax_tooltip_text_value: tooltip,
          action: "click->distribution-rule#stopTooltipClick"
        }
      )
    ], " ")
  end
%>

<%= ax_aside_panel(
      title: "Configuração da regra",
      token: "Distribuição",
      rail_label: "Abrir configurações da regra",
      rail_icon: "sliders",
      collapse_label: "Recolher configurações da regra",
      panel_class: "distribution-rule-aside-panel",
      header_class: "distribution-rule-aside-panel__header"
    ) do %>
  <div class="distribution-rule-aside__body">
    <%= ax_operational_panel(eyebrow: "Lógica", title: "Modo de distribuição") do %>
      <div class="ax-panel-body">
        <div class="ax-option-stack distribution-rule-modes">
          <% [
              [:rotary, "arrow-repeat", "Rotativo", "Fila sequencial", "Entrega para um corretor por vez, seguindo a ordem da fila. Depois que recebe um lead, o corretor vai para o fim da fila."],
              [:performance, "graph-up", "Performance", "Baseado em peso", "Escolhe um corretor por sorteio ponderado. Corretores com peso maior têm mais chance de receber o lead, sem seguir uma fila fixa."],
              [:shark_tank, "lightning-charge", "Shark Tank", "Primeiro a aceitar", "Notifica todos os corretores elegíveis da regra. O primeiro que aceitar assume o lead; os demais veem que perderam a vez."]
            ].each do |mode, icon, label, sub, tooltip| %>
            <%= f.radio_button :distribution_mode, mode, class: "ax-option-card__input", id: "mode_#{mode}", data: { action: "change->distribution-rule#toggleMode" } %>
            <%= f.label "mode_#{mode}", class: "ax-option-card distribution-rule-mode", for: "mode_#{mode}" do %>
              <i class="bi bi-<%= icon %>" aria-hidden="true"></i>
              <span>
                <strong>
                  <%= label %>
                  <button type="button"
                          class="ax-field-label__info distribution-rule-mode__info"
                          aria-label="Ajuda: <%= label %>"
                          data-controller="ax-tooltip"
                          data-ax-tooltip-text-value="<%= tooltip %>">
                    <i class="bi bi-info-circle" aria-hidden="true"></i>
                  </button>
                </strong>
                <small><%= sub %></small>
              </span>
            <% end %>
          <% end %>
        </div>

        <div class="ax-field">
          <%= ax_field_label(nil, nil,
                text: "Preço",
                tooltip: "Filtro opcional pela faixa de valor do lead. Mínimo define o menor valor aceito; máximo define o teto. Deixe vazio para não filtrar por preço."
              ) %>
          <%= ax_field_grid do %>
            <div class="ax-span-6">
              <%= ax_input_group(prefix: "R$") do %>
                <%= f.text_field :min_price,
                      value: (number_to_currency(f.object.min_price, unit: "", separator: ",", delimiter: ".").strip if f.object.min_price.present?),
                      class: "ax-control ax-control--sm",
                      placeholder: "Mínimo",
                      inputmode: "decimal",
                      data: { controller: "mask", mask_type_value: "currency" } %>
              <% end %>
            </div>
            <div class="ax-span-6">
              <%= ax_input_group(prefix: "R$") do %>
                <%= f.text_field :max_price,
                      value: (number_to_currency(f.object.max_price, unit: "", separator: ",", delimiter: ".").strip if f.object.max_price.present?),
                      class: "ax-control ax-control--sm",
                      placeholder: "Máximo",
                      inputmode: "decimal",
                      data: { controller: "mask", mask_type_value: "currency" } %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%= ax_operational_panel(eyebrow: "Campo", title: "Check-in geolocalizado", actions: ax_badge("Opcional", tone: :gray)) do %>
      <div class="ax-panel-body">
        <div class="tw-flex tw-items-center tw-justify-between tw-gap-2">
          <%= ax_field_label(f, :checkin_store_ids, text: "Vinculação com lojas") %>
          <button type="button" class="ax-btn ax-btn--ghost ax-btn--sm tw-gap-2" data-ax-modal-open="#distributionRuleStoreRotationModal">
            <i class="bi bi-info-circle"></i>Como funciona?
          </button>
        </div>
        <div class="ax-field">
          <%= f.collection_select :checkin_store_ids, current_tenant.stores.active.order(:name), :id, :name, { selected: f.object.checkin_store_id_list },
                multiple: true, class: "ax-control",
                data: {
                  controller: "tom-select",
                  placeholder: "Selecione lojas (vazio = todas)",
                  distribution_rule_target: "checkinStoreSelect",
                  action: "change->distribution-rule#toggleStoreContext"
                } %>
          <p class="ax-field__hint">Selecione uma ou mais lojas para a regra acompanhar check-ins. Vazio = qualquer loja ativa.</p>
        </div>

        <div class="section-toggle-container<%= ' tw-hidden' if f.object.checkin_store_id_list.blank? %>" data-distribution-rule-target="storeContextSection">
          <%= ax_inline_notice(tone: :success, icon: "arrow-repeat") do %>
            Com múltiplas lojas, a fila pode ser atualizada intercalando corretores por loja, preservando o rodízio entre unidades.
          <% end %>

          <div class="ax-option-stack">
            <%= ax_toggle_chip(f, :require_active_checkin,
                  label: distribution_rule_action_label.call(
                    "Exigir check-in ativo",
                    "Só considera corretores com check-in ativo no campo. Sem check-in válido, a regra fica sem candidatos elegíveis por este critério."
                  )) %>
            <%= ax_toggle_chip(f, :require_inside_radius,
                  label: distribution_rule_action_label.call(
                    "Exigir corretor dentro do raio da loja agora",
                    "Além do check-in ativo, remove corretores que já saíram do raio da loja e têm saída de raio registrada."
                  )) %>
            <%= ax_toggle_chip(f, :require_active_shift,
                  label: distribution_rule_action_label.call(
                    "Exigir turno ativo no momento",
                    "O check-in só conta quando a loja vinculada está em uma janela operacional ativa no horário atual."
                  )) %>
            <%= ax_toggle_chip(f, :exclude_suspicious_checkins,
                  label: distribution_rule_action_label.call(
                    "Excluir check-ins suspeitos",
                    "Remove da regra os check-ins marcados pela análise antifraude como suspeitos antes de montar a lista de corretores elegíveis."
                  )) %>
          </div>

          <hr class="ax-separator">

          <div class="ax-option-stack">
            <%= ax_toggle_chip(f, :auto_update_agents_enabled,
                  label: distribution_rule_action_label.call(
                    "Atualizar corretores automaticamente pelos check-ins",
                    "Quando um check-in entra em uma loja vinculada e no evento selecionado, a fila de corretores da regra é recalculada automaticamente."
                  )) %>
            <%= ax_toggle_chip(f, :auto_update_shuffle_agents,
                  label: distribution_rule_action_label.call(
                    "Embaralhar corretores antes de atualizar",
                    "Randomiza a ordem dos corretores elegíveis antes de salvar a fila automática. Desligado, preserva a ordem encontrada por loja e horário."
                  )) %>
          </div>
          <div class="ax-field">
            <%= ax_field_label(f, :auto_update_trigger,
                  text: "Quando atualizar a fila",
                  tooltip: "Define quais eventos de check-in disparam a atualização automática da fila desta regra." ) %>
            <%= f.select :auto_update_trigger,
                  options_for_select(DistributionRule.auto_update_trigger_options, f.object.auto_update_trigger),
                  {},
                  multiple: true,
                  class: "ax-control",
                  data: { controller: "tom-select", placeholder: "Selecione os eventos de check-in" } %>
            <p class="ax-field__hint">A atualização usa os corretores com check-in na loja, na janela escolhida.</p>
          </div>

          <%= ax_inline_notice(tone: :warning, icon: "clock") do %>
            Execução: <strong><%= f.object.auto_update_trigger_label %></strong>.
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Horários e Bolsão %>
    <%= ax_operational_panel(eyebrow: "Horários", title: "Horários e bolsão") do %>
      <div class="ax-panel-body">
        <% secure_push_ready = DistributionRule.pocket_requires_secure_push? %>
        <%= ax_toggle_chip(f, :represamento_active,
              label: "Ativar bolsão (represamento fora do horário)",
              id: "checkRepresamento",
              input_data: { action: "change->distribution-rule#toggleRepresamento" }) %>

        <div class="section-toggle-container<%= ' tw-hidden' unless f.object.represamento_active? %>" data-distribution-rule-target="represamentoSection">
          <table class="ax-table distribution-rule-schedule">
            <thead>
              <tr><th>Dia</th><th class="ax-num">Ativo</th><th>Início</th><th>Fim</th></tr>
            </thead>
            <tbody>
              <% day_labels = { "mon" => "Segunda", "tue" => "Terça", "wed" => "Quarta", "thu" => "Quinta", "fri" => "Sexta", "sat" => "Sábado", "sun" => "Domingo" } %>
              <% %w[mon tue wed thu fri sat sun].each do |day| %>
                <% config = f.object.represamento_schedule[day] || {} %>
                <tr>
                  <td class="ax-strong"><%= day_labels[day] %></td>
                  <td class="ax-num">
                    <%= hidden_field_tag "distribution_rule[represamento_schedule][#{day}][active]", "false" %>
                    <%= check_box_tag "distribution_rule[represamento_schedule][#{day}][active]", "true", config["active"] == "true" %>
                  </td>
                  <td><%= time_field_tag "distribution_rule[represamento_schedule][#{day}][start]", config["start"] || "09:00", class: "ax-control ax-control--sm" %></td>
                  <td><%= time_field_tag "distribution_rule[represamento_schedule][#{day}][end]", config["end"] || "18:00", class: "ax-control ax-control--sm" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <%= ax_toggle_chip(f, :pocket_active,
              label: "Ativar tempo limite (Pocket)",
              disabled: !secure_push_ready,
              id: "checkPocket",
              input_data: { action: "change->distribution-rule#togglePocket" }) %>
        <% unless secure_push_ready %>
          <%= hidden_field_tag "distribution_rule[pocket_active]", "0" %>
          <%= ax_inline_notice(tone: :warning, icon: "shield-lock") do %>
            Para usar Pocket, habilite o <strong>link seguro no canal Push</strong>. O clique precisa passar pelo sistema para aceitar o lead, travar a vez do corretor e mostrar “lead já atendido” nas notificações antigas.
            <%= link_to "Configurar agora", edit_admin_lead_setting_path, class: "tw-font-semibold tw-text-primary" %>
          <% end %>
        <% end %>
        <div class="section-toggle-container<%= ' tw-hidden' unless secure_push_ready && f.object.pocket_active? %>" data-distribution-rule-target="pocketSection">
          <div class="ax-field">
            <%= ax_input_group(suffix: "minutos") do %>
              <%= f.number_field :pocket_time, class: "ax-control", placeholder: "30" %>
            <% end %>
            <p class="ax-field__hint">Tempo que o corretor tem para aceitar o lead antes de ser repassado.</p>
          </div>
        </div>
      </div>
    <% end %>

    <%= ax_quick_modal(id: "distributionRuleStoreRotationModal", title: "Como funciona o rodízio entre lojas?", size: :md) do %>
      <p class="tw-text-ink-muted">
        Quando a regra acompanha mais de uma loja, os corretores encontrados nos check-ins são reunidos em uma fila única.
        A ordem intercala as lojas para evitar que uma unidade com muitos check-ins ocupe toda a fila.
      </p>

      <%= ax_inline_notice(tone: :success, icon: "arrow-repeat") do %>
        <strong>Exemplo prático</strong><br>
        Se as lojas A, B e C tiverem A1, A2, B1, B2 e C1, a fila fica:
        <code>A1 -&gt; B1 -&gt; C1 -&gt; A2 -&gt; B2</code>.
      <% end %>

      <p class="tw-text-sm tw-text-ink-muted tw-mt-3 tw-mb-0">
        Lojas sem corretores naquele evento são puladas. A regra ainda respeita filtros de disponibilidade,
        perfil, canais e demais critérios configurados.
      </p>
    <% end %>

    <%= render "admin/distribution_rules/form_summary" %>
  </div>
<% end %>
