<% content_for :admin_contextbar_breadcrumb do %>
  <%= link_to "Admin", admin_root_path %>
  <i class="bi bi-chevron-right"></i>
  <%= link_to "Distribuição", admin_distribution_rules_path %>
  <i class="bi bi-chevron-right"></i>
  <strong>Nova regra</strong>
<% end %>

<% content_for :admin_contextbar_actions do %>
  <%= link_to admin_distribution_rules_path, class: "ax-contextbar__button" do %>
    <i class="bi bi-arrow-left"></i><span>Voltar</span>
  <% end %>
<% end %>

<header class="ax-dashboard-command ax-property-form-command">
  <div class="ax-dashboard-command__main">
    <span class="ax-dashboard-command__eyebrow">Distribuição de leads</span>
    <h1>Nova regra de distribuição</h1>
    <p>Defina fontes, equipe, modo de distribuição e regras de horário.</p>
  </div>
</header>

<%= render 'form', distribution_rule: @distribution_rule %>
