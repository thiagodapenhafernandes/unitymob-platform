<% content_for :admin_contextbar_breadcrumb do %>
  <%= link_to "Admin", admin_root_path %>
  <i class="bi bi-chevron-right"></i>
  <%= link_to "Distribuição", admin_distribution_rules_path %>
  <i class="bi bi-chevron-right"></i>
  <strong>Nova regra</strong>
<% end %>

<% content_for :admin_contextbar_actions do %>
  <%= ax_button("Objetivo",
        nil,
        size: :sm,
        icon: "info-circle",
        data: { ax_modal_open: "#distributionRuleObjectiveModal" }) %>
  <%= link_to admin_distribution_rules_path, class: "ax-btn ax-btn--sm" do %>
    <i class="bi bi-x-lg ax-ico"></i><span>Cancelar</span>
  <% end %>
  <%= button_tag type: "submit", class: "ax-btn ax-btn--primary ax-btn--sm" do %>
    <i class="bi bi-check2 ax-ico"></i><span>Salvar</span>
  <% end %>
<% end %>

<%= ax_quick_modal(id: "distributionRuleObjectiveModal",
      title: "Qual é o objetivo e para que serve",
      size: :md,
      class_name: "distribution-objective-modal") do %>
  <div class="automation-workflow-objective">
    <div class="automation-workflow-objective__intro">
      <span class="automation-workflow-objective__icon"><i class="bi bi-diagram-3"></i></span>
      <div>
        <div class="automation-workflow-objective__eyebrow">Distribuição vertical</div>
        <p>
          Esta regra controla a entrega primária do lead ao corretor. Tudo que envolve
          origem, destino, fila, represamento, aceite, check-in e horário pertence à
          Distribuição de Leads.
        </p>
      </div>
    </div>
  </div>
<% end %>

<%= render 'form',
      distribution_rule: @distribution_rule,
      form_title: "Nova regra de distribuição",
      form_description: "Defina origem, destino, fila, equipe, modo de distribuição, aceite e regras de horário." %>
