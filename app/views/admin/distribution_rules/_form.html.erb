<%= form_with(model: [:admin, distribution_rule], local: true, data: { controller: "distribution-rule distribution-rule-summary", action: "submit->distribution-rule#validateBeforeSubmit" }, html: { class: "distribution-rule-form distribution-rule-form--workspace" }) do |f| %>
  <%
    form_title = local_assigns.fetch(:form_title) do
      distribution_rule.persisted? ? "Editar regra: #{distribution_rule.name}" : "Nova regra de distribuição"
    end
    form_description = local_assigns.fetch(:form_description) do
      distribution_rule.persisted? ? "Ajuste origem, destino, fila, equipe, modo de distribuição, aceite e regras de horário." : "Defina origem, destino, fila, equipe, modo de distribuição, aceite e regras de horário."
    end
    form_eyebrow = local_assigns.fetch(:form_eyebrow, "Distribuição de leads")
  %>

  <% form_main = capture do %>
    <%# ===== Coluna principal ===== %>
    <div class="distribution-rule-form__main">
      <header class="ax-dashboard-command ax-property-form-command distribution-rule-command">
        <div class="ax-dashboard-command__main">
          <span class="ax-dashboard-command__eyebrow"><%= form_eyebrow %></span>
          <h1><%= form_title %></h1>
          <p><%= form_description %></p>
        </div>
      </header>

      <%# Dados Gerais %>
      <%= ax_operational_panel(
            eyebrow: "Identificação",
            title: "Dados gerais",
            actions: ax_toggle_chip(f, :active, label: "Regra ativa", id: "flexSwitchCheckActive")
          ) do %>
        <div class="ax-panel-body">
          <div class="distribution-rule-general-grid">
            <div class="distribution-rule-general-grid__name">
              <%= ax_text_field(form: f, method: :name, label: "Nome da regra", placeholder: "Ex: Vendas Zona Sul - Facebook") %>
            </div>
            <div class="distribution-rule-general-grid__type">
              <%= ax_select_field(
                    form: f,
                    method: :business_type,
                    label: "Tipo de negócio",
                    choices: DistributionRule.business_types.keys.map { |k| [k.humanize, k] },
                    html_options: {
                      data: {
                        controller: "broadcast-change",
                        broadcast_change_event_value: "distribution:area",
                        action: "change->broadcast-change#change"
                      }
                    },
                    tooltip: "Define também a área do filtro de gestores e quem pode receber: regra de venda distribui a quem atua em venda/ambos; locação idem. Leads sem venda ou locação explícita continuam elegíveis para regras específicas."
                  ) %>
            </div>
          </div>
        </div>
      <% end %>

      <%# Fontes dos leads %>
      <div data-controller="meta-rules" data-meta-rules-structure-value="<%= @meta_structure.to_json %>"
           data-meta-rules-sync-url-value="<%= sync_forms_admin_meta_integrations_path %>">
        <%= ax_operational_panel(eyebrow: "Origem", title: "Fontes dos leads") do %>
          <div class="ax-panel-body distribution-rule-source-panel">
            <%# Meta Ads %>
            <section class="distribution-rule-source-card distribution-rule-source-card--primary">
              <div class="distribution-rule-source__head">
                <span class="distribution-rule-source__icon distribution-rule-source__icon--meta"><i class="bi bi-facebook"></i></span>
                <div class="distribution-rule-source__copy">
                  <strong>Meta Ads</strong>
                  <span>Leads capturados por formulários do Facebook e Instagram.</span>
                </div>
                <div class="distribution-rule-source__actions">
                  <span class="ax-badge ax-badge--green tw-hidden" data-distribution-rule-target="metaStatusBadge">Conectado</span>
                  <%= ax_toggle_chip(f, :source_meta,
                        label: "Ativar",
                        class_name: "distribution-rule-source__toggle",
                        input_data: { action: "change->distribution-rule#toggleMeta" }) %>
                </div>
              </div>

              <div class="section-toggle-container distribution-rule-source__body<%= ' tw-hidden' unless distribution_rule.source_meta? %>" data-distribution-rule-target="metaSection">
                <% selected_forms_count = Array(distribution_rule.meta_forms).compact_blank.size %>
                <%
                  selected_meta_page_ids = Array(distribution_rule.meta_page_ids).compact_blank.map(&:to_s)
                  selected_meta_form_options = selected_meta_page_ids.flat_map { |page_id| Array(@meta_form_options_by_page&.[](page_id)) }
                %>
                <div class="distribution-rule-meta-grid">
                  <div class="distribution-rule-meta-grid__field">
                    <%= ax_field_group(
                          title: "Páginas do Facebook",
                          token: "Conta Meta",
                          class_name: "distribution-rule-source-config",
                          tooltip: "Selecione as páginas Meta que alimentam esta regra: leads de OUTRAS páginas não entram. Vazio = aceita leads de qualquer página Meta."
                        ) do %>
                      <div class="ax-field">
                        <%= f.select :meta_page_ids, @all_page_options || [], {},
                              { multiple: true, class: "ax-control", data: { meta_rules_target: "pageSelect", action: "change->meta-rules#updateForms", controller: "tom-select", tom_select_create_value: "false" } } %>
                      </div>
                    <% end %>
                  </div>

                  <div class="distribution-rule-meta-grid__field">
                    <%= ax_field_group(
                          title: "Formulários específicos",
                          token: "Filtros",
                          class_name: "distribution-rule-source-config",
                          tooltip: "Selecione uma página primeiro e filtre os formulários dela: com formulários selecionados, só leads DESSES formulários entram. Vazio = todos os formulários das páginas escolhidas."
                        ) do %>
                      <div class="ax-field">
                        <%= f.select :meta_forms, options_for_select(selected_meta_form_options, distribution_rule.meta_forms), {},
                              { multiple: true, class: "ax-control",
                                data: { controller: "tom-select", meta_rules_target: "formSelect",
                                        action: "change->meta-rules#syncAutoSummary" } } %>
                        <p class="ax-field__hint" data-meta-rules-target="formCountLabel">
                          <% if selected_forms_count.zero? %>
                            Nenhum formulário selecionado
                          <% else %>
                            <strong><%= selected_forms_count %></strong> formulário<%= "s" if selected_forms_count != 1 %> selecionado<%= "s" if selected_forms_count != 1 %>
                          <% end %>
                        </p>
                      </div>
                    <% end %>
                  </div>
                </div>

                <%= ax_field_group(
                      title: "Sincronização",
                      token: "Meta",
                      class_name: "distribution-rule-source-config distribution-rule-source-sync",
                      tooltip: "Quando ativo, novos formulários criados nas páginas selecionadas entram automaticamente nesta regra."
                    ) do %>
                  <div class="distribution-rule-source-sync__row">
                    <%= ax_toggle_chip(f, :auto_add_forms, label: "Ativar sincronização",
                          id: "autoSyncForms",
                          class_name: "distribution-rule-source-sync__toggle",
                          input_data: { meta_rules_target: "autoSync", action: "change->meta-rules#toggleAutoSync" }) %>
                    <button type="button" class="ax-btn ax-btn--sm distribution-rule-source-sync__button" data-action="click->meta-rules#syncNow">
                      <i class="bi bi-arrow-repeat ax-ico"></i><span>Sincronizar agora</span>
                    </button>
                  </div>
                <% end %>
              </div>
            </section>

            <%# Webhooks %>
            <section class="distribution-rule-source-card">
              <div class="distribution-rule-source__head">
                <span class="distribution-rule-source__icon"><i class="bi bi-share"></i></span>
                <div class="distribution-rule-source__copy">
                  <strong>Webhooks personalizados</strong>
                  <span>Receba leads enviados por integrações externas com tags de roteamento.</span>
                </div>
                <div class="distribution-rule-source__actions">
                  <%= ax_toggle_chip(f, :source_webhook,
                        label: "Ativar",
                        class_name: "distribution-rule-source__toggle",
                        input_data: { action: "change->distribution-rule#toggleWebhook" }) %>
                </div>
              </div>

              <div class="section-toggle-container distribution-rule-source__body<%= ' tw-hidden' unless distribution_rule.source_webhook? %>" data-distribution-rule-target="webhookSection">
                <%= ax_field_group(title: "Tags de filtragem", token: "Webhook", class_name: "distribution-rule-source-config") do %>
                  <div class="ax-field">
                    <%= f.select :webhook_tags, options_for_select(distribution_rule.webhook_tags || [], distribution_rule.webhook_tags), {},
                          { multiple: true, class: "ax-control", data: { controller: "tom-select", tom_select_create_value: "true" } } %>
                    <p class="ax-field__hint">Leads que chegarem via webhook com estas tags serão processados por esta regra.</p>
                  </div>
                <% end %>

                <details class="ax-disclosure-card distribution-rule-webhook-example">
                  <summary class="ax-disclosure-card__summary">
                    <span>Exemplo de payload do webhook</span>
                    <i class="bi bi-chevron-down ax-disclosure-card__chevron"></i>
                  </summary>
                  <div class="ax-disclosure-card__body">
                    <div class="ax-code-snippet">
                      <div class="ax-code-snippet__title">POST JSON</div>
                      <pre><code>{
  "name": "Nome do Lead",
  "email": "lead@email.com",
  "phone": "47999999999",
  "keywords": ["<%= distribution_rule.webhook_tags&.first || 'tag-exemplo' %>"]
}</code></pre>
                    </div>
                  </div>
                </details>
              </div>
            </section>

            <div class="distribution-rule-source-grid">
              <section class="distribution-rule-source-card distribution-rule-source-card--compact">
                <div class="distribution-rule-source__head">
                  <span class="distribution-rule-source__icon"><i class="bi bi-globe2"></i></span>
                  <div class="distribution-rule-source__copy">
                    <strong>Site</strong>
                    <span>WhatsApp, formulários e conversões do site público.</span>
                  </div>
                  <div class="distribution-rule-source__actions">
                    <%= ax_toggle_chip(f, :source_site, label: "Ativar", class_name: "distribution-rule-source__toggle") %>
                  </div>
                </div>
              </section>

              <section class="distribution-rule-source-card distribution-rule-source-card--compact">
                <div class="distribution-rule-source__head">
                  <span class="distribution-rule-source__icon"><i class="bi bi-buildings"></i></span>
                  <div class="distribution-rule-source__copy">
                    <strong>Portais imobiliários</strong>
                    <span>ZAP, VivaReal e integrações de portais cadastrados.</span>
                  </div>
                  <div class="distribution-rule-source__actions">
                    <%= ax_toggle_chip(f, :source_portal, label: "Ativar", class_name: "distribution-rule-source__toggle") %>
                  </div>
                </div>
              </section>
            </div>
          </div>
        <% end %>
      </div>

      <%# Equipe %>
      <div id="team" data-controller="team-rules"
           data-team-rules-all-agents-value="<%= (@all_agents || []).to_json %>">
        <% initial_agent_count = Array(distribution_rule.distribution_rule_agents).reject(&:marked_for_destruction?).map(&:admin_user_id).compact.size %>
        <%= ax_operational_panel(eyebrow: "Equipe", title: "Corretores e fila",
              actions: raw(%(<span class="ax-badge ax-badge--gray"><span data-distribution-rule-summary-target="agentCount">#{initial_agent_count}</span> na fila</span>))) do %>
          <div class="ax-panel-body">
            <%= render "admin/shared/hierarchical_user_filter",
                  component_id: "distribution_rule_hierarchy_filter",
                  profiles: @distribution_hierarchy_profiles || [],
                  users: @all_agents || [],
                  target_select_id: "agent_select",
                  locked_user_id: @distribution_hierarchy_locked_user_id,
                  mode: :multi,
                  area: distribution_rule.business_type,
                  field_name: "distribution_rule[hierarchy_manager_ids][]",
                  selected_ids: (distribution_rule.respond_to?(:hierarchy_manager_ids) ? distribution_rule.hierarchy_manager_ids : []),
                  label: "Filtrar por gestor",
                  hint: "Escolha um ou mais gestores — a busca de corretores lista a união das equipes selecionadas. Sem gestor selecionado, nenhum corretor é listado." %>

            <div class="ax-field">
              <%= ax_field_label(nil, nil, text: "Corretores na regra", for: "agent_select") %>
              <%
                preselected_agent_ids = Array(distribution_rule.distribution_rule_agents)
                                          .reject { |a| a.marked_for_destruction? }
                                          .map(&:admin_user_id).compact
              %>
              <%# hidden garante que agent_select sempre chegue ao controller (inclusive vazio = fila zerada) %>
              <%= hidden_field_tag "agent_select[]", "" %>
              <%= select_tag :agent_select,
                    options_for_select(@all_users_options || [], preselected_agent_ids),
                    multiple: true, class: "ax-control", data: { team_rules_target: "agentSelect" } %>
              <p class="ax-field__hint">Selecione qualquer corretor. Ao escolher um gestor, a busca passa a listar apenas a equipe dele, preservando quem já estiver na fila.</p>
            </div>

            <div class="ax-field">
              <%= ax_field_label(nil, nil, text: "Fila de distribuição") %>
              <div class="ax-record-list distribution-rule-agent-list" data-team-rules-target="list" data-controller="sortable" data-sortable-handle-value=".drag-handle">
                <%= f.fields_for :distribution_rule_agents do |agent_fields| %>
                  <%= render "agent_fields", f: agent_fields %>
                <% end %>
              </div>
              <p class="ax-field__hint">Arraste pelo ícone para reordenar. No modo <strong>Performance</strong> defina os ciclos (peso); no <strong>Rotativo</strong> a ordem define a fila.</p>
            </div>

            <template data-team-rules-target="template">
              <%= f.fields_for :distribution_rule_agents, DistributionRuleAgent.new, child_index: "NEW_RECORD" do |agent_fields| %>
                <%= render "agent_fields", f: agent_fields %>
              <% end %>
            </template>
          </div>
        <% end %>
      </div>

      <%# Notificações %>
      <% channel_states = notification_channel_states %>
      <%= ax_operational_panel(eyebrow: "Avisos", title: "Notificações") do %>
        <div class="ax-panel-body">
          <div class="ax-option-stack">
            <%# WhatsApp e Push só aparecem quando o canal está disponível para a conta:
                WhatsApp = conta tem o próprio OU o Admin do Sistema liberou o global;
                Push = o Admin do Sistema ativou o transporte global (VAPID). Quando
                indisponível, o toggle some (o valor atual da regra é preservado no save,
                pois o param ausente não altera o atributo). %>
            <% if channel_states[:whatsapp][:configured] %>
              <%= ax_toggle_chip(f, :notify_whatsapp, label: raw("<i class='bi bi-whatsapp' style='color:#1da851'></i> WhatsApp"),
                    input_data: notify_channel_guard_data(:whatsapp, channel_states[:whatsapp])) %>
            <% end %>
            <%= ax_toggle_chip(f, :notify_email, label: raw("<i class='bi bi-envelope'></i> E-mail ao corretor"),
                  input_data: notify_channel_guard_data(:email, channel_states[:email])) %>
            <% if channel_states[:push][:configured] %>
              <%= ax_toggle_chip(f, :notify_push, label: raw("<i class='bi bi-phone-vibrate'></i> Push no PWA"),
                    input_data: notify_channel_guard_data(:push, channel_states[:push])) %>
            <% end %>
            <%= ax_toggle_chip(f, :notify_webhook, label: raw("<i class='bi bi-broadcast'></i> Webhook externo"),
                  input_data: { action: "change->distribution-rule#toggleNotifyWebhook" }) %>
          </div>

          <div class="section-toggle-container<%= ' tw-hidden' unless distribution_rule.notify_webhook? %>" data-distribution-rule-target="notifyWebhookSection">
            <%= ax_field_group(title: "URLs de disparo", token: "Webhook externo", class_name: "distribution-rule-source-config") do %>
              <div class="ax-field">
                <%= f.select :notify_webhook_urls,
                      options_for_select(distribution_rule.notify_webhook_url_list, distribution_rule.notify_webhook_url_list), {},
                      { multiple: true, class: "ax-control", data: { controller: "tom-select", tom_select_create_value: "true", distribution_rule_target: "notifyWebhookSelect" } } %>
                <p class="ax-field__hint">Cada lead distribuído por esta regra é enviado (POST JSON completo — lead, histórico, corretor e gestor) para todas estas URLs, além de cair na fila do corretor. Digite a URL e tecle Enter para adicionar.</p>
                <p class="tw-hidden" data-distribution-rule-target="notifyWebhookError" style="color:#b42318;font-size:12px;font-weight:650;margin-top:6px;">
                  <i class="bi bi-exclamation-triangle"></i> Adicione ao menos uma URL de disparo ou desative o Webhook externo.
                </p>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# Modal de canal não configurado (preenchido pelo controller distribution-rule) %>
      <%= ax_quick_modal(
            id: "notifyChannelModal",
            title: "Configure a conexão primeiro",
            size: :sm,
            data: { distribution_rule_target: "channelModal" },
            footer: capture do %>
              <button type="button" class="ax-btn" data-action="ax-modal#close">Agora não</button>
              <%= link_to "#", class: "ax-btn ax-btn--primary", target: "_blank", rel: "noopener",
                    data: { distribution_rule_target: "channelModalLink" } do %>
                <i class="bi bi-box-arrow-up-right ax-ico"></i> Ir para configuração
              <% end %>
            <% end) do %>
        <p>O canal <strong data-distribution-rule-target="channelModalName">—</strong> ainda não está configurado e não pode ser ativado.</p>
        <p class="ax-field__hint" data-distribution-rule-target="channelModalInstructions"></p>
      <% end %>
    </div>
  <% end %>

  <% form_aside = render("admin/distribution_rules/form_aside", f: f) %>

  <div class="distribution-rule-form__content">
    <%= ax_error_summary(distribution_rule) %>

    <%= render "admin/shared/ui/workspace_shell",
          class_name: "distribution-rule-workspace",
          main_class: "distribution-rule-main-pane",
          main_label: "Regra de distribuição",
          main_body_class: "distribution-rule-main-body",
          main: form_main,
          aside: form_aside,
          aside_class: "distribution-rule-aside",
          aside_label: "Configurações da regra",
          contextbar_class: "distribution-rule-middle-contextbar",
          controller: "ax-aside",
          storage_key: "admin-distribution-rule-form-aside-collapsed",
          preload_class: "ax-distribution-rule-aside-collapsed-preload" %>
  </div>
<% end %>
