<%# Regras de Distribuição — listagem. A ação "Nova regra" vem da contextbar global. %>
<header class="ax-dashboard-command ax-property-form-command">
  <div class="ax-dashboard-command__main">
    <span class="ax-dashboard-command__eyebrow">Distribuição de leads</span>
    <h1>Regras de Distribuição</h1>
    <p>Gerencie o fluxo vertical de entrada, fila, responsável, aceite e entrega dos leads à equipe.</p>
  </div>
  <div class="ax-dashboard-command__status">
    <%= ax_button("Objetivo",
          nil,
          size: :sm,
          icon: "info-circle",
          data: { ax_modal_open: "#distributionObjectiveModal" }) %>
    <i class="bi bi-diagram-3"></i>
    <%= ax_badge("#{@distribution_rules.size} regra#{'s' if @distribution_rules.size != 1}", tone: :gray) %>
  </div>
</header>

<%= ax_quick_modal(id: "distributionObjectiveModal",
      title: "Qual é o objetivo e para que serve",
      size: :md,
      class_name: "distribution-objective-modal") do %>
  <div class="automation-workflow-objective">
    <div class="automation-workflow-objective__intro">
      <span class="automation-workflow-objective__icon"><i class="bi bi-diagram-3"></i></span>
      <div>
        <div class="automation-workflow-objective__eyebrow">Distribuição vertical</div>
        <p>
          Use este módulo para controlar de onde o lead entra e para onde ele vai:
          origem, regra, fila, corretor, disponibilidade, represamento, próximo horário,
          aceite, check-in e notificações de distribuição.
        </p>
      </div>
    </div>
  </div>
<% end %>

<% if @holding_leads_count.to_i.positive? %>
  <div class="distribution-rules-index__notice">
    <%= ax_inline_notice(tone: :warning, icon: "pause-circle-fill") do %>
      <strong>Leads represados:</strong> <%= @holding_leads_count %> aguardando distribuição no bolsão.
      <%= link_to "Ver leads", admin_leads_path(status: Lead.status_value(:represado)), class: "ax-dashboard-panel__link distribution-rules-index__notice-link" %>
    <% end %>
  </div>
<% end %>

<div class="ax-table-wrap distribution-rules-index__table">
  <table class="ax-table">
    <thead>
      <tr>
        <th>Nome</th>
        <th class="distribution-rules-index__col-type">Tipo</th>
        <th class="distribution-rules-index__col-sources">Fontes</th>
        <th class="distribution-rules-index__col-mode">Modo</th>
        <th class="distribution-rules-index__col-status">Status</th>
        <th class="ax-num distribution-rules-index__col-actions">Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @distribution_rules.each do |rule| %>
        <tr>
          <td>
            <div class="ax-strong"><%= rule.name %></div>
            <div class="tw-flex tw-gap-1 tw-mt-1">
              <% if rule.pocket_active? %><span class="ax-badge ax-badge--amber"><i class="bi bi-hourglass-split"></i> <%= rule.pocket_time %>m</span><% end %>
              <% if rule.represamento_active? %><span class="ax-badge ax-badge--blue"><i class="bi bi-moon-stars"></i> Bolsão</span><% end %>
            </div>
          </td>
          <td><span class="ax-badge ax-badge--gray tw-uppercase tw-font-mono"><%= rule.business_type %></span></td>
          <td>
            <span class="tw-inline-flex tw-gap-2 tw-text-base">
              <% if rule.source_meta? %><i class="bi bi-facebook tw-text-blue-600" title="Meta"></i><% end %>
              <% if rule.source_webhook? %><i class="bi bi-diagram-2 tw-text-ink-muted" title="Webhook"></i><% end %>
              <% if rule.source_site? %><i class="bi bi-globe tw-text-cyan-600" title="Site"></i><% end %>
              <% if rule.source_portal? %><i class="bi bi-building tw-text-green-600" title="Portais"></i><% end %>
            </span>
          </td>
          <td>
            <span class="tw-inline-flex tw-items-center tw-gap-1.5 tw-text-2xs tw-uppercase tw-font-semibold tw-text-ink-muted">
              <i class="bi bi-<%= rule.rotary? ? 'arrow-repeat' : (rule.performance? ? 'graph-up-arrow' : 'lightning-fill') %>"></i>
              <%= rule.distribution_mode %>
            </span>
          </td>
          <td>
            <% if rule.active? %><span class="ax-badge ax-badge--green ax-badge--dot">Ativa</span>
            <% else %><span class="ax-badge ax-badge--gray ax-badge--dot">Inativa</span><% end %>
          </td>
          <td class="ax-num">
            <span class="tw-inline-flex tw-gap-0.5">
              <%= link_to admin_distribution_rule_path(rule), class: "ax-ico-btn", title: "Ver" do %><i class="bi bi-eye"></i><% end %>
              <%= link_to edit_admin_distribution_rule_path(rule), class: "ax-ico-btn", title: "Editar" do %><i class="bi bi-pencil"></i><% end %>
              <%= button_to toggle_active_admin_distribution_rule_path(rule), method: :patch, form_class: "tw-inline", class: "ax-ico-btn", title: rule.active? ? "Pausar" : "Ativar" do %><i class="bi bi-<%= rule.active? ? 'pause-circle' : 'play-circle' %>"></i><% end %>
              <%= button_to admin_distribution_rule_path(rule), method: :delete, form_class: "tw-inline", data: { turbo_confirm: "Tem certeza?" }, class: "ax-ico-btn", title: "Excluir" do %><i class="bi bi-trash"></i><% end %>
            </span>
          </td>
        </tr>
      <% end %>

      <% if @distribution_rules.empty? %>
        <tr><td colspan="6"><div class="ax-empty">
          <i class="bi bi-diagram-3 tw-text-2xl tw-block tw-mb-2 tw-text-ink-faint"></i>
          Nenhuma regra definida ainda.
          <div class="tw-mt-3">
            <%= ax_button("Criar primeira regra",
                  new_admin_distribution_rule_path,
                  variant: :primary,
                  size: :sm,
                  icon: "plus-lg") %>
          </div>
        </div></td></tr>
      <% end %>
    </tbody>
  </table>
</div>
