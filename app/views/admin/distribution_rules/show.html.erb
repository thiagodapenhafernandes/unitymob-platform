<%
  enabled_sources = distribution_rule_enabled_sources(@rule)
  enabled_notifications = distribution_rule_enabled_notifications(@rule)
  meta_pages = distribution_rule_meta_pages(@rule)
  meta_forms = distribution_rule_meta_forms(@rule)
  checkin_store_names = distribution_rule_store_names(@rule)
%>

<% content_for :admin_contextbar_breadcrumb do %>
  <%= link_to "Admin", admin_root_path %>
  <i class="bi bi-chevron-right"></i>
  <%= link_to "Distribuição", admin_distribution_rules_path %>
  <i class="bi bi-chevron-right"></i>
  <strong><%= @rule.name %></strong>
<% end %>

<% content_for :admin_contextbar_actions do %>
  <%= link_to admin_distribution_rules_path, class: "ax-btn ax-btn--sm" do %>
    <i class="bi bi-arrow-left ax-ico"></i><span>Voltar</span>
  <% end %>
  <%= link_to edit_admin_distribution_rule_path(@rule), class: "ax-btn ax-btn--primary ax-btn--sm" do %>
    <i class="bi bi-pencil ax-ico"></i><span>Editar regra</span>
  <% end %>
<% end %>

<div class="distribution-rule-show">
  <header class="ax-dashboard-command ax-property-form-command">
    <div class="ax-dashboard-command__main">
      <span class="ax-dashboard-command__eyebrow">Regra de distribuição</span>
      <div class="ax-dashboard-command__title-row">
        <h1><%= @rule.name %></h1>
        <%= ax_badge(@rule.active? ? "Ativa" : "Inativa", tone: @rule.active? ? :green : :gray, dot: true) %>
      </div>
      <p><%= distribution_rule_business_label(@rule) %> · <%= distribution_rule_mode_label(@rule) %> · <%= enabled_sources.presence&.to_sentence || "Nenhuma fonte habilitada" %></p>
    </div>
  </header>

  <div class="distribution-rule-show__kpis">
    <%= ax_metric_card(label: "Tipo", value: distribution_rule_business_label(@rule)) %>
    <%= ax_metric_card(label: "Distribuição", value: distribution_rule_mode_label(@rule)) %>
    <%= ax_metric_card(label: "Corretores", value: "#{@agents_queue.size} na fila") %>
    <%= ax_metric_card(label: "Preço", value: distribution_rule_price_range(@rule)) %>
  </div>

  <div class="distribution-rule-show__kpis">
    <%= ax_metric_card(label: "Leads (total)", value: number_with_delimiter(@leads_total), hint: "recebidos por esta regra") %>
    <%= ax_metric_card(label: "Distribuídos", value: number_with_delimiter(@leads_distributed), hint: "atribuídos a um corretor") %>
    <%= ax_metric_card(label: "Entraram hoje", value: number_with_delimiter(@leads_today)) %>
    <%= ax_metric_card(label: "Último lead", value: @last_lead_at ? l(@last_lead_at, format: :short) : "--") %>
  </div>

  <div class="distribution-rule-show__grid">
    <div class="distribution-rule-show__col">
      <%= ax_operational_panel(eyebrow: "Configuração", title: "Configuração da regra") do %>
        <div class="distribution-rule-show__body">
          <div class="distribution-rule-show__block">
            <span class="distribution-rule-show__block-label">Fontes habilitadas</span>
            <% if enabled_sources.any? %>
              <div class="distribution-rule-show__chips">
                <% enabled_sources.each do |source| %><%= ax_badge(source, tone: :blue) %><% end %>
              </div>
            <% else %>
              <p class="distribution-rule-show__muted">Nenhuma fonte habilitada.</p>
            <% end %>
          </div>

          <div class="distribution-rule-show__block">
            <span class="distribution-rule-show__block-label">Meta Ads</span>
            <% if @rule.source_meta? %>
              <p class="distribution-rule-show__line"><strong>Páginas:</strong> <%= meta_pages.any? ? meta_pages.map(&:name).to_sentence : "nenhuma página encontrada." %></p>
              <p class="distribution-rule-show__line"><strong>Formulários:</strong> <%= distribution_rule_meta_forms_summary(@rule) %></p>
              <% if meta_forms.any? && !@rule.auto_add_forms? %>
                <div class="distribution-rule-show__chips">
                  <% meta_forms.each do |form| %>
                    <%= ax_badge("#{form.name}#{" · #{form.meta_facebook_page.name}" if form.meta_facebook_page.present?}", tone: :gray) %>
                  <% end %>
                </div>
              <% end %>
            <% else %>
              <p class="distribution-rule-show__muted">Meta Ads desligado nesta regra.</p>
            <% end %>
          </div>

          <div class="distribution-rule-show__block">
            <span class="distribution-rule-show__block-label">Webhook personalizado</span>
            <% if @rule.source_webhook? %>
              <p class="distribution-rule-show__line"><strong>URL:</strong> <span class="distribution-rule-show__break"><%= @rule.webhook_url.presence || "Não configurada" %></span></p>
              <p class="distribution-rule-show__line"><strong>Tags:</strong> <%= Array(@rule.webhook_tags).compact_blank.any? ? Array(@rule.webhook_tags).compact_blank.to_sentence : "sem tags específicas." %></p>
            <% else %>
              <p class="distribution-rule-show__muted">Webhook desligado nesta regra.</p>
            <% end %>
          </div>

          <div class="distribution-rule-show__block">
            <span class="distribution-rule-show__block-label">Filtros adicionais</span>
            <% if Array(@rule.neighborhoods).compact_blank.any? || Array(@rule.custom_filters).compact_blank.any? %>
              <% if Array(@rule.neighborhoods).compact_blank.any? %>
                <p class="distribution-rule-show__line"><strong>Bairros:</strong> <%= Array(@rule.neighborhoods).compact_blank.to_sentence %></p>
              <% end %>
              <% if Array(@rule.custom_filters).compact_blank.any? %>
                <p class="distribution-rule-show__line"><strong>Filtros:</strong> <%= Array(@rule.custom_filters).compact_blank.to_sentence %></p>
              <% end %>
            <% else %>
              <p class="distribution-rule-show__muted">Sem filtros adicionais configurados.</p>
            <% end %>
          </div>
        </div>
      <% end %>

      <%= ax_operational_panel(eyebrow: "Campo", title: "Check-in geolocalizado") do %>
        <div class="distribution-rule-show__body">
          <dl class="distribution-rule-show__state">
            <% distribution_rule_checkin_rows(@rule).each do |label, enabled| %>
              <div class="distribution-rule-show__state-row">
                <dt><%= label %></dt>
                <dd><%= ax_badge(enabled ? "Ativo" : "Desligado", tone: enabled ? :green : :gray) %></dd>
              </div>
            <% end %>
          </dl>
          <div class="distribution-rule-show__block distribution-rule-show__block--spaced">
            <span class="distribution-rule-show__block-label">Lojas consideradas</span>
            <% if checkin_store_names.any? %>
              <div class="distribution-rule-show__chips">
                <% checkin_store_names.each do |store_name| %><%= ax_badge(store_name, tone: :gray) %><% end %>
              </div>
            <% else %>
              <p class="distribution-rule-show__muted">Todas as lojas contam para esta regra.</p>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="distribution-rule-show__col">
      <%= ax_operational_panel(
            eyebrow: "Fila",
            title: "Fila de distribuição",
            actions: link_to(edit_admin_distribution_rule_path(@rule, anchor: "team"), class: "ax-btn ax-btn--sm") { safe_join([tag.i(class: "bi bi-people"), " Alterar corretores"]) }
          ) do %>
        <div class="distribution-rule-show__body">
          <p class="distribution-rule-show__muted distribution-rule-show__queue-note">Arraste pelo ícone para mudar a ordem e salve somente a fila.</p>
          <% if @agents_queue.any? %>
            <%= form_with url: reorder_agents_admin_distribution_rule_path(@rule), method: :patch do %>
              <div class="distribution-rule-show__queue" data-controller="sortable" data-sortable-handle-value=".drag-handle">
                <% @agents_queue.each do |dra| %>
                  <div class="ax-record-item distribution-rule-show__queue-item">
                    <span class="drag-handle distribution-rule-show__queue-handle" title="Arrastar para reordenar"><i class="bi bi-grip-vertical"></i></span>
                    <%= hidden_field_tag "agent_ids[]", dra.id %>
                    <span class="distribution-rule-show__queue-pos position-display"><%= dra.position %></span>
                    <div class="ax-record-item__copy distribution-rule-show__queue-main">
                      <div class="distribution-rule-show__queue-name">
                        <strong><%= dra.admin_user&.name %></strong>
                        <% if @next_agent_user_id == dra.admin_user_id %><%= ax_badge("Próximo", tone: :green, dot: true) %><% end %>
                      </div>
                      <span><%= dra.admin_user&.email %></span>
                    </div>
                    <div class="distribution-rule-show__queue-meta">
                      <span>Leads recebidos</span>
                      <strong><%= number_with_delimiter(@leads_per_agent[dra.admin_user_id] || 0) %></strong>
                    </div>
                    <div class="distribution-rule-show__queue-meta">
                      <span>Último lead</span>
                      <strong><%= dra.last_lead_received_at.present? ? l(dra.last_lead_received_at, format: :short) : "--" %></strong>
                    </div>
                    <% if @rule.performance? %><%= ax_badge("Peso #{dra.weight}", tone: :blue) %><% end %>
                  </div>
                <% end %>
              </div>
              <div class="ax-form-actions">
                <%= submit_tag "Salvar ordem da fila", class: "ax-btn ax-btn--primary" %>
              </div>
            <% end %>
          <% else %>
            <%= ax_empty_state(title: "Nenhum corretor selecionado", description: "Esta regra ainda não tem corretores na fila.", icon: "person-plus") %>
          <% end %>
        </div>
      <% end %>

      <div class="distribution-rule-show__grid distribution-rule-show__grid--half">
        <%= ax_operational_panel(eyebrow: "Horários", title: "Horários e bolsão") do %>
          <div class="distribution-rule-show__body">
            <div class="distribution-rule-show__state-row">
              <dt>Bolsão fora do horário</dt>
              <dd><%= ax_badge(@rule.represamento_active? ? "Ativo" : "Desligado", tone: @rule.represamento_active? ? :amber : :gray) %></dd>
            </div>
            <% if @rule.represamento_active? %>
              <table class="ax-table distribution-rule-show__table">
                <thead><tr><th>Dia</th><th>Status</th><th>Horário</th></tr></thead>
                <tbody>
                  <% distribution_rule_schedule_rows(@rule).each do |label, active, start_time, end_time| %>
                    <tr>
                      <td class="ax-strong"><%= label %></td>
                      <td><%= active ? "Ativo" : "Desligado" %></td>
                      <td><%= active ? "#{start_time} às #{end_time}" : "--" %></td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            <% else %>
              <p class="distribution-rule-show__muted">Leads não ficam represados por horário nesta regra.</p>
            <% end %>
            <div class="distribution-rule-show__state-row distribution-rule-show__state-row--separated">
              <dt>Tempo limite para aceite</dt>
              <dd><%= ax_badge(@rule.pocket_active? ? "#{@rule.pocket_time} min" : "Desligado", tone: @rule.pocket_active? ? :blue : :gray) %></dd>
            </div>
          </div>
        <% end %>

        <%= ax_operational_panel(eyebrow: "Notificações", title: "Notificações") do %>
          <div class="distribution-rule-show__body">
            <% if enabled_notifications.any? %>
              <div class="distribution-rule-show__chips">
                <% enabled_notifications.each do |notification| %><%= ax_badge(notification, tone: :red) %><% end %>
              </div>
            <% else %>
              <p class="distribution-rule-show__muted">Nenhum canal de notificação ativo.</p>
            <% end %>

            <% webhook_urls = @rule.notify_webhook_url_list %>
            <% if @rule.notify_webhook? && webhook_urls.any? %>
              <div class="distribution-rule-show__block distribution-rule-show__block--spaced">
                <span class="distribution-rule-show__block-label">URLs do webhook externo</span>
                <% webhook_urls.each do |url| %>
                  <p class="distribution-rule-show__line distribution-rule-show__break"><i class="bi bi-link-45deg"></i> <%= url %></p>
                <% end %>
              </div>
            <% end %>

            <p class="distribution-rule-show__muted distribution-rule-show__block--spaced">Canais ativos são usados quando um lead passa por esta regra. Para mudar destinatários, ordem ou peso, use a fila acima ou a edição completa.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
