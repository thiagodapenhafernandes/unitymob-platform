<%= form_with model: [:admin, @home_section], local: true do |f| %>
  <% if @home_section.errors.any? %>
    <div class="alert alert-danger">
      <h5><%= pluralize(@home_section.errors.count, "erro") %>:</h5>
      <ul class="mb-0">
        <% @home_section.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card shadow-sm">
    <div class="card-body">
      <div class="row">
        <div class="col-md-6 mb-3">
          <%= f.label :section_type, "Tipo de Seção", class: "form-label" %>
          <%= f.select :section_type, 
              HomeSection.section_type_options,
              {}, class: "form-select" %>
        </div>

        <div class="col-md-6 mb-3">
          <%= f.label :order_position, "Ordem de Exibição", class: "form-label" %>
          <%= f.number_field :order_position, class: "form-control", value: @home_section.order_position || (@home_section.persisted? ? @home_section.order_position : HomeSection.maximum(:order_position).to_i + 1) %>
          <small class="text-muted">A ordem define a posição da seção na página inicial</small>
        </div>
      </div>

      <div class="mb-3">
        <%= f.label :title, "Título", class: "form-label" %>
        <%= f.text_field :title, class: "form-control", required: true %>
      </div>

      <div class="mb-3">
        <%= f.label :subtitle, "Subtítulo (opcional)", class: "form-label" %>
        <%= f.text_area :subtitle, rows: 2, class: "form-control" %>
      </div>

      <div class="form-check form-switch mb-3">
        <%= f.check_box :active, class: "form-check-input", role: "switch", checked: @home_section.persisted? ? @home_section.active : true %>
        <%= f.label :active, "Seção Ativa", class: "form-check-label" %>
        <small class="d-block text-muted">Seções inativas não aparecem na página inicial</small>
      </div>

      <% if @home_section.section_type.in?(%w[featured_properties opportunities developments rentals]) || !@home_section.persisted? %>
        <div class="border rounded-3 p-3 mb-3">
          <h6 class="fw-bold text-secondary mb-2">Filtros dos imóveis</h6>
          <p class="text-muted small mb-3">
            Estes filtros refinam a lista padrão deste tipo de seção. Deixe todos desmarcados para preservar o comportamento atual.
          </p>

          <div class="row g-2">
            <% HomeSection::PROPERTY_FILTER_OPTIONS.each do |key, option| %>
              <div class="col-md-6 col-lg-4">
                <label class="border rounded-3 px-3 py-2 w-100 d-flex align-items-center gap-2 bg-light">
                  <%= check_box_tag "home_section[property_filters][#{key}]",
                                    "1",
                                    @home_section.property_filter_enabled?(key),
                                    class: "form-check-input m-0" %>
                  <span class="fw-semibold"><%= option[:label] %></span>
                </label>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <div class="d-flex gap-2">
        <%= link_to "Cancelar", admin_home_sections_path, class: "btn btn-secondary" %>
        <%= f.submit @home_section.persisted? ? "Atualizar Seção" : "Criar Seção", class: "btn btn-primary" %>
      </div>
    </div>
  </div>
<% end %>
