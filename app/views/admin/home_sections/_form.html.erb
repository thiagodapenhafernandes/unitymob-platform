<%= form_with model: [:admin, @home_section], local: true do |f| %>
  <%= ax_error_summary(@home_section) %>

  <div class="ax-card">
    <div class="ax-card__body">
      <%= ax_field_grid do %>
        <div class="ax-span-6 tw-mb-3">
          <%= f.label :section_type, "Tipo de Seção", class: "ax-label" %>
          <%= f.select :section_type,
              HomeSection.section_type_options,
              {}, class: "ax-control" %>
        </div>

        <div class="ax-span-6 tw-mb-3">
          <%= f.label :order_position, "Ordem de Exibição", class: "ax-label" %>
          <%= f.number_field :order_position, class: "ax-control", value: @home_section.order_position || (@home_section.persisted? ? @home_section.order_position : HomeSection.maximum(:order_position).to_i + 1) %>
          <small class="tw-text-ink-muted">A ordem define a posição da seção na página inicial</small>
        </div>
      <% end %>

      <div class="tw-mb-3">
        <%= f.label :title, "Título", class: "ax-label" %>
        <%= f.text_field :title, class: "ax-control", required: true %>
      </div>

      <div class="tw-mb-3">
        <%= f.label :subtitle, "Subtítulo (opcional)", class: "ax-label" %>
        <%= f.text_area :subtitle, rows: 2, class: "ax-control" %>
      </div>

      <div class="tw-mb-3">
        <%= ax_switch_field(label: "Seção Ativa", form: f, method: :active, input_html: { role: "switch", checked: @home_section.persisted? ? @home_section.active : true }) %>
        <small class="tw-text-ink-muted">Seções inativas não aparecem na página inicial</small>
      </div>

      <% if @home_section.section_type.in?(%w[featured_properties opportunities developments rentals]) || !@home_section.persisted? %>
        <div class="border tw-rounded-lg tw-p-2 tw-mb-3">
          <h6 class="tw-font-bold tw-text-ink-muted tw-mb-2">Filtros dos imóveis</h6>
          <p class="ax-page-subtitle tw-mb-3">
            Estes filtros refinam a lista padrão deste tipo de seção. Deixe todos desmarcados para preservar o comportamento atual.
          </p>

          <%= ax_chip_grid do %>
            <% HomeSection::PROPERTY_FILTER_OPTIONS.each do |key, option| %>
              <%= ax_toggle_chip(
                    label: option[:label],
                    name: "home_section[property_filters][#{key}]",
                    checked: @home_section.property_filter_enabled?(key),
                    include_hidden: false,
                    class_name: "ax-toggle-chip--full"
                  ) %>
            <% end %>
          <% end %>
        </div>
      <% end %>

      <div class="tw-flex tw-gap-2">
        <%= link_to "Cancelar", admin_home_sections_path, class: "ax-btn ax-btn--ghost" %>
        <%= f.submit @home_section.persisted? ? "Atualizar Seção" : "Criar Seção", class: "ax-btn ax-btn--primary" %>
      </div>
    </div>
  </div>
<% end %>
