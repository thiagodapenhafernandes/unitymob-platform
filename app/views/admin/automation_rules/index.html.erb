<div class="automation-rules-admin">
  <%= ax_workspace_heading(
        eyebrow: "Automações · Acompanhamento",
        icon: "diagram-3",
        title: "Automação de acompanhamento",
        subtitle: "Crie intervenções horizontais para apoiar a jornada dos leads sem substituir a Distribuição de Leads.",
        metrics: [
          { value: @workflows.size, label: "fluxos" },
          { value: @rules.size, label: "regras" }
        ],
        actions: safe_join([
          ax_button("Eventos recentes", admin_automation_events_path, size: :sm, icon: "activity"),
          ax_button("Nova intervenção", new_admin_automation_rule_path, variant: :primary, size: :sm, icon: "diagram-3")
        ])
      ) %>

  <%= render "admin/shared/module_objective_notice",
        icon: "intersect",
        eyebrow: "Automação horizontal",
        description: "Use este módulo para criar intervenções que atravessam a jornada do lead sem assumir a distribuição primária: tarefas, lembretes, avisos, mensagens, notas, integrações e acompanhamentos quando alguma condição acontecer." %>

  <%= ax_dismissible_hint(key: "automacao", icon: "diagram-3",
        text: "A Distribuição de Leads continua dona de origem, destino, fila, corretor, aceite, represamento e horários. A automação observa estados e faz pequenas intervenções de apoio.") %>

  <% if @workflows.any? %>
    <%= ax_operational_panel(eyebrow: "Builder", title: "Fluxos recentes", class_name: "tw-mb-4") do %>
      <div class="ax-record-list">
        <% @workflows.each do |workflow| %>
          <% workflow_actions = capture do %>
            <% if workflow.whatsapp_campaign_source? %>
              <%= ax_button("Ver disparo", admin_whatsapp_campaign_path(workflow.whatsapp_campaign_source_id), size: :sm, icon: "megaphone") %>
            <% end %>
            <%= ax_button("Abrir builder", builder_admin_automation_workflow_path(workflow), size: :sm, icon: "pencil-square") %>
          <% end %>

          <%= ax_record_item(
                title: workflow.name,
                eyebrow: "Fluxo",
                meta: workflow.active_version ? "Versão publicada ##{workflow.active_version.version_number}" : "Rascunho ainda não publicado",
                icon: "diagram-3",
                actions: workflow_actions
              ) do %>
            <div class="tw-flex tw-flex-wrap tw-items-center tw-gap-2">
              <%= ax_badge(workflow.status_label, tone: workflow.status == "active" ? :green : :gray, dot: true) %>
              <% if workflow.whatsapp_campaign_source? %>
                <%= ax_badge("Disparo WhatsApp ##{workflow.whatsapp_campaign_source_id}", tone: :cyan) %>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <%= ax_operational_panel(eyebrow: "Intervenções", title: "Regras de acompanhamento", class_name: "tw-mb-4") do %>
    <% if @rules.any? %>
      <div class="ax-record-list">
        <% @rules.each do |rule| %>
          <% rule_actions = capture do %>
            <%= button_to toggle_active_admin_automation_rule_path(rule),
                          method: :patch,
                          form_class: "tw-inline",
                          class: "ax-ico-btn",
                          title: rule.active? ? "Pausar" : "Ativar",
                          aria: { label: "#{rule.active? ? 'Pausar' : 'Ativar'} #{rule.name}" } do %>
              <i class="bi <%= rule.active? ? "bi-pause-circle" : "bi-play-circle" %>"></i>
            <% end %>
            <%= link_to edit_admin_automation_rule_path(rule), class: "ax-ico-btn", title: "Editar", aria: { label: "Editar #{rule.name}" } do %>
              <i class="bi bi-pencil"></i>
            <% end %>
            <%= button_to admin_automation_rule_path(rule),
                          method: :delete,
                          form_class: "tw-inline",
                          class: "ax-ico-btn",
                          title: "Remover",
                          aria: { label: "Remover #{rule.name}" },
                          data: { turbo_confirm: "Remover esta regra?" } do %>
              <i class="bi bi-trash"></i>
            <% end %>
          <% end %>

          <%= ax_record_item(
                title: rule.name,
                eyebrow: "Regra",
                meta: ("#{rule.runs_count} execuções" if rule.runs_count.to_i.positive?),
                icon: "lightning-charge-fill",
                class_name: ("tw-opacity-60" unless rule.active?),
                actions: rule_actions
              ) do %>
            <div class="tw-grid tw-gap-2 tw-text-sm">
              <div class="tw-flex tw-flex-wrap tw-items-center tw-gap-2">
                <%= ax_badge(rule.active? ? "Ativa" : "Pausada", tone: rule.active? ? :green : :gray, dot: true) %>
                <%= ax_badge("QUANDO", tone: :blue) %>
                <span><%= rule.trigger_label.downcase %></span>
                <% if rule.conditions_hash[:stage].present? %><%= ax_badge("etapa: #{rule.conditions_hash[:stage]}", tone: :gray) %><% end %>
                <% if rule.conditions_hash[:source].present? %><%= ax_badge("origem: #{rule.conditions_hash[:source]}", tone: :gray) %><% end %>
                <% if rule.idle_hours.positive? %><%= ax_badge("+ #{rule.idle_hours}h parado", tone: :amber) %><% end %>
              </div>
              <div class="tw-flex tw-flex-wrap tw-items-center tw-gap-2">
                <%= ax_badge("INTERVENÇÃO", tone: :green) %>
                <% rule.actions_summary.each do |label| %>
                  <span class="tw-inline-flex tw-items-center tw-gap-1"><i class="bi bi-arrow-right-short"></i><%= label %></span>
                <% end %>
                <% if rule.actions_summary.empty? %><span class="ax-page-subtitle">sem ações</span><% end %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <%= ax_empty_state(
            title: "Nenhuma intervenção automatizada ainda",
            description: "Exemplo: quando um lead fica duas horas parado em Atendimento, criar tarefa e avisar o responsável.",
            icon: "lightning-charge",
            action: safe_join([
              ax_button("Criar intervenção", new_admin_automation_rule_path, variant: :primary, size: :sm),
              button_to("Criar regra de exemplo", create_example_admin_automation_rules_path, method: :post, class: "ax-btn ax-btn--sm")
            ])
          ) %>
    <% end %>
  <% end %>

  <% if @recent_runs.any? %>
    <%= ax_operational_panel(eyebrow: "Histórico", title: "Execuções recentes") do %>
      <div class="ax-table-wrap">
        <table class="ax-table">
          <thead>
            <tr>
              <th class="ax-table__col--w-150">Quando</th>
              <th>Regra</th>
              <th>Lead</th>
              <th class="ax-table__col--w-120">Status</th>
            </tr>
          </thead>
          <tbody>
            <% @recent_runs.each do |run| %>
              <% status_tone = { "executed" => :green, "scheduled" => :blue, "skipped" => :gray, "error" => :red }[run.status] || :gray %>
              <tr>
                <td><%= run.created_at.strftime("%d/%m %H:%M") %></td>
                <td><%= run.automation_rule&.name %></td>
                <td><%= run.lead ? link_to(run.lead.display_name, admin_lead_path(run.lead), class: "tw-text-primary") : "—" %></td>
                <td><%= ax_badge(run.status_label, tone: status_tone, dot: true) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  <% end %>
</div>
