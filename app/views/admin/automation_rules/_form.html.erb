<%# locals: rule, url, method %>
<%= form_with model: rule, url: url, method: local_assigns.fetch(:method, :post), scope: :automation_rule,
      data: { controller: "automation-builder", action: "submit->automation-builder#serialize" } do |f| %>
  <% if rule.errors.any? %>
    <%= ax_error_summary(rule) %>
  <% end %>

  <%= render "admin/shared/module_objective_notice",
        icon: "intersect",
        eyebrow: "Automação horizontal",
        description: "Configure pequenas intervenções de acompanhamento. A distribuição primária do lead, filas, responsáveis, aceite, represamento e horários continuam sendo configurados apenas em Distribuição de Leads." %>

  <%# Identificação + QUANDO %>
  <%= ax_operational_panel(eyebrow: "Configuração", title: "Identificação e gatilho", class_name: "tw-mb-4") do %>
      <%= ax_field_grid do %>
        <div class="ax-span-10">
          <label class="ax-label">Nome da regra</label>
          <%= f.text_field :name, class: "ax-control", placeholder: "Ex.: Resgate de lead frio" %>
        </div>
        <div class="ax-span-2 tw-flex tw-items-end">
          <%= ax_toggle_chip(f, :active, label: "Regra ativa") %>
        </div>
      <% end %>

      <%= ax_field_group(title: "Quando", token: "Gatilho", class_name: "ax-field-group--panel tw-mt-3") do %>
        <%= ax_field_grid do %>
        <div class="ax-span-4">
          <label class="ax-label">Evento</label>
          <%= f.select :trigger_event, AutomationRule::TRIGGERS.map { |k, v| [v, k] }, {}, class: "ax-control", data: { automation_builder_target: "trigger", action: "change->automation-builder#syncTrigger" } %>
        </div>
        <div class="ax-span-3">
          <label class="ax-label">Etapa do lead (opcional)</label>
          <select name="automation_rule[conditions][stage]" class="ax-control">
            <option value="">Qualquer etapa</option>
            <% @status_options.each do |s| %><option value="<%= s %>" <%= 'selected' if rule.conditions_hash[:stage].to_s == s %>><%= s %></option><% end %>
          </select>
        </div>
        <div class="ax-span-3">
          <label class="ax-label">Origem (opcional)</label>
          <select name="automation_rule[conditions][source]" class="ax-control">
            <option value="">Qualquer origem</option>
            <% @source_options.each do |s| %><option value="<%= s %>" <%= 'selected' if rule.conditions_hash[:source].to_s == s %>><%= s %></option><% end %>
          </select>
        </div>
        <div class="ax-span-2" data-automation-builder-target="idleCond">
          <label class="ax-label">Parado há (horas)</label>
          <input type="number" name="automation_rule[conditions][idle_hours]" class="ax-control" placeholder="48" value="<%= rule.idle_hours.positive? ? rule.idle_hours : nil %>">
        </div>
        <% end %>
      <% end %>
  <% end %>

  <%# ENTÃO — ações %>
  <%= ax_operational_panel(
        eyebrow: "Execução",
        title: "Intervenções",
        class_name: "tw-mb-4",
        actions: button_tag(type: "button", class: "ax-btn ax-btn--sm", data: { action: "automation-builder#addRow" }) { safe_join([tag.i(class: "bi bi-plus-lg ax-ico"), tag.span("Adicionar intervenção")]) }
      ) do %>

      <div data-automation-builder-target="rows">
        <% rule.action_list.each do |a| %>
          <%= render "action_row", action: a %>
        <% end %>
      </div>

      <template data-automation-builder-target="template"><%= render "action_row", action: {} %></template>
      <%= hidden_field_tag "automation_rule[actions_json]", rule.actions.to_json, data: { automation_builder_target: "json" } %>
      <p class="ax-page-subtitle tw-mt-2"><i class="bi bi-info-circle"></i> Use <strong>Esperar (nutrição)</strong> entre intervenções para acompanhar o lead ao longo de dias.</p>
  <% end %>

  <% if @simulation_result %>
    <%= ax_operational_panel(eyebrow: "Prévia", title: "Resultado da simulação", class_name: "tw-mb-4") do %>
        <div class="tw-flex tw-items-start tw-gap-3">
          <i class="bi bi-search tw-text-primary" aria-hidden="true"></i>
          <div>
            <h2 class="ax-page-title tw-text-base tw-mb-1"><%= @simulation_result.title %></h2>
            <p class="ax-page-subtitle tw-mb-2"><%= @simulation_result.summary %></p>
            <div class="tw-flex tw-flex-wrap tw-gap-2 tw-mb-2">
              <% @simulation_result.actions.each do |label| %>
                <%= ax_badge(label, tone: :green) %>
              <% end %>
            </div>
            <% if @simulation_result.sample_leads.any? %>
              <p class="ax-page-subtitle tw-mb-2"><strong>Amostra:</strong> <%= @simulation_result.sample_leads.map(&:display_name).to_sentence %></p>
            <% end %>
            <% @simulation_result.warnings.each do |warning| %>
              <%= ax_inline_notice(tone: :warning, icon: "info-circle", class_name: "tw-mb-1") { warning } %>
            <% end %>
          </div>
        </div>
    <% end %>
  <% end %>

  <%= ax_form_actions do %>
    <%= link_to "Cancelar", admin_automation_rules_path, class: "ax-btn ax-btn--sm" %>
    <%= button_tag type: "submit",
          formaction: (rule.persisted? ? simulate_admin_automation_rule_path(rule) : simulate_admin_automation_rules_path),
          formmethod: :post,
          class: "ax-btn ax-btn--sm" do %>
      <i class="bi bi-search ax-ico"></i><span>Simular</span>
    <% end %>
    <%= f.submit "Salvar regra", class: "ax-btn ax-btn--sm ax-btn--primary" %>
  <% end %>
<% end %>
