<div class="public-site-workspace">
  <%= ax_workspace_heading(
        eyebrow: "Site público · Estrutura",
        icon: "telephone",
        title: "Contato",
        subtitle: "Gerencie canais de atendimento e redes sociais exibidos no site.",
        actions: ax_button("Voltar", admin_root_path, variant: :ghost, size: :sm, icon: "arrow-left")
      ) %>

  <%= form_with(model: @contact_setting, url: admin_contact_setting_path, method: :patch) do |f| %>
    <%= ax_error_summary(@contact_setting) %>

    <%= ax_field_grid do %>
      <div class="ax-span-6">
        <%= ax_operational_panel(eyebrow: "Atendimento", title: "Contato principal") do %>
          <div class="tw-grid tw-gap-4">
            <div class="ax-field">
              <%= ax_field_label(f, :whatsapp_primary, text: "WhatsApp principal") %>
              <%= ax_input_group(prefix: tag.i(class: "bi bi-whatsapp tw-text-green-600", aria: { hidden: true })) do %>
                <%= f.text_field :whatsapp_primary, class: "ax-control", placeholder: "(47) 99123-4567", autocomplete: "tel", data: { controller: "phone-input" } %>
              <% end %>
              <p class="ax-field__hint">Formato: código do país + DDD + número.</p>
            </div>

            <div class="ax-field">
              <%= ax_field_label(f, :phone, text: "Telefone fixo") %>
              <%= ax_input_group(prefix: tag.i(class: "bi bi-telephone tw-text-primary", aria: { hidden: true })) do %>
                <%= f.text_field :phone, class: "ax-control", placeholder: "(47) 3311-1067", autocomplete: "tel", data: { controller: "phone-input" } %>
              <% end %>
              <p class="ax-field__hint">Telefone fixo da empresa.</p>
            </div>

            <div class="ax-field">
              <%= ax_field_label(f, :email_primary, text: "E-mail principal") %>
              <%= ax_input_group(prefix: tag.i(class: "bi bi-envelope tw-text-red-600", aria: { hidden: true })) do %>
                <%= f.email_field :email_primary, class: "ax-control", placeholder: "contato@saluteimoveis.com" %>
              <% end %>
              <p class="ax-field__hint">E-mail principal para contato.</p>
            </div>

            <div class="ax-field">
              <div class="tw-flex tw-items-center tw-gap-2">
                <%= ax_field_label(f, :whatsapp_secondary, text: "WhatsApp secundário") %>
                <%= ax_badge("Opcional", tone: :gray) %>
              </div>
              <%= ax_input_group(prefix: tag.i(class: "bi bi-whatsapp tw-text-green-600", aria: { hidden: true })) do %>
                <%= f.text_field :whatsapp_secondary, class: "ax-control", placeholder: "(47) 99123-4567", autocomplete: "tel", data: { controller: "phone-input" } %>
              <% end %>
              <p class="ax-field__hint">Canal alternativo de WhatsApp.</p>
            </div>
          </div>
        <% end %>
      </div>

      <div class="ax-span-6">
        <%= ax_operational_panel(eyebrow: "Presença digital", title: "Redes sociais") do %>
          <div class="tw-grid tw-gap-4">
            <div class="ax-field">
              <%= ax_field_label(f, :facebook_url, text: "Facebook") %>
              <%= ax_input_group(prefix: tag.i(class: "bi bi-facebook tw-text-primary", aria: { hidden: true })) do %>
                <%= f.url_field :facebook_url, class: "ax-control", placeholder: "https://facebook.com/saluteimoveis" %>
              <% end %>
              <p class="ax-field__hint">URL completa da página do Facebook.</p>
            </div>

            <div class="ax-field">
              <%= ax_field_label(f, :instagram_url, text: "Instagram") %>
              <%= ax_input_group(prefix: tag.i(class: "bi bi-instagram tw-text-red-600", aria: { hidden: true })) do %>
                <%= f.url_field :instagram_url, class: "ax-control", placeholder: "https://instagram.com/saluteimoveis" %>
              <% end %>
              <p class="ax-field__hint">URL completa do perfil do Instagram.</p>
            </div>

            <div class="ax-field">
              <%= ax_field_label(f, :youtube_url, text: "YouTube") %>
              <%= ax_input_group(prefix: tag.i(class: "bi bi-youtube tw-text-red-600", aria: { hidden: true })) do %>
                <%= f.url_field :youtube_url, class: "ax-control", placeholder: "https://youtube.com/@saluteimoveis" %>
              <% end %>
              <p class="ax-field__hint">URL completa do canal do YouTube.</p>
            </div>

            <div class="ax-field">
              <%= ax_field_label(f, :linkedin_url, text: "LinkedIn") %>
              <%= ax_input_group(prefix: tag.i(class: "bi bi-linkedin tw-text-primary", aria: { hidden: true })) do %>
                <%= f.url_field :linkedin_url, class: "ax-control", placeholder: "https://linkedin.com/company/saluteimoveis" %>
              <% end %>
              <p class="ax-field__hint">URL completa da página do LinkedIn.</p>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <%= ax_sticky_action_footer(meta: safe_join([tag.i(class: "bi bi-shield-check tw-text-green-600", aria: { hidden: true }), tag.span("As informações serão atualizadas em todo o site")], " ")) do %>
      <%= f.submit "Salvar configurações", class: "ax-btn ax-btn--primary", data: { disable_with: "Salvando..." } %>
    <% end %>
  <% end %>
</div>
