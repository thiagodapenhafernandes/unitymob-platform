<div class="container-fluid py-4">
  <!-- Header -->
  <div class="tw-flex tw-justify-between tw-items-center tw-mb-4">
    <div>
      <h1 class="ax-page-title tw-mb-1"><i class="bi bi-telephone-fill"></i> Informações de Contato</h1>
      <p class="ax-page-subtitle">Configure os canais de comunicação da empresa</p>
    </div>
    <%= link_to 'Voltar', admin_root_path, class: 'ax-btn ax-btn--ghost' %>
  </div>

  <%= form_with(model: @contact_setting, url: admin_contact_setting_path, method: :patch) do |f| %>
    <%= ax_error_summary(@contact_setting) %>

    <div class="tw-grid tw-gap-4" style="grid-template-columns: repeat(12, minmax(0, 1fr));">
      <!-- Contact Information -->
      <div class="ax-span-6">
        <div class="ax-card h-100">
          <div class="ax-card__header bg-primary bg-opacity-10">
            <h5 class="ax-card__title tw-mb-0 tw-text-primary tw-flex tw-items-center tw-gap-2">
              <i class="bi bi-person-lines-fill"></i>Contato Principal
            </h5>
          </div>
          <div class="ax-card__body">
            <!-- WhatsApp Primary -->
            <div class="tw-mb-4">
              <%= f.label :whatsapp_primary, class: "ax-label tw-font-bold tw-flex tw-items-center tw-gap-2" do %>
                <i class="bi bi-whatsapp" style="color:#16a34a"></i>WhatsApp Principal
              <% end %>
              <div class="tw-flex tw-items-center">
                <span class="bg-success bg-opacity-10">
                  <i class="bi bi-whatsapp" style="color:#16a34a"></i>
                </span>
                <%= f.text_field :whatsapp_primary, class: "ax-control", placeholder: "5547991234567" %>
              </div>
              <small class="tw-text-ink-muted">Formato: código do país + DDD + número (sem espaços)</small>
            </div>

            <!-- Phone -->
            <div class="tw-mb-4">
              <%= f.label :phone, class: "ax-label tw-font-bold tw-flex tw-items-center tw-gap-2" do %>
                <i class="bi bi-telephone tw-text-primary"></i>Telefone Fixo
              <% end %>
              <div class="tw-flex tw-items-center">
                <span class="bg-primary bg-opacity-10">
                  <i class="bi bi-telephone tw-text-primary"></i>
                </span>
                <%= f.text_field :phone, class: "ax-control", placeholder: "(47) 3311-1067" %>
              </div>
              <small class="tw-text-ink-muted">Telefone fixo da empresa</small>
            </div>

            <!-- Email -->
            <div class="tw-mb-4">
              <%= f.label :email_primary, class: "ax-label tw-font-bold tw-flex tw-items-center tw-gap-2" do %>
                <i class="bi bi-envelope" style="color:#dc2626"></i>Email Principal
              <% end %>
              <div class="tw-flex tw-items-center">
                <span class="bg-danger bg-opacity-10">
                  <i class="bi bi-envelope" style="color:#dc2626"></i>
                </span>
                <%= f.email_field :email_primary, class: "ax-control", placeholder: "contato@saluteimoveis.com" %>
              </div>
              <small class="tw-text-ink-muted">Email principal para contato</small>
            </div>

            <!-- WhatsApp Secondary -->
            <div class="tw-mb-0">
              <%= f.label :whatsapp_secondary, class: "ax-label tw-font-bold tw-flex tw-items-center tw-gap-2" do %>
                <i class="bi bi-whatsapp" style="color:#16a34a"></i>WhatsApp Secundário
                <span class="ax-badge ax-badge--gray">Opcional</span>
              <% end %>
              <div class="tw-flex tw-items-center">
                <span class="bg-success bg-opacity-10">
                  <i class="bi bi-whatsapp" style="color:#16a34a"></i>
                </span>
                <%= f.text_field :whatsapp_secondary, class: "ax-control", placeholder: "5547991234567" %>
              </div>
              <small class="tw-text-ink-muted">WhatsApp alternativo (opcional)</small>
            </div>
          </div>
        </div>
      </div>

      <!-- Social Media -->
      <div class="ax-span-6">
        <div class="ax-card h-100">
          <div class="ax-card__header bg-info bg-opacity-10">
            <h5 class="ax-card__title tw-mb-0 tw-flex tw-items-center tw-gap-2" style="color:var(--admin-primary)">
              <i class="bi bi-share-fill"></i>Redes Sociais
            </h5>
          </div>
          <div class="ax-card__body">
            <!-- Facebook -->
            <div class="tw-mb-4">
              <%= f.label :facebook_url, class: "ax-label tw-font-bold tw-flex tw-items-center tw-gap-2" do %>
                <i class="bi bi-facebook tw-text-primary"></i>Facebook
              <% end %>
              <div class="tw-flex tw-items-center">
                <span class="bg-primary bg-opacity-10">
                  <i class="bi bi-facebook tw-text-primary"></i>
                </span>
                <%= f.url_field :facebook_url, class: "ax-control", placeholder: "https://facebook.com/saluteimoveis" %>
              </div>
              <small class="tw-text-ink-muted">URL completa da página do Facebook</small>
            </div>

            <!-- Instagram -->
            <div class="tw-mb-4">
              <%= f.label :instagram_url, class: "ax-label tw-font-bold tw-flex tw-items-center tw-gap-2" do %>
                <i class="bi bi-instagram" style="color:#dc2626"></i>Instagram
              <% end %>
              <div class="tw-flex tw-items-center">
                <span class="bg-danger bg-opacity-10">
                  <i class="bi bi-instagram" style="color:#dc2626"></i>
                </span>
                <%= f.url_field :instagram_url, class: "ax-control", placeholder: "https://instagram.com/saluteimoveis" %>
              </div>
              <small class="tw-text-ink-muted">URL completa do perfil do Instagram</small>
            </div>

            <!-- YouTube -->
            <div class="tw-mb-4">
              <%= f.label :youtube_url, class: "ax-label tw-font-bold tw-flex tw-items-center tw-gap-2" do %>
                <i class="bi bi-youtube" style="color:#dc2626"></i>YouTube
              <% end %>
              <div class="tw-flex tw-items-center">
                <span class="bg-danger bg-opacity-10">
                  <i class="bi bi-youtube" style="color:#dc2626"></i>
                </span>
                <%= f.url_field :youtube_url, class: "ax-control", placeholder: "https://youtube.com/@saluteimoveis" %>
              </div>
              <small class="tw-text-ink-muted">URL completa do canal do YouTube</small>
            </div>

            <!-- LinkedIn -->
            <div class="tw-mb-0">
              <%= f.label :linkedin_url, class: "ax-label tw-font-bold tw-flex tw-items-center tw-gap-2" do %>
                <i class="bi bi-linkedin tw-text-primary"></i>LinkedIn
              <% end %>
              <div class="tw-flex tw-items-center">
                <span class="bg-primary bg-opacity-10">
                  <i class="bi bi-linkedin tw-text-primary"></i>
                </span>
                <%= f.url_field :linkedin_url, class: "ax-control", placeholder: "https://linkedin.com/company/saluteimoveis" %>
              </div>
              <small class="tw-text-ink-muted">URL completa da página do LinkedIn</small>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Preview Section -->
    <div class="ax-card tw-mt-4">
      <div class="ax-card__header bg-warning bg-opacity-10">
        <h5 class="ax-card__title tw-mb-0 tw-flex tw-items-center tw-gap-2" style="color:#d97706">
          <i class="bi bi-eye-fill"></i>Preview dos Links
        </h5>
      </div>
      <div class="ax-card__body">
        <%= ax_field_grid do %>
          <div class="ax-span-3">
            <div class="tw-flex tw-items-center p-3 bg-light rounded tw-gap-3">
              <i class="bi bi-whatsapp" style="color:#16a34a; font-size: 1.75rem;"></i>
              <div>
                <small class="tw-text-ink-muted d-block">WhatsApp</small>
                <strong style="color:#16a34a"><%= @contact_setting.whatsapp_primary || "Não configurado" %></strong>
              </div>
            </div>
          </div>
          <div class="ax-span-3">
            <div class="tw-flex tw-items-center p-3 bg-light rounded tw-gap-3">
              <i class="bi bi-telephone tw-text-primary" style="font-size: 1.75rem;"></i>
              <div>
                <small class="tw-text-ink-muted d-block">Telefone</small>
                <strong class="tw-text-primary"><%= @contact_setting.phone || "Não configurado" %></strong>
              </div>
            </div>
          </div>
          <div class="ax-span-6">
            <div class="tw-flex tw-items-center p-3 bg-light rounded tw-gap-3">
              <i class="bi bi-envelope" style="color:#dc2626; font-size: 1.75rem;"></i>
              <div class="flex-grow-1">
                <small class="tw-text-ink-muted d-block">Email</small>
                <strong class="text-truncate d-block" style="color:#dc2626"><%= @contact_setting.email_primary || "Não configurado" %></strong>
              </div>
            </div>
          </div>
        <% end %>

        <%= ax_field_grid(class_name: "tw-mt-2") do %>
          <div class="ax-span-12">
            <p class="tw-text-ink-muted tw-mb-2 tw-flex tw-items-center tw-gap-2"><i class="bi bi-share"></i>Redes Sociais Configuradas:</p>
            <div class="tw-flex tw-gap-2 tw-flex-wrap">
              <% if @contact_setting.facebook_url.present? %>
                <a href="<%= @contact_setting.facebook_url %>" target="_blank" class="ax-btn ax-btn--ghost ax-btn--sm tw-flex tw-items-center tw-gap-1">
                  <i class="bi bi-facebook"></i>Facebook
                </a>
              <% end %>
              <% if @contact_setting.instagram_url.present? %>
                <a href="<%= @contact_setting.instagram_url %>" target="_blank" class="ax-btn ax-btn--danger ax-btn--sm tw-flex tw-items-center tw-gap-1">
                  <i class="bi bi-instagram"></i>Instagram
                </a>
              <% end %>
              <% if @contact_setting.youtube_url.present? %>
                <a href="<%= @contact_setting.youtube_url %>" target="_blank" class="ax-btn ax-btn--danger ax-btn--sm tw-flex tw-items-center tw-gap-1">
                  <i class="bi bi-youtube"></i>YouTube
                </a>
              <% end %>
              <% if @contact_setting.linkedin_url.present? %>
                <a href="<%= @contact_setting.linkedin_url %>" target="_blank" class="ax-btn ax-btn--ghost ax-btn--sm tw-flex tw-items-center tw-gap-1">
                  <i class="bi bi-linkedin"></i>LinkedIn
                </a>
              <% end %>
              <% if [@contact_setting.facebook_url, @contact_setting.instagram_url, @contact_setting.youtube_url, @contact_setting.linkedin_url].all?(&:blank?) %>
                <span class="tw-text-ink-muted fst-italic">Nenhuma rede social configurada</span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Info Alert -->
    <%= ax_inline_notice(tone: :info, icon: "info-circle") do %>
      <strong>Importante:</strong> Essas informações são exibidas no footer do site e na página de contato. Certifique-se de que todos os links estejam corretos e funcionando.
    <% end %>

    <!-- Save Button -->
    <div class="tw-flex tw-justify-between tw-items-center tw-mt-4 p-4 bg-light rounded tw-gap-2">
      <div class="tw-flex tw-items-center tw-gap-2">
        <i class="bi bi-shield-check" style="color:#16a34a"></i>
        <span class="tw-text-ink-muted">As informações serão atualizadas em todo o site</span>
      </div>
      <%= f.submit "Salvar Configurações", class: "ax-btn ax-btn--primary", style: "padding-left: 3rem; padding-right: 3rem;", data: { disable_with: "Salvando..." } %>
    </div>
  <% end %>
</div>
