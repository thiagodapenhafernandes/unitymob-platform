<div class="public-site-workspace">
  <%= ax_workspace_heading(eyebrow: "Site público · Estrutura", icon: "layout-sidebar", title: "Rodapé", subtitle: "Gerencie colunas, links, lojas, redes e informações legais.", actions: ax_button("Voltar", admin_root_path, variant: :ghost, size: :sm, icon: "arrow-left")) %>

  <%# Remove extra admin-content wrapper to avoid redundant margins %>
  <%= form_with(model: [:admin, @footer_setting], local: true, class: "needs-validation") do |f| %>
    <%= ax_error_summary(@footer_setting) %>

    <%= ax_operational_panel(eyebrow: "Estrutura pública", title: "Conteúdo do rodapé") do %>
        <ul class="ax-form-tabs" id="footerTabs" role="tablist" data-controller="ax-tabs" data-ax-tabs-panel-selector-value="#footerTabsContent">
          <li>
            <button class="ax-form-tabs__item active" id="general-tab" data-ax-tabs-target="tab" data-ax-tabs-target-param="#general" data-action="click->ax-tabs#select" type="button" role="tab" aria-controls="general" aria-selected="true" tabindex="0">
              <i class="bi bi-gear-fill"></i>Geral & Títulos
            </button>
          </li>
          <li>
            <button class="ax-form-tabs__item" id="links-tab" data-ax-tabs-target="tab" data-ax-tabs-target-param="#links" data-action="click->ax-tabs#select" type="button" role="tab" aria-controls="links" aria-selected="false" tabindex="-1">
              <i class="bi bi-link-45deg"></i>Links Rápidos
            </button>
          </li>
          <li>
            <button class="ax-form-tabs__item" id="stores-tab" data-ax-tabs-target="tab" data-ax-tabs-target-param="#stores" data-action="click->ax-tabs#select" type="button" role="tab" aria-controls="stores" aria-selected="false" tabindex="-1">
              <i class="bi bi-geo-alt-fill"></i>Nossas Lojas
            </button>
          </li>
          <li>
            <button class="ax-form-tabs__item" id="social-tab" data-ax-tabs-target="tab" data-ax-tabs-target-param="#social" data-action="click->ax-tabs#select" type="button" role="tab" aria-controls="social" aria-selected="false" tabindex="-1">
              <i class="bi bi-share-fill"></i>Redes Sociais
            </button>
          </li>
        </ul>
        <div class="ax-form-tabs__panels" id="footerTabsContent">
          
          <!-- Tab: Geral & Títulos -->
          <div class="ax-form-tabs__panel active show" id="general" role="tabpanel" aria-labelledby="general-tab" aria-hidden="false" tabindex="0">
            <%= ax_field_grid(columns: 12, gap: :compact) do %>
              <div class="ax-span-6">
                <div class="ax-card tw-h-full">
                  <div class="ax-card__header">
                    <h5 class="ax-card__title">Sobre a Empresa (Coluna 1)</h5>
                  </div>
                  <div class="ax-card__body">
                    <div class="tw-mb-3">
                      <%= ax_text_field(form: f, method: :about_title, label: "Título da coluna", placeholder: "Ex: Salute Imóveis") %>
                    </div>
                    <div>
                      <%= ax_text_field(form: f, method: :about_text, label: "Texto 'Sobre nós'", type: :textarea,
                            rows: 4, placeholder: "Breve descrição da imobiliária...") %>
                    </div>
                  </div>
                </div>
              </div>

              <div class="ax-span-6">
                <div class="ax-card tw-h-full">
                  <div class="ax-card__header">
                    <h5 class="ax-card__title">Títulos das Colunas 2, 3 e 4</h5>
                  </div>
                  <div class="ax-card__body">
                    <div class="tw-mb-3">
                      <%= ax_text_field(form: f, method: :links_title, label: "Título coluna 2 (Links)", placeholder: "Ex: Links Rápidos") %>
                    </div>
                    <div class="tw-mb-3">
                      <%= ax_text_field(form: f, method: :stores_title, label: "Título coluna 3 (Lojas)", placeholder: "Ex: Nossas Lojas") %>
                    </div>
                    <div>
                      <%= ax_text_field(form: f, method: :contact_title, label: "Título coluna 4 (Contato)", placeholder: "Ex: Contato") %>
                    </div>
                  </div>
                </div>
              </div>

              <div class="ax-span-12">
                <div class="ax-card">
                  <div class="ax-card__header">
                    <h5 class="ax-card__title">Informações Globais & Rodapé</h5>
                  </div>
                  <div class="ax-card__body">
                    <%= ax_field_grid(columns: 12, gap: :compact) do %>
                      <div class="ax-span-6 tw-mb-3">
                        <%= ax_field_label(f, :whatsapp, text: "WhatsApp de contato") %>
                        <%= ax_input_group(prefix: tag.i(class: "bi bi-whatsapp footer-contact-icon footer-contact-icon--whatsapp")) do %>
                          <%= f.telephone_field :whatsapp,
                                                class: "ax-control",
                                                placeholder: "(47) 98863-0198",
                                                data: { controller: "phone-input" } %>
                        <% end %>
                      </div>
                      <div class="ax-span-6 tw-mb-3">
                        <%= ax_field_label(f, :email, text: "E-mail de contato") %>
                        <%= ax_input_group(prefix: tag.i(class: "bi bi-envelope footer-contact-icon footer-contact-icon--email")) do %>
                          <%= f.email_field :email, class: "ax-control", placeholder: "exemplo@email.com" %>
                        <% end %>
                      </div>
                      <div class="ax-span-12">
                        <%= ax_text_field(form: f, method: :copyright_text, label: "Texto de copyright (barra inferior)",
                              placeholder: "© 2026 Salute Imóveis...") %>
                      </div>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>

          <!-- Tab: Links Rápidos -->
          <div class="ax-form-tabs__panel" id="links" role="tabpanel" aria-labelledby="links-tab" aria-hidden="true" tabindex="0" hidden>
            <div data-controller="nested-form" data-nested-form-wrapper-selector-value=".nested-fields">
              <div class="tw-flex tw-justify-between tw-items-center tw-mb-3">
                <h5 class="tw-mb-0 tw-flex tw-items-center tw-gap-2"><i class="bi bi-link-45deg"></i>Gerenciar Links Rápidos</h5>
                <button type="button" class="ax-btn ax-btn--primary ax-btn--sm tw-gap-2" data-action="nested-form#add">
                  <i class="bi bi-plus-circle"></i> Adicionar Link
                </button>
              </div>

              <template data-nested-form-target="template">
                <%= f.fields_for :footer_links, FooterLink.new, child_index: 'NEW_RECORD' do |link_f| %>
                  <%= render 'footer_link_fields', f: link_f %>
                <% end %>
              </template>

              <div class="tw-flex tw-flex-col tw-gap-3" data-nested-form-target="container">
                <%= f.fields_for :footer_links do |link_f| %>
                  <%= render 'footer_link_fields', f: link_f %>
                <% end %>
              </div>
            </div>
          </div>

          <!-- Tab: Nossas Lojas -->
          <div class="ax-form-tabs__panel" id="stores" role="tabpanel" aria-labelledby="stores-tab" aria-hidden="true" tabindex="0" hidden>
            <div data-controller="nested-form" data-nested-form-wrapper-selector-value=".nested-fields">
              <div class="tw-flex tw-justify-between tw-items-center tw-mb-3">
                <h5 class="tw-mb-0 tw-flex tw-items-center tw-gap-2"><i class="bi bi-geo-alt-fill"></i>Gerenciar Unidades / Lojas</h5>
                <button type="button" class="ax-btn ax-btn--primary ax-btn--sm tw-gap-2" data-action="nested-form#add">
                  <i class="bi bi-plus-circle"></i> Adicionar Loja
                </button>
              </div>

              <template data-nested-form-target="template">
                <%= f.fields_for :footer_stores, FooterStore.new, child_index: 'NEW_RECORD' do |store_f| %>
                  <%= render 'footer_store_fields', f: store_f %>
                <% end %>
              </template>

              <div class="tw-flex tw-flex-col tw-gap-3" data-nested-form-target="container">
                <%= f.fields_for :footer_stores do |store_f| %>
                  <%= render 'footer_store_fields', f: store_f %>
                <% end %>
              </div>
            </div>
          </div>

          <!-- Tab: Redes Sociais -->
          <div class="ax-form-tabs__panel" id="social" role="tabpanel" aria-labelledby="social-tab" aria-hidden="true" tabindex="0" hidden>
            <div data-controller="nested-form" data-nested-form-wrapper-selector-value=".nested-fields">
              <div class="tw-flex tw-justify-between tw-items-center tw-mb-3">
                <h5 class="tw-mb-0 tw-flex tw-items-center tw-gap-2"><i class="bi bi-share-fill"></i>Ícones de Redes Sociais</h5>
                <button type="button" class="ax-btn ax-btn--primary ax-btn--sm tw-gap-2" data-action="nested-form#add">
                  <i class="bi bi-plus-circle"></i> Adicionar Rede Social
                </button>
              </div>

              <template data-nested-form-target="template">
                <%= f.fields_for :footer_social_links, FooterSocialLink.new, child_index: 'NEW_RECORD' do |social_f| %>
                  <%= render 'footer_social_link_fields', f: social_f %>
                <% end %>
              </template>

              <div class="tw-flex tw-flex-col tw-gap-3" data-nested-form-target="container">
                <%= f.fields_for :footer_social_links do |social_f| %>
                  <%= render 'footer_social_link_fields', f: social_f %>
                <% end %>
              </div>
            </div>
          </div>

        </div>

        <%= ax_form_actions(sticky: false, submit_label: "Salvar configurações", form: f) %>
    <% end %>
  <% end %>
</div>
