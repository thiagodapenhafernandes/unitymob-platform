<div class="admin-header">
  <div class="header-body">
    <div class="tw-flex tw-items-end tw-justify-between tw-gap-3">
      <div>
        <h6 class="header-pretitle">Administração</h6>
        <h1 class="ax-page-title">Configurações do Rodapé</h1>
      </div>
      <div>
        <%= link_to admin_root_path, class: "ax-btn ax-btn--ghost tw-gap-2" do %>
          <i class="bi bi-arrow-left"></i> Voltar
        <% end %>
      </div>
    </div>
  </div>
</div>

  <%# Remove extra admin-content wrapper to avoid redundant margins %>
  <%= form_with(model: [:admin, @footer_setting], local: true, class: "needs-validation") do |f| %>
    <%= ax_error_summary(@footer_setting) %>

    <!-- Tabs Card -->
    <div class="ax-card">
      <div class="ax-card__header">
        <ul class="ax-form-tabs" id="footerTabs" role="tablist" data-controller="ax-tabs" data-ax-tabs-panel-selector-value="#footerTabsContent">
          <li>
            <button class="ax-form-tabs__item active" id="general-tab" data-ax-tabs-target="tab" data-ax-tabs-target-param="#general" data-action="click->ax-tabs#select" type="button" role="tab">
              <i class="bi bi-gear-fill"></i>Geral & Títulos
            </button>
          </li>
          <li>
            <button class="ax-form-tabs__item" id="links-tab" data-ax-tabs-target="tab" data-ax-tabs-target-param="#links" data-action="click->ax-tabs#select" type="button" role="tab">
              <i class="bi bi-link-45deg"></i>Links Rápidos
            </button>
          </li>
          <li>
            <button class="ax-form-tabs__item" id="stores-tab" data-ax-tabs-target="tab" data-ax-tabs-target-param="#stores" data-action="click->ax-tabs#select" type="button" role="tab">
              <i class="bi bi-geo-alt-fill"></i>Nossas Lojas
            </button>
          </li>
          <li>
            <button class="ax-form-tabs__item" id="social-tab" data-ax-tabs-target="tab" data-ax-tabs-target-param="#social" data-action="click->ax-tabs#select" type="button" role="tab">
              <i class="bi bi-share-fill"></i>Redes Sociais
            </button>
          </li>
        </ul>
      </div>

      <div class="ax-card__body">
        <div class="tab-content" id="footerTabsContent">
          
          <!-- Tab: Geral & Títulos -->
          <div class="tab-pane fade show active" id="general" role="tabpanel">
            <%= ax_field_grid(columns: 12, gap: :compact) do %>
              <div class="ax-span-6">
                <div class="ax-card tw-h-full">
                  <div class="ax-card__header">
                    <h5 class="ax-card__title">Sobre a Empresa (Coluna 1)</h5>
                  </div>
                  <div class="ax-card__body">
                    <div class="tw-mb-3">
                      <%= f.label :about_title, "Título da Coluna", class: "ax-label" %>
                      <%= f.text_field :about_title, class: "ax-control", placeholder: "Ex: Salute Imóveis" %>
                    </div>
                    <div>
                      <%= f.label :about_text, "Texto 'Sobre Nós'", class: "ax-label" %>
                      <%= f.text_area :about_text, rows: 4, class: "ax-control", placeholder: "Breve descrição da imobiliária..." %>
                    </div>
                  </div>
                </div>
              </div>

              <div class="ax-span-6">
                <div class="ax-card tw-h-full">
                  <div class="ax-card__header">
                    <h5 class="ax-card__title">Títulos das Colunas 2, 3 e 4</h5>
                  </div>
                  <div class="ax-card__body">
                    <div class="tw-mb-3">
                      <%= f.label :links_title, "Título Coluna 2 (Links)", class: "ax-label" %>
                      <%= f.text_field :links_title, class: "ax-control", placeholder: "Ex: Links Rápidos" %>
                    </div>
                    <div class="tw-mb-3">
                      <%= f.label :stores_title, "Título Coluna 3 (Lojas)", class: "ax-label" %>
                      <%= f.text_field :stores_title, class: "ax-control", placeholder: "Ex: Nossas Lojas" %>
                    </div>
                    <div>
                      <%= f.label :contact_title, "Título Coluna 4 (Contato)", class: "ax-label" %>
                      <%= f.text_field :contact_title, class: "ax-control", placeholder: "Ex: Contato" %>
                    </div>
                  </div>
                </div>
              </div>

              <div class="ax-span-12">
                <div class="ax-card">
                  <div class="ax-card__header">
                    <h5 class="ax-card__title">Informações Globais & Rodapé</h5>
                  </div>
                  <div class="ax-card__body">
                    <%= ax_field_grid(columns: 12, gap: :compact) do %>
                      <div class="ax-span-6 tw-mb-3">
                        <%= f.label :whatsapp, "WhatsApp de Contato", class: "ax-label" %>
                        <%= ax_input_group(prefix: tag.i(class: "bi bi-whatsapp", style: "color: #16a34a;")) do %>
                          <%= f.telephone_field :whatsapp,
                                                class: "ax-control",
                                                placeholder: "(47) 98863-0198",
                                                data: { controller: "phone-input" } %>
                        <% end %>
                      </div>
                      <div class="ax-span-6 tw-mb-3">
                        <%= f.label :email, "E-mail de Contato", class: "ax-label" %>
                        <%= ax_input_group(prefix: tag.i(class: "bi bi-envelope", style: "color: var(--admin-primary);")) do %>
                          <%= f.email_field :email, class: "ax-control", placeholder: "exemplo@email.com" %>
                        <% end %>
                      </div>
                      <div class="ax-span-12">
                        <%= f.label :copyright_text, "Texto de Copyright (Barra Inferior)", class: "ax-label" %>
                        <%= f.text_field :copyright_text, class: "ax-control", placeholder: "© 2026 Salute Imóveis..." %>
                      </div>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>

          <!-- Tab: Links Rápidos -->
          <div class="tab-pane fade" id="links" role="tabpanel">
            <div data-controller="nested-form" data-nested-form-wrapper-selector-value=".nested-fields">
              <div class="tw-flex tw-justify-between tw-items-center tw-mb-3">
                <h5 class="tw-mb-0 tw-flex tw-items-center tw-gap-2"><i class="bi bi-link-45deg"></i>Gerenciar Links Rápidos</h5>
                <button type="button" class="ax-btn ax-btn--primary ax-btn--sm tw-gap-2" data-action="nested-form#add">
                  <i class="bi bi-plus-circle"></i> Adicionar Link
                </button>
              </div>

              <template data-nested-form-target="template">
                <%= f.fields_for :footer_links, FooterLink.new, child_index: 'NEW_RECORD' do |link_f| %>
                  <%= render 'footer_link_fields', f: link_f %>
                <% end %>
              </template>

              <div class="tw-flex tw-flex-col tw-gap-3" data-nested-form-target="container">
                <%= f.fields_for :footer_links do |link_f| %>
                  <%= render 'footer_link_fields', f: link_f %>
                <% end %>
              </div>
            </div>
          </div>

          <!-- Tab: Nossas Lojas -->
          <div class="tab-pane fade" id="stores" role="tabpanel">
            <div data-controller="nested-form" data-nested-form-wrapper-selector-value=".nested-fields">
              <div class="tw-flex tw-justify-between tw-items-center tw-mb-3">
                <h5 class="tw-mb-0 tw-flex tw-items-center tw-gap-2"><i class="bi bi-geo-alt-fill"></i>Gerenciar Unidades / Lojas</h5>
                <button type="button" class="ax-btn ax-btn--primary ax-btn--sm tw-gap-2" data-action="nested-form#add">
                  <i class="bi bi-plus-circle"></i> Adicionar Loja
                </button>
              </div>

              <template data-nested-form-target="template">
                <%= f.fields_for :footer_stores, FooterStore.new, child_index: 'NEW_RECORD' do |store_f| %>
                  <%= render 'footer_store_fields', f: store_f %>
                <% end %>
              </template>

              <div class="tw-flex tw-flex-col tw-gap-3" data-nested-form-target="container">
                <%= f.fields_for :footer_stores do |store_f| %>
                  <%= render 'footer_store_fields', f: store_f %>
                <% end %>
              </div>
            </div>
          </div>

          <!-- Tab: Redes Sociais -->
          <div class="tab-pane fade" id="social" role="tabpanel">
            <div data-controller="nested-form" data-nested-form-wrapper-selector-value=".nested-fields">
              <div class="tw-flex tw-justify-between tw-items-center tw-mb-3">
                <h5 class="tw-mb-0 tw-flex tw-items-center tw-gap-2"><i class="bi bi-share-fill"></i>Ícones de Redes Sociais</h5>
                <button type="button" class="ax-btn ax-btn--primary ax-btn--sm tw-gap-2" data-action="nested-form#add">
                  <i class="bi bi-plus-circle"></i> Adicionar Rede Social
                </button>
              </div>

              <template data-nested-form-target="template">
                <%= f.fields_for :footer_social_links, FooterSocialLink.new, child_index: 'NEW_RECORD' do |social_f| %>
                  <%= render 'footer_social_link_fields', f: social_f %>
                <% end %>
              </template>

              <div class="tw-flex tw-flex-col tw-gap-3" data-nested-form-target="container">
                <%= f.fields_for :footer_social_links do |social_f| %>
                  <%= render 'footer_social_link_fields', f: social_f %>
                <% end %>
              </div>
            </div>
          </div>

        </div>
      </div>

      <div class="ax-card__footer tw-flex tw-justify-end tw-p-4">
        <%= f.submit "Salvar Configurações", class: "ax-btn ax-btn--primary tw-px-5" %>
      </div>
    </div>
  <% end %>
<%# Closing tag removed as the wrapper was removed %>
