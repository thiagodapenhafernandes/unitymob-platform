<div class="nested-fields footer-nested-field" data-new-record="<%= f.object.new_record? %>">
  <div class="ax-card footer-nested-card">
    <div class="ax-card__body">
      <div class="tw-flex tw-justify-between tw-mb-2">
        <div class="tw-flex tw-items-center tw-gap-2">
          <span class="ax-badge ax-badge--blue footer-nested-position" data-position-label>
            <%= f.object.position || 1 %>
          </span>
          <label class="ax-label tw-font-bold tw-inline-flex tw-items-center tw-gap-2 footer-nested-label"><i class="bi bi-share"></i>Rede Social</label>
          <div class="tw-inline-flex tw-items-center">
            <button type="button" class="ax-btn ax-btn--ghost ax-btn--sm" data-action="nested-form#moveUp" title="Mover para cima">
              <i class="bi bi-chevron-up"></i>
            </button>
            <button type="button" class="ax-btn ax-btn--ghost ax-btn--sm" data-action="nested-form#moveDown" title="Mover para baixo">
              <i class="bi bi-chevron-down"></i>
            </button>
          </div>
        </div>
        <button type="button" class="ax-btn ax-btn--danger ax-btn--sm tw-gap-2" data-action="nested-form#remove">
          <i class="bi bi-trash"></i> Remover
        </button>
      </div>
      <%= f.hidden_field :_destroy %>
      <%= f.hidden_field :position %>

      <div class="tw-mb-2">
        <%= ax_select_field(form: f, method: :platform, label: "Plataforma",
              choices: ['Instagram', 'Facebook', 'WhatsApp', 'YouTube', 'TikTok', 'LinkedIn'],
              select_options: { prompt: 'Selecione a plataforma' }, html_options: { class: "ax-control--sm" }) %>
      </div>

      <div class="tw-mb-2">
        <%= ax_text_field(form: f, method: :url, label: "Link do perfil", class: "ax-control--sm", placeholder: "https://...") %>
      </div>

      <%= ax_switch_field(label: "Ativo", form: f, method: :enabled, id: "switch_#{f.object.id}") %>
    </div>
  </div>
</div>
