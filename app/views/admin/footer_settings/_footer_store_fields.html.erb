<div class="nested-fields footer-nested-field" data-new-record="<%= f.object.new_record? %>">
  <div class="ax-card footer-nested-card">
    <div class="ax-card__body">
      <div class="tw-flex tw-justify-between tw-mb-2">
        <div class="tw-flex tw-items-center tw-gap-2">
          <span class="ax-badge ax-badge--blue footer-nested-position" data-position-label>
            <%= f.object.position || 1 %>
          </span>
          <label class="ax-label tw-font-bold tw-inline-flex tw-items-center tw-gap-2 footer-nested-label"><i class="bi bi-geo-alt"></i>Unidade / Loja</label>
          <div class="tw-inline-flex tw-items-center">
            <button type="button" class="ax-btn ax-btn--ghost ax-btn--sm" data-action="nested-form#moveUp" title="Mover para cima">
              <i class="bi bi-chevron-up"></i>
            </button>
            <button type="button" class="ax-btn ax-btn--ghost ax-btn--sm" data-action="nested-form#moveDown" title="Mover para baixo">
              <i class="bi bi-chevron-down"></i>
            </button>
          </div>
        </div>
        <button type="button" class="ax-btn ax-btn--danger ax-btn--sm tw-gap-2" data-action="nested-form#remove">
          <i class="bi bi-trash"></i> Remover
        </button>
      </div>
      <%= f.hidden_field :_destroy %>
      <%= f.hidden_field :position %>

      <div class="tw-mb-2">
        <%= ax_text_field(form: f, method: :name, label: "Nome da loja", class: "ax-control--sm", placeholder: "Ex: Loja Centro") %>
      </div>

      <div class="tw-mb-2">
        <%= ax_text_field(form: f, method: :address, label: "Endereço completo", class: "ax-control--sm", autocomplete: "address-line1") %>
      </div>

      <%= ax_field_grid do %>
        <div class="ax-span-6 tw-mb-2">
          <%= ax_text_field(form: f, method: :zip_code, label: "CEP", class: "ax-control--sm", autocomplete: "postal-code") %>
        </div>
        <div class="ax-span-6 tw-mb-2">
          <%= ax_text_field(form: f, method: :creci, label: "CRECI", class: "ax-control--sm") %>
        </div>
      <% end %>

      <div class="tw-mb-1">
        <%= ax_text_field(form: f, method: :phone, label: "Telefone", type: :tel, class: "ax-control--sm",
              placeholder: "(47) 3311-1067", autocomplete: "tel", data: { controller: "phone-input" }) %>
      </div>
    </div>
  </div>
</div>
