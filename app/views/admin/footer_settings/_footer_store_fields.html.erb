<div class="col-12 nested-fields" data-new-record="<%= f.object.new_record? %>">
  <div class="ax-card bg-light">
    <div class="ax-card__body">
      <div class="tw-flex tw-justify-between tw-mb-2">
        <div class="tw-flex tw-items-center tw-gap-2">
          <span class="ax-badge ax-badge--blue" data-position-label style="width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; border-radius: 50%;">
            <%= f.object.position || 1 %>
          </span>
          <label class="ax-label tw-font-bold tw-inline-flex tw-items-center tw-gap-2" style="margin-bottom:0;"><i class="bi bi-geo-alt"></i>Unidade / Loja</label>
          <div class="tw-inline-flex tw-items-center">
            <button type="button" class="ax-btn ax-btn--ghost ax-btn--sm" data-action="nested-form#moveUp" title="Mover para cima">
              <i class="bi bi-chevron-up"></i>
            </button>
            <button type="button" class="ax-btn ax-btn--ghost ax-btn--sm" data-action="nested-form#moveDown" title="Mover para baixo">
              <i class="bi bi-chevron-down"></i>
            </button>
          </div>
        </div>
        <button type="button" class="ax-btn ax-btn--danger ax-btn--sm tw-gap-2" data-action="nested-form#remove">
          <i class="bi bi-trash"></i> Remover
        </button>
      </div>
      <%= f.hidden_field :_destroy %>
      <%= f.hidden_field :position %>

      <div class="tw-mb-2">
        <%= f.text_field :name, class: "ax-control ax-control--sm", placeholder: "Nome da Loja (ex: Loja Centro)" %>
      </div>

      <div class="tw-mb-2">
        <%= f.text_field :address, class: "ax-control ax-control--sm", placeholder: "Endereço completo" %>
      </div>

      <%= ax_field_grid do %>
        <div class="ax-span-6 tw-mb-2">
          <%= f.text_field :zip_code, class: "ax-control ax-control--sm", placeholder: "CEP" %>
        </div>
        <div class="ax-span-6 tw-mb-2">
          <%= f.text_field :creci, class: "ax-control ax-control--sm", placeholder: "CRECI" %>
        </div>
      <% end %>

      <div class="tw-mb-1">
        <%= f.text_field :phone, class: "ax-control ax-control--sm", placeholder: "+55 (47) 3311-1067", autocomplete: "tel", data: { controller: "phone-input" } %>
      </div>
    </div>
  </div>
</div>
