<div class="captacao-goals-admin">
  <%= ax_workspace_heading(
        eyebrow: "Captações · Planejamento",
        icon: "bullseye",
        title: "Metas de captação",
        subtitle: "Defina objetivos por período e tipo; região e faixa de valor orientam o acompanhamento operacional.",
        metrics: [{ value: @goals.size, label: "metas" }],
        actions: ax_button("Nova meta", new_admin_captacao_goal_path, variant: :primary, size: :sm, icon: "plus-lg")
      ) %>

  <%= ax_operational_panel(eyebrow: "Planejamento", title: "Metas cadastradas") do %>
    <div class="ax-table-wrap">
      <table class="ax-table">
        <thead>
          <tr>
            <th>Período</th>
            <th class="ax-table__col--md">Tipo</th>
            <th class="ax-num ax-table__col--compact">Meta</th>
            <th>Observação</th>
            <th class="ax-table__col--lg">Faixa de valor</th>
            <th class="ax-num ax-table__col--compact">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% @goals.each do |goal| %>
            <tr>
              <td class="ax-strong"><%= goal.period_label %></td>
              <td><%= ax_badge(goal.kind_venda? ? "Venda" : "Locação", tone: goal.kind_venda? ? :blue : :amber) %></td>
              <td class="ax-num ax-strong"><%= goal.target %></td>
              <td><%= goal.foco_regiao.presence || "—" %></td>
              <td>
                <% if goal.foco_valor_min || goal.foco_valor_max %>
                  <%= number_to_currency(goal.foco_valor_min, unit: "R$ ", precision: 0) if goal.foco_valor_min %> — <%= number_to_currency(goal.foco_valor_max, unit: "R$ ", precision: 0) if goal.foco_valor_max %>
                <% else %>
                  —
                <% end %>
              </td>
              <td class="ax-num">
                <span class="tw-inline-flex tw-gap-0.5">
                  <%= link_to edit_admin_captacao_goal_path(goal), class: "ax-ico-btn", title: "Editar", aria: { label: "Editar meta #{goal.period_label}" } do %>
                    <i class="bi bi-pencil"></i>
                  <% end %>
                  <%= button_to admin_captacao_goal_path(goal),
                                method: :delete,
                                form_class: "tw-inline",
                                class: "ax-ico-btn",
                                data: { turbo_confirm: "Remover esta meta?" },
                                title: "Excluir",
                                aria: { label: "Excluir meta #{goal.period_label}" } do %>
                    <i class="bi bi-trash"></i>
                  <% end %>
                </span>
              </td>
            </tr>
          <% end %>

          <% if @goals.empty? %>
            <tr>
              <td colspan="6">
                <%= ax_empty_state(
                      title: "Nenhuma meta cadastrada",
                      description: "Crie uma meta para acompanhar o planejamento mensal de captações.",
                      icon: "bullseye",
                      action: ax_button("Criar primeira meta", new_admin_captacao_goal_path, variant: :primary, size: :sm)
                    ) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
