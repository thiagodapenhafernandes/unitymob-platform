<div class="captacao-goals-admin">
  <%= ax_workspace_heading(
        eyebrow: "Captações · Planejamento",
        icon: "bullseye",
        title: "Nova meta de captação",
        subtitle: "Defina período, tipo, quantidade e critérios de foco para o acompanhamento.",
        actions: ax_button("Voltar", admin_captacao_goals_path, size: :sm, icon: "arrow-left")
      ) %>

  <%= ax_operational_panel(eyebrow: "Configuração", title: "Dados da meta") do %>
    <%= render "form", goal: @goal %>
  <% end %>
</div>
