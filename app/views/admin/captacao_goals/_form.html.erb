<%= form_with model: [:admin, goal], local: true do |f| %>
  <%= ax_error_summary(goal) %>

  <%= ax_field_grid do %>
    <div class="ax-span-3">
      <%= f.label :start_date, "Data inicial", class: "ax-label" %>
      <%= f.date_field :start_date, class: "ax-control" %>
    </div>
    <div class="ax-span-3">
      <%= f.label :end_date, "Data final", class: "ax-label" %>
      <%= f.date_field :end_date, class: "ax-control" %>
    </div>
    <div class="ax-span-3">
      <%= f.label :kind, "Tipo", class: "ax-label" %>
      <%= f.select :kind, [["Venda", "venda"], ["Locação", "locacao"]], {}, class: "ax-control" %>
    </div>
    <div class="ax-span-3">
      <%= f.label :target, "Meta de captações", class: "ax-label" %>
      <%= f.number_field :target, class: "ax-control", min: 1 %>
    </div>

    <div class="ax-span-12">
      <%= f.label :foco_regiao, "Observação da meta (opcional)", class: "ax-label" %>
      <%= f.text_field :foco_regiao, class: "ax-control", placeholder: "Ex.: meta comercial interna" %>
    </div>
    <div class="ax-span-6">
      <%= f.label :foco_valor_min, "Faixa de valor — mínimo (R$)", class: "ax-label" %>
      <%= f.number_field :foco_valor_min, step: 0.01, class: "ax-control" %>
    </div>
    <div class="ax-span-6">
      <%= f.label :foco_valor_max, "Faixa de valor — máximo (R$)", class: "ax-label" %>
      <%= f.number_field :foco_valor_max, step: 0.01, class: "ax-control" %>
    </div>
  <% end %>

  <div class="tw-flex tw-justify-end tw-gap-2 tw-mt-3">
    <%= link_to "Cancelar", admin_captacao_goals_path, class: "ax-btn ax-btn--ghost" %>
    <%= f.submit class: "ax-btn ax-btn--primary" %>
  </div>
<% end %>
