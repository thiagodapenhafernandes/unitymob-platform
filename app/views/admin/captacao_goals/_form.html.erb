<%= form_with model: [:admin, goal], local: true, html: { class: "captacao-goals-form" } do |form| %>
  <%= ax_error_summary(goal) %>

  <%= ax_field_grid do %>
    <div class="ax-span-3">
      <%= ax_date_field(form:, method: :start_date, label: "Data inicial") %>
    </div>
    <div class="ax-span-3">
      <%= ax_date_field(form:, method: :end_date, label: "Data final") %>
    </div>
    <div class="ax-span-3">
      <%= ax_select_field(form:, method: :kind, label: "Tipo", choices: [["Venda", "venda"], ["Locação", "locacao"]]) %>
    </div>
    <div class="ax-span-3">
      <%= ax_number_field(form:, method: :target, label: "Meta de captações", min: 1) %>
    </div>

    <div class="ax-span-12">
      <%= ax_text_field(form:, method: :foco_regiao, label: "Observação da meta (opcional)", placeholder: "Ex.: meta comercial interna") %>
    </div>
    <div class="ax-span-6">
      <%= ax_number_field(form:, method: :foco_valor_min, label: "Faixa de valor — mínimo (R$)", step: 0.01) %>
    </div>
    <div class="ax-span-6">
      <%= ax_number_field(form:, method: :foco_valor_max, label: "Faixa de valor — máximo (R$)", step: 0.01) %>
    </div>
  <% end %>

  <%= ax_form_actions(cancel_path: admin_captacao_goals_path, submit_label: goal.persisted? ? "Atualizar meta" : "Criar meta", form:) %>
<% end %>
