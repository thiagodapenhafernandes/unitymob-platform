<% conversation = local_assigns.fetch(:conversation, nil) %>
<% messages = local_assigns.fetch(:messages, nil) %>
<% quoted_messages = local_assigns.fetch(:quoted_messages, nil) %>
<% thread_context_locals = local_assigns.fetch(:thread_context_locals, nil) %>
<% focus_mode = local_assigns.fetch(:focus_mode, false) %>
<% integration = local_assigns.fetch(:integration, nil) %>
<% templates = local_assigns.fetch(:templates, []) %>
<% current_thread_url = local_assigns.fetch(:current_thread_url, nil) %>
<% thread_compact = local_assigns.fetch(:thread_compact, true) %>
<% composer_compact = local_assigns.fetch(:composer_compact, true) %>

<% if conversation %>
  <section class="wa-inbox-panel wa-inbox-panel--thread wa-inbox-panel--compact" aria-label="Conversa ativa">
    <div class="wa-inbox-chat-header">
      <div class="wa-inbox-chat-header__identity">
        <span class="wa-inbox-chat-header__avatar" aria-hidden="true"><%= wa_initials(conversation.display_name) %></span>
        <div class="wa-inbox-chat-header__copy">
          <strong><%= conversation.display_name %></strong>
          <span><i class="bi bi-circle-fill"></i> online</span>
        </div>
      </div>
      <div class="wa-inbox-chat-header__actions">
        <%= render "admin/whatsapp_inbox/presentation_tools", conversation: conversation, variant: :icon %>
        <span class="wa-inbox-chat-header__status"><i class="bi bi-circle-fill"></i> Ativo</span>
        <button type="button"
                class="wa-inbox-chat-header__icon"
                title="Tela cheia"
                aria-label="Tela cheia"
                data-wa-workspace-target="enter"
                data-action="wa-workspace#enterFullscreen">
          <i class="bi bi-arrows-fullscreen"></i>
        </button>
        <button type="button"
                class="wa-inbox-chat-header__icon"
                title="Sair da tela cheia"
                aria-label="Sair da tela cheia"
                data-wa-workspace-target="exit"
                data-action="wa-workspace#exitFullscreen"
                hidden>
          <i class="bi bi-fullscreen-exit"></i>
        </button>
        <% if conversation.lead %>
          <div class="wa-inbox-chat-header__menu" data-controller="ax-dropdown">
            <button type="button"
                    class="wa-inbox-chat-header__icon"
                    aria-label="Mais opções"
                    aria-expanded="false"
                    data-ax-dropdown-target="trigger"
                    data-action="click->ax-dropdown#toggle">
              <i class="bi bi-three-dots-vertical"></i>
            </button>
            <div class="ax-menu" data-ax-dropdown-target="menu" hidden>
              <%= link_to admin_lead_path(conversation.lead), class: "ax-menu__item" do %>
                <i class="bi bi-person-badge"></i><span>Ver lead no CRM</span>
              <% end %>
              <%= render "admin/lead_labels/button",
                    lead: conversation.lead,
                    trigger_label: "Gerenciar etiquetas",
                    trigger_class: "ax-menu__item" %>
              <%= render "admin/tasks/form_modal",
                    lead: conversation.lead,
                    trigger_label: "Nova tarefa",
                    trigger_class: "ax-menu__item" %>
              <%= render "admin/appointments/form_modal",
                    lead: conversation.lead,
                    trigger_label: "Agendar visita",
                    trigger_class: "ax-menu__item" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%= render "thread_workspace",
          conversation: conversation,
          messages: messages,
          quoted_messages: quoted_messages,
          thread_context_locals: thread_context_locals,
          focus_mode: focus_mode,
          compact_mode: thread_compact %>

    <% if can?(:manage, :whatsapp_inbox) %>
      <% presentation_gate = integration&.presentation_required_for?(conversation, current_admin_user) %>
      <% if presentation_gate %>
        <%# Gate "exigir apresentação": o composer fica ATIVO; o back-end recusa envios livres sem card. %>
        <div class="wa-inbox-composer--gated-banner">
          <i class="bi bi-shield-check"></i>
          <span><strong>Envie sua apresentação primeiro.</strong> Escolha um cartão em "Enviar apresentação" no painel ao lado — o texto entra aqui para você revisar e enviar.</span>
        </div>
      <% end %>
      <%= render "admin/shared/ui/whatsapp_composer",
            title: "Responder no CRM",
            conversation: conversation,
            templates: templates,
            return_to: current_thread_url,
            file_input_id: "wa-inbox-media-file",
            placeholder: "Digite uma mensagem...",
            compact_mode: composer_compact %>
    <% end %>
  </section>
<% else %>
  <section class="wa-inbox-panel wa-inbox-panel--thread" aria-label="Conversa ativa">
    <div class="wa-inbox-thread__placeholder">
      <%= ax_empty_state(
            title: "Selecione uma conversa",
            description: "Escolha um contato à esquerda para ver o histórico e responder.",
            icon: "whatsapp"
          ) %>
    </div>
  </section>
<% end %>
