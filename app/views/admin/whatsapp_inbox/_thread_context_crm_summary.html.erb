<%# Seção "Imóvel de interesse": pin do imóvel principal (property_id do lead,
    intacto) + chips removíveis de interesses + autocomplete. Sem lead, nada. %>
<% if thread_lead %>
  <%= render layout: "admin/whatsapp_inbox/context_section", locals: { label: "Imóvel de interesse" } do %>
    <% if thread_property %>
      <div class="ax-context-pin ax-context-pin--property">
        <%= link_to admin_habitation_path(thread_property), class: "ax-context-pin__link" do %>
          <i class="bi bi-house-door"></i>
          <span><%= thread_property.display_title %></span>
        <% end %>
      </div>
    <% elsif thread_lead.property_id.present? %>
      <div class="ax-context-pin ax-context-pin--property">
        <span class="ax-context-pin__link"><i class="bi bi-house-door"></i><span>Imóvel indisponível</span></span>
      </div>
    <% end %>
    <%= render "admin/whatsapp_inbox/thread_property_interests",
          lead: thread_lead,
          show_empty: thread_lead.property_id.blank? %>
  <% end %>
<% end %>
