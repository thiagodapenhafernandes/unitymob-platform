<div class="wa-inbox-thread__identity">
  <span class="wa-inbox-thread__avatar"><%= wa_initials(conversation.display_name) %></span>
  <div class="wa-inbox-thread__identity-copy">
    <strong><%= conversation.display_name %></strong>
    <span><%= conversation.contact_phone %></span>
  </div>
</div>

<% if conversation.lead %>
  <% lead_status = thread_lead&.status&.to_s&.humanize.presence %>
  <%= render layout: "admin/whatsapp_inbox/context_section", locals: { label: "Lead vinculado" } do %>
    <div class="ax-context-pin ax-context-pin--lead">
      <%= link_to admin_lead_path(conversation.lead), class: "ax-context-pin__link" do %>
        <i class="bi bi-person-badge"></i>
        <span class="tw-sr-only">Lead no CRM</span>
        <span><%= conversation.lead.name.presence || "Ver lead" %></span>
      <% end %>
      <% if lead_status.present? %>
        <%= ax_badge(lead_status, tone: (lead_status == "Novo" ? :blue : :gray), class_name: "wa-inbox-thread__status-badge") %>
      <% end %>
    </div>
  <% end %>
<% end %>

<% if thread_summary[:last_activity_at].present? %>
  <span class="wa-inbox-thread__last-activity">Última atividade <%= l(thread_summary[:last_activity_at], format: "%d/%m %H:%M") %></span>
<% end %>
