<%
  focus_url = @conversation ? admin_whatsapp_conversation_path(@conversation, workspace: "focus") : admin_whatsapp_conversations_path(workspace: "focus")
  standard_url = @conversation ? admin_whatsapp_conversation_path(@conversation) : admin_whatsapp_conversations_path
  current_thread_url = @conversation ? (@focus_mode ? admin_whatsapp_conversation_path(@conversation, workspace: "focus") : admin_whatsapp_conversation_path(@conversation)) : nil
  queue_compact = true
  thread_compact = true
  composer_compact = true
  thread_panel_compact = true
%>

<% heading_actions = capture do %>
  <div class="wa-inbox-heading-actions tw-inline-flex tw-flex-wrap tw-items-center tw-justify-end tw-gap-2">
    <%= link_to (@focus_mode ? standard_url : focus_url),
          class: "ax-btn ax-btn--sm ax-btn--ghost" do %>
      <i class="bi bi-layout-sidebar-inset-reverse ax-ico"></i><span><%= @focus_mode ? "Sair do foco" : "Modo foco" %></span>
    <% end %>

    <% if @focus_mode %>
      <button type="button"
              class="ax-btn ax-btn--sm ax-btn--ghost"
              title="Tela cheia"
              aria-label="Tela cheia"
              data-wa-workspace-target="enter"
              data-action="wa-workspace#enterFullscreen">
        <i class="bi bi-arrows-fullscreen ax-ico"></i><span>Tela cheia</span>
      </button>
      <button type="button"
              class="ax-btn ax-btn--sm ax-btn--ghost"
              title="Sair da tela cheia"
              aria-label="Sair da tela cheia"
              data-wa-workspace-target="exit"
              data-action="wa-workspace#exitFullscreen"
              hidden>
        <i class="bi bi-fullscreen-exit ax-ico"></i><span>Sair da tela cheia</span>
      </button>
    <% end %>

    <% if can?(:manage, :whatsapp_inbox) %>
      <%= button_to sync_templates_admin_whatsapp_conversations_path, method: :post, class: "ax-btn ax-btn--sm ax-btn--ghost wa-inbox-heading__sync", form_class: "tw-inline" do %>
        <i class="bi bi-arrow-repeat ax-ico"></i><span>Sincronizar modelos</span>
      <% end %>
    <% end %>
  </div>
<% end %>

<div class="wa-inbox-page <%= 'wa-inbox-page--focus' if @focus_mode %>"
     data-controller="wa-workspace">
  <div class="wa-inbox-page__header">
    <%= ax_workspace_heading(
          eyebrow: (@focus_mode ? "Workspace dedicado" : "Atendimento"),
          icon: "whatsapp",
          title: "Atendimento WhatsApp",
          subtitle: (@focus_mode ? "Tela de operação contínua para fila, thread e resposta." : "Fila, thread e resposta."),
          metrics: [
            { value: number_with_delimiter(@conversation_count.to_i), label: "conv.", data: { wa_inbox_heading_metric: "conversations" } },
            { value: number_with_delimiter(@total_unread.to_i), label: "n. lidas", data: { wa_inbox_heading_metric: "unread" } }
          ],
          actions: heading_actions
        ) %>

    <% unless @integration&.messaging_ready? %>
      <%= ax_inline_notice(tone: :warning, icon: "exclamation-triangle", class_name: "wa-inbox__integration-notice") do %>
        O número do WhatsApp ainda não está conectado para envio/recebimento. Conclua a conexão em
        <%= link_to "Integrações › WhatsApp", admin_whatsapp_integration_path, class: "tw-text-primary" %>.
        O inbox funciona, mas as mensagens só trafegam com o número conectado.
      <% end %>
    <% end %>
  </div>

<div class="wa-inbox-page__shell" data-wa-workspace-target="shell">
<div class="wa-inbox-shell">
  <% list_actions = capture do %>
    <div class="wa-inbox-list-actions">
      <% if team_available?(:whatsapp_inbox) %>
        <%= ax_team_toggle(:whatsapp_inbox) %>
      <% end %>
    </div>
  <% end %>

  <% unread_conversation_count = @conversations.count { |conv| conv.unread_count.to_i.positive? } %>
  <% unlinked_conversation_count = @conversations.count { |conv| conv.lead.blank? } %>

  <%= ax_operational_panel(eyebrow: "Fila", title: "Conversas", actions: list_actions, class_name: "wa-inbox-panel wa-inbox-panel--list #{'wa-inbox-panel--compact' if queue_compact}") do %>
    <div class="wa-inbox-list-shell" data-controller="wa-queue">
      <div class="wa-inbox-list-toolbar">
        <label class="wa-inbox-list-search-shell" for="wa-inbox-search">
          <i class="bi bi-search"></i>
          <span class="tw-sr-only">Buscar conversas</span>
          <input type="search"
                 id="wa-inbox-search"
                 name="queue_search"
                 class="ax-control ax-control--sm wa-inbox-list-search"
                 placeholder="Buscar"
                 aria-label="Buscar conversas"
                 autocomplete="off"
                 data-action="input->wa-queue#search"
                 data-wa-queue-target="search">
        </label>
        <div class="wa-inbox-list-filters">
          <button type="button"
                  class="wa-inbox-list-filter is-active"
                  data-filter="all"
                  data-action="wa-queue#filter"
                  data-wa-queue-target="filterButton">
            <span>Todas</span>
            <small data-wa-inbox-filter-count="all"><%= @conversation_count %></small>
          </button>
          <button type="button"
                  class="wa-inbox-list-filter"
                  data-filter="unread"
                  data-action="wa-queue#filter"
                  data-wa-queue-target="filterButton">
            <span>Não lidas</span>
            <small data-wa-inbox-filter-count="unread"><%= unread_conversation_count %></small>
          </button>
          <button type="button"
                  class="wa-inbox-list-filter"
                  data-filter="unlinked"
                  data-action="wa-queue#filter"
                  data-wa-queue-target="filterButton">
            <span>Sem lead</span>
            <small data-wa-inbox-filter-count="unlinked"><%= unlinked_conversation_count %></small>
          </button>
        </div>
      </div>

      <div class="wa-inbox-list" data-wa-queue-list data-wa-queue-target="list">
      <% if @conversations.any? %>
        <% @conversations.each do |conv| %>
          <%= render "conversation_item", conv: conv, active: @conversation&.id == conv.id, focus_mode: @focus_mode, compact_mode: queue_compact %>
        <% end %>
      <% else %>
        <div class="wa-inbox-list__empty">
          <%= ax_empty_state(
                title: "Nenhuma conversa ainda",
                description: "Mensagens recebidas no número conectado aparecem aqui.",
                icon: "whatsapp"
              ) %>
        </div>
      <% end %>
      </div>
    </div>
  <% end %>

  <% if @conversation %>
    <% thread_lead = @thread_context_locals[:thread_lead] %>
    <% can_manage_comercial = @thread_context_locals[:can_manage_comercial] %>
    <% thread_actions = capture do %>
      <div class="wa-inbox-thread-actions">
        <% if thread_lead %>
          <%= render "admin/lead_labels/button", lead: thread_lead, trigger_label: "Etiquetas", trigger_class: "ax-btn ax-btn--sm" %>
        <% end %>
        <% if can_manage_comercial && thread_lead %>
          <%= render "admin/tasks/form_modal", modal_id: "whatsappInboxTask", lead: thread_lead, trigger_label: "Tarefa", trigger_class: "ax-btn ax-btn--sm" %>
          <%= render "admin/appointments/form_modal", lead: thread_lead, trigger_label: "Agendar", trigger_class: "ax-btn ax-btn--sm" %>
          <%= link_to new_admin_lead_proposal_path(thread_lead), class: "ax-btn ax-btn--sm ax-btn--primary" do %>
            <i class="bi bi-file-earmark-text ax-ico"></i><span>Proposta</span>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <%= ax_operational_panel(eyebrow: "Thread", title: "Conversa ativa", actions: thread_actions, class_name: "wa-inbox-panel wa-inbox-panel--thread #{'wa-inbox-panel--compact' if thread_panel_compact}") do %>
      <%= render "thread_workspace",
            conversation: @conversation,
            messages: @messages,
            thread_context_locals: @thread_context_locals,
            focus_mode: @focus_mode,
            compact_mode: thread_compact %>

      <% if can?(:manage, :whatsapp_inbox) %>
        <%= render "admin/shared/ui/whatsapp_composer",
              title: "Responder no CRM",
              conversation: @conversation,
              templates: @templates,
              return_to: current_thread_url,
              file_input_id: "wa-inbox-media-file",
              compact_mode: composer_compact %>
      <% end %>
    <% end %>
  <% else %>
    <%= ax_operational_panel(eyebrow: "Thread", title: "Selecione uma conversa", class_name: "wa-inbox-panel wa-inbox-panel--thread") do %>
      <div class="wa-inbox-thread__placeholder">
        <%= ax_empty_state(
              title: "Selecione uma conversa",
              description: "Escolha um contato à esquerda para ver o histórico e responder.",
              icon: "whatsapp"
            ) %>
      </div>
    <% end %>
  <% end %>
</div>
</div>
</div>
