<% content_for :admin_contextbar_breadcrumb do %>
  <%= link_to "Admin", admin_root_path %>
  <i class="bi bi-chevron-right"></i>
  <%= link_to "Usuários", admin_admin_users_path %>
  <i class="bi bi-chevron-right"></i>
  <strong>Hierarquia</strong>
<% end %>

<% content_for :admin_contextbar_actions do %>
  <%= link_to admin_admin_users_path, class: "ax-contextbar__button" do %>
    <i class="bi bi-arrow-left"></i><span>Lista</span>
  <% end %>
  <%= link_to new_admin_admin_user_path, class: "ax-contextbar__button ax-contextbar__button--primary" do %>
    <i class="bi bi-person-plus"></i><span>Novo usuário</span>
  <% end %>
<% end %>

<div class="hier" data-controller="hierarchy-tree">
  <header class="ax-dashboard-command ax-property-form-command">
    <div class="ax-dashboard-command__main">
      <span class="ax-dashboard-command__eyebrow">Organização</span>
      <h1>Hierarquia da equipe</h1>
      <p>Estrutura de gestão (gestor → subordinados). Expanda os nós para ver a árvore.</p>
    </div>
    <div class="ax-dashboard-command__status">
      <%= ax_badge("#{@total_users} usuários", tone: :gray) %>
      <%= ax_badge("#{@manager_count} gestores", tone: :blue) %>
    </div>
  </header>

  <div class="hier__toolbar">
    <button type="button" class="ax-btn ax-btn--sm" data-hier-expand-all data-action="hierarchy-tree#expandAll"><i class="bi bi-arrows-expand"></i> Expandir tudo</button>
    <button type="button" class="ax-btn ax-btn--sm" data-hier-collapse-all data-action="hierarchy-tree#collapseAll"><i class="bi bi-arrows-collapse"></i> Recolher tudo</button>
    <% if @can_reorganize %>
      <span class="hier__hint"><i class="bi bi-grip-vertical"></i> Arraste pelo punho para mover de gestor, soltar dentro de outro usuário ou reordenar. Solte no topo para tirar da hierarquia.</span>
    <% end %>
  </div>

  <div class="ax-panel">
    <div class="hier__tree<%= ' is-editable' if @can_reorganize %>"
         data-action="click->hierarchy-tree#toggle"
         <% if @can_reorganize %>data-controller="hierarchy-sortable" data-hierarchy-sortable-url-value="<%= move_hierarchy_admin_admin_users_path %>"<% end %>>
      <% if @roots.any? %>
        <ul class="hier-list hier-root-list" data-hierarchy-list data-manager-id="">
          <% @roots.each do |root| %>
            <%= render "hierarchy_node",
                  user: root,
                  children_by_manager: @children_by_manager,
                  descendant_count: @descendant_count,
                  habitations_count: @habitations_count_by_admin_user,
                  depth: 0,
                  can_reorganize: @can_reorganize %>
          <% end %>
        </ul>
      <% else %>
        <%= ax_empty_state(title: "Sem hierarquia", description: "Nenhum usuário no topo da árvore. Defina gestores no cadastro dos usuários.", icon: "diagram-3") %>
      <% end %>
    </div>
  </div>
</div>

<style id="hierarchy-styles">
  .hier { display: grid; gap: 8px; padding-top: 8px; }
  .hier__toolbar { display: flex; gap: 6px; align-items: center; flex-wrap: wrap; }
  .hier__hint { color: #8a93a3; font-size: 11.5px; display: inline-flex; align-items: center; gap: 5px; }
  .hier__hint i { color: var(--admin-primary, #365f8f); }
  .hier__tree { padding: 8px; display: grid; gap: 8px; }

  .hier-list { list-style: none; margin: 0; padding: 0; display: grid; gap: 8px; }
  .hier-children { margin: 8px 0 0 18px !important; padding-left: 14px; border-left: 2px solid var(--ax-border-soft, #e7ebf2); }
  /* Folhas têm uma lista-filha vazia (alvo de drop). Fora do arraste, ela não deve ocupar espaço.
     display:none garante zero espaço de forma robusta (margin/border/min-height zerados ainda
     deixavam o margin-top do grid escapar em alguns cascatas, criando espaçamentos desiguais). */
  .hier-children:empty { display: none; }
  .hier-node { display: block; }
  .hier-row {
    display: flex; align-items: center; gap: 10px;
    padding: 8px 10px;
    border: 1px solid var(--ax-border-soft, #e7ebf2);
    border-radius: 8px;
    background: #fff;
  }
  .hier-row.is-root { border-color: color-mix(in srgb, var(--admin-primary, #365f8f) 30%, #e7ebf2); background: #f8fafc; }

  .hier-row__handle { flex: 0 0 auto; display: inline-flex; align-items: center; justify-content: center; width: 18px; color: #b4bdca; cursor: grab; }
  .hier-row__handle:active { cursor: grabbing; }
  .hier-row__handle:hover { color: var(--admin-primary, #365f8f); }

  /* Estados de drag (SortableJS) */
  .hier-chosen > .hier-row { box-shadow: 0 0 0 2px color-mix(in srgb, var(--admin-primary, #365f8f) 45%, transparent); }
  .hier-ghost > .hier-row { opacity: .45; }
  .hier-drag { opacity: .9; }
  .hier__tree.is-dragging .hier-children:empty {
    display: grid;
    min-height: 30px; margin: 8px 0 0 18px; border: 1px dashed color-mix(in srgb, var(--admin-primary, #365f8f) 40%, #cbd5e1);
    border-left-width: 2px; border-radius: 6px; background: color-mix(in srgb, var(--admin-primary, #365f8f) 5%, #fff);
  }
  .hier__tree.is-dragging .hier-root-list { outline: 1px dashed color-mix(in srgb, var(--admin-primary, #365f8f) 35%, #cbd5e1); outline-offset: 4px; border-radius: 8px; }

  .hier-row__toggle {
    flex: 0 0 auto; width: 22px; height: 22px; display: inline-flex; align-items: center; justify-content: center;
    border: 1px solid transparent; border-radius: 6px; background: transparent; color: #64748b; cursor: pointer;
  }
  .hier-row__toggle:hover { background: #eef2f7; }
  .hier-row__toggle[data-hier-leaf] { visibility: hidden; cursor: default; }
  .hier-row__toggle i { transition: transform .15s ease; }
  .hier-row__toggle[aria-expanded="true"] i { transform: rotate(90deg); }

  .hier-row__avatar { flex: 0 0 auto; }
  .hier-row__img { width: 34px; height: 34px; border-radius: 999px; object-fit: cover; }
  .hier-row__initial { display: inline-flex; align-items: center; justify-content: center; width: 34px; height: 34px; border-radius: 999px; background: var(--admin-primary, #365f8f); color: #fff; font-weight: 800; font-size: 12px; }

  .hier-row__main { display: grid; gap: 1px; min-width: 0; flex: 1; }
  .hier-row__main strong { color: #1f2733; font-size: 13px; }
  .hier-row__main span { color: #8a93a3; font-size: 11px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .hier-row__tags { display: inline-flex; flex-wrap: wrap; gap: 5px; flex: 0 0 auto; }
  .hier-row__counts { display: inline-flex; gap: 10px; flex: 0 0 auto; color: #64748b; font-size: 11.5px; }
  .hier-row__counts span { display: inline-flex; align-items: center; gap: 4px; }
  .hier-row__counts strong { color: #1f2733; }
  .hier-row__actions { display: inline-flex; gap: 2px; flex: 0 0 auto; }

  @media (max-width: 860px) {
    .hier-row { flex-wrap: wrap; }
    .hier-row__counts, .hier-row__tags { width: 100%; }
  }
</style>
