<% content_for :admin_contextbar_breadcrumb do %>
  <%= link_to "Admin", admin_root_path %>
  <i class="bi bi-chevron-right"></i>
  <%= link_to "Usuários", admin_admin_users_path %>
  <i class="bi bi-chevron-right"></i>
  <strong><%= @admin_user.name %></strong>
<% end %>

<% content_for :admin_contextbar_actions do %>
  <%= link_to admin_admin_user_path(@admin_user), class: "ax-contextbar__button" do %>
    <i class="bi bi-eye"></i><span>Ver</span>
  <% end %>
  <%= link_to admin_admin_users_path, class: "ax-contextbar__button" do %>
    <i class="bi bi-arrow-left"></i><span>Lista</span>
  <% end %>
<% end %>

<header class="ax-dashboard-command ax-property-form-command">
  <div class="ax-dashboard-command__main">
    <span class="ax-dashboard-command__eyebrow">Equipe</span>
    <h1>Editar usuário: <%= @admin_user.name %></h1>
    <p>Atualize dados, perfil de acesso, atuação, gestor e segurança.</p>
  </div>
</header>

<%= render 'form', admin_user: @admin_user %>
