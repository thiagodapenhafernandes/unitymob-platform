<%
  status = local_assigns[:status] || Vista::SyncStatusService.new.snapshot
  stats = status[:stats] || {}
  show = status[:status] == "processing" || (status[:finished_at].present? && status[:finished_at] > 15.minutes.ago)
  tone = case status[:status]
         when "processing" then :blue
         when "completed"  then :green
         when "failed"     then :red
         else :gray
         end
%>

<% if show %>
  <section id="vista-sync-panel"
           class="ax-builder-card"
           data-controller="vista-sync-status"
           data-vista-sync-status-url-value="<%= vista_sync_status_admin_admin_users_path %>"
           data-vista-sync-status-status-value="<%= status[:status] %>">
    <div class="ax-builder-panel-head">
      <strong class="tw-text-xs"><i class="bi bi-arrow-repeat <%= 'spin' if status[:status] == 'processing' %>"></i> Sincronização Vista</strong>
      <%= ax_badge(status[:status].to_s.humanize, tone:) %>
    </div>
    <div class="tw-grid tw-gap-3 tw-p-3">
      <p class="tw-m-0 tw-text-xs tw-text-ink-muted"><%= status[:message].presence || "Sem atividade recente." %></p>
      <div class="ax-progress tw-mt-0">
        <i style="width:<%= status[:progress].to_i %>%"></i>
      </div>
      <div class="tw-grid tw-grid-cols-5 tw-gap-2">
        <div><b class="tw-block tw-font-mono tw-text-sm"><%= stats["processed"].to_i %></b><span class="tw-text-2xs tw-text-ink-muted">Processados</span></div>
        <div><b class="tw-block tw-font-mono tw-text-sm tw-text-emerald-700"><%= stats["created"].to_i %></b><span class="tw-text-2xs tw-text-ink-muted">Criados</span></div>
        <div><b class="tw-block tw-font-mono tw-text-sm tw-text-blue-700"><%= stats["updated"].to_i %></b><span class="tw-text-2xs tw-text-ink-muted">Atualizados</span></div>
        <div><b class="tw-block tw-font-mono tw-text-sm tw-text-red-700"><%= stats["errors"].to_i %></b><span class="tw-text-2xs tw-text-ink-muted">Erros</span></div>
        <div><b class="tw-block tw-font-mono tw-text-sm"><%= stats["page"].to_i %>/<%= stats["total_pages"].to_i %></b><span class="tw-text-2xs tw-text-ink-muted">Página</span></div>
      </div>
    </div>
  </section>
<% else %>
  <div id="vista-sync-panel"></div>
<% end %>
