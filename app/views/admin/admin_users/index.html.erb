<%# Usuários — listagem. Ações "Hierarquia" e "Novo usuário" vêm da contextbar global. %>
<%
  acting_options = AdminUser.acting_types.keys.map { |k| [I18n.t("enums.admin_user.acting_type.#{k}", default: k.humanize), k] }
  acting_badge = ->(t) { { "sales" => ["Venda", :blue], "rentals" => ["Locação", :amber], "both" => ["Ambos", :green] }[t.to_s] }
  filters_active = params[:query].present? || params[:profile_id].present? || params[:status].present? || params[:acting_type].present? || params[:manager_id].present?
%>

<div class="au-page">
  <header class="ax-dashboard-command ax-property-form-command">
    <div class="ax-dashboard-command__main">
      <span class="ax-dashboard-command__eyebrow">Equipe</span>
      <h1>Usuários</h1>
      <p>Gerencie a equipe, perfis, atuação e a hierarquia de atendimento.</p>
    </div>
    <div class="ax-dashboard-command__actions">
      <%= button_to sync_from_vista_admin_admin_users_path, method: :post, class: "ax-btn ax-btn--sm",
            form: { class: "tw-inline" },
            data: { turbo_confirm: "Sincronizar corretores do Vista agora? Roda em background." } do %>
        <i class="bi bi-arrow-repeat"></i> Sincronizar
      <% end %>
      <%= button_to backfill_brokers_admin_admin_users_path, method: :post, class: "ax-btn ax-btn--sm",
            form: { class: "tw-inline" },
            data: { turbo_confirm: "Vincular imóveis aos corretores (via CodigoCorretor do Vista)? Roda em background." } do %>
        <i class="bi bi-link-45deg"></i> Vincular imóveis
      <% end %>
    </div>
  </header>

  <div class="au-kpis">
    <%= ax_metric_card(label: "Total", value: number_with_delimiter(@total_admin_users)) %>
    <%= ax_metric_card(label: "Ativos", value: number_with_delimiter(@active_admin_users), badge: ax_badge("Ativo", tone: :green, dot: true)) %>
    <%= ax_metric_card(label: "Inativos", value: number_with_delimiter(@inactive_admin_users)) %>
    <%= ax_metric_card(label: "No site", value: number_with_delimiter(@displayed_admin_users)) %>
  </div>

  <%= render "vista_sync_panel" %>
  <%= render "backfill_brokers_panel" %>

  <%= form_with url: admin_admin_users_path, method: :get, class: "au-filters", data: { controller: "auto-submit" } do |f| %>
    <div class="au-filters__search">
      <i class="bi bi-search"></i>
      <%= f.text_field :query, value: params[:query], class: "ax-control", placeholder: "Buscar por nome, e-mail, CRECI ou ID..." %>
    </div>
    <%= f.select :profile_id,
          options_from_collection_for_select(@available_profiles, :id, ->(profile) { profile_filter_label(profile) }, params[:profile_id]),
          { include_blank: "Todos os perfis" },
          { class: "ax-control", data: { action: "change->auto-submit#submit" } } %>
    <%= f.select :acting_type, acting_options,
          { selected: params[:acting_type], prompt: "Todas as atuações" },
          { class: "ax-control", data: { action: "change->auto-submit#submit" } } %>
    <%= f.collection_select :manager_id, @manager_options, :id, :name,
          { selected: params[:manager_id], prompt: "Todos os gestores" },
          { class: "ax-control", data: { action: "change->auto-submit#submit" } } %>
    <%= f.select :status, [["Todos status", ""], ["Apenas ativos", "active"], ["Apenas inativos", "inactive"]],
          { selected: params[:status] },
          { class: "ax-control", data: { action: "change->auto-submit#submit" } } %>
    <div class="au-filters__actions">
      <%= f.submit "Filtrar", class: "ax-btn ax-btn--primary ax-btn--sm" %>
      <% if filters_active %>
        <%= link_to "Limpar", admin_admin_users_path, class: "ax-btn ax-btn--sm" %>
      <% end %>
    </div>
  <% end %>

  <div class="ax-table-wrap">
    <table class="ax-table">
      <thead>
        <tr>
          <th>Usuário</th>
          <th>Perfil de acesso</th>
          <th class="ax-num">Status</th>
          <th class="ax-num">Atuação</th>
          <th>Gestor</th>
          <th class="ax-num">Imóveis</th>
          <th class="ax-num">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% if @admin_users.any? %>
          <% @admin_users.each do |user| %>
            <tr>
              <td>
                <div class="au-user">
                  <div class="au-user__avatar">
                    <% if user.avatar.attached? %>
                      <%= image_tag user.avatar, class: "au-user__img" %>
                    <% else %>
                      <span class="au-user__initial"><%= user.name.to_s.first&.upcase || "?" %></span>
                    <% end %>
                    <% if user.vista_id.present? %><span class="au-user__vista" title="Integrado com Vista"></span><% end %>
                  </div>
                  <div class="au-user__main">
                    <strong><%= user.name %></strong>
                    <span><%= user.email %></span>
                    <div class="au-user__meta">
                      <% if user.creci.present? %><span><i class="bi bi-card-heading"></i> CRECI <%= user.creci %></span><% end %>
                      <% if user.phone.present? %><span><i class="bi bi-whatsapp"></i> <%= format_phone(user.phone) %></span><% end %>
                    </div>
                  </div>
                </div>
              </td>
              <td>
                <%= ax_badge(user.access_profile_name, tone: user.access_profile ? :blue : :gray) %>
              </td>
              <td class="ax-num">
                <%= ax_badge(user.active ? "Ativo" : "Inativo", tone: user.active ? :green : :red, dot: true) %>
              </td>
              <td class="ax-num">
                <% if (b = acting_badge.call(user.acting_type)) %>
                  <%= ax_badge(b[0], tone: b[1]) %>
                <% else %>
                  <span class="au-muted">—</span>
                <% end %>
              </td>
              <td>
                <% if user.manager_display_name.present? %>
                  <span class="au-strong"><%= user.manager_display_name %></span>
                <% else %>
                  <span class="au-muted">—</span>
                <% end %>
              </td>
              <td class="ax-num"><%= ax_badge(@habitations_count_by_admin_user.fetch(user.id, 0).to_s, tone: :gray) %></td>
              <td class="ax-num">
                <span class="au-actions">
                  <%= link_to edit_admin_admin_user_path(user), class: "ax-ico-btn", title: "Editar" do %><i class="bi bi-pencil"></i><% end %>
                  <% if user != current_admin_user %>
                    <button type="button" class="ax-ico-btn" title="Excluir"
                            data-controller="reassign-delete"
                            data-ax-modal-open="#reassignDeleteModal"
                            data-reassign-delete-trigger
                            data-action="click->reassign-delete#prepare"
                            data-url="<%= admin_admin_user_path(user) %>"
                            data-user-id="<%= user.id %>"
                            data-user-name="<%= user.name %>">
                      <i class="bi bi-trash"></i>
                    </button>
                  <% end %>
                </span>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr><td colspan="8">
            <%= ax_empty_state(title: "Nenhum usuário encontrado", description: "Ajuste os filtros de busca, perfil, atuação, gestor ou status.", icon: "people") %>
          </td></tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%= ax_pagination @admin_users, params: request.query_parameters %>
</div>

<%= ax_quick_modal(id: "reassignDeleteModal", title: "Excluir usuário", size: :md, footer: nil) do %>
  <div data-controller="reassign-delete">
    <%= ax_inline_notice(tone: :warning, icon: "exclamation-triangle") do %>
      <span>Você está excluindo <strong data-reassign-delete-target="name">este usuário</strong>. Esta ação é irreversível.</span>
    <% end %>

    <%= form_tag("", method: :delete, data: { reassign_delete_target: "form" }, class: "reassign-delete__form") do %>
      <p class="reassign-delete__hint">Os dados do usuário (leads, imóveis, captações, tarefas, propostas e carteira) serão <strong>reatribuídos</strong> para o admin escolhido. Auditorias permanecem imutáveis com o id histórico.</p>
      <label class="ax-field-label" for="reassign_to_id"><span class="ax-field-label__text">Reatribuir para</span></label>
      <select name="reassign_to_id" id="reassign_to_id" class="ax-control" data-reassign-delete-target="select" required>
        <% manageable_reassign_users = tenant_owner? ? current_tenant.admin_users.account_members.order(:name) : current_tenant.admin_users.account_members.where(id: [current_admin_user.id] + current_admin_user.descendant_ids).order(:name) %>
        <% manageable_reassign_users.each do |a| %>
          <option value="<%= a.id %>" data-user-id="<%= a.id %>"<%= " selected" if a == current_admin_user %>><%= a.name %><%= " (você)" if a == current_admin_user %></option>
        <% end %>
      </select>

      <div class="reassign-delete__actions">
        <button type="button" class="ax-btn" data-action="ax-modal#close">Cancelar</button>
        <button type="submit" class="ax-btn ax-btn--danger">Excluir e reatribuir</button>
      </div>
    <% end %>
  </div>
<% end %>

<style id="admin-users-index-styles">
  .au-page { display: grid; gap: 8px; padding-top: 8px; }
  .au-kpis { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 8px; }
  @media (max-width: 720px) { .au-kpis { grid-template-columns: repeat(2, minmax(0, 1fr)); } }

  .au-filters { display: grid; grid-template-columns: minmax(180px, 1.6fr) repeat(4, minmax(120px, 1fr)) auto; gap: 8px; align-items: center; padding: 10px 12px; border: 1px solid var(--ax-border-soft, #e7ebf2); border-radius: 8px; background: #fff; }
  @media (max-width: 1100px) { .au-filters { grid-template-columns: 1fr 1fr; } .au-filters__search { grid-column: 1 / -1; } .au-filters__actions { grid-column: 1 / -1; } }
  .au-filters__search { position: relative; display: flex; align-items: center; }
  .au-filters__search i { position: absolute; left: 10px; color: #9aa3b2; font-size: 13px; pointer-events: none; }
  .au-filters__search .ax-control { padding-left: 30px; }
  .au-filters__actions { display: flex; gap: 6px; justify-content: flex-end; }

  .au-user { display: flex; align-items: center; gap: 10px; min-width: 0; }
  .au-user__avatar { position: relative; flex: 0 0 auto; }
  .au-user__img { width: 38px; height: 38px; border-radius: 999px; object-fit: cover; }
  .au-user__initial { display: inline-flex; align-items: center; justify-content: center; width: 38px; height: 38px; border-radius: 999px; background: var(--admin-primary, #365f8f); color: #fff; font-weight: 800; font-size: 13px; }
  .au-user__vista { position: absolute; right: -1px; bottom: -1px; width: 11px; height: 11px; border-radius: 999px; background: #16a34a; border: 2px solid #fff; }
  .au-user__main { display: grid; gap: 1px; min-width: 0; }
  .au-user__main strong { color: #1f2733; font-size: 13px; }
  .au-user__main > span { color: #8a93a3; font-size: 11.5px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .au-user__meta { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 1px; }
  .au-user__meta span { color: #9aa3b2; font-size: 10.5px; }
  .au-strong { color: #1f2733; font-size: 12.5px; font-weight: 600; }
  .au-muted { color: #9aa3b2; }
  .au-actions { display: inline-flex; gap: 2px; justify-content: flex-end; }

  .reassign-delete__form { display: grid; gap: 8px; margin-top: 12px; }
  .reassign-delete__hint { margin: 0; color: #8a93a3; font-size: 11.5px; line-height: 1.45; }
  .reassign-delete__actions { display: flex; justify-content: flex-end; gap: 8px; margin-top: 6px; }
</style>
