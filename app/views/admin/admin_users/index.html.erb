<%# Usuários — listagem. Ações "Hierarquia" e "Novo usuário" vêm da contextbar global. %>
<%
  acting_options = AdminUser.acting_types.keys.map { |k| [I18n.t("enums.admin_user.acting_type.#{k}", default: k.humanize), k] }
  acting_badge = ->(t) { { "sales" => ["Venda", :blue], "rentals" => ["Locação", :amber], "both" => ["Ambos", :green] }[t.to_s] }
  filters_active = params[:query].present? || params[:profile_id].present? || params[:status].present? || params[:acting_type].present? || params[:manager_id].present?
%>

<div class="au-page">
  <%= ax_workspace_heading(
        eyebrow: "Equipe",
        icon: "people",
        title: "Usuários",
        subtitle: "Gerencie a equipe, perfis, atuação e a hierarquia de atendimento.",
        actions: safe_join([
          button_to(
            safe_join([ax_icon("arrow-repeat", class_name: "ax-ico"), "Sincronizar"], " "),
            sync_from_vista_admin_admin_users_path,
            method: :post,
            class: "ax-btn ax-btn--sm",
            form: { class: "tw-inline" },
            data: { turbo_confirm: "Sincronizar corretores do Vista agora? Roda em background." }
          ),
          button_to(
            safe_join([ax_icon("link-45deg", class_name: "ax-ico"), "Vincular imóveis"], " "),
            backfill_brokers_admin_admin_users_path,
            method: :post,
            class: "ax-btn ax-btn--sm",
            form: { class: "tw-inline" },
            data: { turbo_confirm: "Vincular imóveis aos corretores (via CodigoCorretor do Vista)? Roda em background." }
          )
        ])
      ) %>

  <div class="au-kpis">
    <%= ax_metric_card(label: "Total", value: number_with_delimiter(@total_admin_users)) %>
    <%= ax_metric_card(label: "Ativos", value: number_with_delimiter(@active_admin_users), badge: ax_badge("Ativo", tone: :green, dot: true)) %>
    <%= ax_metric_card(label: "Inativos", value: number_with_delimiter(@inactive_admin_users)) %>
    <%= ax_metric_card(label: "No site", value: number_with_delimiter(@displayed_admin_users)) %>
  </div>

  <%= render "vista_sync_panel" %>
  <%= render "backfill_brokers_panel" %>

  <%= ax_filter_form(
        url: admin_admin_users_path,
        reset_path: (admin_admin_users_path if filters_active),
        data: { controller: "auto-submit" }
      ) do |f| %>
    <%= ax_text_field(form: f, method: :query, type: :search, label: "Buscar usuários", value: params[:query], class: "ax-search ax-search--fluid", placeholder: "Nome, e-mail, CRECI ou ID") %>
    <%= ax_select_field(form: f, method: :profile_id, label: "Perfil de acesso", choices: @available_profiles.map { |profile| [profile_filter_label(profile), profile.id] }, select_options: { include_blank: "Todos os perfis", selected: params[:profile_id] }, html_options: { data: { action: "change->auto-submit#submit" } }) %>
    <%= ax_select_field(form: f, method: :acting_type, label: "Atuação", choices: acting_options, select_options: { prompt: "Todas as atuações", selected: params[:acting_type] }, html_options: { data: { action: "change->auto-submit#submit" } }) %>
    <%= ax_select_field(form: f, method: :manager_id, label: "Gestor", choices: @manager_options.map { |manager| [manager.name, manager.id] }, select_options: { prompt: "Todos os gestores", selected: params[:manager_id] }, html_options: { data: { action: "change->auto-submit#submit" } }) %>
    <%= ax_select_field(form: f, method: :status, label: "Status", choices: [["Todos", ""], ["Apenas ativos", "active"], ["Apenas inativos", "inactive"]], select_options: { selected: params[:status] }, html_options: { data: { action: "change->auto-submit#submit" } }) %>
  <% end %>

  <div class="ax-table-wrap">
    <table class="ax-table">
      <caption class="tw-sr-only">Usuários da equipe encontrados pelos filtros atuais</caption>
      <thead>
        <tr>
          <th scope="col">Usuário</th>
          <th scope="col">Perfil de acesso</th>
          <th scope="col" class="ax-num">Status</th>
          <th scope="col" class="ax-num">Atuação</th>
          <th scope="col">Gestor</th>
          <th scope="col" class="ax-num">Imóveis</th>
          <th scope="col" class="ax-num">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% if @admin_users.any? %>
          <% @admin_users.each do |user| %>
            <tr>
              <td>
                <div class="au-user">
                  <div class="au-user__avatar">
                    <%= ax_avatar(name: user.name, image: user.avatar, size: :md) %>
                    <% if user.vista_id.present? %><span class="au-user__vista" title="Integrado com Vista"></span><% end %>
                  </div>
                  <div class="au-user__main">
                    <strong><%= user.name %></strong>
                    <span><%= user.email %></span>
                    <div class="au-user__meta">
                      <% if user.creci.present? %><span><i class="bi bi-card-heading" aria-hidden="true"></i> CRECI <%= user.creci %></span><% end %>
                      <% if user.phone.present? %><span><i class="bi bi-whatsapp" aria-hidden="true"></i> <%= format_phone(user.phone) %></span><% end %>
                    </div>
                  </div>
                </div>
              </td>
              <td>
                <%= ax_badge(user.access_profile_name, tone: user.access_profile ? :blue : :gray) %>
              </td>
              <td class="ax-num">
                <%= ax_badge(user.active ? "Ativo" : "Inativo", tone: user.active ? :green : :red, dot: true) %>
              </td>
              <td class="ax-num">
                <% if (b = acting_badge.call(user.acting_type)) %>
                  <%= ax_badge(b[0], tone: b[1]) %>
                <% else %>
                  <span class="au-muted">—</span>
                <% end %>
              </td>
              <td>
                <% if user.manager_display_name.present? %>
                  <span class="au-strong"><%= user.manager_display_name %></span>
                <% else %>
                  <span class="au-muted">—</span>
                <% end %>
              </td>
              <td class="ax-num"><%= ax_badge(@habitations_count_by_admin_user.fetch(user.id, 0).to_s, tone: :gray) %></td>
              <td class="ax-num">
                <span class="au-actions">
                  <%= ax_icon_button(label: "Editar usuário #{user.name}", icon: "pencil", url: edit_admin_admin_user_path(user)) %>
                  <% if user != current_admin_user %>
                    <%= ax_icon_button(
                          label: "Excluir usuário #{user.name}",
                          icon: "trash",
                          variant: :danger,
                          data: {
                            controller: "reassign-delete",
                            ax_modal_open: "#reassignDeleteModal",
                            reassign_delete_trigger: true,
                            action: "click->reassign-delete#prepare",
                            url: admin_admin_user_path(user),
                            user_id: user.id,
                            user_name: user.name
                          }
                        ) %>
                  <% end %>
                </span>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr><td colspan="8">
            <%= ax_empty_state(title: "Nenhum usuário encontrado", description: "Ajuste os filtros de busca, perfil, atuação, gestor ou status.", icon: "people") %>
          </td></tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%= ax_pagination @admin_users, params: request.query_parameters %>
</div>

<%= ax_quick_modal(id: "reassignDeleteModal", title: "Excluir usuário", size: :md, footer: nil) do %>
  <div data-controller="reassign-delete">
    <%= ax_inline_notice(tone: :warning, icon: "exclamation-triangle") do %>
      <span>Você está excluindo <strong data-reassign-delete-target="name">este usuário</strong>. Esta ação é irreversível.</span>
    <% end %>

    <%= form_tag("", method: :delete, data: { reassign_delete_target: "form" }, class: "reassign-delete__form") do %>
      <p class="reassign-delete__hint">Os dados do usuário (leads, imóveis, captações, tarefas, propostas e carteira) serão <strong>reatribuídos</strong> para o admin escolhido. Auditorias permanecem imutáveis com o id histórico.</p>
      <% manageable_reassign_users = tenant_owner? ? current_tenant.admin_users.account_members.order(:name) : current_tenant.admin_users.account_members.where(id: [current_admin_user.id] + current_admin_user.descendant_ids).order(:name) %>
      <%= ax_standalone_select_field(
            name: :reassign_to_id,
            id: "reassign_to_id",
            label: "Reatribuir para",
            choices: manageable_reassign_users.map { |user| [safe_join([user.name, ("(você)" if user == current_admin_user)].compact, " "), user.id] },
            selected: current_admin_user.id,
            required: true,
            data: { reassign_delete_target: "select" }
          ) %>

      <%= ax_form_actions(sticky: false) do %>
        <button type="button" class="ax-btn" data-action="ax-modal#close">Cancelar</button>
        <button type="submit" class="ax-btn ax-btn--danger">Excluir e reatribuir</button>
      <% end %>
    <% end %>
  </div>
<% end %>
