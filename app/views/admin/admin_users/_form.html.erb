<%= form_with(model: [:admin, admin_user], local: true, html: { class: "au-form" }) do |f| %>
  <%= ax_error_summary(admin_user) %>

  <div class="au-form-grid">
    <div class="au-form-main">
      <%= ax_operational_panel(eyebrow: "Identificação", title: "Dados pessoais") do %>
        <div class="au-body">
          <div class="au-avatar-row">
            <div class="au-avatar">
              <%= ax_avatar(
                    name: admin_user.name.presence || admin_user.email || "Usuário",
                    image: admin_user.avatar,
                    size: :xxl
                  ) %>
            </div>
            <%= ax_file_field(form: f, method: :avatar, label: "Foto de perfil", tooltip: "Formatos aceitos: JPG e PNG.", button_label: "Escolher foto", class_name: "au-avatar-row__field") %>
          </div>

          <%= ax_field_grid do %>
            <%= ax_text_field(form: f, method: :name, label: "Nome completo", class_name: "ax-span-6", placeholder: "Ex.: João Silva") %>
            <%= ax_text_field(form: f, method: :email, type: :email, label: "E-mail de acesso", class_name: "ax-span-6", placeholder: "joao@empresa.com") %>

            <%= ax_text_field(form: f, method: :phone, type: :tel, label: "Celular / WhatsApp", class_name: "ax-span-6", placeholder: "(47) 99999-9999", autocomplete: "tel", data: { controller: "phone-input" }) %>
            <%= ax_text_field(form: f, method: :secondary_phone, type: :tel, label: "Telefone secundário", class_name: "ax-span-6", placeholder: "(47) 99999-9999", autocomplete: "tel", data: { controller: "phone-input" }) %>

            <%= ax_text_field(form: f, method: :creci, label: "CRECI", class_name: "ax-span-6", placeholder: "Ex.: 12345SC") %>
            <%= ax_date_field(form: f, method: :birth_date, label: "Data de nascimento", class_name: "ax-span-6") %>

            <%= ax_text_field(form: f, method: :city, label: "Cidade", class_name: "ax-span-6", placeholder: "Ex.: Balneário Camboriú") %>
            <%= ax_text_field(form: f, method: :biography, type: :textarea, label: "Biografia / observações", class_name: "ax-span-12", rows: 4, placeholder: "Breve descrição sobre o usuário...") %>
          <% end %>

          <% if admin_user.respond_to?(:mirror?) && admin_user.mirror? %>
            <%= ax_inline_notice(tone: :info, icon: "person-lock", compact: true) do %>
              Usuário externo (espelho): e-mail e senha pertencem à conta de origem — <strong><%= admin_user.notification_email %></strong>.
            <% end %>
          <% else %>
            <%= ax_field_grid do %>
              <%= ax_text_field(form: f, method: :password, type: :password, label: admin_user.persisted? ? "Senha (em branco = não alterar)" : "Senha", class_name: "ax-span-6", autocomplete: "new-password") %>
              <%= ax_text_field(form: f, method: :password_confirmation, type: :password, label: "Confirmar senha", class_name: "ax-span-6", autocomplete: "new-password") %>
            <% end %>
          <% end %>

          <% if admin_user.persisted? && admin_user.respond_to?(:otp_enabled?) && admin_user.otp_enabled? && current_admin_user.tenant_owner? %>
            <div class="tw-mt-2">
              <%= link_to reset_two_factor_admin_admin_user_path(admin_user),
                    data: { turbo_method: :post,
                            turbo_confirm: "Resetar a verificação em duas etapas de #{admin_user.name}? A pessoa volta a entrar só com a senha e precisará reconfigurar o app autenticador." },
                    class: "ax-btn ax-btn--sm ax-btn--ghost" do %>
                <i class="bi bi-shield-x ax-ico" aria-hidden="true"></i><span>Resetar 2FA (perdeu o aparelho)</span>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="au-form-side">
      <%= ax_operational_panel(eyebrow: "Acesso", title: "Acesso e equipe") do %>
        <div class="au-body" data-controller="admin-user-access">
          <% if current_admin_user&.can?(:manage, :corretores) %>
            <%
              current_access_id = admin_user.horizontal_profile_id.presence || admin_user.profile_id
              access_profile_groups = {
                "Hierarquia" => (@assignable_vertical_profiles || []).map { |profile| [profile.name, profile.id, { data: { axis: "vertical" } }] },
                "Funções operacionais" => (@assignable_horizontal_profiles || []).map do |profile|
                  [
                    safe_join([profile.name, profile.root_vertical_profile ? "· #{profile.root_vertical_profile.name}" : nil].compact, " "),
                    profile.id,
                    { data: { axis: "horizontal", vertical_profile_id: profile.root_vertical_profile&.id } }
                  ]
                end
              }.reject { |_label, choices| choices.empty? }
            %>
            <%= ax_standalone_select_field(
                  name: "admin_user[access_profile_id]",
                  id: "admin_user_access_profile_id",
                  label: "Perfil de acesso",
                  choices: access_profile_groups,
                  selected: current_access_id,
                  include_blank: "Selecione um perfil...",
                  hint: "A hierarquia define escopo e equipe; a função operacional já carrega a hierarquia correspondente.",
                  grouped: true,
                  data: { admin_user_access_target: "accessSelect", action: "change->admin-user-access#sync" }
                ) %>
          <% else %>
            <%= ax_status_list(
                  label: "Perfil de acesso",
                  rows: [{
                    label: "Perfil atual",
                    value: safe_join([admin_user.profile&.name || "Ainda não definido", admin_user.horizontal_profile&.name].compact, " · ")
                  }]
                ) %>
          <% end %>

          <%= ax_chip_grid do %>
            <%= ax_toggle_chip(f, :active, label: "Ativo no sistema", id: "admin_user_active") %>
            <span data-admin-user-access-target="verticalOnly">
              <%= ax_toggle_chip(f, :display_on_site, label: "Exibir perfil no site", id: "admin_user_display_on_site") %>
            </span>
          <% end %>
          <%= ax_inline_notice(tone: :info, icon: "info-circle", compact: true) do %>
            Usuários inativos não recebem leads e ficam fora da distribuição. O status é sincronizado a cada importação do Vista.
          <% end %>

          <div data-admin-user-access-target="verticalOnly">
            <%= ax_select_field(
                  form: f,
                  method: :acting_type,
                  label: "Área de atuação",
                  tooltip: "Venda, Locação ou Ambos. Define quais gestores o usuário precisa.",
                  choices: AdminUser.acting_types.keys.map { |k| [I18n.t("enums.admin_user.acting_type.#{k}", default: k.humanize), k] },
                  select_options: { prompt: "Selecione..." },
                  html_options: { data: { admin_user_access_target: "actingSelect", action: "change->admin-user-access#sync" } }
                ) %>
          </div>

          <% if current_admin_user&.can?(:manage, :corretores) %>
            <% manager_options = @assignable_manager_options || [] %>
            <div data-admin-user-access-target="verticalOnly salesManagerField">
              <%= ax_select_field(form: f, method: :manager_id, label: "Gestor de Venda", tooltip: "Equipe de venda: hierarquia e regras de distribuição de venda.", choices: manager_options.map { |manager| [manager.name, manager.id] }, select_options: { prompt: "Nenhum (topo da hierarquia)" }) %>
            </div>
            <div data-admin-user-access-target="verticalOnly rentalsManagerField">
              <%= ax_select_field(form: f, method: :rentals_manager_id, label: "Gestor de Locação", tooltip: "Equipe de locação: hierarquia e regras de distribuição de locação.", choices: manager_options.map { |manager| [manager.name, manager.id] }, select_options: { prompt: "Nenhum (topo da hierarquia)" }) %>
            </div>
            <div data-admin-user-access-target="verticalOnly">
              <%= ax_inline_notice(tone: :warning, icon: "diagram-3", compact: true) do %>
                Cada área exige o gestor correspondente — <strong>“Ambos” pede os dois</strong>. Sem o vínculo, o usuário fica fora da hierarquia e das regras de distribuição da área.
              <% end %>
            </div>
          <% end %>

          <% if current_admin_user&.tenant_owner? %>
            <%= ax_field_group(title: "Segurança de login") do %>
              <%= ax_chip_grid do %>
                <%= ax_toggle_chip(f, :require_ip_allowlist, label: "Exigir IP permitido", id: "admin_user_require_ip_allowlist") %>
                <%= ax_toggle_chip(f, :require_trusted_device, label: "Exigir aparelho confiável", id: "admin_user_require_trusted_device") %>
              <% end %>
            <% end %>
          <% end %>

          <% if admin_user.vista_id.present? %>
            <%= ax_status_list(
                  label: "Integração Vista",
                  rows: [{ label: "Identificador", value: admin_user.vista_id }, { label: "Estado", value: ax_badge("Conectado", tone: :green, dot: true) }]
                ) %>
          <% end %>
        </div>
      <% end %>

      <% if admin_user.new_record? %>
        <%= ax_inline_notice(tone: :info, icon: "info-circle") do %>
          Usuários criados aqui acessam o painel imediatamente após salvar.
        <% end %>
      <% end %>
    </div>
  </div>

  <%= ax_sticky_action_footer do %>
    <%= link_to "Cancelar", admin_admin_users_path, class: "ax-btn" %>
    <%= f.submit (admin_user.persisted? ? "Salvar alterações" : "Criar usuário"), class: "ax-btn ax-btn--primary" %>
  <% end %>
<% end %>
