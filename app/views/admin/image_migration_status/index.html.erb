<%# Migração de Imagens — compacto (.ax-*). Todos os data-targets do Stimulus preservados. Original em .bootstrap-bak %>
<% worker = @status[:worker] %>
<% execution = @status[:execution] || {} %>
<% latest_attachment_at = @status[:latest_attachment_at] %>
<% file_asset_counts = @status[:file_asset_counts] || {} %>

<div data-controller="image-migration-status" data-image-migration-status-url-value="<%= admin_image_migration_status_path(format: :json) %>">
  <% migration_actions = capture do %>
    <div class="tw-flex tw-gap-2">
      <%= button_to admin_sync_image_migration_path, method: :post, class: "ax-btn ax-btn--sm ax-btn--primary", disabled: worker[:running], data: { image_migration_status_target: "syncButton" }, form: { class: "tw-inline", data: { turbo_confirm: "Iniciar a materialização das fotos com as configurações salvas?" } } do %>
        <i class="bi bi-play-fill ax-ico"></i>Iniciar
      <% end %>
      <%= link_to admin_image_migration_status_path, class: "ax-btn ax-btn--sm" do %><i class="bi bi-arrow-clockwise ax-ico"></i>Atualizar<% end %>
    </div>
  <% end %>
  <%= ax_workspace_heading(
        eyebrow: "Sistema · Active Storage",
        icon: "images",
        title: "Migração de Imagens",
        subtitle: "Materialize fotos da API Vista no Active Storage/DO Spaces, sem baixar novamente o que já está anexado.",
        actions: migration_actions
      ) %>

  <div class="ax-metric-grid tw-mb-4">
    <%= ax_metric_card(
          label: "Imóveis com fotos",
          value: tag.span(number_to_percentage(@status[:property_progress], precision: 2), data: { image_migration_status_target: "propertyProgressValue" }),
          hint: safe_join([tag.strong(number_with_delimiter(@status[:properties_with_photos]), data: { image_migration_status_target: "propertiesWithPhotos" }), " de ", tag.strong(number_with_delimiter(@status[:total_properties]), data: { image_migration_status_target: "totalProperties" })])
        ) %>
    <%= ax_metric_card(
          label: "Pendentes",
          value: tag.span(number_with_delimiter(@status[:pending_properties]), data: { image_migration_status_target: "pendingProperties" }),
          hint: "Imóveis com galeria API/Vista e nenhuma foto anexada."
        ) %>
    <%= ax_metric_card(
          label: "Fotos anexadas",
          value: tag.span(number_with_delimiter(@status[:migrated_images]), data: { image_migration_status_target: "migratedImages" }),
          hint: safe_join([tag.span(number_to_percentage(@status[:image_progress], precision: 2), data: { image_migration_status_target: "imageProgress" }), " do volume estimado de origem."])
        ) %>
    <%= ax_metric_card(
          label: "Processo",
          value: tag.span(worker[:status], class: "ax-badge #{worker[:running] ? 'ax-badge--green' : 'ax-badge--gray'}", data: { image_migration_status_target: "workerBadge" }),
          hint: tag.span(worker[:pid].present? ? "PID #{worker[:pid]}" : "Sem execução ativa", data: { image_migration_status_target: "workerPid" })
        ) %>
  </div>

  <div class="ax-card tw-mb-4">
    <div class="ax-card__body">
      <div class="tw-flex tw-flex-wrap tw-justify-between tw-items-start tw-gap-3 tw-mb-3">
        <div>
          <div class="ax-card__title"><i class="bi bi-sliders"></i> Próxima execução</div>
          <p class="ax-page-subtitle tw-mb-0">O padrão processa somente imóveis pendentes. Fotos já anexadas são preservadas e reaproveitadas por nome de arquivo.</p>
        </div>
        <%= button_to admin_retry_failed_image_migration_path, method: :post, class: "ax-btn ax-btn--sm", disabled: worker[:running] || @status[:failed_properties].zero?, data: { image_migration_status_target: "retryButton" }, form: { class: "tw-inline", data: { turbo_confirm: "Tentar novamente os imóveis com falhas de fotos API/Vista?" } } do %>
          <i class="bi bi-arrow-repeat ax-ico"></i>Retry falhas
        <% end %>
      </div>
      <%= form_with url: admin_image_migration_configuration_path, method: :patch, scope: :image_migration, local: true do |f| %>
        <div class="tw-grid tw-grid-cols-2 lg:tw-grid-cols-6 tw-gap-3 tw-items-end">
          <div class="lg:tw-col-span-2"><%= f.label :mode, "Escopo", class: "ax-label" %><%= f.select :mode, options_for_select(Admin::ImageMigrationStatusController::SYNC_MODES.map { |v, l| [l, v] }, @configuration["mode"]), {}, class: "ax-select" %></div>
          <div><%= f.label :batch_size, "Lote", class: "ax-label" %><%= f.number_field :batch_size, value: @configuration["batch_size"], min: 1, max: 500, class: "ax-input" %></div>
          <div><%= f.label :workers, "Workers", class: "ax-label" %><%= f.number_field :workers, value: @configuration["workers"], min: 1, max: 8, class: "ax-input" %></div>
          <label class="tw-inline-flex tw-items-center tw-gap-1.5 tw-text-2xs tw-text-ink-soft"><%= f.check_box :replace, { checked: @configuration["replace"] == "true" }, "true", "false" %> Substituir ordem/anexos</label>
          <label class="tw-inline-flex tw-items-center tw-gap-1.5 tw-text-2xs tw-text-ink-soft"><%= f.check_box :dry_run, { checked: @configuration["dry_run"] == "true" }, "true", "false" %> Simular</label>
          <div class="lg:tw-col-span-2"><%= f.submit "Salvar configurações", class: "ax-btn tw-w-full" %></div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="ax-card tw-mb-4" data-image-migration-status-target="executionPanel">
    <div class="ax-card__body">
      <div class="tw-flex tw-flex-wrap tw-justify-between tw-items-start tw-gap-3 tw-mb-3">
        <div>
          <div class="ax-stat-label">Execução atual</div>
          <div class="ax-card__title" data-image-migration-status-target="executionLabel"><%= execution[:label].presence || "Aguardando execução" %></div>
          <div class="ax-page-subtitle">Status: <strong data-image-migration-status-target="executionStatus"><%= execution[:running] ? "Rodando" : "Parado" %></strong> · Última foto: <strong data-image-migration-status-target="latestAttachmentAt"><%= latest_attachment_at.present? ? l(latest_attachment_at, format: :short) : "N/D" %></strong></div>
        </div>
        <div class="tw-text-right">
          <div class="ax-stat-value" data-image-migration-status-target="executionProgressPercent"><%= number_to_percentage(execution[:progress].to_f, precision: 2) %></div>
          <div class="ax-page-subtitle" data-image-migration-status-target="executionDetail"><%= number_with_delimiter(execution[:current].to_i) %> de <%= number_with_delimiter(execution[:total].to_i) %></div>
        </div>
      </div>
      <%= ax_progress(
        value: execution[:progress],
        class_name: "ax-progress--lg tw-mb-3",
        label: "Progresso da migração de imagens",
        data: { image_migration_status_target: "executionProgressBar" }
      ) %>
      <div class="tw-grid tw-grid-cols-2 lg:tw-grid-cols-6 tw-gap-3 tw-text-2xs">
        <div><div class="tw-text-ink-muted">Imóveis novos</div><div class="ax-strong" data-image-migration-status-target="executionPropertiesAdded"><%= number_with_delimiter(execution[:properties_added].to_i) %></div></div>
        <div><div class="tw-text-ink-muted">Fotos novas</div><div class="ax-strong" data-image-migration-status-target="executionImagesAdded"><%= number_with_delimiter(execution[:images_added].to_i) %></div></div>
        <div><div class="tw-text-ink-muted">Restantes</div><div class="ax-strong" data-image-migration-status-target="executionRemaining"><%= number_with_delimiter(execution[:remaining].to_i) %></div></div>
        <div><div class="tw-text-ink-muted">Falhas</div><div class="ax-strong" data-image-migration-status-target="executionFailed"><%= number_with_delimiter(execution[:failed].to_i) %></div></div>
        <div><div class="tw-text-ink-muted">Assets baixados</div><div class="ax-strong" data-image-migration-status-target="downloadedFileAssets"><%= number_with_delimiter(@status[:downloaded_file_assets]) %></div></div>
        <div><div class="tw-text-ink-muted">Assets pendentes</div><div class="ax-strong" data-image-migration-status-target="pendingFileAssets"><%= number_with_delimiter(@status[:pending_file_assets]) %></div></div>
      </div>
    </div>
  </div>

  <div class="tw-grid tw-grid-cols-1 lg:tw-grid-cols-12 tw-gap-3 tw-mb-4">
    <div class="lg:tw-col-span-7 ax-card">
      <div class="ax-card__header"><span class="ax-card__title"><i class="bi bi-list-check"></i> Resumo da base</span></div>
      <div class="ax-card__body tw-text-2xs">
        <% [["Total com galeria API/Vista", @status[:total_properties], "summaryTotalProperties"], ["Já com fotos na nossa base", @status[:properties_with_photos], "summaryPropertiesWithPhotos"], ["Pendentes", @status[:pending_properties], "summaryPendingProperties"], ["Pendentes públicos de venda/aluguel", @status[:public_pending_properties], "summaryPublicPendingProperties"], ["Total estimado de imagens de origem", @status[:total_source_images], "summaryTotalSourceImages"]].each do |lbl, val, tgt| %>
          <div class="tw-flex tw-justify-between tw-py-2 tw-border-b tw-border-line last:tw-border-0"><span><%= lbl %></span><strong data-image-migration-status-target="<%= tgt %>"><%= number_with_delimiter(val) %></strong></div>
        <% end %>
      </div>
    </div>
    <div class="lg:tw-col-span-5 ax-card">
      <div class="ax-card__header"><span class="ax-card__title"><i class="bi bi-database-check tw-text-green-600"></i> Índice API/Vista</span></div>
      <div class="ax-card__body tw-text-2xs">
        <div class="tw-flex tw-justify-between tw-py-2 tw-border-b tw-border-line"><span>Baixados/anexados</span><strong data-image-migration-status-target="summaryDownloadedFileAssets"><%= number_with_delimiter(file_asset_counts.fetch("downloaded", 0)) %></strong></div>
        <div class="tw-flex tw-justify-between tw-py-2 tw-border-b tw-border-line"><span>Pendentes no índice</span><strong data-image-migration-status-target="summaryPendingFileAssets"><%= number_with_delimiter(file_asset_counts.fetch("pending", 0)) %></strong></div>
        <div class="tw-flex tw-justify-between tw-py-2 tw-border-b tw-border-line"><span>Falhas</span><strong data-image-migration-status-target="failedProperties"><%= number_with_delimiter(@status[:failed_properties]) %></strong></div>
        <div class="tw-py-2"><span class="tw-text-ink-muted tw-block tw-mb-1">Log da execução</span><code class="tw-text-2xs"><%= @status[:paths][:log] %></code></div>
      </div>
    </div>
  </div>

  <% if @status[:failed_properties].positive? %>
    <%= ax_inline_notice(tone: :warning, icon: "exclamation-triangle") do %>
      <strong>Há imóveis com falha de materialização.</strong> Amostra de IDs: <code><%= @status[:failed_sample].join(", ") %></code>.
    <% end %>
  <% end %>
  <% if @status[:public_vista_first_properties].positive? %>
    <%= ax_inline_notice(tone: :warning, icon: "exclamation-triangle") do %>
      <strong>Há imóveis públicos usando Vista como origem temporária.</strong> Amostra de IDs: <code><%= @status[:public_vista_first_sample].join(", ") %></code>.
    <% end %>
  <% end %>

  <%= ax_inline_notice(tone: :info, icon: "info-circle") do %>
    A execução usa a galeria da API/Vista como origem, reaproveita fotos já anexadas por nome de arquivo e baixa apenas o que ainda falta no Active Storage/DO Spaces.
  <% end %>
</div>
