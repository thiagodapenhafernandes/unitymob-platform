<div class="tw-mb-4">
  <%= link_to admin_lead_path(@lead), class: "ax-page-subtitle tw-inline-flex tw-items-center tw-gap-1" do %>
    <i class="bi bi-chevron-left"></i> Voltar ao lead
  <% end %>
  <h1 class="ax-page-title tw-mt-1">Nova proposta — <%= @lead.display_name %></h1>
  <p class="ax-page-subtitle">Gere uma página compartilhável que o cliente abre no celular para aceitar ou recusar.</p>
</div>

<%= render "form", proposal: @proposal, lead: @lead, url: admin_lead_proposals_path(@lead), method: :post, habitations: @habitations %>
