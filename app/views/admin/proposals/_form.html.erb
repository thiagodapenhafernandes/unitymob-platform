<%# locals: proposal, lead, url, method, habitations %>
<%= form_with model: proposal, url: url, method: local_assigns.fetch(:method, :post), scope: :proposal do |f| %>
  <%= ax_error_summary(proposal, title: "Revise os dados da proposta") %>

  <%= ax_operational_panel(eyebrow: "Condições comerciais", title: "Dados da proposta") do %>
    <%= ax_field_grid do %>
      <div class="ax-field ax-span-12">
        <label class="ax-label">Imóvel</label>
        <%= f.select :habitation_id,
              options_for_select(habitations.map { |h| ["#{h.try(:codigo)} — #{h.try(:display_title)}", h.id] }, proposal.habitation_id),
              { include_blank: "Sem imóvel específico" },
              class: "ax-control", data: { controller: "tom-select" } %>
        <%= render "admin/shared/ui/field_error", form: f, method: :habitation_id %>
      </div>

      <div class="ax-field ax-span-12">
        <label class="ax-label">Título (opcional)</label>
        <%= f.text_field :title, class: "ax-control", placeholder: "Ex.: Proposta de compra — Ap. 302" %>
        <%= render "admin/shared/ui/field_error", form: f, method: :title %>
      </div>

      <%= ax_currency_field(
        form: f,
        method: :valor,
        label: "Valor da proposta",
        class_name: "ax-span-6",
        value: (proposal.valor_cents.to_i.positive? ? number_with_precision(proposal.valor, precision: 2) : nil),
        inputmode: "decimal",
        placeholder: "450000,00"
      ) %>

      <%= ax_currency_field(
        form: f,
        method: :entrada,
        label: "Entrada",
        class_name: "ax-span-6",
        value: (proposal.entrada_cents.to_i.positive? ? number_with_precision(proposal.entrada, precision: 2) : nil),
        inputmode: "decimal",
        placeholder: "90000,00"
      ) %>

      <div class="ax-field ax-span-12">
        <label class="ax-label">Condições</label>
        <%= f.text_area :condicoes, rows: 4, class: "ax-control ax-textarea", placeholder: "Forma de pagamento, financiamento, prazos, observações..." %>
        <%= render "admin/shared/ui/field_error", form: f, method: :condicoes %>
      </div>

      <%= ax_date_field(form: f, method: :validade, label: "Validade", class_name: "ax-span-4", clearable: true) %>
    <% end %>
  <% end %>

  <%= ax_form_actions(cancel_path: admin_lead_path(lead), submit_label: "Salvar proposta", form: f) %>
<% end %>
