<div class="tw-mb-4">
  <%= link_to admin_lead_path(@proposal.lead), class: "ax-page-subtitle tw-inline-flex tw-items-center tw-gap-1" do %>
    <i class="bi bi-chevron-left"></i> Voltar ao lead
  <% end %>
  <h1 class="ax-page-title tw-mt-1">Editar proposta <span class="tw-font-mono"><%= @proposal.public_token %></span></h1>
  <p class="ax-page-subtitle">Status atual: <%= @proposal.status_label %></p>
</div>

<%= render "form", proposal: @proposal, lead: @proposal.lead, url: admin_proposal_path(@proposal), method: :patch, habitations: @habitations %>
