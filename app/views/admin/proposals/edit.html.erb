<%= ax_workspace_heading(
  eyebrow: "Comercial · Propostas",
  icon: "file-earmark-text",
  title: "Editar proposta #{@proposal.public_token}",
  pills: [@proposal.status_label],
  actions: ax_button("Voltar ao lead", admin_lead_path(@proposal.lead), variant: :ghost, size: :sm, icon: "arrow-left")
) %>

<%= render "form", proposal: @proposal, lead: @proposal.lead, url: admin_proposal_path(@proposal), method: :patch, habitations: @habitations %>
