<%= turbo_frame_tag "admin_dashboard_rankings" do %>
  <div class="ax-dashboard-grid ax-dashboard-grid--rankings">
    <% if @is_admin_view %>
      <article class="ax-dashboard-panel">
        <div class="ax-dashboard-panel__header">
          <div>
            <span class="ax-dashboard-panel__eyebrow">Comercial · <%= @dashboard_period %> dias</span>
            <h2>Desempenho por corretor</h2>
          </div>
          <%= link_to "Ver leads", admin_leads_path, class: "ax-dashboard-panel__link", data: { turbo_frame: "_top" } %>
        </div>
        <div class="ax-dashboard-performance">
          <% @broker_performance.each do |row| %>
            <%= link_to admin_leads_path(broker_id: row[:id], start_date: @dashboard_window_start.to_date.iso8601, end_date: Date.current.iso8601), class: "ax-dashboard-performance__row", data: { turbo_frame: "_top" } do %>
              <strong><%= row[:name] %></strong>
              <span><%= row[:total] %> leads</span>
              <span><%= row[:closed] %> concluídos</span>
              <b><%= number_to_percentage(row[:conversion], precision: 1, strip_insignificant_zeros: true) %></b>
            <% end %>
          <% end %>
          <% if @broker_performance.empty? %><div class="ax-dashboard-empty-row">Sem leads atribuídos no período.</div><% end %>
        </div>
      </article>

      <article class="ax-dashboard-panel">
        <div class="ax-dashboard-panel__header">
          <div>
            <span class="ax-dashboard-panel__eyebrow">Distribuição</span>
            <h2>Carteira de imóveis por corretor</h2>
          </div>
          <%= link_to "Ver todos", admin_admin_users_path, class: "ax-dashboard-panel__link", data: { turbo_frame: "_top" } %>
        </div>
        <div class="ax-dashboard-rank">
          <% if @top_brokers.any? %>
            <% max_ct = @top_brokers.first.ct.to_f %>
            <% @top_brokers.each do |broker| %>
              <div class="ax-dashboard-rank__row">
                <div>
                  <strong><%= broker.name %></strong>
                  <span><%= broker.ct %> imóveis</span>
                </div>
                <i style="width:<%= max_ct.positive? ? ((broker.ct.to_f / max_ct) * 100).to_i : 0 %>%"></i>
              </div>
            <% end %>
          <% else %>
            <div class="ax-dashboard-empty-row">Nenhum imóvel vinculado a corretor ainda.</div>
          <% end %>
        </div>
      </article>

      <% if @field_feature_enabled %>
      <article class="ax-dashboard-panel">
        <div class="ax-dashboard-panel__header">
          <div>
            <span class="ax-dashboard-panel__eyebrow">Campo</span>
            <h2>Top lojas por check-ins</h2>
          </div>
          <%= link_to "Ver todas", admin_stores_path, class: "ax-dashboard-panel__link", data: { turbo_frame: "_top" } %>
        </div>
        <div class="ax-dashboard-rank">
          <% if @top_stores.any? %>
            <% max_ct = @top_stores.first.ct.to_f %>
            <% @top_stores.each do |store| %>
              <div class="ax-dashboard-rank__row">
                <div>
                  <strong><i class="bi bi-geo-alt"></i> <%= store.name %></strong>
                  <span><%= store.ct %> check-ins em 30d</span>
                </div>
                <i style="width:<%= max_ct.positive? ? ((store.ct.to_f / max_ct) * 100).to_i : 0 %>%"></i>
              </div>
            <% end %>
          <% else %>
            <div class="ax-dashboard-empty-row">Sem check-ins nos últimos 30 dias.</div>
          <% end %>
        </div>
      </article>
      <% end %>
    <% end %>
  </div>
<% end %>
