<%
  title ||= "Carregando"
  eyebrow ||= "Atualizando"
  rows ||= 4
  chart ||= false
  table ||= false
  compact ||= false
%>

<article class="ax-dashboard-panel ax-dashboard-skeleton <%= 'ax-dashboard-skeleton--compact' if compact %>" role="status" aria-live="polite" aria-busy="true" aria-label="Carregando <%= title %>">
  <div class="ax-dashboard-panel__header">
    <div>
      <span class="ax-dashboard-panel__eyebrow"><%= eyebrow %></span>
      <h2><%= title %></h2>
    </div>
    <span class="ax-skeleton-pill"></span>
  </div>

  <% if chart %>
    <div class="ax-skeleton-chart" aria-hidden="true">
      <% 7.times do %><span></span><% end %>
    </div>
  <% elsif table %>
    <div class="ax-skeleton-table" aria-hidden="true">
      <% rows.times do %>
        <span></span>
      <% end %>
    </div>
  <% else %>
    <div class="ax-skeleton-list" aria-hidden="true">
      <% rows.times do |index| %>
        <span class="ax-skeleton-row">
          <i></i>
          <b class="ax-skeleton-row__line--<%= (index % 5) + 1 %>"></b>
          <em></em>
        </span>
      <% end %>
    </div>
  <% end %>
</article>
