<%= turbo_frame_tag "admin_dashboard_funnel" do %>
  <article class="ax-dashboard-panel ax-dashboard-panel--funnel">
    <div class="ax-dashboard-panel__header">
      <div>
        <span class="ax-dashboard-panel__eyebrow">Funil</span>
        <h2>Conversão comercial</h2>
      </div>
      <%= ax_badge("#{@dashboard_period} dias", tone: :blue) %>
    </div>

    <div class="ax-dashboard-funnel">
      <div class="ax-dashboard-funnel__visual" aria-label="Funil comercial dos últimos 30 dias">
        <% @commercial_funnel_rows.each do |row| %>
          <div class="ax-dashboard-funnel__stage ax-dashboard-funnel__stage--<%= row[:tone] %>">
            <span class="ax-dashboard-funnel__stage-label"><%= row[:label] %></span>
            <strong><%= number_with_delimiter(row[:value]) %></strong>
          </div>
        <% end %>
      </div>

      <div class="ax-dashboard-funnel__rates" aria-label="Taxas observadas e faixas de referência">
        <% @commercial_funnel_rows.each_cons(2) do |from, to| %>
          <div class="ax-dashboard-funnel__rate">
            <span><%= from[:label].split.first %> -> <%= to[:label].split.first %></span>
            <strong><%= number_to_percentage(to[:conversion_rate], precision: 1, strip_insignificant_zeros: true) %></strong>
            <small>Referência: <%= from[:benchmark] %></small>
          </div>
        <% end %>
        <div class="ax-dashboard-funnel__rate ax-dashboard-funnel__rate--overall">
          <span>Impacto -> venda</span>
          <strong><%= number_to_percentage(@commercial_funnel_rows.last[:overall_conversion_rate], precision: 1, strip_insignificant_zeros: true) %></strong>
          <small>Referência: <%= @commercial_funnel_rows.last[:benchmark] %></small>
        </div>
      </div>
    </div>
  </article>
<% end %>
