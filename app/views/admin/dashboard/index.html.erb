<%# Dashboard operacional — shell leve com slices assíncronos via Turbo Frames. %>
<%
  hour = Time.current.hour
  greeting = hour < 12 ? "Bom dia" : (hour < 18 ? "Boa tarde" : "Boa noite")
  first_name = current_admin_user.name.to_s.split.first.presence || current_admin_user.email

  dashboard_subtitle =
    if @is_admin_view && @field_feature_enabled
      "Campo ativo: #{@active_checkins_count} check-ins agora, #{@leads_today} leads hoje."
    elsif @is_admin_view
      "Campo desativado para esta operação. Ative quando houver equipe externa em rota."
    else
      "Painel pessoal: #{@leads_today} leads hoje, #{@properties_count} imóveis atribuídos."
    end

  today_metrics = [
    [@today_new_habitations, "building", "Imóveis atualizados"],
    [@leads_today, "megaphone", "Leads recebidos"],
    [@today_captacoes, "journal-plus", "Captações criadas"],
    [@today_checkins_count, "geo-fill", "Check-ins"]
  ]

  pending_items = []
  pending_items << [admin_captacoes_path(status: "draft"), "file-earmark-text", "amber", "Captações em rascunho", @drafts_count] if @drafts_count.to_i.positive?
  pending_items << [admin_leads_path(status: "represado"), "hourglass-split", "red", "Leads represados", @holding_leads] if @holding_leads.to_i.positive?
  pending_items << [admin_field_manual_checkin_requests_path, "hand-index-thumb", "amber", "Pedidos manuais pendentes", @pending_manual_requests] if @pending_manual_requests.to_i.positive?
  pending_items << [admin_habitations_path(status: "error"), "exclamation-triangle-fill", "red", "Imóveis com erro de sync", @sync_errors_count] if @sync_errors_count.to_i.positive?
%>

<section class="ax-dashboard" aria-label="Dashboard operacional">
  <header class="ax-dashboard-command">
    <div class="ax-dashboard-command__main">
      <span class="ax-dashboard-command__eyebrow">Cockpit operacional</span>
      <div class="ax-dashboard-command__title-row">
        <h1><%= greeting %>, <%= first_name %></h1>
        <%= ax_badge(@is_admin_view ? "Admin" : "Meu painel", tone: :blue) %>
      </div>
      <p><%= l(Date.current, format: :long) %> · <%= dashboard_subtitle %></p>
    </div>

    <div class="ax-dashboard-command__status">
      <span><i class="bi bi-hdd-network"></i> Operação</span>
      <% if @field_feature_enabled %>
        <%= ax_badge("Campo ativo", tone: :green, dot: true) %>
      <% else %>
        <%= ax_badge("Campo pausado", tone: :amber) %>
      <% end %>
    </div>
  </header>

  <div class="ax-dashboard-kpis">
    <%= ax_metric_card(
          label: "Imóveis no catálogo",
          value: number_with_delimiter(@properties_count),
          badge: ax_badge("Ativos", tone: :green, dot: true),
          hint: "#{@featured_count} destaques · #{@developments_count} empreendimentos",
          class_name: "ax-dashboard-kpi"
        ) %>

    <%= ax_metric_card(
          label: "Leads hoje",
          value: number_with_delimiter(@leads_today),
          badge: ax_badge("#{@leads_last_7_days} em 7d", tone: :gray),
          hint: "#{@holding_leads} represados · #{@new_leads} novos",
          class_name: "ax-dashboard-kpi"
        ) %>

    <% if @is_admin_view %>
      <%= ax_metric_card(
            label: "Check-ins ativos",
            value: @active_checkins_count,
            badge: @active_checkins_count.positive? ? ax_badge("Ao vivo", tone: :green, dot: true) : ax_badge("Sem ativos", tone: :gray),
            hint: "#{@today_checkins_count} hoje · #{@suspicious_checkins} suspeitos",
            class_name: "ax-dashboard-kpi"
          ) %>

      <%= ax_metric_card(
            label: "Regras de distribuição",
            value: "#{@distribution_rules_active}/#{@distribution_rules_total}",
            badge: ax_badge("#{@rules_with_checkin} c/ check-in", tone: :blue),
            hint: "#{@brokers_active} corretores · #{@stores_active_count} lojas",
            progress: @distribution_rules_total.to_i.positive? ? ((@distribution_rules_active.to_f / @distribution_rules_total) * 100) : 0,
            class_name: "ax-dashboard-kpi"
          ) %>
    <% end %>
  </div>

  <div class="ax-dashboard-grid ax-dashboard-grid--insights">
    <%= turbo_frame_tag "admin_dashboard_charts", src: admin_dashboard_section_path("charts") do %>
      <%= render "admin/dashboard/sections/loading_panel",
                 title: "Leads - últimos 30 dias",
                 eyebrow: "Aquisição",
                 chart: true %>
    <% end %>

    <%= turbo_frame_tag "admin_dashboard_funnel", src: admin_dashboard_section_path("funnel") do %>
      <%= render "admin/dashboard/sections/loading_panel", title: "Conversão comercial", eyebrow: "Funil", chart: true, compact: true %>
    <% end %>

    <%= turbo_frame_tag "admin_dashboard_status", src: admin_dashboard_section_path("status") do %>
      <%= render "admin/dashboard/sections/loading_panel", title: "Leads por status", eyebrow: "Status", chart: true, compact: true %>
    <% end %>
  </div>

  <% if @is_admin_view && !@field_feature_enabled %>
    <div class="ax-dashboard-alert ax-dashboard-alert--compact">
      <div>
        <i class="bi bi-pause-circle"></i>
        <strong>Módulo Campo desativado</strong>
        <span>Ative somente quando a operação externa estiver em uso.</span>
      </div>
      <%= ax_button("Ativar campo", edit_admin_field_settings_path, size: :sm, icon: "toggles2") %>
    </div>
  <% end %>

  <div class="ax-dashboard-grid ax-dashboard-grid--monitoring">
    <aside class="ax-dashboard-panel ax-dashboard-panel--today">
      <div class="ax-dashboard-panel__header">
        <div>
          <span class="ax-dashboard-panel__eyebrow">Hoje</span>
          <h2><%= l(Date.current, format: :short) %></h2>
        </div>
        <%= ax_badge("#{pending_items.size} pend.", tone: pending_items.any? ? :amber : :green) %>
      </div>

      <div class="ax-dashboard-today-grid">
        <% today_metrics.each do |value, icon, label| %>
          <div class="ax-dashboard-today-cell">
            <strong><%= number_with_delimiter(value) %></strong>
            <span><i class="bi bi-<%= icon %>"></i> <%= label %></span>
          </div>
        <% end %>
      </div>

      <div class="ax-dashboard-list ax-dashboard-list--compact">
        <div class="ax-dashboard-list__title"><i class="bi bi-kanban"></i> Pendências</div>
        <% if pending_items.any? %>
          <% pending_items.each do |path, icon, color, label, count| %>
            <% pending_link_content = capture do %>
              <span><i class="bi bi-<%= icon %>"></i> <%= label %></span>
              <span class="ax-badge ax-badge--<%= color == 'red' ? 'red' : 'amber' %>"><%= count %></span>
            <% end %>
            <%= link_to pending_link_content, path, class: "ax-dashboard-list__row ax-dashboard-list__row--link" %>
          <% end %>
        <% else %>
          <div class="ax-dashboard-empty-row"><i class="bi bi-check-circle-fill"></i> Nenhuma pendência no momento.</div>
        <% end %>
      </div>
    </aside>

    <%= turbo_frame_tag "admin_dashboard_rankings", src: admin_dashboard_section_path("rankings"), loading: "lazy" do %>
      <div class="ax-dashboard-grid ax-dashboard-grid--rankings">
        <%= render "admin/dashboard/sections/loading_panel", title: "Top corretores", eyebrow: "Performance", rows: 5, compact: true %>
        <%= render "admin/dashboard/sections/loading_panel", title: "Top lojas", eyebrow: "Campo", rows: 5, compact: true %>
      </div>
    <% end %>
  </div>

  <%= turbo_frame_tag "admin_dashboard_operations", src: admin_dashboard_section_path("operations"), loading: "lazy" do %>
    <div class="ax-dashboard-grid ax-dashboard-grid--operations">
      <%= render "admin/dashboard/sections/loading_panel", title: "Atividade recente", eyebrow: "Auditoria", rows: 6 %>
      <%= render "admin/dashboard/sections/loading_panel", title: "Últimos imóveis atualizados", eyebrow: "Catálogo", table: true, rows: 6 %>
    </div>
  <% end %>

  <%= turbo_frame_tag "admin_dashboard_support", src: admin_dashboard_section_path("support"), loading: "lazy" do %>
    <div class="ax-dashboard-grid ax-dashboard-grid--support">
      <%= render "admin/dashboard/sections/loading_panel", title: "Últimas captações", eyebrow: "Captação", rows: 5 %>
      <%= render "admin/dashboard/sections/loading_panel", title: "Distribuição por categoria", eyebrow: "Mix", rows: 6 %>
    </div>
  <% end %>
</section>
