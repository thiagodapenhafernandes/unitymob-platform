<div class="integration-workspace scheduling-property-workspace">
<%= ax_workspace_heading(eyebrow: "Operação · Fotografia", icon: "camera", title: @habitation.display_title, pills: [@habitation.codigo], subtitle: [@habitation.endereco, @habitation.bairro, @habitation.cidade].compact_blank.join(" · "), actions: ax_button("Voltar para agenda", admin_scheduling_integration_path, variant: :ghost, size: :sm, icon: "arrow-left")) %>

<div class="scheduling-property-layout">
  <%= ax_operational_panel(eyebrow: "Imóvel", title: "Dados para fotografia", class_name: "scheduling-property-details") do %>
    <dl class="scheduling-property-facts">
      <% [["Código", @habitation.codigo], ["Tipo", [@habitation.categoria, @habitation.status].compact_blank.join(" · ")], ["Endereço", [@habitation.endereco, @habitation.numero, @habitation.bairro, @habitation.cidade].compact_blank.join(" - ")], ["Condomínio", @habitation.nome_empreendimento.presence || "Não informado"], ["Captador", @habitation.admin_user&.name.presence || "Sem captador"]].each do |label, value| %>
        <div><dt><%= label %></dt><dd><%= value %></dd></div>
      <% end %>
    </dl>
  <% end %>

  <%= ax_operational_panel(eyebrow: "Agenda", title: "Horário solicitado", class_name: "scheduling-property-appointment") do %>
      <div class="scheduling-property-date">
        <% if @habitation.photo_session_requested_at.present? %>
          <strong><%= l(@habitation.photo_session_requested_at, format: "%d/%m/%Y") %></strong>
          <span><%= l(@habitation.photo_session_requested_at, format: "%H:%M") %></span>
        <% else %>
          <%= ax_badge("Sem horário definido", tone: :amber) %>
        <% end %>
      </div>
  <% end %>
</div>
</div>
