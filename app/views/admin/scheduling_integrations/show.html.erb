<% can_manage_schedule = can?(:manage, :agenda_fotografia) || can?(:manage, :integracoes) %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-1 text-gray-800">Agenda de fotografia</h1>
    <p class="text-muted small mb-0">Acompanhe os imóveis pendentes de fotos e controle os dias indisponíveis.</p>
  </div>
</div>

<div class="row g-4">
  <div class="col-xl-7">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white py-3 d-flex align-items-center justify-content-between">
        <h5 class="card-title mb-0 fw-bold"><i class="bi bi-camera me-2 text-primary"></i>Pendentes de fotografia</h5>
        <span class="badge bg-primary-subtle text-primary"><%= @pending_photo_habitations.size %></span>
      </div>
      <div class="card-body p-0">
        <% if @pending_photo_habitations.any? %>
          <div class="table-responsive">
            <table class="table align-middle mb-0">
              <thead class="table-light small text-uppercase text-muted">
                <tr>
                  <th>Imóvel</th>
                  <th>Agendamento</th>
                  <th>Captador</th>
                  <th class="text-end">Ações</th>
                </tr>
              </thead>
              <tbody>
                <% @pending_photo_habitations.each do |habitation| %>
                  <tr>
                    <td>
                      <div class="fw-semibold"><%= habitation.display_title.presence || habitation.categoria.presence || "Imóvel sem título" %></div>
                      <div class="small text-muted">
                        <%= habitation.codigo %>
                        <% if habitation.endereco.present? || habitation.cidade.present? %>
                          · <%= [habitation.endereco, habitation.cidade].compact_blank.join(" - ") %>
                        <% end %>
                      </div>
                    </td>
                    <td>
                      <% if habitation.photo_session_requested_at.present? %>
                        <span class="fw-semibold"><%= l(habitation.photo_session_requested_at, format: "%d/%m/%Y %H:%M") %></span>
                      <% else %>
                        <span class="badge bg-warning-subtle text-warning-emphasis">Sem horário</span>
                      <% end %>
                    </td>
                    <td><%= habitation.admin_user&.name.presence || "Sem captador" %></td>
                    <td class="text-end">
                      <% details_path = can?(:manage, :captacoes) ? edit_admin_captacao_path(habitation, step: "fotos") : pending_property_admin_scheduling_integration_path(habitation) %>
                      <%= link_to "Abrir", details_path, class: "btn btn-sm btn-outline-primary" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="p-4 text-muted">Nenhum imóvel pendente de fotografia no momento.</div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-xl-5">
    <div class="card shadow-sm border-0 mb-4">
      <div class="card-header bg-white py-3">
        <h5 class="card-title mb-0 fw-bold"><i class="bi bi-calendar2-check me-2 text-primary"></i>Configuração da agenda</h5>
      </div>
      <div class="card-body p-4">
        <% if can_manage_schedule %>
          <%= form_with url: admin_scheduling_integration_path, method: :patch, scope: :scheduling, local: true do |f| %>
            <div class="mb-3">
              <%= f.label :photography_schedule_url, "URL externa de agendamento", class: "form-label fw-semibold" %>
              <%= f.url_field :photography_schedule_url,
                              class: "form-control",
                              value: @photography_schedule_url,
                              placeholder: "https://calendly.com/fotografias-saluteimoveis/30min" %>
              <div class="form-text">
                Se estiver preenchida, a captação abre essa agenda em uma nova aba. Se ficar vazia, o sistema usa o agendador interno.
              </div>
            </div>

            <%= f.submit "Salvar configuração", class: "btn btn-primary" %>
          <% end %>
        <% else %>
          <p class="text-muted small mb-0">Você pode consultar os imóveis pendentes. A configuração da agenda fica disponível para perfis com permissão de gerenciar.</p>
        <% end %>
      </div>
    </div>

    <div class="card shadow-sm border-0">
      <div class="card-header bg-white py-3">
        <h5 class="card-title mb-0 fw-bold"><i class="bi bi-calendar-x me-2 text-primary"></i>Dias bloqueados</h5>
      </div>
      <div class="card-body p-4">
        <% if @block_day_error.present? %>
          <div class="alert alert-danger py-2"><%= @block_day_error %></div>
        <% end %>

        <% if can_manage_schedule %>
          <%= form_with url: block_day_admin_scheduling_integration_path, scope: :photography_schedule_block, local: true, class: "row g-2 mb-4" do |f| %>
            <div class="col-sm-5">
              <%= f.label :date, "Data", class: "form-label fw-semibold" %>
              <%= f.date_field :date, class: "form-control", min: Date.current %>
            </div>
            <div class="col-sm-7">
              <%= f.label :reason, "Motivo", class: "form-label fw-semibold" %>
              <%= f.text_field :reason, class: "form-control", placeholder: "Ex: feriado, evento, folga" %>
            </div>
            <div class="col-12">
              <%= f.submit "Bloquear dia", class: "btn btn-outline-danger btn-sm" %>
            </div>
          <% end %>
        <% end %>

        <% if @blocked_days.any? %>
          <div class="list-group list-group-flush">
            <% @blocked_days.each do |block| %>
              <div class="list-group-item px-0 d-flex justify-content-between align-items-center">
                <div>
                  <div class="fw-semibold"><%= l(block.date, format: "%d/%m/%Y") %></div>
                  <div class="small text-muted"><%= block.reason.presence || "Sem motivo informado" %></div>
                </div>
                <% if can_manage_schedule %>
                  <%= button_to "Remover",
                                unblock_day_admin_scheduling_integration_path(block),
                                method: :delete,
                                class: "btn btn-sm btn-outline-secondary" %>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-muted small mb-0">Nenhum dia bloqueado.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
