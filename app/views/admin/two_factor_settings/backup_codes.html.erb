<% content_for :title, "Códigos de backup — Verificação em duas etapas" %>

<div class="layout-settings-workspace">
  <%= ax_workspace_heading(
        eyebrow: "Segurança · Acesso",
        icon: "key",
        title: "Guarde seus códigos de backup",
        subtitle: "Eles aparecem só esta vez. Cada código entra uma única vez no lugar do aplicativo.",
        pills: ["uso único"]
      ) %>

  <div class="layout-settings-grid">
    <div class="layout-settings-main">
      <%= ax_operational_panel(eyebrow: "Uso único", title: "Seus 10 códigos") do %>
        <div class="ax-panel-body">
          <%= ax_inline_notice(tone: :warning, icon: "exclamation-triangle") do %>
            Copie ou imprima AGORA — por segurança, o sistema não mostra estes códigos de novo.
          <% end %>

          <div class="two-factor-backup-grid"
               data-controller="clipboard"
               data-clipboard-success-content-value="Copiado!">
            <% @backup_codes.each do |code| %>
              <code class="two-factor-backup-code"><%= code %></code>
            <% end %>
            <textarea class="tw-sr-only"
                      readonly
                      tabindex="-1"
                      aria-hidden="true"
                      data-clipboard-target="source"><%= @backup_codes.join("\n") %></textarea>

            <div class="two-factor-backup-actions">
              <button type="button"
                      class="ax-btn"
                      data-action="clipboard#copy"
                      data-clipboard-target="button">
                <span data-clipboard-target="content">Copiar todos</span>
              </button>
              <%= link_to "Concluir", admin_two_factor_settings_path, class: "ax-btn ax-btn--primary" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
