<span class="tw-hidden" data-dwv-sync-status-state data-sync-status="<%= @loft_sync_status.presence || "idle" %>"></span>

<div class="ax-card loft-integration-status-card tw-mb-4">
  <div class="ax-card__body">
    <div class="loft-integration-section-title"><i class="bi bi-info-circle"></i>Status Atual</div>
    <ul class="loft-integration-status-list">
      <li class="loft-integration-status-list__item">Integração ativa: <strong><%= @loft_enabled ? "Sim" : "Não" %></strong></li>
      <li class="loft-integration-status-list__item">Host configurado: <strong><%= @loft_host.present? ? "Sim" : "Não" %></strong></li>
      <li class="loft-integration-status-list__item">Token configurado: <strong><%= @loft_token.present? ? "Sim" : "Não" %></strong></li>
      <li class="loft-integration-status-list__item">Preservar campos manuais: <strong><%= @loft_preserve_manual_fields ? "Ativo" : "Inativo" %></strong></li>
      <li class="loft-integration-status-list__item">Status atual: <strong><%= @loft_sync_status %></strong></li>
      <li class="loft-integration-status-list__item">Progresso atual: <strong><%= @loft_sync_progress %>%</strong></li>
      <li class="loft-integration-status-list__item">Última execução: <strong><%= @loft_last_sync_time.present? ? l(@loft_last_sync_time, format: :short) : "N/D" %></strong></li>
      <li>Resumo: <%= @loft_last_sync_message.presence || "Sem execuções registradas." %></li>
    </ul>

    <div class="tw-mt-3">
      <div class="tw-flex tw-justify-between tw-text-sm tw-mb-1">
        <span>Andamento</span>
        <span><%= @loft_sync_progress %>%</span>
      </div>
      <%= ax_progress(value: @loft_sync_progress, tone: (@loft_sync_status == 'failed' ? :red : (@loft_sync_status == 'completed' ? :green : :blue))) %>
    </div>
  </div>
</div>

<div class="ax-card tw-mb-4">
  <div class="ax-card__body">
    <div class="loft-integration-section-title"><i class="bi bi-clock-history"></i>Últimas 5 Sincronizações</div>
    <% if @loft_sync_history.present? %>
      <div class="ax-table-wrap">
        <table class="ax-table">
          <thead>
            <tr>
              <th>Data/Hora</th>
              <th>Status</th>
              <th>Modo</th>
              <th>Criados</th>
              <th>Atualizados</th>
              <th>Fotos</th>
              <th>Erros</th>
            </tr>
          </thead>
          <tbody>
            <% @loft_sync_history.each do |item| %>
              <% item_time = (Time.zone.parse(item["at"].to_s) rescue nil) %>
              <% status = item["status"].to_s %>
              <% stats = item["stats"].is_a?(Hash) ? item["stats"] : {} %>
              <tr>
                <td class="loft-integration-nowrap"><%= item_time ? l(item_time, format: :short) : "N/D" %></td>
                <td>
                  <span class="ax-badge <%= status == 'completed' ? 'ax-badge--green' : (status == 'failed' ? 'ax-badge--red' : (status == 'processing' ? 'ax-badge--blue' : 'ax-badge--gray')) %>">
                    <%= status.presence || "N/D" %>
                  </span>
                </td>
                <td class="tw-text-sm"><%= item["mode"].presence || "-" %></td>
                <td class="tw-text-sm"><%= stats["created"].to_i %></td>
                <td class="tw-text-sm"><%= stats["updated"].to_i %></td>
                <% photos_count = stats["images_synced"].presence || (stats["photos_reused"].to_i + stats["photos_downloaded"].to_i + stats["photos_pending_download"].to_i) %>
                <td class="tw-text-sm" title="Reaproveitadas, baixadas ou pendentes de download"><%= photos_count.to_i %></td>
                <td class="tw-text-sm"><%= stats["errors_count"].to_i %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="tw-text-sm tw-text-ink-muted tw-mb-0">Ainda não há histórico de sincronizações.</p>
    <% end %>
  </div>
</div>
