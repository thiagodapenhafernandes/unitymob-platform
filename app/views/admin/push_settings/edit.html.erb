<% content_for :title, "Push (PWA) — Configurações da Conta" %>

<div class="layout-settings-workspace">
  <%= ax_workspace_heading(
        eyebrow: "Configurações · Comunicação",
        icon: "phone-vibrate",
        title: "Push no PWA",
        subtitle: "Notificações Web Push enviadas ao aparelho dos corretores — novo lead chega mesmo com o app fechado."
      ) %>

  <% if @read_only %>
    <%= ax_inline_notice(tone: :info, icon: "info-circle") do %>
      As chaves e o transporte Web Push são <strong>globais</strong> e só o Admin do Sistema pode alterá-los.
      Esta tela é somente-leitura — a saúde do push da sua conta continua visível abaixo.
    <% end %>
  <% end %>

  <div class="layout-settings-grid">
    <div class="layout-settings-main">
      <%= form_with(model: [:admin, @push_setting], url: admin_push_setting_path, method: :patch, local: true, class: "layout-settings-form") do |f| %>
        <%= ax_error_summary(@push_setting) %>

        <%= ax_operational_panel(eyebrow: "Ativação", title: "Canal de push") do %>
          <div class="ax-panel-body">
            <%= ax_toggle_chip(f, :enabled, label: raw("<i class='bi bi-power'></i> Ativar Web Push"), disabled: @read_only) %>
            <p class="ax-field__hint">Desativado, nenhum push é enviado — mesmo que a regra de distribuição marque o canal.</p>

            <div class="tw-mt-3">
              <% if @push_setting.subject_email.blank? && ENV["VAPID_SUBJECT_EMAIL"].present? %>
                <%= ax_text_field(form: f, method: :subject_email, label: "E-mail de contato (VAPID subject)",
                      type: :email, placeholder: ENV["VAPID_SUBJECT_EMAIL"], disabled: @read_only,
                      hint: "Usando do ambiente: #{ENV['VAPID_SUBJECT_EMAIL']}. Preencha apenas para sobrescrever.") %>
              <% else %>
                <%= ax_text_field(form: f, method: :subject_email, label: "E-mail de contato (VAPID subject)",
                      type: :email, placeholder: "suporte@suaimobiliaria.com.br", disabled: @read_only,
                      hint: "Exigido pelo protocolo Web Push como canal de contato do remetente.") %>
              <% end %>
            </div>
          </div>
        <% end %>

        <% unless @read_only %>
          <%= ax_form_actions do %>
            <%= f.submit "Salvar configurações", class: "ax-btn ax-btn--primary" %>
          <% end %>
        <% end %>
      <% end %>

      <%= ax_operational_panel(eyebrow: "Últimos 7 dias", title: "Saúde do push por corretor",
            actions: (@push_health.present? ? safe_join([
              (@push_health_summary[:green].to_i.positive? ? ax_badge("#{@push_health_summary[:green]} saudável", tone: :green, dot: true) : nil),
              (@push_health_summary[:amber].to_i.positive? ? ax_badge("#{@push_health_summary[:amber]} instável", tone: :amber, dot: true) : nil),
              (@push_health_summary[:red].to_i.positive? ? ax_badge("#{@push_health_summary[:red]} sem confirmar", tone: :red, dot: true) : nil),
              (@push_health_summary[:gray].to_i.positive? ? ax_badge("#{@push_health_summary[:gray]} sem aparelho", tone: :gray) : nil)
            ].compact, " ") : nil)) do %>
        <div class="ax-panel-body">
          <% if @push_health.blank? %>
            <%= ax_empty_state(title: "Sem atividade de push na última semana",
                  description: "Quando os corretores registrarem aparelhos e receberem envios, a saúde de cada um aparece aqui.",
                  icon: "phone-vibrate") %>
          <% else %>
            <div class="ax-table-wrap">
              <table class="ax-table">
                <thead>
                  <tr>
                    <th>Corretor</th>
                    <th>Status</th>
                    <th class="tw-text-center" title="Aparelhos com inscrição ativa">Aparelhos</th>
                    <th class="tw-text-center" title="Pushes aceitos pelo provedor (FCM/APNs)">Enviados</th>
                    <th class="tw-text-center" title="Confirmados no aparelho pelo service worker">Recebidos</th>
                    <th class="tw-text-center" title="Inscrição inválida, erro de provedor ou sem inscrição">Falhas</th>
                    <th class="ax-num">Último recebido</th>
                  </tr>
                </thead>
                <tbody>
                  <% @push_health.each do |row| %>
                    <tr>
                      <td><strong><%= row[:user].name %></strong></td>
                      <td><%= ax_badge(row[:label], tone: row[:tone], dot: true) %></td>
                      <td class="tw-text-center"><%= row[:devices] %></td>
                      <td class="tw-text-center"><%= row[:sent] %></td>
                      <td class="tw-text-center"><%= row[:received] %></td>
                      <td class="tw-text-center <%= 'tw-text-red-600 tw-font-bold' if row[:failures].positive? %>"><%= row[:failures] %></td>
                      <td class="ax-num tw-text-ink-muted"><%= row[:last_received_at] ? l(row[:last_received_at], format: "%d/%m %H:%M") : "—" %></td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
            <p class="ax-field__hint tw-mt-2 tw-mb-0">
              <strong>Não confirma</strong> = o provedor aceita mas o aparelho nunca reporta recepção — inscrição morta ou app fechado há muito tempo;
              peça ao corretor para <strong>abrir o app uma vez</strong> (a inscrição se renova sozinha).
            </p>
          <% end %>
        </div>
      <% end %>

      <%= ax_operational_panel(eyebrow: "Credenciais", title: "Chaves VAPID",
            actions: (@push_setting.keys_source == :custom ? ax_badge("Personalizadas", tone: :amber) : (@push_setting.keys_source == :env ? ax_badge("Do ambiente (ENV)", tone: :blue) : ax_badge("Ausentes", tone: :gray)))) do %>
        <div class="ax-panel-body">
          <% if @push_setting.keys_present? %>
            <div class="ax-field">
              <%= ax_field_label(nil, nil, text: "Chave pública (em uso)") %>
              <textarea class="ax-control" rows="2" readonly><%= @push_setting.effective_public_key %></textarea>
              <p class="ax-field__hint">
                <% if @push_setting.keys_source == :env %>
                  Vindas da configuração do servidor (<code>VAPID_*</code>). É o recomendado — os dispositivos já inscritos continuam funcionando.
                <% else %>
                  Geradas nesta tela e guardadas criptografadas. A chave privada nunca é exibida.
                <% end %>
              </p>
            </div>
          <% else %>
            <%= ax_inline_notice(tone: :warning, icon: "key") do %>
              Nenhuma chave VAPID disponível. Defina <code>VAPID_PUBLIC_KEY</code> / <code>VAPID_PRIVATE_KEY</code> no ambiente
              <% if @push_setting.encryption_ready? %>ou gere um par abaixo<% end %>.
            <% end %>
          <% end %>

          <% unless @read_only %>
            <div class="tw-flex tw-items-center tw-gap-2 tw-mt-3">
              <% if @push_setting.keys_source == :custom && @push_setting.env_keys_available? %>
                <%= form_with(url: use_env_keys_admin_push_setting_path, method: :post, local: true) do %>
                  <%= submit_tag "Usar chaves do ambiente", class: "ax-btn ax-btn--sm ax-btn--primary", data: { turbo: false } %>
                <% end %>
              <% end %>

              <%= form_with(url: generate_keys_admin_push_setting_path, method: :post, local: true) do %>
                <%= submit_tag(@push_setting.keys_source == :custom ? "Gerar outro par" : "Gerar par personalizado",
                      class: "ax-btn ax-btn--sm ax-btn--ghost",
                      disabled: !@push_setting.encryption_ready?,
                      data: { turbo: false, confirm: "Gerar novas chaves invalida TODAS as assinaturas push atuais; cada dispositivo precisará reativar. Use apenas se você não tem chaves VAPID no servidor. Continuar?" }) %>
              <% end %>
            </div>
            <p class="ax-field__hint tw-mt-2">
              Se o servidor já tem <code>VAPID_*</code> que funcionam, <strong>não gere novas chaves</strong> — use as do ambiente.
            </p>
          <% end %>
        </div>
      <% end %>
    </div>

    <aside class="layout-settings-inspector">
      <%= ax_operational_panel(eyebrow: "Status", title: "Diagnóstico") do %>
        <div class="ax-panel-body">
          <% vapid_status = case @push_setting.keys_source
             when :env then ax_badge("Do ambiente", tone: :blue)
             when :custom then ax_badge("Personalizadas", tone: :amber)
             else ax_badge("Ausentes", tone: :gray)
             end %>
          <%= ax_status_list(
                label: "Diagnóstico do canal push",
                rows: [
                  { label: "Canal pronto para enviar", value: ax_badge(@push_setting.configured? ? "Pronto" : "Incompleto", tone: @push_setting.configured? ? :green : :gray, dot: true) },
                  { label: "Chaves VAPID", value: vapid_status },
                  { label: "E-mail de contato", value: ax_badge(@push_setting.effective_subject.present? ? "OK" : "Faltando", tone: @push_setting.effective_subject.present? ? :green : :gray) }
                ]
              ) %>
          <p class="ax-field__hint tw-mt-2 tw-mb-0">
            O canal só dispara <strong>ativado</strong>, com chaves VAPID e e-mail de contato preenchidos.
          </p>
        </div>
      <% end %>

      <%= ax_operational_panel(eyebrow: "Onde ativar", title: "Nos aparelhos") do %>
        <div class="ax-panel-body">
          <p class="ax-field__hint tw-mt-0"><strong>Android:</strong> abrir o app (Chrome) e tocar em "Ativar" no aviso de notificações.</p>
          <p class="ax-field__hint"><strong>iPhone (iOS 16.4+):</strong> Compartilhar → "Adicionar à Tela de Início", abrir pelo ícone e permitir notificações — o app orienta com um aviso na tela.</p>
          <p class="ax-field__hint tw-mb-0">O destino do clique no push fica em <%= link_to "Configurações de Leads", edit_admin_lead_setting_path, class: "tw-text-primary" %>.</p>
        </div>
      <% end %>

      <%= ax_operational_panel(eyebrow: "Como funciona", title: "Fluxo do push") do %>
        <div class="ax-panel-body">
          <ol class="ax-field__hint ax-field__hint--steps">
            <li>O aparelho do corretor se inscreve com a <strong>chave pública</strong> e renova a inscrição sozinho.</li>
            <li>Ao distribuir um lead, o servidor assina com a <strong>chave privada</strong> e envia com prioridade alta.</li>
            <li>Google/Apple entregam; o app confirma a recepção — é o que alimenta a tabela de saúde.</li>
          </ol>
        </div>
      <% end %>
    </aside>
  </div>
</div>
