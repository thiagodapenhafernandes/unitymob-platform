<%= form_with(model: [:admin, proprietor], local: true, class: "needs-validation") do |f| %>
  <%= ax_error_summary(proprietor) %>

  <%= ax_field_grid do %>
    <div class="ax-span-4">
      <%= f.label :vista_code, "Código", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
      <%= f.text_field :vista_code, class: "ax-control #{'bg-light' if proprietor.persisted?}", readonly: proprietor.persisted? %>
    </div>
    <div class="ax-span-4">
      <%= f.label :role, "Tipo", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
      <%= f.select :role, [
        ["Proprietário", "owner"],
        ["Incorporadora", "developer"],
        ["Construtora", "builder"],
        ["Imobiliária", "real_estate_agency"],
        ["Corretor", "broker"],
        ["Parceiro", "partner"],
        ["Investidor", "investor"]
      ], {}, class: "ax-control" %>
    </div>
    <div class="ax-span-4 tw-flex tw-items-end">
      <label class="tw-flex tw-items-center tw-gap-2">
        <%= f.check_box :is_client %>
        Cliente
      </label>
    </div>

    <div class="ax-span-6">
      <%= f.label :name, "Nome", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
      <%= f.text_field :name, class: "ax-control", required: true, autocomplete: "name" %>
    </div>
    <div class="ax-span-3">
      <%= f.label :cpf_cnpj, "CPF / CNPJ", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
      <%= f.text_field :cpf_cnpj, class: "ax-control", data: { controller: "mask", mask_type_value: "cpf_cnpj" } %>
    </div>
    <div class="ax-span-3">
      <%= f.label :rg_ie, "RG / IE", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
      <%= f.text_field :rg_ie, class: "ax-control" %>
    </div>

    <div class="ax-span-4">
      <%= f.label :email, "E-mail", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
      <%= f.email_field :email, class: "ax-control", autocomplete: "email" %>
    </div>
    <div class="ax-span-2">
      <%= f.label :phone_primary, "Telefone", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
      <%= f.text_field :phone_primary, class: "ax-control", autocomplete: "tel", data: { controller: "mask", mask_type_value: "phone" } %>
    </div>
    <div class="ax-span-2">
      <%= f.label :mobile_phone, "Celular", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
      <%= f.text_field :mobile_phone, class: "ax-control", autocomplete: "tel-national", data: { controller: "mask", mask_type_value: "phone" } %>
    </div>
    <div class="ax-span-2">
      <%= f.label :residential_phone, "Residencial", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
      <%= f.text_field :residential_phone, class: "ax-control", autocomplete: "tel", data: { controller: "mask", mask_type_value: "phone" } %>
    </div>
    <div class="ax-span-2">
      <%= f.label :business_phone, "Comercial", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
      <%= f.text_field :business_phone, class: "ax-control", autocomplete: "tel", data: { controller: "mask", mask_type_value: "phone" } %>
    </div>

    <div class="ax-span-3">
      <%= f.label :profession, "Profissão", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
      <%= f.text_field :profession, class: "ax-control" %>
    </div>
    <div class="ax-span-3">
      <%= f.label :marital_status, "Estado civil", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
      <%= f.select :marital_status,
                   options_for_select(Proprietor::MARITAL_STATUS_OPTIONS, f.object.marital_status),
                   { include_blank: "Selecione..." },
                   { class: "ax-control", data: { controller: "tom-select", tom_select_create_value: true } } %>
    </div>
    <div class="ax-span-3">
      <%= f.label :marriage_regime, "Regime de casamento", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
      <%= f.text_field :marriage_regime, class: "ax-control" %>
    </div>
    <div class="ax-span-3">
      <%= f.label :nationality, "Nacionalidade", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
      <%= f.text_field :nationality, class: "ax-control" %>
    </div>

    <div class="ax-span-3">
      <%= f.label :capture_vehicle, "Veículo de captação", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
      <%= f.select :capture_vehicle,
                   options_for_select(Proprietor::CAPTURE_VEHICLES, f.object.capture_vehicle),
                   { include_blank: "Selecione..." },
                   { class: "ax-control", data: { controller: "tom-select", tom_select_create_value: true } } %>
    </div>
    <div class="ax-span-3">
      <%= f.label :registered_at, "Cadastro", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
      <%= f.date_field :registered_at, class: "ax-control" %>
    </div>
    <div class="ax-span-3">
      <%= f.label :birth_date, "Data nascimento", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
      <%= f.date_field :birth_date, class: "ax-control", autocomplete: "bday" %>
    </div>
    <div class="ax-span-3">
      <%= f.label :issuing_authority, "Emissor", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
      <%= f.select :issuing_authority,
                   options_for_select(Proprietor::ISSUING_AUTHORITIES, f.object.issuing_authority),
                   { include_blank: "Selecione..." },
                   { class: "ax-control", data: { controller: "tom-select", tom_select_create_value: true } } %>
    </div>

    <div class="ax-span-12">
      <div class="ax-card bg-light-subtle">
        <div class="ax-card__header bg-transparent pb-0">
          <h6 class="ax-card__title tw-font-bold tw-text-primary tw-mb-0 tw-flex tw-items-center tw-gap-2">
            <i class="bi bi-geo-alt"></i>Endereço
          </h6>
        </div>
        <div class="ax-card__body pt-3">
          <div data-controller="cep-search">
            <%= ax_field_grid do %>
              <div class="ax-span-5">
                <%= f.label :cep, "CEP", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
                <div class="tw-flex tw-items-center">
                  <%= f.text_field :cep,
                                   class: "ax-control",
                                   placeholder: "00000-000",
                                   autocomplete: "postal-code",
                                   data: { controller: "mask", mask_type_value: "cep", cep_search_target: "cep", action: "blur->cep-search#search" } %>
                  <button class="ax-btn ax-btn--ghost tw-flex tw-items-center tw-gap-1" type="button" data-action="click->cep-search#search">
                    <i class="bi bi-search"></i> Buscar CEP
                  </button>
                </div>
              </div>
              <div class="ax-span-3">
                <%= f.label :address_type, "Tipo de endereço", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
                <%= f.select :address_type,
                             options_for_select(Proprietor::ADDRESS_TYPES, f.object.address_type),
                             { include_blank: "Selecione..." },
                             { class: "ax-control", data: { controller: "tom-select", tom_select_create_value: true, cep_search_target: "tipo" } } %>
              </div>
              <div class="ax-span-2">
                <%= f.label :uf, "UF", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
                <%= f.select :uf, Habitation::UF_OPTIONS,
                             { include_blank: "UF" },
                             { class: "ax-control", autocomplete: "address-level1", data: { cep_search_target: "uf" } } %>
              </div>
            <% end %>

            <%= ax_field_grid(class_name: "tw-mt-2") do %>
              <div class="ax-span-6">
                <%= f.label :street, "Logradouro", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
                <%= f.text_field :street, class: "ax-control", autocomplete: "address-line1", data: { cep_search_target: "logradouro" } %>
              </div>
              <div class="ax-span-2">
                <%= f.label :number, "Número", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
                <%= f.text_field :number, class: "ax-control", autocomplete: "address-line2", data: { cep_search_target: "numero" } %>
              </div>
              <div class="ax-span-3">
                <%= f.label :complement, "Complemento", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
                <%= f.text_field :complement, class: "ax-control", autocomplete: "address-line3", data: { cep_search_target: "complemento" } %>
              </div>
              <div class="ax-span-1">
                <%= f.label :block, "Bloco", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
                <%= f.text_field :block, class: "ax-control" %>
              </div>
            <% end %>

            <%= ax_field_grid(class_name: "tw-mt-2") do %>
              <div class="ax-span-5">
                <%= f.label :neighborhood, "Bairro", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
                <%= f.text_field :neighborhood, class: "ax-control", autocomplete: "address-level3", data: { cep_search_target: "bairro" } %>
              </div>
              <div class="ax-span-5">
                <%= f.label :city, "Cidade", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
                <%= f.text_field :city, class: "ax-control", autocomplete: "address-level2", data: { cep_search_target: "cidade" } %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
    <div class="ax-span-4">
      <%= f.label :profile_image, "Imagem de perfil", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
      <%= f.file_field :profile_image, class: "ax-control", accept: "image/*" %>
      <% if proprietor.profile_image.attached? %>
        <div class="tw-mt-2">
          <%= image_tag proprietor.profile_image, class: "img-thumbnail", style: "max-height: 120px;" %>
        </div>
      <% end %>
    </div>

    <div class="ax-span-12">
      <div class="ax-card bg-light-subtle">
        <div class="ax-card__header bg-transparent pb-0">
          <h6 class="ax-card__title tw-font-bold tw-text-primary tw-mb-0 tw-flex tw-items-center tw-gap-2">
            <i class="bi bi-people"></i>Dados do Cônjuge
          </h6>
        </div>
        <div class="ax-card__body pt-3">
          <%= ax_field_grid do %>
            <div class="ax-span-5">
              <%= f.label :spouse_name, "Nome", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
              <%= f.text_field :spouse_name, class: "ax-control", autocomplete: "section-spouse name" %>
            </div>
            <div class="ax-span-3">
              <%= f.label :spouse_email, "E-mail", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
              <%= f.email_field :spouse_email, class: "ax-control", autocomplete: "section-spouse email" %>
            </div>
            <div class="ax-span-2">
              <%= f.label :spouse_phone, "Telefone", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
              <%= f.text_field :spouse_phone, class: "ax-control", autocomplete: "section-spouse tel", data: { controller: "mask", mask_type_value: "phone" } %>
            </div>
            <div class="ax-span-2">
              <%= f.label :spouse_cpf_cnpj, "CPF / CNPJ", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
              <%= f.text_field :spouse_cpf_cnpj, class: "ax-control", data: { controller: "mask", mask_type_value: "cpf_cnpj" } %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="ax-span-12">
      <%= f.label :notes, "Observações", class: "ax-label tw-font-bold tw-text-sm tw-text-ink-muted text-uppercase" %>
      <%= f.text_area :notes, class: "ax-control", rows: 3 %>
    </div>
  <% end %>

  <div class="tw-flex tw-justify-end tw-gap-2 pt-3 border-top tw-mt-3">
    <%= link_to "Cancelar", admin_proprietors_path, class: "ax-btn ax-btn--ghost" %>
    <%= f.submit(proprietor.persisted? ? "Salvar Alterações" : "Cadastrar Proprietário", class: "ax-btn ax-btn--primary tw-font-bold") %>
  </div>
<% end %>
