<%= form_with(model: [:admin, proprietor], local: true, class: "proprietor-form") do |f| %>
  <%= ax_error_summary(proprietor) %>

  <%= ax_field_grid do %>
    <div class="ax-span-4">
      <%= ax_text_field(form: f, method: :vista_code, label: "Código", readonly: proprietor.persisted?) %>
    </div>
    <div class="ax-span-4">
      <%= ax_select_field(form: f, method: :role, label: "Tipo", choices: [
            ["Proprietário", "owner"],
            ["Incorporadora", "developer"],
            ["Construtora", "builder"],
            ["Imobiliária", "real_estate_agency"],
            ["Corretor", "broker"],
            ["Parceiro", "partner"],
            ["Investidor", "investor"]
          ]) %>
    </div>
    <div class="ax-span-4 tw-flex tw-items-end">
      <%= ax_toggle_chip(f, :is_client, label: "Cliente") %>
    </div>

    <div class="ax-span-6">
      <%= ax_text_field(form: f, method: :name, label: "Nome", required: true, autocomplete: "name") %>
    </div>
    <div class="ax-span-3">
      <%= ax_text_field(form: f, method: :cpf_cnpj, label: "CPF / CNPJ", data: { controller: "mask", mask_type_value: "cpf_cnpj" }) %>
    </div>
    <div class="ax-span-3">
      <%= ax_text_field(form: f, method: :rg_ie, label: "RG / IE") %>
    </div>

    <div class="ax-span-4">
      <%= ax_text_field(form: f, method: :email, label: "E-mail", type: :email, autocomplete: "email") %>
    </div>
    <div class="ax-span-2">
      <%= ax_text_field(form: f, method: :phone_primary, label: "Telefone", type: :tel, autocomplete: "tel", data: { controller: "phone-input" }) %>
    </div>
    <div class="ax-span-2">
      <%= ax_text_field(form: f, method: :mobile_phone, label: "Celular", type: :tel, autocomplete: "tel", data: { controller: "phone-input" }) %>
    </div>
    <div class="ax-span-2">
      <%= ax_text_field(form: f, method: :residential_phone, label: "Residencial", type: :tel, autocomplete: "tel", data: { controller: "phone-input" }) %>
    </div>
    <div class="ax-span-2">
      <%= ax_text_field(form: f, method: :business_phone, label: "Comercial", type: :tel, autocomplete: "tel", data: { controller: "phone-input" }) %>
    </div>

    <div class="ax-span-3">
      <%= ax_text_field(form: f, method: :profession, label: "Profissão") %>
    </div>
    <div class="ax-span-3">
      <%= ax_select_field(form: f, method: :marital_status, label: "Estado civil",
                          choices: Proprietor::MARITAL_STATUS_OPTIONS,
                          select_options: { include_blank: "Selecione..." },
                          html_options: { data: { controller: "tom-select", tom_select_create_value: true } }) %>
    </div>
    <div class="ax-span-3">
      <%= ax_text_field(form: f, method: :marriage_regime, label: "Regime de casamento") %>
    </div>
    <div class="ax-span-3">
      <%= ax_text_field(form: f, method: :nationality, label: "Nacionalidade") %>
    </div>

    <div class="ax-span-3">
      <%= ax_select_field(form: f, method: :capture_vehicle, label: "Veículo de captação",
                          choices: Proprietor::CAPTURE_VEHICLES,
                          select_options: { include_blank: "Selecione..." },
                          html_options: { data: { controller: "tom-select", tom_select_create_value: true } }) %>
    </div>
    <div class="ax-span-3">
      <%= ax_date_field(form: f, method: :registered_at, label: "Cadastro") %>
    </div>
    <div class="ax-span-3">
      <%= ax_date_field(form: f, method: :birth_date, label: "Data nascimento", autocomplete: "bday") %>
    </div>
    <div class="ax-span-3">
      <%= ax_select_field(form: f, method: :issuing_authority, label: "Emissor",
                          choices: Proprietor::ISSUING_AUTHORITIES,
                          select_options: { include_blank: "Selecione..." },
                          html_options: { data: { controller: "tom-select", tom_select_create_value: true } }) %>
    </div>

    <div class="ax-span-12">
      <%= ax_field_group(title: "Endereço", token: "Localização", class_name: "ax-field-group--panel") do %>
          <div data-controller="cep-search">
            <%= ax_field_grid do %>
              <div class="ax-span-5">
                <%= ax_field_label(f, :cep, text: "CEP") %>
                <%= ax_input_group(action: capture { %>
                  <button class="ax-btn ax-btn--ghost" type="button" data-action="click->cep-search#search">
                    <i class="bi bi-search"></i> Buscar CEP
                  </button>
                <% }) do %>
                  <%= f.text_field :cep,
                                   class: "ax-control",
                                   placeholder: "00000-000",
                                   autocomplete: "postal-code",
                                   data: { controller: "mask", mask_type_value: "cep", cep_search_target: "cep", action: "blur->cep-search#search" } %>
                <% end %>
              </div>
              <div class="ax-span-3">
                <%= ax_select_field(form: f, method: :address_type, label: "Tipo de endereço",
                                    choices: Proprietor::ADDRESS_TYPES,
                                    select_options: { include_blank: "Selecione..." },
                                    html_options: { data: { controller: "tom-select", tom_select_create_value: true, cep_search_target: "tipo" } }) %>
              </div>
              <div class="ax-span-2">
                <%= ax_select_field(form: f, method: :uf, label: "UF", choices: Habitation::UF_OPTIONS,
                                    select_options: { include_blank: "UF" },
                                    html_options: { autocomplete: "address-level1", data: { cep_search_target: "uf" } }) %>
              </div>
            <% end %>

            <%= ax_field_grid(class_name: "tw-mt-2") do %>
              <div class="ax-span-6">
                <%= ax_text_field(form: f, method: :street, label: "Logradouro", autocomplete: "address-line1", data: { cep_search_target: "logradouro" }) %>
              </div>
              <div class="ax-span-2">
                <%= ax_text_field(form: f, method: :number, label: "Número", autocomplete: "address-line2", data: { cep_search_target: "numero" }) %>
              </div>
              <div class="ax-span-3">
                <%= ax_text_field(form: f, method: :complement, label: "Complemento", autocomplete: "address-line3", data: { cep_search_target: "complemento" }) %>
              </div>
              <div class="ax-span-1">
                <%= ax_text_field(form: f, method: :block, label: "Bloco") %>
              </div>
            <% end %>

            <%= ax_field_grid(class_name: "tw-mt-2") do %>
              <div class="ax-span-5">
                <%= ax_text_field(form: f, method: :neighborhood, label: "Bairro", autocomplete: "address-level3", data: { cep_search_target: "bairro" }) %>
              </div>
              <div class="ax-span-5">
                <%= ax_text_field(form: f, method: :city, label: "Cidade", autocomplete: "address-level2", data: { cep_search_target: "cidade" }) %>
              </div>
            <% end %>
          </div>
      <% end %>
    </div>
    <div class="ax-span-4">
      <%= ax_file_field(form: f, method: :profile_image, label: "Imagem de perfil", accept: "image/*", button_label: "Escolher imagem") %>
      <% if proprietor.profile_image.attached? %>
        <div class="proprietor-form__avatar-preview tw-mt-2">
          <%= image_tag proprietor.profile_image, alt: "Imagem atual de #{proprietor.name}" %>
        </div>
      <% end %>
    </div>

    <div class="ax-span-12">
      <%= ax_field_group(title: "Dados do cônjuge", token: "Opcional", class_name: "ax-field-group--panel") do %>
          <%= ax_field_grid do %>
            <div class="ax-span-5">
              <%= ax_text_field(form: f, method: :spouse_name, label: "Nome", autocomplete: "section-spouse name") %>
            </div>
            <div class="ax-span-3">
              <%= ax_text_field(form: f, method: :spouse_email, label: "E-mail", type: :email, autocomplete: "section-spouse email") %>
            </div>
            <div class="ax-span-2">
              <%= ax_text_field(form: f, method: :spouse_phone, label: "Telefone", type: :tel, autocomplete: "section-spouse tel", data: { controller: "phone-input" }) %>
            </div>
            <div class="ax-span-2">
              <%= ax_text_field(form: f, method: :spouse_cpf_cnpj, label: "CPF / CNPJ", data: { controller: "mask", mask_type_value: "cpf_cnpj" }) %>
            </div>
          <% end %>
      <% end %>
    </div>

    <div class="ax-span-12">
      <%= ax_text_field(form: f, method: :notes, label: "Observações", type: :textarea, rows: 3) %>
    </div>
  <% end %>

  <%= ax_form_actions(
        cancel_path: admin_proprietors_path,
        submit_label: proprietor.persisted? ? "Salvar alterações" : "Cadastrar proprietário",
        form: f
      ) %>
<% end %>
