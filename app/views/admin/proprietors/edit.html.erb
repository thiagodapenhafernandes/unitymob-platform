<div class="proprietor-editor">
  <%= ax_workspace_heading(
        eyebrow: "Cadastros · Proprietários",
        icon: "person-vcard",
        title: "Editar proprietário",
        subtitle: "Atualize os dados cadastrais e acompanhe os imóveis vinculados.",
        metrics: [
          { value: @linked_habitations.total_entries, label: "imóveis vinculados" }
        ]
      ) %>

  <%= ax_operational_panel(eyebrow: "Cadastro", title: "Dados do proprietário", class_name: "tw-mb-4") do %>
    <%= render "form", proprietor: @proprietor %>
  <% end %>

  <%= ax_operational_panel(eyebrow: "Portfólio", title: "Imóveis vinculados") do %>
    <%= form_with url: edit_admin_proprietor_path(@proprietor), method: :get, local: true, class: "tw-mb-3" do |f| %>
      <%= ax_field_grid do %>
        <div class="ax-span-8">
          <%= f.label :habitation_q, "Buscar imóvel", class: "ax-label" %>
          <%= f.text_field :habitation_q, value: @habitation_q, class: "ax-control", placeholder: "Código, título, bairro, cidade..." %>
        </div>
        <div class="ax-span-3">
          <%= f.label :habitation_status, "Status", class: "ax-label" %>
          <%= f.select :habitation_status,
                       options_for_select(@habitation_status_options, @habitation_status),
                       { include_blank: "Todos" },
                       class: "ax-control" %>
        </div>
        <div class="ax-span-1 tw-flex tw-items-end">
          <%= f.submit "Filtrar", class: "ax-btn ax-btn--primary tw-w-full" %>
        </div>
      <% end %>
    <% end %>

    <% if @linked_habitations.any? %>
      <div class="tw-flex tw-justify-end tw-text-sm tw-text-ink-muted tw-mb-2">
        <%= @linked_habitations.total_entries %> encontrados
      </div>

      <div class="proprietor-properties">
        <% @linked_habitations.each do |habitation| %>
          <% title = habitation.titulo_anuncio.presence || habitation.nome_empreendimento.presence || "Imóvel sem título" %>
          <% city = habitation.address&.cidade.presence || habitation.cidade.presence || "-" %>
          <% neighborhood = habitation.address&.bairro.presence || habitation.bairro.presence || "-" %>
          <% address_line = [habitation.endereco.presence, habitation.numero.presence].compact.join(", ") %>
          <% image_url = habitation.primary_image_url %>

          <article class="proprietor-property">
            <div class="proprietor-property__selection">
              <input type="checkbox" aria-label="Selecionar imóvel <%= habitation.codigo %>" disabled>
            </div>

            <div class="proprietor-property__media">
              <% if image_url.present? %>
                <%= image_tag image_url, alt: title, loading: "lazy", class: "proprietor-property__image" %>
              <% else %>
                <div class="proprietor-property__empty-media">
                  <i class="bi bi-image" aria-hidden="true"></i>
                  <span>Sem imagem</span>
                </div>
              <% end %>
            </div>

            <div class="proprietor-property__body">
              <div class="proprietor-property__header">
                <div>
                  <strong class="proprietor-property__title"><%= neighborhood %></strong>
                  <div class="tw-flex tw-flex-wrap tw-items-center tw-gap-2 tw-mt-1">
                    <%= ax_badge("Referência #{habitation.codigo}", tone: :gray) %>
                    <%= ax_badge(habitation.status.presence || "Sem status", tone: :blue) %>
                  </div>
                  <p class="proprietor-property__subtitle"><%= title %></p>
                </div>
                <div class="tw-flex tw-gap-1">
                  <%= link_to admin_habitation_internal_path(habitation), class: "ax-ico-btn", title: admin_habitation_internal_action_label(habitation), aria: { label: admin_habitation_internal_action_label(habitation) } do %>
                    <i class="bi bi-pencil-square"></i>
                  <% end %>
                  <%= link_to habitation_path(habitation), target: "_blank", rel: "noopener", class: "ax-ico-btn", title: "Ver no site", aria: { label: "Ver imóvel no site" } do %>
                    <i class="bi bi-box-arrow-up-right"></i>
                  <% end %>
                </div>
              </div>

              <div class="proprietor-property__address">
                <% if address_line.present? %><span><%= address_line %></span><% end %>
                <span><%= [neighborhood, city].join(", ") %></span>
              </div>

              <div class="proprietor-property__price">
                <span>Preço</span>
                <strong><%= habitation.preco_principal %></strong>
              </div>

              <dl class="proprietor-property__facts">
                <div><dt>Dormitórios</dt><dd><%= habitation.dormitorios_qtd.to_i %></dd></div>
                <div><dt>Suítes</dt><dd><%= habitation.suites_qtd.to_i %></dd></div>
                <div><dt>Vagas</dt><dd><%= habitation.vagas_qtd.to_i %></dd></div>
                <div><dt>Área total</dt><dd><%= number_with_precision(habitation.area_total_m2.to_f, precision: 0) %> m²</dd></div>
              </dl>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <%= ax_empty_state(
            title: "Nenhum imóvel vinculado",
            description: "Não encontramos imóveis para os filtros informados.",
            icon: "houses"
          ) %>
    <% end %>

    <%= ax_pagination @linked_habitations,
                      param_name: :habitations_page,
                      params: { habitation_q: @habitation_q, habitation_status: @habitation_status } %>
  <% end %>
</div>
