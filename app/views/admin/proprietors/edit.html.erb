<div class="mb-4">
  <%= link_to admin_proprietors_path, class: "btn btn-link text-decoration-none text-muted p-0 small mb-2" do %>
    <i class="bi bi-arrow-left me-1"></i> Voltar para lista
  <% end %>
  <h1 class="h3 mb-1 text-gray-800 fw-bold" style="color: #bfa15f !important; font-family: 'Outfit', sans-serif;">Editar Proprietário</h1>
  <p class="text-muted small">Atualize os dados cadastrais e imagem de perfil.</p>
</div>

<div class="card border-0 shadow-sm rounded-4">
  <div class="card-body p-4">
    <%= render "form", proprietor: @proprietor %>
  </div>
</div>

<div class="card border-0 shadow-sm rounded-4 mt-4">
  <div class="card-header bg-white py-3 border-0">
    <h5 class="card-title mb-0 fw-bold text-primary">
      <i class="bi bi-houses me-2"></i>Imóveis vinculados
    </h5>
  </div>
  <div class="card-body">
    <style>
      .proprietor-h-card-main { display: flex; }
      .proprietor-h-card-check { width: 40px; min-width: 40px; }
      .proprietor-h-card-image { width: 240px; min-width: 240px; height: 220px; }

      @media (max-width: 991.98px) {
        .proprietor-h-card-main { display: block; }
        .proprietor-h-card-check {
          width: 100%;
          min-width: 100%;
          height: 38px;
          border-bottom: 1px solid #dee2e6;
        }
        .proprietor-h-card-image {
          width: 100%;
          min-width: 100%;
          height: 220px;
          border-right: 0 !important;
          border-bottom: 1px solid #dee2e6;
        }
      }
    </style>

    <%= form_with url: edit_admin_proprietor_path(@proprietor), method: :get, local: true, class: "row g-2 align-items-end mb-3" do |f| %>
      <div class="col-md-8">
        <label class="form-label small fw-bold text-muted text-uppercase mb-1">Buscar imóvel</label>
        <%= f.text_field :habitation_q, value: @habitation_q, class: "form-control", placeholder: "Código, título, bairro, cidade..." %>
      </div>
      <div class="col-md-3">
        <label class="form-label small fw-bold text-muted text-uppercase mb-1">Status</label>
        <%= f.select :habitation_status,
                     options_for_select(@habitation_status_options, @habitation_status),
                     { include_blank: "Todos" },
                     class: "form-select" %>
      </div>
      <div class="col-md-1 d-grid">
        <%= f.submit "Filtrar", class: "btn btn-primary" %>
      </div>
    <% end %>

    <% if @linked_habitations.any? %>
      <div class="d-flex justify-content-end small text-muted mb-2">
        <%= @linked_habitations.total_entries %> encontrados
      </div>
      <div class="d-flex flex-column gap-3">
        <% @linked_habitations.each do |habitation| %>
          <% title = habitation.titulo_anuncio.presence || habitation.nome_empreendimento.presence || "Imóvel sem título" %>
          <% city = habitation.address&.cidade.presence || habitation.cidade.presence || "-" %>
          <% neighborhood = habitation.address&.bairro.presence || habitation.bairro.presence || "-" %>
          <% address_line = [habitation.endereco.presence, habitation.numero.presence].compact.join(", ") %>
          <% image_url = habitation.primary_image_url %>

          <div class="card border shadow-sm overflow-hidden">
            <div class="proprietor-h-card-main">
              <div class="proprietor-h-card-check d-flex align-items-center justify-content-center px-2 border-end bg-light">
                <input type="checkbox" class="form-check-input m-0" aria-label="Selecionar imóvel <%= habitation.codigo %>" disabled>
              </div>

              <div class="proprietor-h-card-image border-end bg-light">
                <% if image_url.present? %>
                  <%= image_tag image_url,
                      alt: title,
                      loading: "lazy",
                      class: "w-100 h-100",
                      style: "object-fit: cover;" %>
                <% else %>
                  <div class="w-100 h-100 d-flex flex-column align-items-center justify-content-center text-muted">
                    <i class="bi bi-image fs-2"></i>
                    <span class="small">Sem imagem</span>
                  </div>
                <% end %>
              </div>

              <div class="flex-grow-1 d-flex flex-column">
                <div class="d-flex justify-content-between align-items-start p-3 pb-2">
                  <div>
                    <h6 class="fw-bold mb-1"><%= neighborhood %></h6>
                    <div class="d-inline-flex align-items-center rounded border px-2 py-1 small text-muted mb-1">
                      Referência <%= habitation.codigo %>
                    </div>
                    <div class="small text-muted text-uppercase">
                      <i class="bi bi-file-earmark-text me-1"></i><%= habitation.status.presence || "Sem status" %> - <%= title %>
                    </div>
                  </div>
                  <div class="d-flex gap-2">
                    <%= link_to admin_habitation_internal_path(habitation), class: "btn btn-sm btn-light border", title: admin_habitation_internal_action_label(habitation) do %>
                      <i class="bi bi-pencil-square"></i>
                    <% end %>
                    <%= link_to habitation_path(habitation), target: "_blank", class: "btn btn-sm btn-light border", title: "Ver no site" do %>
                      <i class="bi bi-box-arrow-up-right"></i>
                    <% end %>
                  </div>
                </div>

                <div class="px-3 pb-2 text-muted">
                  <% if address_line.present? %>
                    <div><%= address_line %></div>
                  <% end %>
                  <div><%= [neighborhood, city].join(", ") %></div>
                </div>

                <div class="px-3 pb-3">
                  <div class="small text-muted">Preço</div>
                  <div class="fw-bold fs-5 text-dark"><%= habitation.preco_principal %></div>
                </div>

                <div class="mt-auto border-top px-3 py-2 bg-light">
                  <div class="row g-2 text-center text-muted small">
                    <div class="col-3">
                      <div class="fw-semibold text-dark"><%= habitation.dormitorios_qtd.to_i %></div>
                      <div>Dormitórios</div>
                    </div>
                    <div class="col-3">
                      <div class="fw-semibold text-dark"><%= habitation.suites_qtd.to_i %></div>
                      <div>Suítes</div>
                    </div>
                    <div class="col-3">
                      <div class="fw-semibold text-dark"><%= habitation.vagas_qtd.to_i %></div>
                      <div>Vagas</div>
                    </div>
                    <div class="col-3">
                      <div class="fw-semibold text-dark"><%= number_with_precision(habitation.area_total_m2.to_f, precision: 0) %> m²</div>
                      <div>Total</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center text-muted py-4">
        Nenhum imóvel vinculado para os filtros informados.
      </div>
    <% end %>

    <div class="d-flex justify-content-center mt-3">
      <%= will_paginate @linked_habitations,
                        param_name: :habitations_page,
                        params: { habitation_q: @habitation_q, habitation_status: @habitation_status },
                        renderer: WillPaginate::ActionView::BootstrapLinkRenderer,
                        class: "shadow-sm" %>
    </div>
  </div>
</div>
