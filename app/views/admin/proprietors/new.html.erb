<div class="proprietor-editor">
  <%= ax_workspace_heading(
        eyebrow: "Cadastros · Proprietários",
        icon: "person-plus",
        title: "Novo proprietário",
        subtitle: "Cadastre dados pessoais, contatos, endereço e informações complementares."
      ) %>

  <%= ax_operational_panel(eyebrow: "Cadastro", title: "Dados do proprietário") do %>
    <%= render 'form', proprietor: @proprietor %>
  <% end %>
</div>
