<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-1 text-gray-800" style="color: #bfa15f !important; font-family: 'Outfit', sans-serif; font-weight: 700;">Proprietários</h1>
    <p class="text-muted small mb-0">Gerencie proprietários e parceiros vinculados aos imóveis.</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to admin_root_path, class: "btn btn-white border d-flex align-items-center shadow-sm" do %>
      <i class="bi bi-arrow-left me-2"></i> Voltar
    <% end %>
    <%= link_to new_admin_proprietor_path, class: "btn btn-primary d-flex align-items-center fw-bold px-4 shadow-sm" do %>
      <i class="bi bi-plus-lg me-2"></i> Novo Proprietário
    <% end %>
  </div>
</div>

<div class="row g-3" data-controller="proprietor-table">
  <div class="col-xl-5">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body p-3 p-lg-4">
        <%= form_with url: admin_proprietors_path, method: :get, scope: :filters, local: true do |f| %>
          <div class="d-flex align-items-center gap-2 mb-3">
            <%= f.submit "Pesquisar", class: "btn btn-success px-3" %>
            <% if @filters.values.any?(&:present?) %>
              <%= link_to "Limpar filtros", admin_proprietors_path, class: "btn btn-link text-muted text-decoration-none" %>
            <% end %>
          </div>

          <div class="row g-2">
            <div class="col-md-6">
              <label class="form-label mb-1 small">Código</label>
              <%= f.text_field :vista_code, value: @filters[:vista_code], class: "form-control" %>
            </div>
            <div class="col-md-6">
              <label class="form-label mb-1 small">Cadastro</label>
              <%= f.date_field :registered_at, value: @filters[:registered_at], class: "form-control" %>
            </div>

            <div class="col-12">
              <label class="form-label mb-1 small">Nome</label>
              <%= f.select :name,
                           options_for_select(@name_options, @filters[:name]),
                           { include_blank: "Selecione ou digite..." },
                           class: "form-select",
                           data: { controller: "tom-select", tom_select_create_value: true, tom_select_options_value: { placeholder: "Selecione ou digite..." } } %>
            </div>

            <div class="col-12">
              <label class="form-label mb-1 small">Email</label>
              <%= f.select :email,
                           options_for_select(@email_options, @filters[:email]),
                           { include_blank: "Selecione ou digite..." },
                           class: "form-select",
                           data: { controller: "tom-select", tom_select_create_value: true, tom_select_options_value: { placeholder: "Selecione ou digite..." } } %>
            </div>

            <div class="col-md-4">
              <label class="form-label mb-1 small">Telefone</label>
              <%= f.select :phone,
                           options_for_select(@phone_options, @filters[:phone]),
                           { include_blank: "Selecione ou digite..." },
                           class: "form-select",
                           data: { controller: "tom-select", tom_select_create_value: true, tom_select_options_value: { placeholder: "Selecione ou digite..." } } %>
            </div>
            <div class="col-md-3">
              <label class="form-label mb-1 small">CPF</label>
              <%= f.text_field :cpf_cnpj, value: @filters[:cpf_cnpj], class: "form-control" %>
            </div>
            <div class="col-md-5">
              <label class="form-label mb-1 small">Veículo de captação</label>
              <%= f.select :capture_vehicle,
                           options_for_select(@capture_vehicle_options, @filters[:capture_vehicle]),
                           { include_blank: "Selecione..." },
                           class: "form-select" %>
            </div>

            <div class="col-md-4">
              <label class="form-label mb-1 small">Cidade</label>
              <%= f.select :city,
                           options_for_select(@city_options, @filters[:city]),
                           { include_blank: "Selecione ou digite..." },
                           class: "form-select",
                           data: { controller: "tom-select", tom_select_create_value: true, tom_select_options_value: { placeholder: "Selecione ou digite..." } } %>
            </div>
          </div>

          <div class="border-top mt-3 pt-3">
            <button class="btn btn-link text-decoration-none p-0 small text-muted text-uppercase d-flex align-items-center gap-2 spouse-collapse-toggle"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#spouseFiltersCollapse"
                    aria-expanded="false"
                    aria-controls="spouseFiltersCollapse">
              <i class="bi bi-chevron-down spouse-collapse-icon"></i>
              Cônjuge
            </button>
            <div class="collapse mt-2" id="spouseFiltersCollapse">
              <div class="row g-2">
                <div class="col-12">
                  <label class="form-label mb-1 small">Nome</label>
                  <%= f.select :spouse_name,
                               options_for_select(@spouse_name_options, @filters[:spouse_name]),
                               { include_blank: "Selecione ou digite..." },
                               class: "form-select",
                               data: { controller: "tom-select", tom_select_create_value: true, tom_select_options_value: { placeholder: "Selecione ou digite..." } } %>
                </div>
                <div class="col-12">
                  <label class="form-label mb-1 small">Email</label>
                  <%= f.select :spouse_email,
                               options_for_select(@spouse_email_options, @filters[:spouse_email]),
                               { include_blank: "Selecione ou digite..." },
                               class: "form-select",
                               data: { controller: "tom-select", tom_select_create_value: true, tom_select_options_value: { placeholder: "Selecione ou digite..." } } %>
                </div>
                <div class="col-md-6">
                  <label class="form-label mb-1 small">Telefone</label>
                  <%= f.select :spouse_phone,
                               options_for_select(@spouse_phone_options, @filters[:spouse_phone]),
                               { include_blank: "Selecione ou digite..." },
                               class: "form-select",
                               data: { controller: "tom-select", tom_select_create_value: true, tom_select_options_value: { placeholder: "Selecione ou digite..." } } %>
                </div>
                <div class="col-md-6">
                  <label class="form-label mb-1 small">CPF</label>
                  <%= f.text_field :spouse_cpf_cnpj, value: @filters[:spouse_cpf_cnpj], class: "form-control" %>
                </div>
              </div>
            </div>
          </div>

          <div class="border-top mt-3 pt-3">
            <h6 class="small text-muted text-uppercase mb-2">Imóvel</h6>
            <div class="row g-2">
              <div class="col-md-4">
                <label class="form-label mb-1 small">Referência</label>
                <%= f.select :habitation_reference,
                             options_for_select(@habitation_reference_options, @filters[:habitation_reference]),
                             { include_blank: "Selecione ou digite..." },
                             class: "form-select",
                             data: { controller: "tom-select", tom_select_create_value: true, tom_select_options_value: { placeholder: "Selecione ou digite..." } } %>
              </div>
              <div class="col-md-4">
                <label class="form-label mb-1 small">Data Cadastro</label>
                <%= f.date_field :habitation_registered_at, value: @filters[:habitation_registered_at], class: "form-control" %>
              </div>
              <div class="col-md-4">
                <label class="form-label mb-1 small">Data Atualização</label>
                <%= f.date_field :habitation_updated_at, value: @filters[:habitation_updated_at], class: "form-control" %>
              </div>

              <div class="col-md-9">
                <label class="form-label mb-1 small">Endereço</label>
                <%= f.select :habitation_address,
                             options_for_select(@habitation_address_options, @filters[:habitation_address]),
                             { include_blank: "Selecione ou digite..." },
                             class: "form-select",
                             data: { controller: "tom-select", tom_select_create_value: true, tom_select_options_value: { placeholder: "Selecione ou digite..." } } %>
              </div>
              <div class="col-md-3">
                <label class="form-label mb-1 small">Número</label>
                <%= f.select :habitation_number,
                             options_for_select(@habitation_number_options, @filters[:habitation_number]),
                             { include_blank: "Selecione ou digite..." },
                             class: "form-select",
                             data: { controller: "tom-select", tom_select_create_value: true, tom_select_options_value: { placeholder: "Selecione ou digite..." } } %>
              </div>

              <div class="col-md-6">
                <label class="form-label mb-1 small">Categoria</label>
                <%= f.select :habitation_category,
                            options_for_select(@habitation_category_options, @filters[:habitation_category]),
                            { include_blank: "Selecione uma opção" },
                            class: "form-select",
                            data: { controller: "tom-select", tom_select_create_value: true, tom_select_options_value: { placeholder: "Selecione ou digite..." } } %>
              </div>
              <div class="col-md-6">
                <label class="form-label mb-1 small">Status</label>
                <%= f.select :habitation_status,
                            options_for_select(@habitation_status_options, @filters[:habitation_status]),
                            { include_blank: "Selecione uma opção" },
                            class: "form-select",
                            data: { controller: "tom-select", tom_select_create_value: true, tom_select_options_value: { placeholder: "Selecione ou digite..." } } %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-xl-7">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white d-flex align-items-center justify-content-between py-3">
        <div class="d-flex align-items-center gap-2">
          <div class="btn-group btn-group-sm">
            <button type="button" class="btn btn-light border" data-action="click->proprietor-table#toggleAll">
              <i class="bi bi-check2-square"></i>
            </button>
            <button type="button" class="btn btn-light border dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false">
              <span class="visually-hidden">Selecionar</span>
            </button>
            <ul class="dropdown-menu">
              <li><button class="dropdown-item" type="button" data-action="click->proprietor-table#selectAll">Selecionar todos da página</button></li>
              <li><button class="dropdown-item" type="button" data-action="click->proprietor-table#clearAll">Limpar seleção</button></li>
            </ul>
          </div>

          <div class="btn-group btn-group-sm">
            <button type="button" class="btn btn-light border" data-bs-toggle="dropdown" aria-expanded="false">
              <i class="bi bi-printer"></i>
            </button>
            <button type="button" class="btn btn-light border dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false">
              <span class="visually-hidden">Imprimir</span>
            </button>
            <ul class="dropdown-menu">
              <li>
                <%= form_with url: print_admin_proprietors_path, method: :get, local: true, html: { target: "_blank", class: "m-0" } do %>
                  <%= hidden_field_tag :report_type, "proprietors" %>
                  <%= hidden_field_tag :selected_ids, "", data: { proprietor_table_target: "selectedIdsInput" } %>
                  <% @filters.each do |key, value| %>
                    <% next if value.blank? %>
                    <%= hidden_field_tag "filters[#{key}]", value %>
                  <% end %>
                  <button type="submit" class="dropdown-item"><%= @report_types["proprietors"] %></button>
                <% end %>
              </li>
              <li>
                <%= form_with url: print_admin_proprietors_path, method: :get, local: true, html: { target: "_blank", class: "m-0" } do %>
                  <%= hidden_field_tag :report_type, "proprietors_with_habitations" %>
                  <%= hidden_field_tag :selected_ids, "", data: { proprietor_table_target: "selectedIdsInput" } %>
                  <% @filters.each do |key, value| %>
                    <% next if value.blank? %>
                    <%= hidden_field_tag "filters[#{key}]", value %>
                  <% end %>
                  <button type="submit" class="dropdown-item"><%= @report_types["proprietors_with_habitations"] %></button>
                <% end %>
              </li>
            </ul>
          </div>

          <button class="btn btn-light border btn-sm" type="button" data-bs-toggle="modal" data-bs-target="#proprietorsExportModal">
            <i class="bi bi-download"></i>
          </button>
        </div>
        <span class="small text-muted"><%= @proprietors.total_entries %> encontrados</span>
      </div>

      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th style="width: 42px;"></th>
              <th>Nome/Denominação</th>
              <th>Fone principal</th>
              <th>CPF/CNPJ</th>
              <th>Cidade</th>
              <th>Imóveis</th>
              <th class="text-end" style="width: 130px;">Ações</th>
            </tr>
          </thead>
          <tbody>
            <% if @proprietors.any? %>
              <% @proprietors.each do |proprietor| %>
                <% principal_phone = proprietor.phone_primary.presence || proprietor.mobile_phone.presence || proprietor.business_phone.presence || proprietor.residential_phone.presence || "-" %>
                <tr>
                  <td>
                    <input type="checkbox"
                           class="form-check-input"
                           value="<%= proprietor.id %>"
                           data-proprietor-table-target="rowCheckbox"
                           data-action="change->proprietor-table#syncSelection"
                           aria-label="Selecionar <%= proprietor.name %>">
                  </td>
                  <td>
                    <div class="fw-semibold text-truncate" style="max-width: 220px;" title="<%= proprietor.name %>"><%= proprietor.name %></div>
                    <div class="small text-muted"><%= proprietor.display_role %> · Código <%= proprietor.vista_code.presence || "-" %></div>
                  </td>
                  <td><%= principal_phone %></td>
                  <td><%= proprietor.cpf_cnpj.presence || "-" %></td>
                  <td><%= proprietor.city.presence || "-" %></td>
                  <td><span class="badge bg-light text-dark border"><%= @habitations_count_by_proprietor[proprietor.id].to_i %></span></td>
                  <td class="text-end">
                    <div class="btn-group btn-group-sm">
                      <%= link_to edit_admin_proprietor_path(proprietor), class: "btn btn-outline-primary" do %>
                        <i class="bi bi-pencil"></i>
                      <% end %>
                      <%= button_to admin_proprietor_path(proprietor), method: :delete, class: "btn btn-outline-danger", form: { class: "d-inline", data: { turbo_confirm: "Tem certeza?" } } do %>
                        <i class="bi bi-trash"></i>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="7" class="text-center text-muted py-4">Nenhum proprietário encontrado com os filtros aplicados.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <div class="card-footer bg-white">
        <div class="d-flex justify-content-center">
          <%= will_paginate @proprietors,
                            params: { filters: @filters },
                            renderer: WillPaginate::ActionView::BootstrapLinkRenderer,
                            class: "shadow-sm" %>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="proprietorsExportModal" tabindex="-1" aria-labelledby="proprietorsExportModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="proprietorsExportModalLabel">
          <i class="bi bi-download me-2"></i>Exportar proprietários
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
      </div>
      <%= form_with url: export_admin_proprietors_path, method: :get, local: true do %>
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Formatação dos dados:</label>
            <select name="data_format" class="form-select" required>
              <option value="">Selecione...</option>
              <option value="csv">CSV (vírgula)</option>
              <option value="csv_semicolon">CSV (ponto e vírgula)</option>
            </select>
          </div>

          <div class="mb-2">
            <label class="form-label fw-bold bg-light border rounded w-100 px-3 py-2 mb-2">Selecione os campos para exportação</label>
            <div class="border rounded">
              <% @export_fields.each_with_index do |(field_key, field_label), index| %>
                <label class="d-flex align-items-center gap-2 px-3 py-2 <%= 'border-top' if index.positive? %>">
                  <%= check_box_tag "fields[]", field_key, @default_export_fields.include?(field_key), class: "form-check-input mt-0" %>
                  <span><%= field_label %></span>
                </label>
              <% end %>
            </div>
          </div>

          <div class="mb-0">
            <label class="form-label">Tipo de listagem:</label>
            <select name="report_type" class="form-select">
              <% @report_types.each do |type_key, type_label| %>
                <option value="<%= type_key %>"><%= type_label %></option>
              <% end %>
            </select>
          </div>

          <div class="small text-muted mt-2" data-proprietor-table-target="selectedCount">
            Exportando todos os resultados filtrados.
          </div>

          <%= hidden_field_tag :selected_ids, "", data: { proprietor_table_target: "selectedIdsInput" } %>

          <% @filters.each do |key, value| %>
            <% next if value.blank? %>
            <%= hidden_field_tag "filters[#{key}]", value %>
          <% end %>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-link text-muted text-decoration-none" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-success px-4">Exportar</button>
        </div>
      <% end %>
    </div>
  </div>
</div>
