<%# Proprietários — listagem compacta (.ax-*). Original em index.html.erb.bootstrap-bak.
    Deferido p/ rollout: filtros avançados (cônjuge, imóvel), seleção em massa, export e relatórios. %>
<div class="admin-entity-dark">
<%= ax_workspace_heading(
      eyebrow: "Cadastros · Relacionamentos",
      icon: "people",
      title: "Proprietários",
      subtitle: "Gerencie proprietários e parceiros vinculados aos imóveis.",
      metrics: [{ value: number_with_delimiter(@proprietors.total_entries), label: "encontrados" }],
      actions: ax_button("Novo proprietário", new_admin_proprietor_path, variant: :primary, size: :sm, icon: "plus-lg")
    ) %>

<%# Filtros principais %>
<%= ax_filter_form(url: admin_proprietors_path, reset_path: (@filters.values.any?(&:present?) ? admin_proprietors_path : nil), submit_label: "Pesquisar", class_name: "tw-mb-3", scope: :filters) do |f| %>
  <%= ax_field_grid do %>
      <div class="ax-span-4">
        <label class="ax-label" for="filters_name">Nome / Denominação</label>
        <%= f.search_field :name, value: @filters[:name], class: "ax-search ax-search--fluid", placeholder: "Buscar por nome..." %>
      </div>
      <div class="ax-span-3">
        <label class="ax-label" for="filters_city">Cidade</label>
        <%= f.text_field :city, value: @filters[:city], class: "ax-control", placeholder: "Cidade" %>
      </div>
      <div class="ax-span-2">
        <label class="ax-label" for="filters_vista_code">Código Vista</label>
        <%= f.text_field :vista_code, value: @filters[:vista_code], class: "ax-control", placeholder: "Código" %>
      </div>
      <div class="ax-span-3">
        <label class="ax-label" for="filters_cpf_cnpj">CPF / CNPJ</label>
        <%= f.text_field :cpf_cnpj, value: @filters[:cpf_cnpj], class: "ax-control", placeholder: "Documento" %>
      </div>
  <% end %>
<% end %>

<%= ax_operational_panel(eyebrow: "Cadastro", title: "Proprietários encontrados") do %>
<div class="ax-table-wrap">
  <table class="ax-table">
    <thead>
      <tr>
        <th>Nome / Denominação</th>
        <th class="ax-table__col--w-150">Fone principal</th>
        <th class="ax-table__col--w-160">CPF / CNPJ</th>
        <th class="ax-table__col--w-160">Cidade</th>
        <th class="ax-num ax-table__col--compact">Imóveis</th>
        <th class="ax-num ax-table__col--xs">Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @proprietors.each do |proprietor| %>
        <% principal_phone = proprietor.phone_primary.presence || proprietor.mobile_phone.presence || proprietor.business_phone.presence || proprietor.residential_phone.presence %>
        <tr>
          <td>
            <%= link_to proprietor.name, edit_admin_proprietor_path(proprietor), class: "ax-strong" %>
            <div class="tw-text-2xs tw-text-ink-faint"><%= proprietor.display_role %> · Código <%= proprietor.vista_code.presence || "—" %></div>
          </td>
          <td><%= principal_phone.present? ? format_phone(principal_phone) : "—" %></td>
          <td><%= proprietor.cpf_cnpj.presence || "—" %></td>
          <td><%= proprietor.city.presence || "—" %></td>
          <td class="ax-num"><span class="ax-badge ax-badge--gray"><%= @habitations_count_by_proprietor[proprietor.id].to_i %></span></td>
          <td class="ax-num">
            <%= ax_icon_button(
                  label: "Editar proprietário #{proprietor.name}",
                  icon: "pencil",
                  url: edit_admin_proprietor_path(proprietor)
                ) %>
          </td>
        </tr>
      <% end %>

      <% if @proprietors.empty? %>
        <tr><td colspan="6"><%= ax_empty_state(title: "Nenhum proprietário encontrado", description: "Ajuste os filtros ou cadastre um novo proprietário.", icon: "people", action: ax_button("Novo proprietário", new_admin_proprietor_path, variant: :primary, size: :sm), compact: true) %></td></tr>
      <% end %>
    </tbody>
  </table>
</div>
<% end %>

<%= ax_pagination @proprietors, params: request.query_parameters %>
</div>
