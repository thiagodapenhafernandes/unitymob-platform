<%# Proprietários — listagem compacta (.ax-*). Original em index.html.erb.bootstrap-bak.
    Deferido p/ rollout: filtros avançados (cônjuge, imóvel), seleção em massa, export e relatórios. %>
<div class="tw-flex tw-flex-wrap tw-items-center tw-justify-between tw-gap-3 tw-mb-4">
  <div>
    <h1 class="ax-page-title">Proprietários</h1>
    <p class="ax-page-subtitle">Gerencie proprietários e parceiros vinculados aos imóveis.</p>
  </div>
  <%= link_to new_admin_proprietor_path, class: "ax-btn ax-btn--sm ax-btn--primary" do %>
    <i class="bi bi-plus-lg ax-ico"></i><span>Novo proprietário</span>
  <% end %>
</div>

<%# Filtros principais %>
<%= form_with url: admin_proprietors_path, method: :get, scope: :filters do |f| %>
  <div class="ax-card tw-mb-3">
    <div class="ax-card__body tw-flex tw-flex-wrap tw-items-end tw-gap-3">
      <div class="tw-flex-1 tw-min-w-[200px]">
        <label class="ax-label">Nome / Denominação</label>
        <%= f.text_field :name, value: @filters[:name], class: "ax-input", placeholder: "Buscar por nome..." %>
      </div>
      <div class="tw-w-44">
        <label class="ax-label">Cidade</label>
        <%= f.text_field :city, value: @filters[:city], class: "ax-input", placeholder: "Cidade" %>
      </div>
      <div class="tw-w-36">
        <label class="ax-label">Código Vista</label>
        <%= f.text_field :vista_code, value: @filters[:vista_code], class: "ax-input", placeholder: "Código" %>
      </div>
      <div class="tw-w-44">
        <label class="ax-label">CPF / CNPJ</label>
        <%= f.text_field :cpf_cnpj, value: @filters[:cpf_cnpj], class: "ax-input", placeholder: "Documento" %>
      </div>
      <div class="tw-flex tw-items-center tw-gap-2">
        <button type="submit" class="ax-btn ax-btn--primary"><i class="bi bi-search ax-ico"></i>Pesquisar</button>
        <% if @filters.values.any?(&:present?) %>
          <%= link_to "Limpar", admin_proprietors_path, class: "ax-btn ax-btn--ghost" %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<div class="tw-flex tw-items-center tw-justify-between tw-mb-2">
  <span class="ax-page-subtitle"><span class="tw-font-semibold tw-text-ink"><%= number_with_delimiter(@proprietors.total_entries) %></span> encontrados</span>
</div>

<div class="ax-table-wrap">
  <table class="ax-table">
    <thead>
      <tr>
        <th>Nome / Denominação</th>
        <th style="width:150px">Fone principal</th>
        <th style="width:160px">CPF / CNPJ</th>
        <th style="width:160px">Cidade</th>
        <th class="ax-num" style="width:90px">Imóveis</th>
        <th class="ax-num" style="width:74px">Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @proprietors.each do |proprietor| %>
        <% principal_phone = proprietor.phone_primary.presence || proprietor.mobile_phone.presence || proprietor.business_phone.presence || proprietor.residential_phone.presence %>
        <tr>
          <td>
            <%= link_to proprietor.name, edit_admin_proprietor_path(proprietor), class: "ax-strong" %>
            <div class="tw-text-2xs tw-text-ink-faint"><%= proprietor.display_role %> · Código <%= proprietor.vista_code.presence || "—" %></div>
          </td>
          <td><%= principal_phone.presence || "—" %></td>
          <td><%= proprietor.cpf_cnpj.presence || "—" %></td>
          <td><%= proprietor.city.presence || "—" %></td>
          <td class="ax-num"><span class="ax-badge ax-badge--gray"><%= @habitations_count_by_proprietor[proprietor.id].to_i %></span></td>
          <td class="ax-num">
            <span class="tw-inline-flex tw-gap-0.5">
              <%= link_to edit_admin_proprietor_path(proprietor), class: "ax-ico-btn", title: "Editar" do %><i class="bi bi-pencil"></i><% end %>
            </span>
          </td>
        </tr>
      <% end %>

      <% if @proprietors.empty? %>
        <tr><td colspan="6"><div class="ax-empty">Nenhum proprietário encontrado com os filtros aplicados.</div></td></tr>
      <% end %>
    </tbody>
  </table>
</div>

<%= ax_pagination @proprietors, params: request.query_parameters %>
