<div class="layout-settings-workspace">
  <%
    email_status = if @email_transport_source == :global
      ax_badge("Usando SMTP global do sistema", tone: :blue, dot: true)
    elsif @email_transport_source == :tenant
      ax_badge("Usando SMTP próprio da conta", tone: :green, dot: true)
    end
  %>
  <%= ax_workspace_heading(
        eyebrow: "Configurações · Notificações",
        icon: "envelope-at",
        title: "Meu SMTP",
        subtitle: "Servidor de envio desta conta para avisar corretores sobre novos leads e demais notificações por e-mail. Sem SMTP próprio, a conta pode usar o SMTP global quando o fallback estiver liberado.",
        actions: email_status
      ) %>

  <div class="layout-settings-grid">
    <div class="layout-settings-main">
      <% unless @email_setting.encryption_ready? %>
        <%= ax_inline_notice(tone: :warning, icon: "shield-lock") do %>
          Criptografia indisponível: defina <code>AR_ENCRYPTION_PRIMARY_KEY</code>, <code>AR_ENCRYPTION_DETERMINISTIC_KEY</code>
          e <code>AR_ENCRYPTION_KEY_DERIVATION_SALT</code> no ambiente para guardar a senha SMTP com segurança.
        <% end %>
      <% end %>

      <% if @email_transport_source == :global %>
        <%= ax_inline_notice(tone: :info, icon: "globe2") do %>
          <strong>Esta conta está usando o SMTP global do sistema.</strong>
          As notificações por e-mail saem pelo global enquanto o SMTP próprio abaixo não estiver configurado e ativo.
        <% end %>
      <% end %>

      <%= form_with(model: [:admin, @email_setting], url: admin_email_setting_path, method: :patch, local: true, class: "layout-settings-form") do |f| %>
        <%= ax_error_summary(@email_setting) %>

        <%= ax_operational_panel(eyebrow: "Ativação", title: "Canal de e-mail") do %>
          <div class="ax-panel-body">
            <%= ax_toggle_chip(f, :enabled, label: raw("<i class='bi bi-power'></i> Ativar envio de e-mails")) %>
            <p class="ax-field__hint">Quando desativado, nenhuma notificação por e-mail é enviada — mesmo que a regra de distribuição marque o canal.</p>
          </div>
        <% end %>

        <%= ax_operational_panel(eyebrow: "Remetente", title: "Identidade do e-mail") do %>
          <div class="ax-panel-body">
            <%= ax_field_grid do %>
              <div class="ax-span-6">
                <%= ax_text_field(form: f, method: :from_name, label: "Nome do remetente", placeholder: "Ex.: Salute Imóveis") %>
              </div>
              <div class="ax-span-6">
                <%= ax_text_field(form: f, method: :from_email, label: "E-mail do remetente", type: :email, placeholder: "leads@suaimobiliaria.com.br") %>
              </div>
              <div class="ax-span-6">
                <%= ax_text_field(form: f, method: :reply_to, label: "Responder para (reply-to)", type: :email, placeholder: "opcional") %>
              </div>
            <% end %>
          </div>
        <% end %>

        <%= ax_operational_panel(eyebrow: "Servidor", title: "Conexão SMTP") do %>
          <div class="ax-panel-body">
            <%= ax_field_grid do %>
              <div class="ax-span-8">
                <%= ax_text_field(form: f, method: :smtp_address, label: "Host SMTP", placeholder: "smtp.seuprovedor.com") %>
              </div>
              <div class="ax-span-4">
                <%= ax_number_field(form: f, method: :smtp_port, label: "Porta", placeholder: "587") %>
              </div>
              <div class="ax-span-6">
                <%= ax_text_field(form: f, method: :smtp_user_name, label: "Usuário", placeholder: "leads@suaimobiliaria.com.br") %>
              </div>
              <div class="ax-span-6">
                <div class="ax-field">
                  <%= ax_field_label(f, :smtp_password, text: "Senha") %>
                  <%# password_field nunca renderiza o valor (a senha fica só no banco, criptografada). %>
                  <% password_set = @email_setting.encryption_ready? && @email_setting.smtp_password.present? rescue false %>
                  <%= f.password_field :smtp_password, value: nil, class: "ax-control",
                        autocomplete: "new-password",
                        placeholder: password_set ? "•••••••• (preenchida)" : "" %>
                  <p class="ax-field__hint">Deixe em branco para manter a senha atual.</p>
                </div>
              </div>
              <div class="ax-span-6">
                <%= ax_select_field(form: f, method: :smtp_authentication, label: "Autenticação",
                      choices: EmailSetting::AUTHENTICATIONS.map { |a| [a, a] }) %>
              </div>
              <div class="ax-span-6">
                <%= ax_text_field(form: f, method: :smtp_domain, label: "Domínio (HELO)", placeholder: "opcional") %>
              </div>
            <% end %>
            <div class="tw-mt-2">
              <%= ax_toggle_chip(f, :smtp_enable_starttls_auto, label: raw("<i class='bi bi-lock'></i> STARTTLS automático")) %>
            </div>
          </div>
        <% end %>

        <%= ax_form_actions(sticky: false, class_name: "layout-settings-actions") do %>
          <%= link_to "Cancelar", admin_root_path, class: "ax-btn" %>
          <%= f.submit "Salvar configurações", class: "ax-btn ax-btn--primary" %>
        <% end %>
      <% end %>
    </div>

    <aside class="layout-settings-inspector">
      <%= ax_operational_panel(eyebrow: "Status", title: "Diagnóstico") do %>
        <div class="ax-panel-body">
          <%
            channel_status = if @email_transport_source == :global
              ax_badge("Global ativo", tone: :blue, dot: true)
            elsif @email_setting.configured?
              ax_badge("Pronto", tone: :green, dot: true)
            else
              ax_badge("Incompleto", tone: :gray, dot: true)
            end
            encryption_status = @email_setting.encryption_ready? ? ax_badge("Ativa", tone: :green) : ax_badge("Indisponível", tone: :amber)
          %>
          <%= ax_status_list(
                label: "Diagnóstico do canal de e-mail",
                rows: [
                  { label: "Canal pronto para enviar", value: channel_status },
                  { label: "Criptografia de credenciais", value: encryption_status }
                ]
              ) %>
          <p class="ax-field__hint tw-mt-2">
            O canal dispara pelo SMTP próprio quando estiver <strong>ativado</strong> e completo; se não estiver, usa o SMTP global quando o fallback da conta estiver liberado.
          </p>
        </div>
      <% end %>

      <%= ax_operational_panel(eyebrow: "Validação", title: "Enviar e-mail de teste") do %>
        <div class="ax-panel-body">
          <%= form_with(url: test_admin_email_setting_path, method: :post, local: true) do %>
            <%= ax_standalone_field(
                  name: "to",
                  id: "smtp_test_to",
                  label: "Destinatário do teste",
                  value: @effective_email_setting&.from_email || @email_setting.from_email,
                  type: :email,
                  placeholder: "destino@exemplo.com",
                  hint: "Em branco usa o e-mail do remetente.",
                  action: submit_tag(
                    "Enviar teste",
                    class: "ax-btn ax-btn--sm",
                    disabled: !@effective_email_setting&.configured?,
                    data: { turbo: false }
                  )
                ) %>
          <% end %>
          <% unless @effective_email_setting&.configured? %>
            <p class="ax-field__hint tw-mt-2">
              Para habilitar o teste falta: <strong><%= @email_setting.missing_configuration_items.join(", ") %></strong>.
            </p>
          <% end %>

          <%# Resultado persistente do último teste — o toast some em segundos %>
          <% last_test = (JSON.parse(Setting.get("email_smtp_last_test").to_s) rescue nil) %>
          <% if last_test %>
            <div class="tw-mt-3 tw-flex tw-items-center tw-gap-2 tw-flex-wrap">
              <% if last_test["ok"] %>
                <%= ax_badge("Último teste: enviado", tone: :green, dot: true) %>
              <% else %>
                <%= ax_badge("Último teste: falhou", tone: :red, dot: true) %>
              <% end %>
              <span class="ax-field__hint tw-m-0">
                para <strong><%= last_test["to"] %></strong>
                em <%= (l(Time.zone.parse(last_test["at"]), format: "%d/%m %H:%M") rescue last_test["at"]) %>
                <% if last_test["error"].present? %> — <code class="tw-text-xs"><%= last_test["error"] %></code><% end %>
              </span>
            </div>
          <% end %>
        </div>
      <% end %>
    </aside>
  </div>
</div>
