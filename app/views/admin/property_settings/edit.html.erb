<div class="container-fluid py-3">
  <div class="tw-flex tw-items-center tw-justify-between tw-gap-3 tw-flex-wrap tw-mb-4">
    <div>
      <div class="ax-page-subtitle tw-font-semibold" style="text-transform: uppercase;">Administração</div>
      <h1 class="ax-page-title tw-mb-1">Config Imóveis</h1>
      <p class="ax-page-subtitle">Configurações específicas para o cadastro e mídia dos imóveis.</p>
    </div>
  </div>

  <%= form_with model: @property_setting, url: admin_property_setting_path, method: :patch, html: { multipart: true }, class: "tw-grid tw-gap-4", style: "grid-template-columns: repeat(12, minmax(0, 1fr));", data: { controller: "watermark-preview" } do |f| %>
    <% if @property_setting.errors.any? %>
      <div class="ax-span-12">
        <%= ax_error_summary(@property_setting) %>
      </div>
    <% end %>

    <div class="ax-span-6">
      <div class="ax-card h-100">
        <div class="ax-card__body p-4">
          <h2 class="tw-text-ink-muted tw-font-semibold tw-mb-3" style="text-transform: uppercase;">Marca d'água das fotos</h2>

          <div class="tw-mb-4">
            <%= f.label :watermark_image, "Imagem da marca d'água", class: "ax-label tw-font-semibold" %>
            <%= f.file_field :watermark_image,
                  class: "ax-control",
                  accept: "image/png,image/jpeg,image/webp",
                  data: { action: "change->watermark-preview#loadFile", watermark_preview_target: "fileInput" } %>
            <div class="form-text">
              Use preferencialmente PNG com fundo transparente.
            </div>
          </div>

          <% if @property_setting.watermark_image.attached? %>
            <div class="current-watermark-preview tw-flex tw-items-center tw-gap-3 border tw-rounded-lg p-3 tw-mb-4">
              <div class="current-watermark-thumb rounded border overflow-hidden">
                <%= image_tag @property_setting.watermark_image, alt: "Imagem atual da marca d'água" %>
              </div>
              <div class="tw-text-sm">
                <div class="tw-font-semibold">Imagem atual</div>
                <div class="tw-text-ink-muted"><%= @property_setting.watermark_image.filename %></div>
                <div class="tw-text-ink-muted"><%= number_to_human_size(@property_setting.watermark_image.byte_size) %></div>
              </div>
            </div>

            <div class="tw-flex tw-items-center tw-gap-2 tw-mb-4">
              <%= check_box_tag "property_setting[remove_watermark_image]", "1", false, id: "property_setting_remove_watermark_image" %>
              <%= label_tag "property_setting_remove_watermark_image", "Remover imagem atual" %>
            </div>
          <% end %>

          <div class="tw-mb-4">
            <%= f.label :watermark_position, "Posição padrão", class: "ax-label tw-font-semibold" %>
            <%= ax_field_grid do %>
              <% PropertySetting::WATERMARK_POSITIONS.each do |value, label| %>
                <div class="ax-span-4">
                  <label class="border rounded px-3 py-2 tw-flex tw-items-center tw-gap-2 h-100">
                    <%= f.radio_button :watermark_position, value, class: "m-0", data: { action: "watermark-preview#update", watermark_preview_target: "positionInput" } %>
                    <span class="tw-text-sm tw-font-semibold"><%= label %></span>
                  </label>
                </div>
              <% end %>
            <% end %>
          </div>

          <div class="tw-mb-4">
            <div class="tw-flex tw-items-center tw-justify-between tw-gap-3">
              <%= f.label :watermark_size_percentage, "Tamanho da marca d'água", class: "ax-label tw-font-semibold tw-mb-1" %>
              <span class="ax-badge ax-badge--gray border" data-watermark-preview-target="sizeValue"><%= @property_setting.watermark_size_percentage %>%</span>
            </div>
            <%= f.range_field :watermark_size_percentage,
                  min: PropertySetting::WATERMARK_SIZE_RANGE.begin,
                  max: PropertySetting::WATERMARK_SIZE_RANGE.end,
                  step: 1,
                  class: "form-range",
                  data: { action: "input->watermark-preview#update", watermark_preview_target: "sizeInput" } %>
            <div class="tw-flex tw-justify-between tw-text-sm tw-text-ink-muted">
              <span>Menor</span>
              <span>Maior</span>
            </div>
          </div>

          <div class="tw-mb-4">
            <div class="tw-flex tw-items-center tw-justify-between tw-gap-3">
              <%= f.label :watermark_opacity_percentage, "Opacidade da marca d'água", class: "ax-label tw-font-semibold tw-mb-1" %>
              <span class="ax-badge ax-badge--gray border" data-watermark-preview-target="opacityValue"><%= @property_setting.watermark_opacity_percentage %>%</span>
            </div>
            <%= f.range_field :watermark_opacity_percentage,
                  min: PropertySetting::WATERMARK_OPACITY_RANGE.begin,
                  max: PropertySetting::WATERMARK_OPACITY_RANGE.end,
                  step: 1,
                  class: "form-range",
                  data: { action: "input->watermark-preview#update", watermark_preview_target: "opacityInput" } %>
            <div class="tw-flex tw-justify-between tw-text-sm tw-text-ink-muted">
              <span>Mais discreta</span>
              <span>Mais intensa</span>
            </div>
          </div>

          <div class="tw-flex tw-items-center tw-gap-2">
            <%= f.submit "Salvar configurações", class: "ax-btn ax-btn--primary tw-font-semibold" %>
            <%= link_to "Voltar", admin_root_path, class: "ax-btn ax-btn--ghost" %>
          </div>
        </div>
      </div>

      <div class="ax-card tw-mt-4">
        <div class="ax-card__body p-4">
          <h2 class="tw-text-ink-muted tw-font-semibold tw-mb-3" style="text-transform: uppercase;">Fluxo de revisão administrativa</h2>
          <p class="tw-text-ink-muted tw-mb-3">As configurações de revisão foram movidas para a tela dedicada.</p>
          <%= link_to review_workflow_admin_property_setting_path, class: "ax-btn ax-btn--ghost tw-font-semibold tw-flex tw-items-center tw-gap-2" do %>
            <i class="bi bi-diagram-3"></i>
            Ajustar fluxo e regras de revisão
          <% end %>
        </div>
      </div>
    </div>

    <div class="ax-span-6">
      <div class="ax-card h-100">
        <div class="ax-card__body p-4">
          <h2 class="tw-text-ink-muted tw-font-semibold tw-mb-3" style="text-transform: uppercase;">Prévia</h2>
          <div class="watermark-preview-frame rounded overflow-hidden position-relative bg-light border"
               data-watermark-preview-target="frame"
               style="--watermark-size: <%= @property_setting.watermark_size_percentage %>%; --watermark-opacity: <%= @property_setting.watermark_opacity_percentage.to_f / 100 %>;">
            <div class="watermark-preview-photo"></div>
            <% logo_class = "watermark-preview-logo watermark-position-#{@property_setting.watermark_position}" %>
            <% logo_class = "#{logo_class} tw-hidden" unless @property_setting.watermark_image.attached? %>
            <% if @property_setting.watermark_image.attached? %>
              <%= image_tag @property_setting.watermark_image,
                    class: logo_class,
                    data: { watermark_preview_target: "logo" },
                    alt: "Marca d'água configurada" %>
            <% else %>
              <%= tag.img class: logo_class,
                    data: { watermark_preview_target: "logo" },
                    alt: "Marca d'água configurada" %>
            <% end %>
            <div class="position-absolute top-50 start-50 translate-middle tw-text-center tw-text-ink-muted px-4 <%= "tw-hidden" if @property_setting.watermark_image.attached? %>"
                 data-watermark-preview-target="placeholder">
              <i class="bi bi-image d-block tw-mb-2" style="font-size: 2rem;"></i>
              Envie uma imagem para visualizar a marca d'água.
            </div>
          </div>
          <p class="tw-text-ink-muted tw-text-sm tw-mt-3 tw-mb-0">
            A marca d'água será aplicada somente nas novas fotos enviadas quando a opção estiver marcada no cadastro do imóvel.
          </p>
        </div>
      </div>
    </div>
  <% end %>
</div>

<style>
  .watermark-preview-frame {
    aspect-ratio: 16 / 10;
    min-height: 260px;
  }

  .watermark-preview-photo {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 78% 28%, rgba(255,255,255,.24) 0 7%, transparent 8%),
      radial-gradient(circle at 69% 66%, rgba(14, 116, 144, .4) 0 9%, transparent 10%),
      linear-gradient(90deg, rgba(8, 13, 23, .78) 0 27%, transparent 28%),
      linear-gradient(145deg, #1f2937 0%, #64748b 38%, #d7ded8 72%, #334155 100%);
  }

  .watermark-preview-photo::after {
    content: "";
    position: absolute;
    inset: 18% 8% 0 38%;
    background: rgba(255,255,255,.26);
    transform: skewX(-12deg);
  }

  .current-watermark-preview {
    background: #f8fafc;
  }

  .current-watermark-thumb {
    width: 132px;
    height: 74px;
    flex: 0 0 auto;
    display: grid;
    place-items: center;
    background:
      linear-gradient(45deg, #334155 25%, transparent 25%),
      linear-gradient(-45deg, #334155 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, #334155 75%),
      linear-gradient(-45deg, transparent 75%, #334155 75%),
      #0f172a;
    background-size: 18px 18px;
    background-position: 0 0, 0 9px, 9px -9px, -9px 0;
  }

  .current-watermark-thumb img {
    max-width: 88%;
    max-height: 76%;
    object-fit: contain;
  }

  .watermark-preview-logo {
    position: absolute;
    width: var(--watermark-size, 28%);
    max-width: none;
    max-height: none;
    object-fit: contain;
    opacity: var(--watermark-opacity, 1);
    filter: drop-shadow(0 4px 10px rgba(15, 23, 42, .18));
  }

  .watermark-position-bottom_left {
    left: 5%;
    bottom: 7%;
  }

  .watermark-position-bottom_right {
    right: 5%;
    bottom: 7%;
  }

  .watermark-position-center {
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
  }
</style>
