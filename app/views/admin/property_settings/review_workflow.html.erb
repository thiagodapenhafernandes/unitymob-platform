<% content_for :admin_contextbar_breadcrumb do %>
  <%= link_to "Admin", admin_root_path %>
  <i class="bi bi-chevron-right"></i>
  <%= link_to "Config de imóveis", edit_admin_property_setting_path %>
  <i class="bi bi-chevron-right"></i>
  <strong>Fluxo de revisão</strong>
<% end %>

<% content_for :admin_contextbar_actions do %>
  <%= link_to edit_admin_property_setting_path, class: "ax-contextbar__button" do %>
    <i class="bi bi-gear"></i><span>Config Imóveis</span>
  <% end %>
  <button type="submit" form="review_workflow_form" class="ax-contextbar__button ax-contextbar__button--primary">
    <i class="bi bi-check2"></i><span>Salvar regra</span>
  </button>
<% end %>

<%
  selected_checks = @selected_rule.active_broker_capture_checks
  selected_sections = @selected_rule.active_returnable_intake_edit_sections
  context_label = [
    PropertyReviewPolicy.registration_label(@review_registration_type),
    (@review_selected_categories.size > 1 ? "#{@review_selected_categories.size} categorias" : @review_category),
    PropertyReviewPolicy.modality_label(@review_modality)
  ].compact_blank.join(" · ")
%>

<%= ax_workflow(label: "Configuração do fluxo de revisão por conjunto operacional") do %>
  <%= ax_workspace_heading(
        eyebrow: "Configuração operacional",
        icon: "diagram-3",
        title: "Revisão por tipo, categoria e modalidade",
        subtitle: "Escolha um conjunto e veja exatamente o que o sistema exige na captação, revisão e publicação.",
        actions: ax_badge(@review_result.source_label, tone: @review_result.specific? ? :green : :gray, dot: true),
        class_name: "ax-workflow__heading"
      ) %>

  <%= ax_operational_panel(eyebrow: "Conjunto", title: "Escolha o cenário que quer configurar") do %>
    <div class="ax-workflow__panel-body">
      <%= form_with url: review_workflow_admin_property_setting_path,
            method: :get,
            local: true,
            class: "ax-field-grid ax-field-grid--12 tw-items-end",
            data: {
              controller: "auto-submit review-policy-context",
              review_policy_context_categories_by_type_value: PropertyReviewPolicy::CATEGORIES_BY_REGISTRATION_TYPE.to_json
            } do |f| %>
        <div class="ax-span-4">
          <%= ax_select_field(
                form: f,
                method: :registration_type,
                label: "Tipo de cadastro",
                choices: @review_registration_types,
                select_options: { selected: @review_registration_type },
                html_options: { data: { review_policy_context_target: "registrationType", action: "change->review-policy-context#sync change->auto-submit#submit" } }
              ) %>
        </div>
        <div class="ax-span-4">
          <%= ax_multiselect_field(
                form: f,
                method: :category,
                label: "Categoria relacionada",
                choices: @review_categories.map { |category| [category, category] },
                selected: @review_selected_categories,
                id: "review_workflow_category",
                placeholder: "Selecione uma ou mais categorias",
                data: {
                  review_policy_context_target: "category",
                  action: "change->auto-submit#submit",
                  tom_select_tags_value: false,
                  tom_select_options_value: { plugins: ["remove_button"] }
                }
              ) %>
        </div>
        <div class="ax-span-3">
          <%= ax_select_field(
                form: f,
                method: :modality,
                label: "Modalidade",
                choices: @review_modalities,
                select_options: { selected: @review_modality },
                html_options: { data: { action: "change->auto-submit#submit" } }
              ) %>
        </div>
        <div class="ax-span-1">
          <%= f.submit "Aplicar", class: "ax-btn ax-btn--sm ax-btn--primary" %>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="ax-workflow__layout">
    <div class="ax-workflow__main">
      <%= ax_operational_panel(
            eyebrow: "Resultado",
            title: "Regra aplicada agora",
            actions: ax_badge(@review_result.specific? ? "Própria" : "Padrão", tone: @review_result.specific? ? :green : :gray)
          ) do %>
        <div class="ax-workflow__panel-body">
          <%= ax_inline_notice(tone: @review_result.specific? ? :success : :info, icon: @review_result.specific? ? "check-circle" : "info-circle") do %>
            <strong><%= context_label %></strong><br>
            <% if @review_result.specific? %>
              Este conjunto tem uma regra própria. A operação real de captação, revisão e publicação usa esta configuração.
            <% else %>
              Este conjunto ainda usa a regra padrão da conta. Salvar abaixo cria uma regra própria sem alterar os demais conjuntos.
            <% end %>
            <% if @review_selected_categories.size > 1 %>
              <br>O resultado exibido usa <strong><%= @review_category %></strong> como referência. Ao salvar, a mesma regra será aplicada às <strong><%= @review_selected_categories.size %> categorias selecionadas</strong>.
            <% end %>
          <% end %>

          <dl class="ax-workflow__state">
            <div class="ax-workflow__state-row">
              <dt>Próximo passo após checklist</dt>
              <dd><strong><%= @selected_rule.broker_capture_layer_enabled ? "Revisão administrativa" : "Publicar Site" %></strong></dd>
            </div>
            <div class="ax-workflow__state-row">
              <dt>Publicação no site</dt>
              <dd><%= ax_badge("Sempre manual", tone: :amber) %></dd>
            </div>
            <div class="ax-workflow__state-row">
              <dt>Origem da regra</dt>
              <dd><%= ax_badge(@review_result.source_label, tone: @review_result.specific? ? :green : :gray) %></dd>
            </div>
          </dl>
        </div>
      <% end %>

      <%= ax_operational_panel(
            eyebrow: "Bloqueios",
            title: "O sistema vai exigir",
            actions: ax_badge("#{@review_result.applicable_checks.size} itens", tone: :blue)
          ) do %>
        <div class="ax-workflow__panel-body">
          <% if @review_result.applicable_checks.any? %>
            <div class="ax-chip-grid">
              <% @review_result.applicable_checks.each do |_key, label| %>
                <span class="ax-badge ax-badge--blue"><i class="bi bi-check2"></i> <%= label %></span>
              <% end %>
            </div>
          <% else %>
            <%= ax_inline_notice(tone: :warning, icon: "exclamation-triangle") do %>
              Nenhuma validação aplicável foi encontrada para este conjunto. Revise a configuração antes de salvar.
            <% end %>
          <% end %>
        </div>
      <% end %>

      <%= ax_operational_panel(
            eyebrow: "Condições",
            title: "Não se aplica neste conjunto",
            actions: ax_badge("#{@review_result.ignored_checks.size} itens", tone: @review_result.ignored_checks.any? ? :amber : :gray)
          ) do %>
        <div class="ax-workflow__panel-body">
          <% if @review_result.ignored_checks.any? %>
            <dl class="ax-workflow__state">
              <% @review_result.ignored_checks.each do |ignored| %>
                <div class="ax-workflow__state-row">
                  <dt><%= ignored.label %></dt>
                  <dd><%= ignored.reason %></dd>
                </div>
              <% end %>
            </dl>
          <% else %>
            <p class="ax-workflow__hint">Todas as validações marcadas se aplicam ao conjunto selecionado.</p>
          <% end %>
        </div>
      <% end %>

      <%= ax_operational_panel(eyebrow: "Editar", title: "Ajustar regra deste conjunto") do %>
        <div class="ax-workflow__panel-body">
          <%= form_with model: @review_policy, url: review_workflow_admin_property_setting_path(registration_type: @review_registration_type, category: @review_selected_categories, modality: @review_modality), method: :patch, html: { id: "review_workflow_form", class: "ax-workflow__form" } do |f| %>
            <% if @review_policy.errors.any? %>
              <%= ax_error_summary(@review_policy) %>
            <% end %>

            <div class="habitation-form-ui ax-workflow__switches">
              <%= ax_toggle_chip(f, :broker_capture_layer_enabled,
                    label: "Exigir aprovação administrativa antes de publicar",
                    checked_value: "true",
                    unchecked_value: "false",
                    class_name: "ax-workflow__switch") %>
            </div>

            <div class="ax-workflow__field habitation-form-ui">
              <%= hidden_field_tag "property_review_policy[required_broker_intake_checks][]", "" %>
              <%= ax_multiselect_field(
                    form: f,
                    method: :required_broker_intake_checks,
                    label: "Validações que bloqueiam envio/aprovação",
                    tooltip: "A aplicabilidade final ainda respeita categoria e modalidade. Ex.: garantia locatícia só bloqueia locação.",
                    choices: PropertySetting::BROKER_INTAKE_CHECK_OPTIONS.map { |key, label| [label, key] },
                    selected: selected_checks,
                    id: "property_review_policy_required_broker_intake_checks",
                    placeholder: "Selecione as validações exigidas...",
                    data: { tom_select_tags_value: false }
                  ) %>
            </div>

            <div class="ax-workflow__field">
              <span class="ax-workflow__field-label">Se devolver ao captador, o que ele pode corrigir?</span>
              <p class="ax-workflow__hint">Esses blocos reabrem quando o administrativo devolve a captação. O restante continua protegido.</p>
              <%= hidden_field_tag "property_review_policy[returnable_intake_edit_sections][]", "" %>
              <%= ax_chip_grid do %>
                <% PropertySetting::RETURNABLE_INTAKE_EDIT_SECTION_OPTIONS.each do |key, label| %>
                  <% section_id = "property_review_policy_returnable_intake_edit_sections_#{key}" %>
                  <% section_checked = Array(selected_sections).include?(key) %>
                  <label class="ax-toggle-chip <%= "is-checked" if section_checked %>" data-controller="ax-checkbox-chips">
                    <%= check_box_tag "property_review_policy[returnable_intake_edit_sections][]", key, section_checked,
                          id: section_id,
                          class: "ax-toggle-chip__input",
                          data: { action: "change->ax-checkbox-chips#sync" } %>
                    <span class="ax-toggle-chip__box" aria-hidden="true"><i class="bi bi-check-lg"></i></span>
                    <span class="ax-toggle-chip__label"><%= label %></span>
                  </label>
                <% end %>
              <% end %>
            </div>

            <div class="habitation-form-ui ax-workflow__switches">
              <%= ax_toggle_chip(f, :notify_internal_review_events,
                    label: "Avisar admins e revisores dentro do sistema",
                    checked_value: "true",
                    unchecked_value: "false",
                    class_name: "ax-workflow__switch") %>
              <%= ax_toggle_chip(f, :notify_email_review_events,
                    label: "Enviar e-mail também",
                    checked_value: "true",
                    unchecked_value: "false",
                    class_name: "ax-workflow__switch") %>
            </div>

            <div class="ax-workflow__field">
              <%= ax_field_label(f, :review_notification_emails, text: "Quem recebe e-mail de acompanhamento") %>
              <%= f.text_area :review_notification_emails,
                    rows: 3,
                    class: "ax-control",
                    placeholder: "admin1@empresa.com, admin2@empresa.com" %>
              <p class="ax-workflow__hint">Use vírgula, ponto e vírgula ou uma linha por e-mail.</p>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <aside class="ax-workflow__inspector" aria-label="Resumo da regra selecionada">
      <%= ax_operational_panel(eyebrow: "Resumo", title: "Leitura rápida") do %>
        <div class="ax-workflow__panel-body">
          <dl class="ax-workflow__state">
            <div class="ax-workflow__state-row">
              <dt>Tipo</dt>
              <dd><%= PropertyReviewPolicy.registration_label(@review_registration_type) %></dd>
            </div>
            <div class="ax-workflow__state-row">
              <dt>Categoria</dt>
              <dd><%= @review_selected_categories.size > 1 ? "#{@review_selected_categories.size} selecionadas" : @review_category %></dd>
            </div>
            <div class="ax-workflow__state-row">
              <dt>Modalidade</dt>
              <dd><%= PropertyReviewPolicy.modality_label(@review_modality) %></dd>
            </div>
            <div class="ax-workflow__state-row">
              <dt>Validações ativas</dt>
              <dd><strong><%= @review_result.required_checks.size %></strong></dd>
            </div>
            <div class="ax-workflow__state-row">
              <dt>Aplicáveis agora</dt>
              <dd><strong><%= @review_result.applicable_checks.size %></strong></dd>
            </div>
          </dl>
        </div>
      <% end %>
    </aside>
  </div>

  <%= ax_sticky_action_footer(
        meta: safe_join([tag.i(class: "bi bi-shield-check", aria: { hidden: true }), tag.span("A regra salva é usada na operação real")], " "),
        class_name: "ax-workflow__actions"
      ) do %>
    <%= link_to "Voltar para Config Imóveis", edit_admin_property_setting_path, class: "ax-btn ax-btn--ghost" %>
    <%= button_tag "Salvar regra deste conjunto", type: "submit", form: "review_workflow_form", class: "ax-btn ax-btn--primary" %>
  <% end %>
<% end %>
