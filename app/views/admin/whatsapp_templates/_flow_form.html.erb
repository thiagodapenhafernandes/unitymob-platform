<%= form_with model: [:admin, template],
              class: "whatsapp-template-form",
              data: {
                controller: "whatsapp-template-form",
                action: "submit->whatsapp-template-form#submitStarted"
              } do |f| %>
  <%= hidden_field_tag :whatsapp_sender_number_id, sender_number&.id if sender_number %>
  <%= f.hidden_field :template_type, value: "flow" %>
  <%= f.hidden_field :header_format, value: "none" %>

  <%= render "form_feedback", template: template %>

  <section class="whatsapp-template-header whatsapp-template-header--approval">
    <div class="whatsapp-template-header__icon"><i class="bi bi-diagram-3"></i></div>
    <div>
      <strong>Template com Flow</strong>
      <span>Conecte uma mensagem aprovada a um Flow já criado na Meta.</span>
    </div>
  </section>

  <%= ax_operational_panel(eyebrow: "Flow", title: "Informações do template") do %>
    <div class="ax-panel-body whatsapp-template-form__stack">
      <div class="whatsapp-template-form__grid">
        <div class="ax-field">
          <%= ax_field_label(f, :name, text: "Nome interno", tooltip: "Use um nome curto para localizar o template e criar campanhas depois.") %>
          <%= f.text_field :name, class: "ax-control", placeholder: "ex: flow_agendamento_visita" %>
        </div>
        <div class="ax-field">
          <%= ax_field_label(f, :category, text: "Categoria", tooltip: "Flows podem ser usados em Marketing ou Utility conforme o objetivo da mensagem.") %>
          <%= f.select :category, WhatsappTemplate::CATEGORIES.map { |category| [category.titleize, category] }, {}, class: "ax-control" %>
        </div>
        <div class="ax-field">
          <%= ax_field_label(f, :language, text: "Idioma", tooltip: "Idioma usado na revisão da mensagem pela Meta.") %>
          <%= f.select :language, [["Português (Brasil)", "pt_BR"], ["English", "en_US"], ["Español", "es"]], {}, class: "ax-control" %>
        </div>
        <label class="whatsapp-template-check">
          <%= f.check_box :allow_category_change %>
          <span>Permitir ajuste automático de categoria</span>
        </label>
      </div>

      <div class="ax-field">
        <%= ax_field_label(f, :body, text: "Texto da mensagem", tooltip: "Texto que introduz o botão do Flow. Use variáveis como {{1}} quando precisar personalizar.") %>
        <%= f.text_area :body,
                        class: "ax-control",
                        rows: 5,
                        maxlength: 1024,
                        placeholder: "Olá {{1}}, toque no botão para continuar.",
                        data: {
                          whatsapp_template_form_target: "bodyInput",
                          action: "input->whatsapp-template-form#syncExamples"
                        } %>
      </div>
    </div>
  <% end %>

  <%= ax_operational_panel(eyebrow: "Configuração", title: "Conexão com Flow") do %>
    <div class="ax-panel-body whatsapp-template-form__stack">
      <% config = template.clean_flow_config %>
      <div class="whatsapp-template-flow-grid">
        <div class="ax-field">
          <%= label_tag "whatsapp_template_flow_config_flow_id", "ID do Flow na Meta", class: "ax-label" %>
          <%= text_field_tag "whatsapp_template[flow_config][flow_id]", config["flow_id"], id: "whatsapp_template_flow_config_flow_id", class: "ax-control", placeholder: "Ex: 123456789012345" %>
          <p class="ax-field__hint">Informe o ID do Flow publicado na Meta. A campanha usa esse vínculo no botão.</p>
        </div>
        <div class="ax-field">
          <%= label_tag "whatsapp_template_flow_config_button_text", "Texto do botão", class: "ax-label" %>
          <%= text_field_tag "whatsapp_template[flow_config][button_text]", config["button_text"].presence || "Abrir", id: "whatsapp_template_flow_config_button_text", class: "ax-control", maxlength: 25, placeholder: "Abrir cadastro" %>
        </div>
        <div class="ax-field">
          <%= label_tag "whatsapp_template_flow_config_action", "Ação do Flow", class: "ax-label" %>
          <%= select_tag "whatsapp_template[flow_config][action]",
                         options_for_select(WhatsappTemplate::FLOW_ACTIONS.map { |key, label| [label, key] }, config["action"].presence || "navigate"),
                         id: "whatsapp_template_flow_config_action",
                         class: "ax-control",
                         data: {
                           whatsapp_template_form_target: "flowActionSelect",
                           action: "change->whatsapp-template-form#toggleFlowFields"
                         } %>
        </div>
        <div class="ax-field" data-whatsapp-template-form-target="flowScreenField">
          <%= label_tag "whatsapp_template_flow_config_screen", "Tela inicial", class: "ax-label" %>
          <%= text_field_tag "whatsapp_template[flow_config][screen]", config["screen"], id: "whatsapp_template_flow_config_screen", class: "ax-control", placeholder: "Ex: APPOINTMENT" %>
          <p class="ax-field__hint">Opcional. Use quando o Flow precisa abrir em uma tela específica.</p>
        </div>
      </div>
      <div class="ax-field">
        <%= ax_field_label(f, :footer_text, text: "Rodapé", tooltip: "Texto curto opcional exibido abaixo da mensagem.") %>
        <%= f.text_field :footer_text, class: "ax-control", placeholder: "Texto adicional ou instruções" %>
      </div>
    </div>
  <% end %>

  <%= ax_operational_panel(eyebrow: "Variáveis", title: "Exemplos para aprovação") do %>
    <div class="ax-panel-body whatsapp-template-form__stack">
      <div class="whatsapp-template-examples__head">
        <p class="ax-field__hint">Adicione um exemplo para cada variável usada no texto da mensagem.</p>
        <button type="button" class="ax-btn ax-btn--sm" data-action="whatsapp-template-form#addExample">
          <i class="bi bi-plus-lg ax-ico"></i><span>Adicionar exemplo</span>
        </button>
      </div>
      <div class="whatsapp-template-example-grid" data-whatsapp-template-form-target="examplesList">
        <% example_rows = Array(template.example_values).map(&:to_s).reject(&:blank?) %>
        <% example_rows = [""] if example_rows.blank? %>
        <% example_rows.each_with_index do |value, index| %>
          <div class="ax-field whatsapp-template-example-row" data-whatsapp-template-form-target="exampleRow">
            <%= label_tag "whatsapp_template_example_values_#{index}", "Exemplo #{index + 1}", class: "ax-label" %>
            <div class="whatsapp-template-example-row__input">
              <%= text_field_tag "whatsapp_template[example_values][]",
                                 value,
                                 id: "whatsapp_template_example_values_#{index}",
                                 class: "ax-control",
                                 placeholder: index.zero? ? "Maria Silva" : "",
                                 data: { whatsapp_template_form_target: "exampleInput" } %>
              <button type="button" class="ax-btn ax-btn--sm whatsapp-template-example-row__remove" aria-label="Remover exemplo" data-action="whatsapp-template-form#removeExample">
                <i class="bi bi-trash"></i>
              </button>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <footer class="whatsapp-template-form__footer">
    <%= link_to "Cancelar", admin_whatsapp_templates_path(whatsapp_sender_number_id: sender_number&.id), class: "ax-btn" %>
    <button type="submit" class="ax-btn ax-btn--primary">
      <i class="bi bi-send-check ax-ico"></i><span>Enviar para aprovação</span>
    </button>
  </footer>
<% end %>
