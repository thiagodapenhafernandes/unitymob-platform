<%= form_with model: [:admin, campaign], local: true, html: { class: "marketing-campaign-form" } do |f| %>
  <%= ax_error_summary(campaign) %>

  <%= ax_operational_panel(eyebrow: "Cadastro", title: "Configuração da campanha", class_name: "tw-mb-4") do %>
      <%= ax_field_grid do %>
        <div class="ax-span-6">
          <%= ax_text_field(form: f, method: :name, label: "Nome da campanha", required: true) %>
        </div>
        <div class="ax-span-4">
          <%= ax_select_field(form: f, method: :seo_setting_id, label: "Página SEO vinculada",
                choices: @seo_settings.map { |setting| [setting.display_name, setting.id] },
                select_options: { include_blank: "Sem vínculo" }) %>
        </div>
        <div class="ax-span-4">
          <%= ax_select_field(form: f, method: :channel, label: "Canal",
                choices: MarketingCampaign::CHANNELS.map { |key, label| [label, key] }) %>
        </div>
        <div class="ax-span-4">
          <%= ax_select_field(form: f, method: :status, label: "Status",
                choices: MarketingCampaign::STATUSES.map { |key, label| [label, key] }) %>
        </div>
        <div class="ax-span-4">
          <%= ax_number_field(form: f, method: :priority, label: "Prioridade", min: 1, max: 5) %>
        </div>
        <div class="ax-span-6">
          <%= ax_text_field(form: f, method: :target_url, label: "URL alvo", placeholder: "/imoveis/frente-mar") %>
        </div>
        <div class="ax-span-4">
          <%= ax_currency_field(form: f, method: :budget, label: "Orçamento previsto",
                value: number_with_precision(campaign.budget, precision: 2), placeholder: "0,00") %>
        </div>
        <div class="ax-span-12">
          <%= ax_operational_panel(eyebrow: "Rastreamento", title: "UTM Builder") do %>
            <div class="tw-flex tw-justify-between tw-items-center tw-mb-2 tw-flex-wrap tw-gap-2">
              <div>
                <p class="tw-text-sm tw-text-ink-muted">Preencha os campos para gerar o link final da campanha.</p>
              </div>
              <% if campaign.persisted? %>
                <span class="ax-badge ax-badge--blue"><%= campaign.clicks_count %> cliques · <%= campaign.conversions_count %> conversões</span>
              <% end %>
            </div>
            <%= ax_field_grid do %>
              <div class="ax-span-4">
                <%= ax_text_field(form: f, method: :utm_source, label: "Origem", placeholder: "google, instagram, footer") %>
              </div>
              <div class="ax-span-4">
                <%= ax_text_field(form: f, method: :utm_medium, label: "Mídia", placeholder: "cpc, social, organic") %>
              </div>
              <div class="ax-span-4">
                <%= ax_text_field(form: f, method: :utm_campaign, label: "Campanha", placeholder: "frente-mar-maio") %>
              </div>
              <div class="ax-span-6">
                <%= ax_text_field(form: f, method: :utm_term, label: "Termo", placeholder: "apartamento frente mar") %>
              </div>
              <div class="ax-span-6">
                <%= ax_text_field(form: f, method: :utm_content, label: "Conteúdo", placeholder: "botao-footer, criativo-a") %>
              </div>
            <% end %>
            <% if campaign.target_url.present? %>
              <div class="tw-mt-3">
                <%= ax_standalone_field(name: nil, id: "marketing_campaign_generated_url", label: "Link atual gerado",
                      value: campaign.generated_url(request.base_url), readonly: true, input_class: "ax-control--sm") %>
              </div>
            <% end %>
          <% end %>
        </div>
        <div class="ax-span-4">
          <%= ax_date_field(form: f, method: :starts_on, label: "Início") %>
        </div>
        <div class="ax-span-4">
          <%= ax_date_field(form: f, method: :ends_on, label: "Fim") %>
        </div>
        <div class="ax-span-12">
          <%= ax_text_field(form: f, method: :objective, label: "Objetivo", placeholder: "Ex: gerar leads para imóveis frente mar") %>
        </div>
        <div class="ax-span-12">
          <%= ax_text_field(form: f, method: :notes, label: "Notas", type: :textarea, rows: 5) %>
        </div>
      <% end %>
  <% end %>

  <%= ax_form_actions(cancel_path: admin_marketing_campaigns_path, submit_label: "Salvar campanha", form: f) %>
<% end %>
