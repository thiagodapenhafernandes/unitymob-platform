<%
  can_launch_signup = @diagnostics.all? { |item| item[:ok] || item[:fallback].present? }
  active_tab = params[:tab].presence || "whatsapp"
  connected = @whatsapp_integration.connected?
  effective_connected = connected || @whatsapp_effective_ready
%>

<% content_for :admin_contextbar_breadcrumb do %>
  <%= link_to "Admin", admin_root_path %>
  <i class="bi bi-chevron-right"></i>
  <span>Integrações</span>
  <i class="bi bi-chevron-right"></i>
  <strong>WhatsApp</strong>
<% end %>

<% content_for :admin_contextbar_actions do %>
  <%= link_to admin_whatsapp_conversations_path, class: "ax-contextbar__button" do %>
    <i class="bi bi-chat-dots"></i><span>Atendimento</span>
  <% end %>
  <% if @whatsapp_integration.persisted? && connected %>
    <%= button_to disconnect_admin_whatsapp_integration_path, method: :delete,
                  class: "ax-contextbar__button ax-contextbar__button--danger",
                  data: { turbo_confirm: "Remover a conexão atual do WhatsApp?" } do %>
      <i class="bi bi-box-arrow-right"></i><span>Desconectar</span>
    <% end %>
  <% end %>
<% end %>

<div class="wa-workspace"
     data-controller="whatsapp-integration"
     data-whatsapp-integration-app-id-value="<%= ENV.fetch('FACEBOOK_APP_ID', '') %>"
     data-whatsapp-integration-api-version-value="<%= ENV['WHATSAPP_EMBEDDED_SIGNUP_API_VERSIONS'].presence || ENV['WHATSAPP_GRAPH_API_VERSION'].presence || ENV['META_API_VERSION'].presence || 'v24.0' %>"
     data-whatsapp-integration-config-id-value="<%= @embedded_signup_config_id %>"
     data-whatsapp-integration-callback-url-value="<%= embedded_signup_callback_admin_whatsapp_integration_path %>"
     data-whatsapp-integration-test-url-value="<%= test_connection_admin_whatsapp_integration_path %>"
     data-whatsapp-integration-send-url-value="<%= send_test_admin_whatsapp_integration_path %>">
  <header class="ax-dashboard-command ax-property-form-command wa-command">
    <div class="ax-dashboard-command__main">
      <span class="ax-dashboard-command__eyebrow">Integração</span>
      <h1><i class="bi bi-whatsapp" style="color:#1da851"></i> Integração WhatsApp</h1>
      <p>Conecte o WhatsApp Business pela Meta e configure os telefones usados nos formulários do site.</p>
    </div>
    <div class="ax-dashboard-command__status">
      <% if @whatsapp_using_global %>
        <%= ax_badge("Usando conexão global", tone: :blue, dot: true) %>
      <% elsif connected %>
        <%= ax_badge("Conectado", tone: :green, dot: true) %>
      <% else %>
        <%= ax_badge("Aguardando conexão", tone: :gray) %>
      <% end %>
    </div>
  </header>

  <nav class="wa-tabs" aria-label="Seções da integração">
    <%= link_to admin_whatsapp_integration_path(tab: "whatsapp"),
                class: "wa-tabs__item #{'is-active' if active_tab == 'whatsapp'}" do %>
      <i class="bi bi-whatsapp"></i><span>WhatsApp Business API</span>
    <% end %>
    <%= link_to admin_whatsapp_integration_path(tab: "site_phones"),
                class: "wa-tabs__item #{'is-active' if active_tab == 'site_phones'}" do %>
      <i class="bi bi-telephone-outbound"></i><span>Telefones do Site</span>
    <% end %>
  </nav>

  <% if active_tab == "site_phones" %>
    <div class="wa-grid">
      <div class="wa-main">
        <%= ax_operational_panel(
              eyebrow: "Formulários do site",
              title: "Telefones dos formulários do site"
            ) do %>
          <div class="wa-panel-body">
            <p class="wa-hint">Defina o número de destino e se o visitante passa pelo formulário intermediário antes do WhatsApp.</p>

            <% if @phone_settings_errors.present? %>
              <%= ax_inline_notice(tone: :warning, icon: "exclamation-triangle") do %>
                <strong>Revise os campos:</strong> <%= @phone_settings_errors.to_sentence %>
              <% end %>
            <% end %>

            <%= form_with model: @whatsapp_integration, url: phone_settings_admin_whatsapp_integration_path, method: :patch, html: { class: "habitation-form-ui wa-form" } do |f| %>
              <div class="wa-field">
                <%= ax_field_label(f, :default_whatsapp_number, text: "Número padrão",
                      tooltip: "Usado quando o tipo de negociação não tiver número específico.") %>
                <%= ax_input_group(prefix: tag.i(class: "bi bi-whatsapp", style: "color:#1da851")) do %>
                  <%= f.telephone_field :default_whatsapp_number,
                        class: "ax-control",
                        placeholder: "5547999999999",
                        value: @whatsapp_integration.default_whatsapp_number.presence || ContactSetting.first&.whatsapp_primary,
                        data: { controller: "phone-input" } %>
                <% end %>
              </div>

              <div class="wa-negotiations">
                <% WhatsappBusinessIntegration::NEGOTIATION_TYPES.each do |key, config| %>
                  <section class="wa-negotiation">
                    <header class="wa-negotiation__head">
                      <span class="wa-negotiation__icon"><i class="bi bi-whatsapp"></i></span>
                      <div>
                        <strong><%= config[:label] %></strong>
                        <span><%= config[:default_message] %></span>
                      </div>
                    </header>
                    <div class="wa-field">
                      <%= ax_field_label(f, config[:phone_attribute], text: "WhatsApp de destino") %>
                      <%= f.telephone_field config[:phone_attribute],
                                            class: "ax-control",
                                            placeholder: "Usar número padrão",
                                            data: { controller: "phone-input" } %>
                    </div>
                    <%= ax_toggle_chip(f, config[:form_attribute],
                          label: "Captar dados antes de redirecionar",
                          checked_value: "1", unchecked_value: "0",
                          class_name: "wa-negotiation__toggle") %>
                  </section>
                <% end %>
              </div>

              <div class="wa-field" style="margin-top:12px;padding-top:12px;border-top:1px solid #eceef1">
                <%= ax_field_label(text: "Cartão de apresentação do corretor",
                      tooltip: "Vale para toda a equipe. Desligado, os cartões saem sempre como texto (sem a foto do corretor). O telefone pessoal do corretor nunca é enviado.") %>
                <%= ax_switch_field(form: f, method: :allow_photo_presentation,
                      label: "Permitir cartão com foto do corretor",
                      checked: @whatsapp_integration.allow_photo_presentation?) %>
              </div>

              <div class="ax-form-actions">
                <%= f.submit "Salvar telefones do site", class: "ax-btn ax-btn--primary" %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>

      <aside class="wa-aside">
        <%= ax_operational_panel(eyebrow: "Resumo", title: "Como o site usa") do %>
          <div class="wa-panel-body">
            <dl class="wa-state">
              <% @site_phone_settings[:negotiations].each do |key, item| %>
                <div class="wa-state__row">
                  <dt>
                    <strong><%= item[:label] %></strong>
                    <span><%= item[:requires_form] ? "Com formulário intermediário" : "Direto para o WhatsApp" %></span>
                  </dt>
                  <dd><code><%= item[:phone].presence || @site_phone_settings[:default_phone] %></code></dd>
                </div>
              <% end %>
            </dl>
          </div>
        <% end %>

        <%= ax_operational_panel(eyebrow: "Regra", title: "Regra padrão") do %>
          <div class="wa-panel-body">
            <p class="wa-hint">Se um número específico ficar em branco, o site usa o número padrão. Locação diária entra na regra de locação.</p>
          </div>
        <% end %>
      </aside>
    </div>
  <% else %>
    <div class="wa-grid">
      <div class="wa-main">
        <% if @whatsapp_using_global %>
          <%= ax_inline_notice(tone: :info, icon: "globe2") do %>
            <strong>Esta conta está usando o WhatsApp global do sistema.</strong>
            As notificações de distribuição saem pela conexão global enquanto esta conta não tiver uma conexão própria pronta.
          <% end %>
        <% end %>

        <%= ax_operational_panel(
              eyebrow: "Config WABA Unitymob: #{@embedded_signup_config_id}",
              title: "Embedded Signup v4",
              actions: ax_badge(@whatsapp_using_global ? "Global ativo" : (connected ? "Conectado" : "Aguardando conexão"), tone: @whatsapp_using_global ? :blue : (connected ? :green : :gray))
            ) do %>
          <div class="wa-panel-body">
            <% if connected %>
              <div class="wa-connected">
                <% [
                     ["WABA ID", @whatsapp_integration.waba_id],
                     ["Phone Number ID", @whatsapp_integration.phone_number_id],
                     ["Business ID", @whatsapp_integration.business_id.presence || "Não informado"],
                     ["Token", @whatsapp_integration.token_preview || "Salvo"],
                     ["Conectado por", @whatsapp_integration.connected_by_admin_user&.name || "Sistema"],
                     ["Data", (@whatsapp_integration.connected_at ? l(@whatsapp_integration.connected_at, format: :short) : "—")]
                   ].each do |label, value| %>
                  <div class="wa-connected__cell">
                    <span><%= label %></span>
                    <strong><%= value %></strong>
                  </div>
                <% end %>
              </div>
            <% end %>

            <%# Webhook de mensagens (inbox) — agora editável %>
            <section class="wa-webhook">
              <header class="wa-webhook__head">
                <div>
                  <span class="ax-operational-panel__eyebrow">Inbox</span>
                  <h3>Webhook de mensagens</h3>
                </div>
                <%= link_to "Abrir Atendimento", admin_whatsapp_conversations_path, class: "ax-btn ax-btn--sm" %>
              </header>
              <p class="wa-hint">Configure no painel da Meta (WhatsApp › Configuration › Webhook) para receber mensagens e retornos de aprovação. Campos a assinar: <code>messages</code> e <code>message_template_status_update</code>.</p>

              <% if @webhook_settings_errors.present? %>
                <%= ax_inline_notice(tone: :warning, icon: "exclamation-triangle") do %>
                  <strong>Revise os campos:</strong> <%= @webhook_settings_errors.to_sentence %>
                <% end %>
              <% end %>

              <%= form_with model: @whatsapp_integration, url: admin_whatsapp_integration_path, method: :patch, html: { class: "habitation-form-ui wa-form" } do |f| %>
                <div class="wa-webhook__grid">
                  <div class="wa-field">
                    <%= ax_field_label(f, :webhook_callback_url, text: "Callback URL",
                          tooltip: "Em produção, use o domínio público (HTTPS). Em branco, usa o padrão: #{@default_webhook_callback_url}") %>
                    <%= f.url_field :webhook_callback_url, class: "ax-control", value: @webhook_callback_url, placeholder: @default_webhook_callback_url %>
                  </div>
                  <div class="wa-field">
                    <%= ax_field_label(f, :webhook_verify_token, text: "Verify Token",
                          tooltip: "Cole este valor no painel da Meta ao assinar o webhook.") %>
                    <%= f.text_field :webhook_verify_token, class: "ax-control", value: @webhook_verify_token %>
                  </div>
                </div>
                <div class="wa-webhook__actions">
                  <%= f.submit "Salvar webhook", class: "ax-btn ax-btn--primary ax-btn--sm" %>
                </div>
              <% end %>
            </section>

            <% if !connected && @whatsapp_integration.last_error_message.present? %>
              <%= ax_inline_notice(tone: :warning, icon: "exclamation-triangle") do %>
                <strong>Último retorno da Meta:</strong>
                <%= @whatsapp_integration.last_error_message %>
                <% if @whatsapp_integration.last_error_code.present? %>
                  <span class="wa-hint">(<%= @whatsapp_integration.last_error_code %>)</span>
                <% end %>
              <% end %>
            <% end %>

            <div id="whatsapp-signup-feedback" class="ax-inline-notice" hidden role="alert" data-whatsapp-integration-target="signupFeedback"
                 style="display:none;align-items:center;gap:7px;min-height:34px;padding:7px 9px;border:1px solid #d8e1ec;border-left-width:3px;border-radius:7px;background:#f8fafc;color:#475467;font-size:12px;font-weight:650;line-height:1.25;"></div>

            <div class="wa-connect">
              <button type="button"
                      id="whatsapp-embedded-signup-button"
                      class="ax-btn ax-btn--primary wa-connect__button"
                      data-whatsapp-integration-target="signupButton"
                      data-action="whatsapp-integration#launchSignup"
                      <%= "disabled" unless can_launch_signup %>>
                <i class="bi bi-whatsapp"></i> Conectar WhatsApp pela Meta
              </button>
              <% unless can_launch_signup %>
                <span class="wa-hint">Revise os itens de configuração antes de conectar.</span>
              <% end %>
            </div>
          </div>
        <% end %>

        <%# Conexão manual (System User / Cloud API) — número fixo das notificações do sistema %>
        <%= ax_operational_panel(
              eyebrow: "Notificações do sistema",
              title: "Número fixo para notificações automáticas",
              actions: ax_badge(@whatsapp_using_global ? "Usando global" : (@whatsapp_integration.messaging_ready? ? "Pronto p/ envio" : "Não configurado"), tone: @whatsapp_using_global ? :blue : (@whatsapp_integration.messaging_ready? ? :green : :gray))
            ) do %>
          <div class="wa-panel-body">
            <section class="wa-context-block wa-context-block--primary">
              <div class="wa-context-block__head">
                <div>
                  <span>Envio automático</span>
                  <strong>Número das notificações do sistema</strong>
                  <p>Usado para distribuição de leads e avisos internos. Este número é único para as notificações automáticas da conta.</p>
                </div>
              </div>

              <% if @phone_info %>
                <% quality_tone = { "GREEN" => :green, "YELLOW" => :amber, "RED" => :red }[@phone_info[:quality].to_s] || :gray %>
                <div class="wa-phone-info">
                  <div class="wa-phone-info__cell">
                    <span>Número</span>
                    <strong><%= @phone_info[:number].presence || "—" %></strong>
                  </div>
                  <div class="wa-phone-info__cell">
                    <span>Nome verificado</span>
                    <strong><%= @phone_info[:name].presence || "—" %></strong>
                  </div>
                  <div class="wa-phone-info__cell">
                    <span>Quality rating</span>
                    <%= ax_badge(@phone_info[:quality].presence || "—", tone: quality_tone, dot: quality_tone != :gray) %>
                  </div>
                </div>
              <% end %>

              <% if @manual_connection_errors.present? %>
                <%= ax_inline_notice(tone: :warning, icon: "exclamation-triangle") do %>
                  <strong>Revise os campos:</strong> <%= @manual_connection_errors.to_sentence %>
                <% end %>
              <% end %>

              <%= form_with model: @whatsapp_integration, url: manual_connection_admin_whatsapp_integration_path, method: :patch, html: { class: "habitation-form-ui wa-form" } do |f| %>
                <div class="wa-field">
                  <%= ax_field_label(f, :access_token, text: "Access Token (System User / permanente)",
                        tooltip: "Token usado pelas notificações do sistema e como credencial base para testar/enviar pelos números cadastrados abaixo. Salvo no backend, nunca exibido completo.") %>
                  <%= f.password_field :access_token,
                        class: "ax-control",
                        value: "",
                        autocomplete: "off",
                        placeholder: @whatsapp_integration.access_token.present? ? "Token salvo (#{@whatsapp_integration.token_preview}) — preencha para substituir" : "Cole o token da Cloud API" %>
                </div>

                <div class="wa-webhook__grid">
                  <div class="wa-field">
                    <%= ax_field_label(f, :phone_number_id, text: "Phone Number ID das notificações") %>
                    <%= f.text_field :phone_number_id, class: "ax-control", value: @whatsapp_integration.phone_number_id, placeholder: "Ex.: 649374078254590" %>
                  </div>
                  <div class="wa-field">
                    <%= ax_field_label(f, :waba_id, text: "WABA das notificações") %>
                    <%= f.text_field :waba_id, class: "ax-control", value: @whatsapp_integration.waba_id, placeholder: "Ex.: 616242481017427" %>
                  </div>
                  <div class="wa-field">
                    <%= ax_field_label(f, :business_id, text: "Business ID (opcional)") %>
                    <%= f.text_field :business_id, class: "ax-control", value: @whatsapp_integration.business_id %>
                  </div>
                  <div class="wa-field">
                    <%= ax_field_label(f, :app_secret, text: "App Secret (opcional, p/ webhook)",
                          tooltip: "Valida a assinatura do webhook. Deixe em branco para manter o atual.") %>
                    <%= f.password_field :app_secret, class: "ax-control", value: "", autocomplete: "off",
                          placeholder: @whatsapp_integration.app_secret.present? ? "Salvo — preencha para substituir" : "Opcional" %>
                  </div>
                </div>

                <div class="wa-webhook__actions">
                  <%= f.submit "Salvar número das notificações", class: "ax-btn ax-btn--primary ax-btn--sm" %>
                </div>
              <% end %>

              <div class="wa-test">
                <div class="wa-test__bar">
                  <button type="button" class="ax-btn ax-btn--sm" data-action="whatsapp-integration#testConnection">
                    <i class="bi bi-plug"></i> Testar conexão
                  </button>
                  <div class="wa-test__send">
                    <input type="text" class="ax-control" data-whatsapp-integration-target="testTo" placeholder="Número p/ teste (5547...)" aria-label="Número para teste">
                    <button type="button" class="ax-btn ax-btn--sm ax-btn--primary" data-action="whatsapp-integration#sendTest">
                      <i class="bi bi-send"></i> Enviar teste
                    </button>
                  </div>
                </div>
                <div data-whatsapp-integration-target="testResult" class="ax-inline-notice" hidden role="status"
                     style="display:none;align-items:center;gap:7px;min-height:34px;padding:7px 9px;border:1px solid #d8e1ec;border-left-width:3px;border-radius:7px;background:#f8fafc;color:#475467;font-size:12px;font-weight:650;line-height:1.3;"></div>
              </div>
            </section>

            <% notification_template_actions = capture do %>
              <div class="wa-context-actions">
                <%= button_to sync_notification_templates_admin_whatsapp_integration_path,
                              method: :post,
                              class: "ax-btn ax-btn--sm",
                              form: { data: { turbo_confirm: "Sincronizar templates da WABA do número fixo das notificações?" } } do %>
                  <i class="bi bi-arrow-repeat ax-ico"></i><span>Sincronizar templates</span>
                <% end %>
                <%= ax_button("Adicionar finalidade", nil, variant: :success, size: :sm, icon: "plus-circle", data: { ax_modal_open: "#notificationTemplateSettingModal" }) %>
              </div>
            <% end %>

            <section class="wa-context-block">
              <div class="wa-context-block__head">
                <div>
                  <span>Templates do sistema</span>
                  <strong>Templates usados nas notificações automáticas</strong>
                  <p>Cada finalidade aponta para um template aprovado da WABA do número das notificações.</p>
                </div>
                <%= notification_template_actions %>
              </div>

              <p class="wa-hint">Para distribuição de leads, o mapa padrão usa: cliente, origem, nome, telefone/link, email/link e outros dados.</p>

              <% if @notification_template_options.empty? %>
                <%= ax_inline_notice(tone: :warning, icon: "exclamation-triangle") do %>
                  Nenhum template aprovado sincronizado para esta conta. Sincronize ou cadastre o template na área de Templates antes de ativar a notificação por WhatsApp.
                <% end %>
              <% end %>

              <div class="wa-number-list">
                <% @notification_template_settings.each do |setting| %>
                  <article class="wa-number-row">
                    <div class="wa-number-row__main">
                      <strong><%= setting.purpose_label %></strong>
                      <span><%= setting.whatsapp_template&.name || "Template não definido" %></span>
                      <small><%= setting.purpose_description %></small>
                    </div>
                    <div class="wa-number-row__badges">
                      <%= ax_badge(setting.active? ? "Ativo" : "Inativo", tone: setting.active? ? :green : :gray, dot: setting.active?) %>
                    </div>
                    <div class="wa-number-row__actions">
                      <%= ax_button("Editar", nil, size: :sm, icon: "pencil", data: { ax_modal_open: "#notificationTemplateSettingEditModal#{setting.id}" }) %>
                      <%= button_to admin_notification_template_setting_path(setting),
                                    method: :delete,
                                    class: "ax-btn ax-btn--sm ax-btn--danger",
                                    form: { data: { turbo_confirm: "Remover esta configuração de template?" } } do %>
                        <i class="bi bi-trash ax-ico"></i><span>Remover</span>
                      <% end %>
                    </div>
                  </article>

                  <%= ax_quick_modal(id: "notificationTemplateSettingEditModal#{setting.id}", title: "Editar template da finalidade", size: :sm, class_name: "whatsapp-sender-modal") do %>
                    <%= form_with model: [:admin, setting],
                                  url: admin_notification_template_setting_path(setting),
                                  method: :patch,
                                  local: true,
                                  class: "whatsapp-sender-modal__form" do |f| %>
                      <%= f.hidden_field :channel, value: "whatsapp" %>
                      <div class="ax-field">
                        <%= f.label :purpose, "Finalidade", class: "ax-label" %>
                        <%= f.select :purpose, @notification_template_purpose_options, {}, class: "ax-control" %>
                      </div>
                      <div class="ax-field">
                        <%= f.label :whatsapp_template_id, "Template aprovado", class: "ax-label" %>
                        <%= f.select :whatsapp_template_id, @notification_template_options, { include_blank: "Selecione" }, class: "ax-control" %>
                      </div>
                      <div class="ax-field">
                        <span class="ax-label">Mapa das variáveis</span>
                        <% edit_mapping = setting.variable_mapping.presence || setting.default_variable_mapping %>
                        <% edit_count = [setting.whatsapp_template&.variable_count.to_i, edit_mapping.keys.map(&:to_i).max || 0, 1].max %>
                        <% edit_refs = Array(setting.whatsapp_template&.variable_references).index_by { |item| item[:index].to_i } %>
                        <div class="wa-variable-map">
                          <% (1..edit_count).each do |index| %>
                            <label class="wa-variable-map__row">
                              <span>{{<%= index %>}}<small><%= edit_refs.dig(index, :context) %></small></span>
                              <%= select_tag "notification_template_setting[variable_mapping][#{index}]",
                                    options_for_select(setting.variable_source_options, edit_mapping[index.to_s]),
                                    class: "ax-control" %>
                            </label>
                          <% end %>
                        </div>
                      </div>
                      <label class="wa-number-checkbox">
                        <%= f.check_box :active %>
                        <span>Ativo</span>
                      </label>
                      <div class="whatsapp-sender-modal__actions">
                        <button type="button" class="ax-btn ax-btn--ghost" data-action="ax-modal#close">Cancelar</button>
                        <button type="submit" class="ax-btn ax-btn--primary">
                          <i class="bi bi-check2 ax-ico"></i><span>Salvar</span>
                        </button>
                      </div>
                    <% end %>
                  <% end %>
                <% end %>

                <% if @notification_template_settings.empty? %>
                  <div class="wa-number-row wa-number-row--empty">
                    <div class="wa-number-row__main">
                      <strong>Nenhuma finalidade configurada</strong>
                      <span>Adicione a finalidade de distribuição para o WhatsApp notificar o corretor com o template correto.</span>
                    </div>
                  </div>
                <% end %>
              </div>
            </section>

            <%= ax_quick_modal(id: "notificationTemplateSettingModal", title: "Adicionar template de notificação", size: :sm, class_name: "whatsapp-sender-modal") do %>
              <%= form_with model: [:admin, @new_notification_template_setting],
                            url: admin_notification_template_settings_path,
                            local: true,
                            class: "whatsapp-sender-modal__form" do |f| %>
                <%= f.hidden_field :channel, value: "whatsapp" %>
                <%= f.hidden_field :active, value: "1" %>
                <div class="ax-field">
                  <%= f.label :purpose, "Finalidade", class: "ax-label" %>
                  <%= f.select :purpose, @notification_template_purpose_options, {}, class: "ax-control" %>
                </div>
                <div class="ax-field">
                  <%= f.label :whatsapp_template_id, "Template aprovado", class: "ax-label" %>
                  <%= f.select :whatsapp_template_id, @notification_template_options, { include_blank: "Selecione" }, class: "ax-control" %>
                </div>
                <div class="ax-field">
                  <span class="ax-label">Mapa padrão das variáveis</span>
                  <div class="wa-variable-map">
                    <% @new_notification_template_setting.default_variable_mapping.each do |index, source| %>
                      <label class="wa-variable-map__row">
                        <span>{{<%= index %>}}</span>
                        <%= select_tag "notification_template_setting[variable_mapping][#{index}]",
                              options_for_select(@new_notification_template_setting.variable_source_options, source),
                              class: "ax-control" %>
                      </label>
                    <% end %>
                  </div>
                </div>
                <p class="wa-hint">O sistema usa o mapa acima para preencher dinamicamente os placeholders do template. Em templates com outra quantidade de variáveis, salve e ajuste em Editar.</p>
                <div class="whatsapp-sender-modal__actions">
                  <button type="button" class="ax-btn ax-btn--ghost" data-action="ax-modal#close">Cancelar</button>
                  <button type="submit" class="ax-btn ax-btn--primary">
                    <i class="bi bi-check2 ax-ico"></i><span>Salvar finalidade</span>
                  </button>
                </div>
              <% end %>
            <% end %>

            <% sender_panel_actions = capture do %>
              <%= ax_button("Adicionar número", nil, variant: :success, size: :sm, icon: "plus-circle", data: { ax_modal_open: "#whatsappAccountNumberModal" }) %>
            <% end %>

            <section class="wa-context-block">
              <div class="wa-context-block__head">
                <div>
                  <span>Campanhas</span>
                  <strong>Números disponíveis para campanhas</strong>
                  <p>Estes números aparecem na seleção das campanhas de disparo. Não alteram o número fixo das notificações acima.</p>
                </div>
                <%= sender_panel_actions %>
              </div>

              <div class="wa-number-list">
                <% @whatsapp_sender_numbers.each do |number| %>
                  <article class="wa-number-row">
                    <div class="wa-number-row__main">
                      <strong><%= number.formatted_phone %></strong>
                      <span><%= number.label %></span>
                      <small>Phone Number ID: <%= number.phone_number_id %><%= " · WABA: #{number.waba_id}" if number.waba_id.present? %></small>
                    </div>
                    <div class="wa-number-row__badges">
                      <%= ax_badge(number.messaging_ready? ? "Conectado" : number.status.humanize, tone: number.messaging_ready? ? :green : :amber, dot: true) %>
                    </div>
                    <div class="wa-number-row__actions">
                      <%= ax_button("Editar", nil, size: :sm, icon: "pencil", data: { ax_modal_open: "#whatsappAccountNumberEditModal#{number.id}" }) %>
                      <button type="button"
                              class="ax-btn ax-btn--sm"
                              data-action="whatsapp-integration#testSenderConnection"
                              data-test-url="<%= test_connection_admin_whatsapp_sender_number_path(number) %>">
                        <i class="bi bi-plug ax-ico"></i><span>Testar</span>
                      </button>

                      <%= button_to admin_whatsapp_sender_number_path(number),
                                    method: :delete,
                                    class: "ax-btn ax-btn--sm ax-btn--danger",
                                    form: { data: { turbo_confirm: "Remover este número da conta? O histórico de campanhas será preservado." } } do %>
                        <%= hidden_field_tag :return_to, admin_whatsapp_integration_path %>
                        <i class="bi bi-trash ax-ico"></i><span>Remover</span>
                      <% end %>
                    </div>
                    <div class="wa-number-row__test" data-wa-number-test-result hidden></div>
                  </article>

                  <%= ax_quick_modal(id: "whatsappAccountNumberEditModal#{number.id}", title: "Editar número WhatsApp", size: :sm, class_name: "whatsapp-sender-modal") do %>
                    <%= form_with model: [:admin, number],
                                  url: admin_whatsapp_sender_number_path(number),
                                  method: :patch,
                                  local: true,
                                  class: "whatsapp-sender-modal__form" do |f| %>
                      <%= hidden_field_tag :return_to, admin_whatsapp_integration_path %>
                      <div class="ax-field">
                        <%= f.label :label, "Nome interno", class: "ax-label" %>
                        <%= f.text_field :label, class: "ax-control" %>
                      </div>
                      <div class="ax-field">
                        <%= f.label :display_phone_number, "Número WhatsApp", class: "ax-label" %>
                        <%= f.telephone_field :display_phone_number,
                                              class: "ax-control",
                                              data: { controller: "phone-input" } %>
                      </div>
                      <div class="ax-field">
                        <%= f.label :phone_number_id, "Phone Number ID", class: "ax-label" %>
                        <%= f.text_field :phone_number_id, class: "ax-control" %>
                      </div>
                      <div class="ax-field">
                        <%= f.label :waba_id, "WhatsApp Business Account ID (WABA)", class: "ax-label" %>
                        <%= f.text_field :waba_id, class: "ax-control" %>
                      </div>
                      <div class="whatsapp-sender-modal__actions">
                        <button type="button" class="ax-btn ax-btn--ghost" data-action="ax-modal#close">Cancelar</button>
                        <button type="submit" class="ax-btn ax-btn--primary">
                          <i class="bi bi-check2 ax-ico"></i><span>Salvar alterações</span>
                        </button>
                      </div>
                    <% end %>
                  <% end %>
                <% end %>

                <% if @whatsapp_sender_numbers.empty? %>
                  <div class="wa-number-row wa-number-row--empty">
                    <div class="wa-number-row__main">
                      <strong>Nenhum número cadastrado</strong>
                      <span>Adicione os números que poderão ser escolhidos nas campanhas de disparo.</span>
                    </div>
                  </div>
                <% end %>
              </div>
            </section>

            <%= ax_quick_modal(id: "whatsappAccountNumberModal", title: "Adicionar número WhatsApp", size: :sm, class_name: "whatsapp-sender-modal") do %>
              <%= form_with model: [:admin, @new_whatsapp_sender_number],
                            url: admin_whatsapp_sender_numbers_path,
                            local: true,
                            class: "whatsapp-sender-modal__form" do |f| %>
                <%= hidden_field_tag :return_to, admin_whatsapp_integration_path %>
                <div class="ax-field">
                  <%= f.label :label, "Nome interno", class: "ax-label" %>
                  <%= f.text_field :label, class: "ax-control", placeholder: "Ex: Campanhas venda" %>
                </div>
                <div class="ax-field">
                  <%= f.label :display_phone_number, "Número WhatsApp", class: "ax-label" %>
                  <%= f.telephone_field :display_phone_number,
                                        class: "ax-control",
                                        placeholder: "554721228669",
                                        data: { controller: "phone-input" } %>
                </div>
                <div class="ax-field">
                  <%= f.label :phone_number_id, "Phone Number ID", class: "ax-label" %>
                  <%= f.text_field :phone_number_id, class: "ax-control", placeholder: "434291556438028" %>
                </div>
                <div class="ax-field">
                  <%= f.label :waba_id, "WhatsApp Business Account ID (WABA)", class: "ax-label" %>
                  <%= f.text_field :waba_id, class: "ax-control", placeholder: "428655400336219" %>
                </div>
                <p class="wa-hint">O número ficará disponível na seleção da campanha automaticamente.</p>
                <div class="whatsapp-sender-modal__actions">
                  <button type="button" class="ax-btn ax-btn--ghost" data-action="ax-modal#close">Cancelar</button>
                  <button type="submit" class="ax-btn ax-btn--primary">
                    <i class="bi bi-check2 ax-ico"></i><span>Salvar número</span>
                  </button>
                </div>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>

      <aside class="wa-aside">
        <%= ax_operational_panel(eyebrow: "Status", title: "Diagnóstico") do %>
          <div class="wa-panel-body">
            <dl class="wa-state">
              <% @diagnostics.each do |item| %>
                <div class="wa-state__row">
                  <dt>
                    <strong><%= item[:label] %></strong>
                    <% if item[:fallback].present? && !item[:ok] %>
                      <span>Usando padrão: <code><%= item[:fallback] %></code></span>
                    <% elsif item[:detail].present? %>
                      <span><%= item[:detail] %></span>
                    <% end %>
                  </dt>
                  <dd>
                    <% if item[:ok] || item[:fallback].present? %>
                      <i class="bi bi-check-circle-fill" style="color:#0e9f6e"></i>
                    <% else %>
                      <i class="bi bi-exclamation-triangle-fill" style="color:#d9890a"></i>
                    <% end %>
                  </dd>
                </div>
              <% end %>
            </dl>
          </div>
        <% end %>

        <%= ax_operational_panel(eyebrow: "Segurança", title: "Token e segredo") do %>
          <div class="wa-panel-body">
            <p class="wa-hint">O token retornado pela Meta é salvo no backend e não é exibido completo na interface.</p>
          </div>
        <% end %>
      </aside>
    </div>

  <% end %>
</div>

<style id="wa-integration-styles">
  .wa-workspace { display: grid; gap: 8px; padding-top: 8px; }
  .wa-command { margin-bottom: 0; }

  .wa-tabs { display: inline-flex; gap: 3px; padding: 3px; border: 1px solid #d8dee8; border-radius: 8px; background: #eef2f7; }
  .wa-tabs__item {
    display: inline-flex; align-items: center; gap: 6px; min-height: 28px; padding: 0 12px;
    border: 1px solid transparent; border-radius: 6px; color: #64748b;
    font-size: 12px; font-weight: 800; text-decoration: none;
  }
  .wa-tabs__item:hover { background: #fff; color: #1f2937; }
  .wa-tabs__item.is-active { background: #fff; color: var(--admin-primary, #365f8f); border-color: color-mix(in srgb, var(--admin-primary) 28%, #d8dee8); box-shadow: 0 1px 2px rgba(15,23,42,.06); }

  .wa-grid { display: grid; grid-template-columns: minmax(0, 1fr); gap: 8px; align-items: start; }
  @media (min-width: 1080px) { .wa-grid { grid-template-columns: minmax(0, 1fr) 340px; } }
  .wa-main { display: grid; gap: 8px; min-width: 0; }
  .wa-aside { display: grid; gap: 8px; min-width: 0; }
  @media (min-width: 1080px) { .wa-aside { position: sticky; top: calc(var(--ax-navbar-h, 48px) + var(--ax-contextbar-h, 40px) + 8px); } }

  .wa-panel-body { padding: 12px; display: grid; gap: 14px; }
  .wa-hint { margin: 0; color: #8a93a3; font-size: 11.5px; line-height: 1.45; }
  .wa-form { gap: 14px; }
  .wa-field { display: grid; gap: 5px; min-width: 0; }

  .wa-connected { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px; padding: 12px; border: 1px solid var(--ax-border-soft, #e7ebf2); border-radius: 8px; background: #f8fafc; }
  .wa-connected__cell { display: grid; gap: 2px; min-width: 0; }
  .wa-connected__cell span { color: #697586; font-size: 10.5px; text-transform: uppercase; letter-spacing: .04em; font-weight: 700; }
  .wa-connected__cell strong { color: #1f2733; font-size: 13px; overflow-wrap: anywhere; }

  .wa-webhook { border: 1px solid var(--ax-border-soft, #e7ebf2); border-radius: 8px; padding: 12px; display: grid; gap: 10px; }
  .wa-webhook__head { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
  .wa-webhook__head h3 { margin: 2px 0 0; font-size: 13px; font-weight: 800; color: #1f2733; }
  .wa-webhook__grid { display: grid; grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr); gap: 12px; }
  @media (max-width: 720px) { .wa-webhook__grid { grid-template-columns: minmax(0, 1fr); } }
  .wa-webhook__actions { display: flex; justify-content: flex-end; }

  .wa-negotiations { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 10px; }
  .wa-negotiation { border: 1px solid var(--ax-border-soft, #e7ebf2); border-radius: 8px; padding: 12px; display: grid; gap: 10px; }
  .wa-negotiation__head { display: flex; align-items: flex-start; gap: 8px; }
  .wa-negotiation__icon { display: inline-flex; align-items: center; justify-content: center; width: 30px; height: 30px; flex: 0 0 auto; border-radius: 999px; background: #e6f6ec; color: #0e9f6e; }
  .wa-negotiation__head strong { display: block; color: #1f2733; font-size: 12.5px; }
  .wa-negotiation__head span { color: #8a93a3; font-size: 11px; line-height: 1.35; }

  .wa-connect { display: flex; flex-wrap: wrap; align-items: center; gap: 10px; }

  .wa-phone-info { display: flex; flex-wrap: wrap; gap: 10px 22px; align-items: center; padding: 10px 12px; border: 1px solid var(--ax-border-soft, #e7ebf2); border-radius: 8px; background: #f8fafc; }
  .wa-phone-info__cell { display: grid; gap: 2px; min-width: 0; }
  .wa-phone-info__cell span { color: #697586; font-size: 10.5px; text-transform: uppercase; letter-spacing: .04em; font-weight: 700; }
  .wa-phone-info__cell strong { color: #1f2733; font-size: 13.5px; }

  .wa-context-block { display: grid; gap: 12px; padding: 14px; border: 1px solid var(--ax-border-soft, #e7ebf2); border-radius: 8px; background: #fff; }
  .wa-context-block--primary { background: #f8fafc; }
  .wa-context-block__head { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; padding-bottom: 10px; border-bottom: 1px solid var(--ax-border-soft, #e7ebf2); }
  .wa-context-block__head > div { display: grid; gap: 3px; min-width: 0; }
  .wa-context-block__head span { color: #7b8494; font-size: 10.5px; font-weight: 900; letter-spacing: .04em; text-transform: uppercase; }
  .wa-context-block__head strong { color: #1f2733; font-size: 15px; line-height: 1.2; }
  .wa-context-block__head p { margin: 0; color: #8a93a3; font-size: 11.5px; line-height: 1.4; }
  .wa-context-actions { display: inline-flex; flex-wrap: wrap; justify-content: flex-end; gap: 6px; }

  .wa-number-section { display: grid; gap: 12px; margin-top: 14px; padding-top: 14px; border-top: 1px dashed var(--ax-border-soft, #e7ebf2); }
  .wa-number-section__head { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
  .wa-number-section__head > div { display: grid; gap: 2px; min-width: 0; }
  .wa-number-section__head span { color: #7b8494; font-size: 10.5px; font-weight: 900; letter-spacing: .04em; text-transform: uppercase; }
  .wa-number-section__head strong { color: #1f2733; font-size: 15px; line-height: 1.2; }
  .wa-number-list { display: grid; gap: 8px; }
  .wa-number-row { display: grid; grid-template-columns: minmax(0, 1fr) auto auto; align-items: center; gap: 10px; padding: 10px 12px; border: 1px solid var(--ax-border-soft, #e7ebf2); border-radius: 8px; background: #fff; }
  .wa-number-row--empty { grid-template-columns: minmax(0, 1fr); background: #f8fafc; }
  .wa-number-row__main { display: grid; gap: 2px; min-width: 0; }
  .wa-number-row__main strong { color: #1f2733; font-size: 13.5px; overflow-wrap: anywhere; }
  .wa-number-row__main span { color: #4b5565; font-size: 12px; font-weight: 700; }
  .wa-number-row__main small { color: #8a93a3; font-size: 11px; overflow-wrap: anywhere; }
  .wa-number-row__badges,
  .wa-number-row__actions { display: inline-flex; flex-wrap: wrap; align-items: center; justify-content: flex-end; gap: 6px; }
  .wa-number-row__test { grid-column: 1 / -1; display: none; align-items: center; gap: 7px; min-height: 34px; padding: 7px 9px; border: 1px solid #d8e1ec; border-left-width: 3px; border-radius: 7px; background: #f8fafc; color: #475467; font-size: 12px; font-weight: 650; line-height: 1.35; }
  .wa-number-row__test:not([hidden]) { display: flex; }
  .wa-number-checkbox { display: inline-flex; align-items: center; gap: 8px; font-size: 12px; font-weight: 800; color: #344054; }
  .wa-number-checkbox input { width: 16px; height: 16px; }
  .wa-variable-map { display: grid; gap: 8px; }
  .wa-variable-map__row { display: grid; grid-template-columns: 120px minmax(0, 1fr); align-items: center; gap: 8px; }
  .wa-variable-map__row > span { color: #344054; font-size: 12px; font-weight: 800; }
  .wa-variable-map__row small { display: block; margin-top: 2px; color: #8a93a3; font-size: 10.5px; font-weight: 650; line-height: 1.25; }
  @media (max-width: 540px) {
    .wa-variable-map__row { grid-template-columns: minmax(0, 1fr); align-items: start; }
  }
  @media (max-width: 820px) {
    .wa-context-block__head { align-items: flex-start; flex-direction: column; }
    .wa-context-actions { justify-content: flex-start; }
    .wa-number-section__head { align-items: flex-start; flex-direction: column; }
    .wa-number-row { grid-template-columns: minmax(0, 1fr); align-items: start; }
    .wa-number-row__badges,
    .wa-number-row__actions { justify-content: flex-start; }
  }

  .wa-test { display: grid; gap: 8px; padding-top: 4px; border-top: 1px dashed var(--ax-border-soft, #e7ebf2); }
  .wa-test__bar { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; }
  .wa-test__send { display: flex; align-items: center; gap: 6px; margin-left: auto; }
  .wa-test__send .ax-control { max-width: 220px; }

  .wa-state { margin: 0; display: grid; gap: 10px; }
  .wa-state__row { display: flex; align-items: flex-start; justify-content: space-between; gap: 10px; }
  .wa-state__row dt { margin: 0; min-width: 0; }
  .wa-state__row dt strong { display: block; color: #1f2733; font-size: 12.5px; font-weight: 700; }
  .wa-state__row dt span { color: #8a93a3; font-size: 11px; }
  .wa-state__row dd { margin: 0; flex: 0 0 auto; font-size: 12.5px; color: #1f2733; }
</style>
