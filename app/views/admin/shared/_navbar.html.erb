<%# LEGADO não-renderizado — candidato a remoção. %>
<%
  legacy_navbar_site_name = @layout_setting&.site_name.presence || "Salute Imóveis"
  legacy_navbar_area_name = @layout_setting.respond_to?(:admin_area_label) ? @layout_setting.admin_area_label : "Plataforma"
%>
<nav class="admin-navbar">
  <div class="navbar-brand">
    <h4 class="tw-flex tw-items-center tw-gap-2"><i class="bi bi-building"></i> <%= legacy_navbar_site_name %> <%= legacy_navbar_area_name %></h4>
  </div>

  <div class="navbar-actions">
    <span class="user-name"><i class="bi bi-person-circle"></i> <%= current_admin_user.name %></span>
    <%= link_to destroy_admin_user_session_path, data: { turbo_method: :delete }, class: "ax-btn ax-btn--sm ax-btn--ghost" do %>
      <i class="bi bi-box-arrow-right"></i> Sair
    <% end %>
  </div>
</nav>
