<% group_classes = ["ax-field-group", class_name].compact_blank.join(" ") %>

<div class="<%= group_classes %>">
  <div class="ax-field-group__header">
    <h6 class="ax-field-group__title">
      <span><%= title %></span>
      <% if local_assigns[:tooltip].present? %>
        <button type="button"
                class="ax-field-label__info"
                aria-label="Ajuda: <%= title %>"
                data-controller="ax-tooltip"
                data-ax-tooltip-text-value="<%= tooltip %>">
          <i class="bi bi-info-circle" aria-hidden="true"></i>
        </button>
      <% end %>
    </h6>
    <% if token.present? %>
      <span class="ax-field-group__token"><%= token %></span>
    <% end %>
    <% if actions.present? %>
      <div class="ax-field-group__actions"><%= actions %></div>
    <% end %>
  </div>
  <div class="ax-field-group__body">
    <%= body %>
  </div>
</div>
