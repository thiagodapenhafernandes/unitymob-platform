<%
  label_options = {
    class: class_name,
    data: label_data
  }
%>

<% if form.present? && method.present? %>
  <%= form.label method, label, label_options.merge(for: input_id) %>
  <%= form.file_field method,
                      multiple:,
                      direct_upload:,
                      accept:,
                      capture:,
                      class: ["ax-file-upload__input", input_class].compact_blank.join(" "),
                      id: input_id,
                      data: input_data,
                      **input_options %>
<% else %>
  <%= label_tag input_id, label, label_options %>
<% end %>
