<%
  field_classes = ["ax-field", "ax-color-field", field_class].compact_blank.join(" ")
  color_options = (local_assigns[:color_options] || {}).dup
  text_options = (local_assigns[:text_options] || {}).dup
  color_data = (color_options.delete(:data) || {}).dup
  text_data = (text_options.delete(:data) || {}).dup
  token_data = {}

  if local_assigns[:token].present?
    token_data[:action] = "input->layout-theme-preview#update"
    token_data[:theme_token] = token
    token_data[:default_value] = default_value if local_assigns[:default_value].present?
  end

  color_options[:id] ||= "#{form.field_id(method)}_picker"
  color_data[:ax_color_pair_target] = "swatch"
  text_data[:ax_color_pair_target] = "text"
  color_data[:action] = ["input->ax-color-pair#sync", color_data[:action]].compact_blank.join(" ")
  text_data[:action] = ["input->ax-color-pair#sync", text_data[:action]].compact_blank.join(" ")

  color_data = token_data.merge(color_data)
  text_data = token_data.merge(text_data)
  color_class = ["ax-color-control__swatch", color_options.delete(:class)].compact_blank.join(" ")
  text_class = ["ax-color-control__text", text_options.delete(:class)].compact_blank.join(" ")
%>

<div class="<%= field_classes %>">
  <%= ax_field_label(form, method, text: label, tooltip:, class_name:) %>
  <div class="ax-color-control" data-controller="ax-color-pair">
    <%= form.color_field method,
          color_options.merge(
            value: value,
            class: color_class,
            title: swatch_title.presence || "Escolha a cor de #{label}",
            aria: { label: swatch_title.presence || "Escolha a cor de #{label}" },
            data: color_data
          ) %>
    <%= form.text_field method,
          text_options.merge(
            value: value,
            class: text_class,
            spellcheck: false,
            data: text_data
          ) %>
  </div>
  <%= render "admin/shared/ui/field_error", form: form, method: method %>
  <% if local_assigns[:hint].present? && form.object.errors[method].blank? %>
    <p class="ax-field__hint"><%= hint %></p>
  <% end %>
</div>
