<%
  grid_classes = [
    "ax-field-grid",
    "ax-field-grid--#{columns}",
    ("ax-field-grid--#{gap}" if gap.present?),
    class_name
  ].compact_blank.join(" ")
  column_count = columns.to_i.positive? ? columns.to_i : 12
  grid_styles = [
    "grid-template-columns: repeat(#{column_count}, minmax(0, 1fr));",
    ("gap: 8px;" if gap.to_s == "compact")
  ].compact.join(" ")
%>

<style>
  .ax-field-grid > .ax-span-1 { grid-column: span 1 / span 1; }
  .ax-field-grid > .ax-span-2 { grid-column: span 2 / span 2; }
  .ax-field-grid > .ax-span-3 { grid-column: span 3 / span 3; }
  .ax-field-grid > .ax-span-4 { grid-column: span 4 / span 4; }
  .ax-field-grid > .ax-span-5 { grid-column: span 5 / span 5; }
  .ax-field-grid > .ax-span-6 { grid-column: span 6 / span 6; }
  .ax-field-grid > .ax-span-7 { grid-column: span 7 / span 7; }
  .ax-field-grid > .ax-span-8 { grid-column: span 8 / span 8; }
  .ax-field-grid > .ax-span-9 { grid-column: span 9 / span 9; }
  .ax-field-grid > .ax-span-10 { grid-column: span 10 / span 10; }
  .ax-field-grid > .ax-span-11 { grid-column: span 11 / span 11; }
  .ax-field-grid > .ax-span-12 { grid-column: 1 / -1; }
  .ax-field-align-end { display: flex; align-items: end; min-width: 0; }
  @media (max-width: 980px) {
    .ax-field-grid > [class*="ax-span-"] { grid-column: span 6 / span 6; }
    .ax-field-grid > .ax-span-7,
    .ax-field-grid > .ax-span-8,
    .ax-field-grid > .ax-span-9,
    .ax-field-grid > .ax-span-10,
    .ax-field-grid > .ax-span-11,
    .ax-field-grid > .ax-span-12 { grid-column: 1 / -1; }
  }
  @media (max-width: 620px) {
    .ax-field-grid { grid-template-columns: 1fr !important; }
    .ax-field-grid > [class*="ax-span-"] { grid-column: 1 / -1; }
  }
</style>

<%= tag.div(class: grid_classes, data:, style: grid_styles) do %>
  <%= body %>
<% end %>
