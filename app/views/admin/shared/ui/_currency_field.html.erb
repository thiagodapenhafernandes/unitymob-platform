<%
  field_classes = ["ax-field", "ax-currency-field", class_name].compact.join(" ")
  input_options = (options || {}).dup
  input_options[:class] = ["ax-control", input_class, input_options[:class]].compact.join(" ")
%>

<div class="<%= field_classes %>">
  <%= ax_field_label(form, method, text: label, tooltip:) %>
  <%= ax_input_group(prefix: "R$") do %>
    <%= form.text_field method, input_options %>
  <% end %>
  <%= render "admin/shared/ui/field_error", form: form, method: method %>
</div>
