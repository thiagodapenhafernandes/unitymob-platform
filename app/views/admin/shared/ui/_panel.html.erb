<%
  collapsible = local_assigns.fetch(:collapsible, false)
  collapsed = collapsible && local_assigns.fetch(:collapsed, false)
  collapse_id = local_assigns[:collapse_id].presence
%>
<section class="ax-panel <%= 'ax-panel--collapsible' if collapsible %> <%= 'is-open' if collapsible && !collapsed %> <%= local_assigns[:class_name] %>"
         <% if collapsible %>data-controller="ax-disclosure" data-ax-disclosure-open-value="<%= !collapsed %>"<% end %>>
  <% if local_assigns[:title].present? || local_assigns[:actions].present? %>
    <header class="ax-panel__header">
      <% if collapsible %>
        <button type="button"
                class="ax-panel__trigger"
                data-action="ax-disclosure#toggle"
                data-ax-disclosure-target="trigger"
                aria-expanded="<%= !collapsed %>"
                <% if collapse_id %>aria-controls="<%= collapse_id %>"<% end %>>
      <% end %>
      <div class="ax-panel__heading">
        <% if local_assigns[:title].present? %>
          <h2 class="ax-panel__title"><%= title %></h2>
        <% end %>
        <% if local_assigns[:subtitle].present? %>
          <p class="ax-panel__subtitle"><%= subtitle %></p>
        <% end %>
      </div>
      <% if collapsible %>
        <i class="bi bi-chevron-down ax-panel__chevron" aria-hidden="true"></i>
        </button>
      <% end %>
      <% if local_assigns[:actions].present? %>
        <div class="ax-panel__actions"><%= actions %></div>
      <% end %>
    </header>
  <% end %>
  <div class="ax-panel__body"
       <% if collapse_id %>id="<%= collapse_id %>"<% end %>
       <% if collapsible %>data-ax-disclosure-target="content"<% end %>
       <%= "hidden" if collapsed %>>
    <%= local_assigns[:body] %>
  </div>
</section>
