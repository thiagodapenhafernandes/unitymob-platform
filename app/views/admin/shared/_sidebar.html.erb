<%
    system_admin_without_tenant = current_admin_user&.system_admin? && !selected_tenant_context?
    vista_soft_context = controller_name == 'habitations' && params[:sort] == 'last_sync_at'
    can_access = lambda do |action, resource|
      if respond_to?(:can?)
        can?(action, resource)
      else
        user = respond_to?(:current_admin_user) ? current_admin_user : nil
        user&.can?(action, resource)
      end
    rescue Devise::MissingWarden
      false
    end
    nav_section_style = lambda do |key|
      "--nav-section-background:var(--admin-nav-#{key}-background);--nav-section-background-opacity:var(--admin-nav-#{key}-background-opacity);--nav-section-text:var(--admin-nav-#{key}-text);--nav-section-border:var(--admin-nav-#{key}-border);"
    end
  %>
<ul class="ax-nav <%= 'ax-nav--sectioned' unless system_admin_without_tenant %>" data-controller="menu-sections">
  <% if system_admin_without_tenant %>
    <li class="ax-nav__section">Sistema</li>
    <li class="ax-nav__item">
      <%= link_to admin_system_path, class: "ax-nav__link #{'active' if controller_name == 'system'}" do %>
        <i class="bi bi-hdd-stack"></i><span>Painel do Sistema</span>
      <% end %>
    </li>
    <li class="ax-nav__item">
      <%= link_to admin_system_users_path, class: "ax-nav__link #{'active' if controller_name == 'system' && action_name == 'users'}" do %>
        <i class="bi bi-people"></i><span>Usuários</span>
      <% end %>
    </li>
    <li class="ax-nav__item">
      <%= link_to admin_system_error_events_path, class: "ax-nav__link #{'active' if controller_name == 'error_events'}" do %>
        <i class="bi bi-bug"></i><span>Erros da Aplicação</span>
      <% end %>
    </li>
    <li class="ax-nav__item">
      <%= link_to edit_admin_system_notification_settings_path, class: "ax-nav__link #{'active' if controller_name == 'notification_settings'}" do %>
        <i class="bi bi-broadcast-pin"></i><span>Notificações Globais</span>
      <% end %>
    </li>
    <li class="ax-nav__caption">Contas</li>
    <li class="ax-nav__hint">Acesse áreas operacionais apenas por impersonação.</li>
  <% else %>
    <%

    # Visibilidade de cada seção = OR dos itens dela. O header só aparece se a
    # seção tiver ao menos um item visível (evita rótulos de seção vazios).
    produto_visible = can_access.call(:view, :dashboard) || can_access.call(:view, :imoveis) ||
                      can_access.call(:view, :leads)
    operacao_visible = can_access.call(:view, :comercial) || can_access.call(:view, :whatsapp_inbox) ||
                       can_access.call(:view, :whatsapp_campaigns) ||
                       can_access.call(:manage, :automacoes) || can_access.call(:view, :distribution_rules) ||
                       can_access.call(:manage, :distribution_rules) || can_access.call(:view, :captacoes) ||
                       can_access.call(:view, :captacao_dashboard) || can_access.call(:view, :field_checkins) ||
                       can_access.call(:view, :field_manual)
    gestao_visible = can_access.call(:view, :proprietarios) || can_access.call(:view, :lojas) ||
                     can_access.call(:manage, :lojas) || can_access.call(:view, :corretores) ||
                     can_access.call(:view, :metas_captacao)
    crescimento_visible = can_access.call(:manage, :marketing)
  %>
    <% if produto_visible %>
      <li class="ax-nav__section" data-nav-section="product" style="<%= nav_section_style.call('product') %>">
        <button type="button" class="ax-nav__section-trigger" data-menu-sections-target="trigger" data-action="menu-sections#toggle" aria-expanded="true" aria-controls="nav-section-product" title="Produto">
          <i class="bi bi-grid-1x2"></i><span>Produto</span><i class="bi bi-chevron-down"></i>
        </button>
        <ul class="ax-nav__section-items" id="nav-section-product" data-menu-sections-target="items">

    <%# 1. Painel %>
    <% if can_access.call(:view, :dashboard) %>
      <li>
        <%= link_to admin_root_path, class: "ax-nav__link #{'active' if request.path == admin_root_path}" do %>
          <i class="bi bi-speedometer2"></i><span>Painel</span>
        <% end %>
      </li>
    <% end %>

    <%# 2. Imóveis %>
    <% if can_access.call(:view, :imoveis) %>
      <li>
        <%= link_to admin_habitations_path(ownership: "all"), class: "ax-nav__link #{'active' if controller_name == 'habitations'}" do %>
          <i class="bi bi-houses"></i><span>Imóveis</span>
        <% end %>
      </li>
    <% end %>

    <%# 4. Leads %>
    <% if can_access.call(:view, :leads) %>
      <li>
        <%= link_to admin_leads_path, class: "ax-nav__link #{'active' if controller_name == 'leads'}" do %>
          <i class="bi bi-person-badge"></i><span>Leads</span>
        <% end %>
      </li>
    <% end %>
        </ul>
      </li>
    <% end %>

    <% if operacao_visible %>
      <li class="ax-nav__section" data-nav-section="operation" style="<%= nav_section_style.call('operation') %>">
        <button type="button" class="ax-nav__section-trigger" data-menu-sections-target="trigger" data-action="menu-sections#toggle" aria-expanded="false" aria-controls="nav-section-operation" title="Operação">
          <i class="bi bi-briefcase"></i><span>Operação</span><i class="bi bi-chevron-down"></i>
        </button>
        <ul class="ax-nav__section-items" id="nav-section-operation" data-menu-sections-target="items">

    <%# 4a. Comercial: Tarefas + Agenda %>
    <% if can_access.call(:view, :comercial) %>
      <% comercial_open = %w[tasks appointments proposals].include?(controller_name) %>
      <li class="ax-nav__group <%= 'is-open' if comercial_open %>" data-controller="ax-disclosure" data-ax-disclosure-open-value="<%= comercial_open %>">
        <button type="button" class="ax-nav__link ax-nav__link--group" data-action="ax-disclosure#toggle" data-ax-disclosure-target="trigger" aria-expanded="<%= comercial_open %>">
          <i class="bi bi-briefcase"></i><span>Comercial</span>
          <i class="bi bi-chevron-down ax-nav__chevron"></i>
        </button>
        <ul class="ax-nav__sub" data-ax-disclosure-target="content" <%= 'hidden' unless comercial_open %>>
          <li><%= link_to admin_tasks_path, class: "ax-nav__link #{'active' if controller_name == 'tasks'}" do %><i class="bi bi-check2-square"></i><span>Minhas Tarefas</span><% end %></li>
          <li><%= link_to admin_appointments_path, class: "ax-nav__link #{'active' if controller_name == 'appointments'}" do %><i class="bi bi-calendar-event"></i><span>Agenda</span><% end %></li>
        </ul>
      </li>
    <% end %>

    <%# 4a2. Atendimento WhatsApp (inbox) %>
    <% if can_access.call(:view, :whatsapp_inbox) || can_access.call(:view, :whatsapp_campaigns) %>
      <% whatsapp_open = %w[whatsapp_inbox whatsapp_campaigns whatsapp_templates].include?(controller_name) %>
      <li class="ax-nav__group <%= 'is-open' if whatsapp_open %>" data-controller="ax-disclosure" data-ax-disclosure-open-value="<%= whatsapp_open %>">
        <button type="button" class="ax-nav__link ax-nav__link--group" data-action="ax-disclosure#toggle" data-ax-disclosure-target="trigger" aria-expanded="<%= whatsapp_open %>">
          <i class="bi bi-whatsapp"></i><span>WhatsApp</span>
          <i class="bi bi-chevron-down ax-nav__chevron"></i>
        </button>
        <ul class="ax-nav__sub" data-ax-disclosure-target="content" <%= 'hidden' unless whatsapp_open %>>
          <% if can_access.call(:view, :whatsapp_inbox) %>
            <li>
              <%= link_to admin_whatsapp_conversations_path, class: "ax-nav__link #{'active' if controller_name == 'whatsapp_inbox'}" do %>
                <i class="bi bi-chat-dots"></i><span>Atendimento</span>
              <% end %>
            </li>
          <% end %>
          <% if can_access.call(:view, :whatsapp_campaigns) %>
            <li>
              <%= link_to admin_whatsapp_templates_path, class: "ax-nav__link #{'active' if controller_name == 'whatsapp_templates'}" do %>
                <i class="bi bi-grid-3x2-gap"></i><span>Templates</span>
              <% end %>
            </li>
            <li>
              <%= link_to admin_whatsapp_campaigns_path, class: "ax-nav__link #{'active' if controller_name == 'whatsapp_campaigns'}" do %>
                <i class="bi bi-broadcast"></i><span>Disparos</span>
              <% end %>
            </li>
          <% end %>
        </ul>
      </li>
    <% end %>

    <%# 4c. Automação %>
    <% if can_access.call(:manage, :automacoes) %>
      <li>
        <%= link_to admin_automation_rules_path, class: "ax-nav__link #{'active' if %w[automation_rules automation_workflows automation_events].include?(controller_name)}" do %>
          <i class="bi bi-lightning-charge"></i><span>Automação</span>
        <% end %>
      </li>
    <% end %>

    <%# 4b. Distribuição de Leads %>
    <% if can_access.call(:view, :distribution_rules) || can_access.call(:manage, :distribution_rules) %>
      <li>
        <%= link_to admin_distribution_rules_path, class: "ax-nav__link #{'active' if controller_name == 'distribution_rules'}" do %>
          <i class="bi bi-diagram-3"></i><span>Distribuição de Leads</span>
        <% end %>
      </li>
    <% end %>

    <%# Captações %>
    <% if can_access.call(:view, :captacoes) %>
      <li>
        <%= link_to admin_captacoes_path, class: "ax-nav__link #{'active' if controller_name == 'captacoes' && action_name != 'dashboard'}" do %>
          <i class="bi bi-journal-plus"></i><span>Captações</span>
        <% end %>
      </li>
    <% end %>

    <% if can_access.call(:view, :captacao_dashboard) %>
      <li>
        <%= link_to dashboard_admin_captacoes_path, class: "ax-nav__link #{'active' if controller_name == 'captacoes' && action_name == 'dashboard'}" do %>
          <i class="bi bi-bullseye"></i><span>Dashboard Captação</span>
        <% end %>
      </li>
    <% end %>

    <%# Campo: check-ins, pedidos manuais %>
    <% if can_access.call(:view, :field_checkins) %>
      <li>
        <%= link_to admin_field_check_ins_path, class: "ax-nav__link #{'active' if controller_path == 'admin/field/check_ins'}" do %>
          <i class="bi bi-geo-fill"></i><span>Check-ins em Campo</span>
        <% end %>
      </li>
    <% end %>

    <% if can_access.call(:view, :field_manual) %>
      <li>
        <%= link_to admin_field_manual_checkin_requests_path, class: "ax-nav__link #{'active' if controller_path == 'admin/field/manual_checkin_requests'}" do %>
          <i class="bi bi-hand-index-thumb-fill"></i><span>Pedidos manuais</span>
        <% end %>
      </li>
    <% end %>
        </ul>
      </li>
    <% end %>

    <% if gestao_visible %>
      <li class="ax-nav__section" data-nav-section="management" style="<%= nav_section_style.call('management') %>">
        <button type="button" class="ax-nav__section-trigger" data-menu-sections-target="trigger" data-action="menu-sections#toggle" aria-expanded="false" aria-controls="nav-section-management" title="Gestão">
          <i class="bi bi-people"></i><span>Gestão</span><i class="bi bi-chevron-down"></i>
        </button>
        <ul class="ax-nav__section-items" id="nav-section-management" data-menu-sections-target="items">

    <%# Proprietários %>
    <% if can_access.call(:view, :proprietarios) %>
      <li>
        <%= link_to admin_proprietors_path, class: "ax-nav__link #{'active' if controller_name == 'proprietors'}" do %>
          <i class="bi bi-person-vcard"></i><span>Proprietários</span>
        <% end %>
      </li>
    <% end %>

    <%# Lojas %>
    <% if can_access.call(:view, :lojas) || can_access.call(:manage, :lojas) %>
      <li>
        <%= link_to admin_stores_path, class: "ax-nav__link #{'active' if controller_name == 'stores'}" do %>
          <i class="bi bi-shop"></i><span>Lojas</span>
        <% end %>
      </li>
    <% end %>

    <%# Usuários %>
    <% if can_access.call(:view, :corretores) %>
      <li>
        <%= link_to admin_admin_users_path, class: "ax-nav__link #{'active' if controller_name == 'admin_users'}" do %>
          <i class="bi bi-people"></i><span>Usuários</span>
        <% end %>
      </li>
    <% end %>

    <%# Metas de captação %>
    <% if can_access.call(:view, :metas_captacao) %>
      <li>
        <%= link_to admin_captacao_goals_path, class: "ax-nav__link #{'active' if controller_name == 'captacao_goals'}" do %>
          <i class="bi bi-bullseye"></i><span>Metas de Captação</span>
        <% end %>
      </li>
    <% end %>
        </ul>
      </li>
    <% end %>

    <% if crescimento_visible %>
      <li class="ax-nav__section" data-nav-section="growth" style="<%= nav_section_style.call('growth') %>">
        <button type="button" class="ax-nav__section-trigger" data-menu-sections-target="trigger" data-action="menu-sections#toggle" aria-expanded="false" aria-controls="nav-section-growth" title="Crescimento">
          <i class="bi bi-graph-up-arrow"></i><span>Crescimento</span><i class="bi bi-chevron-down"></i>
        </button>
        <ul class="ax-nav__section-items" id="nav-section-growth" data-menu-sections-target="items">

    <%# Marketing e crescimento comercial %>
    <% if can_access.call(:manage, :marketing) %>
      <li><%= link_to admin_marketing_opportunities_path, class: "ax-nav__link #{'active' if controller_name == 'marketing_opportunities'}" do %><i class="bi bi-lightbulb"></i><span>Oportunidades</span><% end %></li>
      <li><%= link_to admin_marketing_campaigns_path, class: "ax-nav__link #{'active' if controller_name == 'marketing_campaigns'}" do %><i class="bi bi-bullseye"></i><span>Campanhas</span><% end %></li>
      <li><%= link_to admin_marketing_tools_path, class: "ax-nav__link #{'active' if controller_name == 'marketing_tools'}" do %><i class="bi bi-link-45deg"></i><span>UTM Builder</span><% end %></li>
      <li><%= link_to admin_marketing_properties_path, class: "ax-nav__link #{'active' if controller_name == 'marketing_properties'}" do %><i class="bi bi-house-heart"></i><span>Imóveis com Potencial</span><% end %></li>
      <li><%= link_to admin_marketing_alerts_path, class: "ax-nav__link #{'active' if controller_name == 'marketing_alerts'}" do %><i class="bi bi-exclamation-triangle"></i><span>Alertas</span><% end %></li>
    <% end %>
        </ul>
      </li>
    <% end %>

    <% if can_access.call(:manage, :marketing) %>
      <li class="ax-nav__section" data-nav-section="public-site" style="<%= nav_section_style.call('public-site') %>">
        <button type="button" class="ax-nav__section-trigger" data-menu-sections-target="trigger" data-action="menu-sections#toggle" aria-expanded="false" aria-controls="nav-section-public-site" title="Site público">
          <i class="bi bi-globe2"></i><span>Site público</span><i class="bi bi-chevron-down"></i>
        </button>
        <ul class="ax-nav__section-items" id="nav-section-public-site" data-menu-sections-target="items">
      <li class="ax-nav__caption">SEO</li>
      <li><%= link_to admin_seo_dashboard_path, class: "ax-nav__link #{'active' if controller_name == 'seo_dashboard'}" do %><i class="bi bi-graph-up-arrow"></i><span>Dashboard SEO</span><% end %></li>
      <li><%= link_to admin_seo_settings_path, class: "ax-nav__link #{'active' if controller_name == 'seo_settings'}" do %><i class="bi bi-search"></i><span>Páginas SEO</span><% end %></li>
      <li><%= link_to admin_seo_redirects_path, class: "ax-nav__link #{'active' if controller_name == 'seo_redirects'}" do %><i class="bi bi-signpost-split"></i><span>Redirecionamentos SEO</span><% end %></li>
      <li class="ax-nav__caption">Conteúdo</li>
      <li><%= link_to admin_landing_pages_path, class: "ax-nav__link #{'active' if controller_name == 'landing_pages'}" do %><i class="bi bi-file-earmark-post"></i><span>Landing Pages</span><% end %></li>
      <li><%= link_to admin_banners_path, class: "ax-nav__link #{'active' if controller_name == 'banners'}" do %><i class="bi bi-image"></i><span>Banners</span><% end %></li>
      <li><%= link_to admin_home_sections_path, class: "ax-nav__link #{'active' if controller_name == 'home_sections'}" do %><i class="bi bi-layout-text-sidebar"></i><span>Seções da Home</span><% end %></li>
      <li class="ax-nav__caption">Estrutura</li>
      <li><%= link_to edit_admin_home_setting_path, class: "ax-nav__link #{'active' if controller_name == 'home_settings'}" do %><i class="bi bi-house-door"></i><span>Home</span><% end %></li>
      <li><%= link_to edit_admin_contact_setting_path, class: "ax-nav__link #{'active' if controller_name == 'contact_settings'}" do %><i class="bi bi-telephone"></i><span>Contato</span><% end %></li>
      <li><%= link_to edit_admin_footer_setting_path, class: "ax-nav__link #{'active' if controller_name == 'footer_settings'}" do %><i class="bi bi-layout-sidebar"></i><span>Rodapé</span><% end %></li>
        </ul>
      </li>
    <% end %>

    <%# Integrações técnicas %>
    <% schedule_context = can_access.call(:view, :agenda_fotografia) || can_access.call(:manage, :agenda_fotografia) || can_access.call(:manage, :integracoes) %>
    <% if can_access.call(:manage, :integracoes) || schedule_context %>
      <li class="ax-nav__section" data-nav-section="integrations" style="<%= nav_section_style.call('integrations') %>">
        <button type="button" class="ax-nav__section-trigger" data-menu-sections-target="trigger" data-action="menu-sections#toggle" aria-expanded="false" aria-controls="nav-section-integrations" title="Integrações">
          <i class="bi bi-plug"></i><span>Integrações</span><i class="bi bi-chevron-down"></i>
        </button>
        <ul class="ax-nav__section-items" id="nav-section-integrations" data-menu-sections-target="items">
      <% if can_access.call(:manage, :integracoes) %>
        <li><%= link_to admin_portal_integrations_path, class: "ax-nav__link #{'active' if controller_name == 'portal_integrations'}" do %><i class="bi bi-building"></i><span>Portais</span><% end %></li>
        <li><%= link_to admin_loft_integrations_path, class: "ax-nav__link #{'active' if controller_name == 'loft_integrations'}" do %><i class="bi bi-hdd-rack"></i><span>Loft Soft</span><% end %></li>
        <li><%= link_to admin_dwv_integrations_path, class: "ax-nav__link #{'active' if controller_name == 'dwv_integrations'}" do %><i class="bi bi-hdd-network"></i><span>DWV</span><% end %></li>
        <li><%= link_to admin_whatsapp_integration_path, class: "ax-nav__link #{'active' if controller_name == 'whatsapp_integrations'}" do %><i class="bi bi-whatsapp"></i><span>WhatsApp</span><% end %></li>
        <li><%= link_to admin_meta_integrations_path, class: "ax-nav__link #{'active' if controller_name == 'meta_integrations'}" do %><i class="bi bi-meta"></i><span>Meta Leads</span><% end %></li>
        <li><%= link_to admin_google_integration_path, class: "ax-nav__link #{'active' if controller_name == 'google_integrations'}" do %><i class="bi bi-google"></i><span>Google</span><% end %></li>
        <li><%= link_to admin_tracking_integration_path, class: "ax-nav__link #{'active' if controller_name == 'tracking_integrations'}" do %><i class="bi bi-bullseye"></i><span>Trackeamento</span><% end %></li>
        <li><%= link_to admin_storage_integration_path, class: "ax-nav__link #{'active' if controller_name == 'storage_integrations'}" do %><i class="bi bi-cloud-arrow-up"></i><span>Armazenamento</span><% end %></li>
      <% end %>
      <% if schedule_context %>
        <li><%= link_to admin_scheduling_integration_path, class: "ax-nav__link #{'active' if controller_name == 'scheduling_integrations'}" do %><i class="bi bi-calendar2-check"></i><span>Agendamento</span><% end %></li>
      <% end %>
      <% if can_access.call(:manage, :integracoes) %>
        <li><%= link_to admin_webhook_settings_path, class: "ax-nav__link #{'active' if controller_name == 'webhook_settings'}" do %><i class="bi bi-broadcast"></i><span>Webhooks</span><% end %></li>
        <li><%= link_to admin_ai_integration_path, class: "ax-nav__link #{'active' if controller_name == 'ai_integrations'}" do %><i class="bi bi-stars"></i><span>IA</span><% end %></li>
        <li><%= link_to admin_habitations_path(sort: "last_sync_at", direction: "desc"), class: "ax-nav__link #{'active' if vista_soft_context}" do %><i class="bi bi-arrow-repeat"></i><span>Imóveis sincronizados</span><% end %></li>
        <li><%= link_to admin_image_migration_status_path, class: "ax-nav__link #{'active' if controller_name == 'image_migration_status'}" do %><i class="bi bi-images"></i><span>Migração de Imagens</span><% end %></li>
      <% end %>
        </ul>
      </li>
    <% end %>

    <%# Webhook de entrada pessoal — item próprio para quem tem a permissão mas
        NÃO tem manage :integracoes (o grupo Integrações não aparece pra ele). %>
    <% if can_access.call(:manage, :inbound_webhooks) && !can_access.call(:manage, :integracoes) %>
      <li class="ax-nav__item">
        <%= link_to admin_webhook_settings_path(tab: "inbound"), class: "ax-nav__link #{'active' if controller_name == 'webhook_settings'}" do %>
          <i class="bi bi-box-arrow-in-down"></i><span>Webhook de entrada</span>
        <% end %>
      </li>
    <% end %>

    <%# Configurações internas %>
    <%
      # "Atendimento WhatsApp" só aparece com o número da empresa conectado.
      sidebar_tenant = respond_to?(:current_tenant) ? current_tenant : Current.tenant
      whatsapp_service_visible = sidebar_tenant.present? &&
                                 can_access.call(:manage, :whatsapp_inbox) &&
                                 WhatsappBusinessIntegration.current(sidebar_tenant)&.messaging_ready?
      settings_visible = can_access.call(:view, :catalogos) ||
                         tenant_owner? ||
                         can_access.call(:manage, :distribution_rules) ||
                         can_access.call(:manage, :field_settings) ||
                         whatsapp_service_visible
    %>
    <% if settings_visible %>
      <li class="ax-nav__section" data-nav-section="settings" style="<%= nav_section_style.call('settings') %>">
        <button type="button" class="ax-nav__section-trigger" data-menu-sections-target="trigger" data-action="menu-sections#toggle" aria-expanded="false" aria-controls="nav-section-settings" title="Configurações">
          <i class="bi bi-sliders"></i><span>Configurações</span><i class="bi bi-chevron-down"></i>
        </button>
        <ul class="ax-nav__section-items" id="nav-section-settings" data-menu-sections-target="items">
      <% if can_access.call(:manage, :distribution_rules) %>
        <li><%= link_to edit_admin_lead_setting_path, class: "ax-nav__link #{'active' if controller_name == 'lead_settings'}" do %><i class="bi bi-person-check"></i><span>Configurações de Leads</span><% end %></li>
      <% end %>
      <% if whatsapp_service_visible %>
        <li><%= link_to edit_admin_whatsapp_service_setting_path, class: "ax-nav__link #{'active' if controller_name == 'whatsapp_service_settings'}" do %><i class="bi bi-whatsapp"></i><span>Atendimento WhatsApp</span><% end %></li>
      <% end %>
      <% if can_access.call(:view, :catalogos) %>
        <li><%= link_to admin_attribute_options_path, class: "ax-nav__link #{'active' if controller_name == 'attribute_options'}" do %><i class="bi bi-tags"></i><span>Catálogos Dinâmicos</span><% end %></li>
      <% end %>
      <% if tenant_owner? %>
        <li><%= link_to edit_admin_property_setting_path, class: "ax-nav__link #{'active' if controller_name == 'property_settings' && action_name == 'edit'}" do %><i class="bi bi-house-gear"></i><span>Configuração de Imóveis</span><% end %></li>
        <li><%= link_to review_workflow_admin_property_setting_path, class: "ax-nav__link #{'active' if controller_name == 'property_settings' && action_name == 'review_workflow'}" do %><i class="bi bi-diagram-3"></i><span>Fluxo de revisão</span><% end %></li>
      <% end %>
      <% if can_access.call(:manage, :field_settings) %>
        <li class="ax-nav__caption">Campo</li>
        <li><%= link_to edit_admin_field_settings_path, class: "ax-nav__link #{'active' if controller_name == 'field_settings'}" do %><i class="bi bi-toggles2"></i><span>Configurações de Campo</span><% end %></li>
      <% end %>
        </ul>
      </li>
    <% end %>

    <%# Configurações da Conta (ex-Administração + marca + notificações) %>
    <%
      audit_menu_visible = can_access.call(:view, :field_audit) || can_access.call(:view, :access_audit) || can_access.call(:view, :data_export_audit)
      security_menu_visible = can_access.call(:manage, :access_security)
      whatsapp_admin_menu_visible = can_access.call(:view, :whatsapp_campaigns)
      brand_menu_visible = can_access.call(:manage, :marketing)
      notif_menu_visible = can_access.call(:manage, :integracoes)
    %>
    <% if tenant_owner? || security_menu_visible || audit_menu_visible || whatsapp_admin_menu_visible || brand_menu_visible || notif_menu_visible %>
      <li class="ax-nav__section" data-nav-section="account" style="<%= nav_section_style.call('account') %>">
        <button type="button" class="ax-nav__section-trigger" data-menu-sections-target="trigger" data-action="menu-sections#toggle" aria-expanded="false" aria-controls="nav-section-account" title="Conta">
          <i class="bi bi-building-gear"></i><span>Conta</span><i class="bi bi-chevron-down"></i>
        </button>
        <ul class="ax-nav__section-items" id="nav-section-account" data-menu-sections-target="items">
      <li><%= link_to admin_account_settings_path, class: "ax-nav__link #{'active' if controller_name == 'account_settings'}" do %><i class="bi bi-grid-1x2"></i><span>Visão geral</span><% end %></li>
      <% if brand_menu_visible %>
        <li><%= link_to edit_admin_layout_setting_path, class: "ax-nav__link #{'active' if controller_name == 'layout_settings'}" do %><i class="bi bi-palette"></i><span>Identidade e Marca</span><% end %></li>
      <% end %>
      <% if tenant_owner? %>
        <li><%= link_to admin_profiles_path, class: "ax-nav__link #{'active' if controller_name == 'profiles'}" do %><i class="bi bi-shield-lock"></i><span>Perfis</span><% end %></li>
      <% end %>
      <% if notif_menu_visible %>
        <li class="ax-nav__caption">Notificações</li>
        <li><%= link_to edit_admin_email_setting_path, class: "ax-nav__link #{'active' if controller_name == 'email_settings'}" do %><i class="bi bi-envelope-at"></i><span>Meu SMTP</span><% end %></li>
        <%# Push (VAPID) é global, administrado pelo Admin do Sistema em Notificações Globais — fora dos perfis de conta. %>
      <% end %>
      <% if whatsapp_admin_menu_visible %>
        <li class="ax-nav__caption">WhatsApp</li>
        <li><%= link_to admin_whatsapp_campaign_recipients_path, class: "ax-nav__link #{'active' if controller_name == 'whatsapp_campaign_recipients'}" do %><i class="bi bi-table"></i><span>Importados CSV</span><% end %></li>
        <li><%= link_to admin_whatsapp_campaign_unsubscribes_path, class: "ax-nav__link #{'active' if controller_name == 'whatsapp_campaign_unsubscribes'}" do %><i class="bi bi-person-dash"></i><span>Descadastros WhatsApp</span><% end %></li>
      <% end %>
      <% if security_menu_visible %>
        <li class="ax-nav__caption">Segurança</li>
        <li><%= link_to admin_access_security_path, class: "ax-nav__link #{'active' if controller_name == 'access_security'}" do %><i class="bi bi-fingerprint"></i><span>Segurança de Acesso</span><% end %></li>
      <% end %>
      <% if audit_menu_visible %>
        <li class="ax-nav__caption">Auditorias</li>
      <% end %>
      <% if can_access.call(:view, :field_audit) %>
        <li><%= link_to admin_field_audit_logs_path, class: "ax-nav__link #{'active' if controller_path == 'admin/field/audit_logs'}" do %><i class="bi bi-shield-lock-fill"></i><span>Auditoria de Campo</span><% end %></li>
      <% end %>
      <% if can_access.call(:view, :access_audit) %>
        <li><%= link_to admin_access_audit_logs_path, class: "ax-nav__link #{'active' if controller_name == 'access_audit_logs'}" do %><i class="bi bi-person-lock"></i><span>Auditoria de Acessos</span><% end %></li>
      <% end %>
      <% if can_access.call(:view, :data_export_audit) %>
        <li><%= link_to admin_data_export_audit_logs_path, class: "ax-nav__link #{'active' if controller_name == 'data_export_audit_logs'}" do %><i class="bi bi-file-earmark-arrow-down"></i><span>Auditoria de Exportações</span><% end %></li>
      <% end %>
      <% if can_access.call(:view, :access_audit) %>
        <li><%= link_to admin_presentation_audit_logs_path, class: "ax-nav__link #{'active' if controller_name == 'presentation_audit_logs'}" do %><i class="bi bi-person-badge"></i><span>Apresentações WhatsApp</span><% end %></li>
      <% end %>
        </ul>
      </li>
    <% end %>

    <%# Admin do Sistema — acima da conta, visível só para super admins. %>
    <% if current_admin_user&.system_admin? %>
      <li class="ax-nav__section">Sistema</li>
      <li class="ax-nav__item">
        <%= link_to admin_system_path, class: "ax-nav__link #{'active' if controller_name == 'system'}" do %>
          <i class="bi bi-hdd-stack"></i><span>Painel do Sistema</span>
        <% end %>
      </li>
      <li class="ax-nav__item">
        <%= link_to admin_system_error_events_path, class: "ax-nav__link #{'active' if controller_name == 'error_events'}" do %>
          <i class="bi bi-bug"></i><span>Erros da Aplicação</span>
        <% end %>
      </li>
      <li class="ax-nav__item">
        <%= link_to edit_admin_system_notification_settings_path, class: "ax-nav__link #{'active' if controller_name == 'notification_settings'}" do %>
          <i class="bi bi-broadcast-pin"></i><span>Notificações Globais</span>
        <% end %>
      </li>
    <% end %>

  <% end %>
</ul>
