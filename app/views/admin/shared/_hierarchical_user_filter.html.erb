<%
  component_id ||= "hierarchical_user_filter_#{SecureRandom.hex(4)}"
  profiles ||= []
  users ||= []
  target_select_id ||= nil
  selection_input_id ||= nil
  locked_user_id ||= nil
  label ||= "Filtrar por hierarquia"
  hint ||= "Selecione um nível para filtrar automaticamente os níveis abaixo."
  submit_on_change ||= false
  mode ||= :single
  multi = mode.to_sym == :multi
  area ||= nil
  field_name ||= nil          # ex: "distribution_rule[hierarchy_manager_ids][]" — persiste a seleção
  selected_ids ||= []         # ids para restaurar o filtro ao editar (modo multi)
%>
<% if profiles.any? %>
<div id="<%= component_id %>"
     class="ax-hierarchy-filter"
     data-controller="hierarchical-user-filter"
     data-hierarchical-user-filter-users-value="<%= users.to_json %>"
     data-hierarchical-user-filter-locked-user-id-value="<%= locked_user_id %>"
     data-hierarchical-user-filter-target-select-id-value="<%= target_select_id %>"
     data-hierarchical-user-filter-selection-input-id-value="<%= selection_input_id %>"
     data-hierarchical-user-filter-mode-value="<%= multi ? 'multi' : 'single' %>"
     data-hierarchical-user-filter-area-value="<%= area %>"
     data-hierarchical-user-filter-selected-ids-value="<%= Array(selected_ids).compact.map(&:to_s).to_json %>"
     <%= %(data-action="hierarchical-user-filter:change->auto-submit#submit").html_safe if submit_on_change %>>
  <div class="ax-field">
    <%= ax_field_label(nil, nil, text: label) %>
    <% if multi && field_name.present? %>
      <%# garante array vazio no POST quando o filtro é limpo %>
      <input type="hidden" name="<%= field_name %>" value="">
    <% end %>
    <div class="ax-hierarchy-filter__grid">
      <% profiles.each do |profile| %>
        <div class="ax-hierarchy-filter__level">
          <label class="ax-label ax-label--sm" for="<%= "#{component_id}_profile_#{profile.id}" %>"><%= profile.name %></label>
          <select id="<%= "#{component_id}_profile_#{profile.id}" %>"
                  class="ax-control ax-control--sm"
                  <%= "multiple" if multi %>
                  <% if multi && field_name.present? %>name="<%= field_name %>"<% end %>
                  data-controller="tom-select"
                  data-placeholder="<%= multi ? 'Selecione...' : 'Todos' %>"
                  data-tom-select-options-value="<%= (multi ? { maxOptions: nil, plugins: ['remove_button'] } : { allowEmptyOption: true, maxOptions: nil }).to_json %>"
                  data-hierarchical-user-filter-target="levelSelect"
                  data-profile-id="<%= profile.id %>"
                  data-action="change->hierarchical-user-filter#filter">
            <% unless multi %><option value="">Todos</option><% end %>
          </select>
        </div>
      <% end %>
    </div>
    <p class="ax-field__hint"><%= hint %></p>
  </div>
</div>
<% end %>
