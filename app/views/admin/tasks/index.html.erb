<%# Minhas Tarefas — lista comercial (.ax-*) %>
<% task_heading_actions = if can?(:manage, :comercial)
     render("admin/tasks/form_modal", modal_id: "newTaskTop", trigger_label: "Nova tarefa")
   end %>
<%= ax_workspace_heading(
      eyebrow: "Comercial · Follow-up",
      icon: "check2-square",
      title: "Minhas Tarefas",
      subtitle: "Acompanhe o que precisa ser feito e nunca perca um follow-up.",
      actions: task_heading_actions
    ) %>

<%= ax_dismissible_hint(key: "tasks", icon: "check2-square",
      text: "Crie tarefas a partir de um lead (botão <strong>Tarefa</strong> na ficha) ou aqui. Os filtros mostram o que é prioridade <strong>hoje</strong> e o que está <strong>atrasado</strong>.") %>

<%# Filtros rápidos com contadores — "bate o olho e entende" %>
<div class="tw-flex tw-flex-wrap tw-gap-2 tw-mb-4">
  <% [
       ["pendentes", "Pendentes", @counts[:pendentes], "gray"],
       ["hoje", "Hoje", @counts[:hoje], "blue"],
       ["atrasadas", "Atrasadas", @counts[:atrasadas], "red"],
       ["semana", "Próx. 7 dias", @counts[:semana], "amber"],
       ["concluidas", "Concluídas", nil, "green"],
       ["todas", "Todas", nil, "gray"]
     ].each do |key, label, count, color| %>
    <%= link_to admin_tasks_path(filter: key, team: params[:team]),
          class: "ax-btn ax-btn--sm #{'ax-btn--primary' if @filter == key}",
          aria: { current: ("page" if @filter == key) } do %>
      <span><%= label %></span>
      <% if count && count > 0 %><span class="ax-badge ax-badge--<%= color %> tw-ml-1"><%= count %></span><% end %>
    <% end %>
  <% end %>
  <%= ax_team_toggle(:comercial, class_name: "tw-ml-auto") %>
</div>

<% if @tasks.any? %>
  <%= ax_operational_panel(eyebrow: "Agenda", title: "Tarefas do filtro atual") do %>
  <div class="ax-table-wrap">
    <table class="ax-table">
      <thead>
        <tr>
          <th class="ax-table__col--w-40"></th>
          <th>Tarefa</th>
          <th class="ax-table__col--w-120">Tipo</th>
          <th class="ax-table__col--w-170">Prazo</th>
          <th class="ax-table__col--lg">Lead</th>
          <th class="ax-num ax-table__col--compact">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% @tasks.each do |task| %>
          <% badge = task_badge(task) %>
          <tr class="<%= 'tw-opacity-60' if task.concluida? %>">
            <td>
              <% if task.pendente? %>
                <%= button_to complete_admin_task_path(task), method: :patch, form_class: "tw-inline", class: "ax-ico-btn", title: "Concluir", aria: { label: "Concluir tarefa #{task.title}" } do %>
                  <i class="bi bi-circle" aria-hidden="true"></i>
                <% end %>
              <% else %>
                <i class="bi bi-check-circle-fill tw-text-green-500" aria-label="Tarefa concluída"></i>
              <% end %>
            </td>
            <td>
              <div class="ax-strong"><%= task.title %></div>
              <% if task.description.present? %><div class="ax-page-subtitle ax-table__text--truncate"><%= task.description %></div><% end %>
            </td>
            <td><span class="ax-badge ax-badge--gray"><%= task.kind_label %></span></td>
            <td><span class="ax-badge ax-badge--<%= badge[:color] %>"><%= badge[:label] %></span></td>
            <td>
              <% if task.lead %><%= link_to task.lead.display_name, admin_lead_path(task.lead), class: "tw-text-primary" %><% else %><span class="ax-page-subtitle">—</span><% end %>
            </td>
            <td class="ax-num">
              <% if can?(:manage, :comercial) %>
                <%= button_to admin_task_path(task), method: :delete, form_class: "tw-inline", class: "ax-ico-btn", title: "Remover", aria: { label: "Remover tarefa #{task.title}" }, data: { turbo_confirm: "Remover esta tarefa?" } do %>
                  <i class="bi bi-trash" aria-hidden="true"></i>
                <% end %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <% end %>
<% else %>
  <%= ax_empty_state(
        title: "Nenhuma tarefa #{@filter == 'pendentes' ? 'pendente' : 'neste filtro'}",
        description: "Crie tarefas a partir de um lead ou aqui no botão Nova tarefa para organizar seus follow-ups.",
        icon: "check2-circle"
      ) %>
<% end %>
