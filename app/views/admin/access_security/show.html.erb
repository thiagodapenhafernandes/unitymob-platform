<% content_for :title, "Segurança de Acesso — Configurações da Conta" %>

<div class="access-security-page">
  <header class="ax-dashboard-command">
    <div class="ax-dashboard-command__main">
      <span class="ax-dashboard-command__eyebrow">Conta &amp; Segurança</span>
      <div class="ax-dashboard-command__title-row">
        <h1><i class="bi bi-fingerprint access-security-heading__icon"></i> Segurança de Acesso</h1>
        <%= ax_badge("Só logins do admin", tone: :gray) %>
      </div>
      <p>Controle logins administrativos por IP, aparelho e verificação em duas etapas — sem bloquear a navegação pública do site.</p>
    </div>

    <div class="ax-dashboard-command__status">
      <span><i class="bi bi-people"></i> Corretores</span>
      <%= ax_badge("IP #{@broker_ip_allowlist_enabled ? 'obrigatório' : 'opcional'}", tone: @broker_ip_allowlist_enabled ? :blue : :gray) %>
      <%= ax_badge("Aparelho #{@broker_trusted_devices_enabled ? 'obrigatório' : 'opcional'}", tone: @broker_trusted_devices_enabled ? :blue : :gray) %>
      <%= link_to admin_access_audit_logs_path, class: "ax-btn ax-btn--sm ax-btn--ghost" do %>
        <i class="bi bi-person-lock ax-ico"></i><span>Ver auditoria</span>
      <% end %>
    </div>
  </header>

  <div class="ax-dashboard-kpis access-security-kpis">
    <% active_rules = @rules.select(&:enabled?).size %>
    <%= ax_metric_card(
          label: "Regras de IP ativas",
          value: active_rules,
          badge: (active_rules.positive? ? ax_badge("Aplicando", tone: :green, dot: true) : ax_badge("Nenhuma", tone: :gray)),
          hint: "Permitidos, bloqueados ou ignorados nas métricas") %>

    <% pending_devices = @trusted_devices.count { |device| device.status == "pending" } %>
    <%= ax_metric_card(
          label: "Aparelhos pendentes",
          value: pending_devices,
          badge: (pending_devices.positive? ? ax_badge("Aguardando aprovação", tone: :amber, dot: true) : ax_badge("Em dia", tone: :green, dot: true)),
          hint: "Novos aparelhos entram pendentes quando a exigência está ativa") %>

    <%
      two_factor_on = current_tenant.respond_to?(:require_two_factor) && current_tenant.require_two_factor?
      enforcement_labels = []
      enforcement_labels << "IP" if @broker_ip_allowlist_enabled
      enforcement_labels << "Aparelho" if @broker_trusted_devices_enabled
      enforcement_labels << "2FA" if two_factor_on
    %>
    <%= ax_metric_card(
          label: "Exigências da conta",
          value: "#{enforcement_labels.size}/3",
          badge: (enforcement_labels.any? ? ax_badge(enforcement_labels.join(" · "), tone: :blue) : ax_badge("Nenhuma", tone: :gray)),
          hint: "IP permitido, aparelho aprovado e verificação em duas etapas") %>
  </div>

  <ul class="ax-form-tabs tw-mb-4" id="accessSecurityTabs" role="tablist" data-controller="ax-tabs" data-ax-tabs-panel-selector-value="#access-security-panels">
    <% if @can_manage_global_access_security %>
      <li role="presentation">
        <button class="ax-form-tabs__item <%= @active_tab == "settings" ? "active" : "" %>" id="settings-tab" data-ax-tabs-target="tab" data-action="click->ax-tabs#select" data-ax-tabs-target-param="#settings-pane" type="button" role="tab">
          Configurações
        </button>
      </li>
    <% end %>
    <li role="presentation">
      <button class="ax-form-tabs__item <%= @active_tab == "rules" ? "active" : "" %>" id="rules-tab" data-ax-tabs-target="tab" data-action="click->ax-tabs#select" data-ax-tabs-target-param="#rules-pane" type="button" role="tab">
        Regras de IP
      </button>
    </li>
    <li role="presentation">
      <button class="ax-form-tabs__item <%= @active_tab == "devices" ? "active" : "" %>" id="devices-tab" data-ax-tabs-target="tab" data-action="click->ax-tabs#select" data-ax-tabs-target-param="#devices-pane" type="button" role="tab">
        Aparelhos
      </button>
    </li>
  </ul>

  <%# Panes: .tab-pane é o contrato do ax-tabs (Stimulus); a visibilidade vem do
      CSS escopado .access-security-panels — sem depender da compat Bootstrap. %>
  <div class="access-security-panels" id="access-security-panels">
    <% if @can_manage_global_access_security %>
      <div class="tab-pane <%= "active" if @active_tab == "settings" %>" id="settings-pane" role="tabpanel" aria-labelledby="settings-tab">
        <%= ax_operational_panel(eyebrow: "Política da conta", title: "Regras gerais para corretores") do %>
          <div class="ax-panel-body">
            <%= form_with url: admin_access_security_path, method: :patch, local: true do %>
              <div class="tw-mb-3">
                <%= ax_switch_field(name: :enforce_broker_ip_allowlist, value: "1", checked: @broker_ip_allowlist_enabled, label: "Corretores só podem logar por IP permitido", id: "enforce_broker_ip_allowlist") %>
                <div class="access-security-help">Use para exigir rede da imobiliária, VPN ou faixas específicas para perfis não administrativos.</div>
              </div>

              <div class="tw-mb-4">
                <%= ax_switch_field(name: :enforce_broker_trusted_devices, value: "1", checked: @broker_trusted_devices_enabled, label: "Corretores só podem logar em aparelhos aprovados", id: "enforce_broker_trusted_devices") %>
                <div class="access-security-help">Ao tentar logar em aparelho novo, ele fica pendente para aprovação nesta tela.</div>
              </div>

              <% if current_tenant.respond_to?(:require_two_factor) %>
                <div class="tw-mb-4">
                  <%= ax_switch_field(name: :require_two_factor, value: "1", checked: current_tenant.require_two_factor?, label: "Exigir verificação em duas etapas (Google Authenticator) de todos", id: "require_two_factor") %>
                  <div class="access-security-help">Quem ainda não ativou é levado à tela de configuração no próximo acesso — ninguém fica trancado fora. Cada usuário ativa em <%= link_to "Verificação em duas etapas", admin_two_factor_settings_path %>.</div>
                </div>
              <% end %>

              <%= submit_tag "Salvar configurações", class: "ax-btn ax-btn--primary" %>
            <% end %>
          </div>
        <% end %>

        <% if current_tenant.respond_to?(:session_timeout_enabled) %>
          <%= ax_operational_panel(eyebrow: "Política da conta", title: "Sessões", class_name: "tw-mt-4") do %>
            <div class="ax-panel-body">
              <%= form_with url: admin_access_security_path, method: :patch, local: true do %>
                <%= hidden_field_tag :section, "sessions" %>
                <div class="tw-mb-3">
                  <%= ax_switch_field(name: :session_timeout_enabled, value: "1", checked: current_tenant.session_timeout_enabled?, label: "Expirar sessão por inatividade", id: "session_timeout_enabled") %>
                  <div class="access-security-help">Quem ficar sem usar o sistema pelo período abaixo precisa entrar de novo — vale também para aparelhos com "lembrar deste dispositivo".</div>
                </div>

                <%= ax_field_grid do %>
                  <div class="ax-span-3">
                    <%= label_tag :session_timeout_days, "Dias de inatividade (1 a 90)", class: "ax-label" %>
                    <%= number_field_tag :session_timeout_days, current_tenant.session_timeout_days || 7, min: 1, max: 90, class: "ax-control" %>
                  </div>
                  <div class="ax-span-4">
                    <%= label_tag :session_remember_days, "Validade do lembrar deste dispositivo (dias)", class: "ax-label" %>
                    <%= number_field_tag :session_remember_days, current_tenant.session_remember_days, min: 1, max: 180, class: "ax-control", placeholder: "Padrão: #{(AdminUser.remember_for / 1.day).round} dias" %>
                    <div class="access-security-help">Opcional — em branco usa o padrão do sistema.</div>
                  </div>
                <% end %>

                <div class="tw-mt-3">
                  <%= submit_tag "Salvar sessões", class: "ax-btn ax-btn--primary" %>
                </div>
              <% end %>

              <div class="tw-mt-4">
                <div class="access-security-help tw-mb-2">Precisa tirar todo mundo agora (troca de equipe, aparelho perdido, suspeita de acesso indevido)? Encerra as sessões e os "lembrar deste dispositivo" de todos os usuários da conta — a sua sessão atual é preservada.</div>
                <%= form_with url: admin_access_security_path, method: :patch, local: true, id: "end_all_sessions_form" do %>
                  <%= hidden_field_tag :end_all_sessions, "1" %>
                <% end %>
                <span data-controller="ax-confirm-submit"
                      data-ax-confirm-submit-form-id-value="end_all_sessions_form"
                      data-ax-confirm-submit-message-value="Encerrar as sessões de todos os usuários da conta agora?"
                      data-ax-confirm-submit-confirm-label-value="Encerrar sessões">
                  <%= button_tag type: "button", class: "ax-btn ax-btn--danger", data: { action: "click->ax-confirm-submit#request" } do %>
                    <i class="bi bi-door-closed ax-ico"></i><span>Encerrar todas as sessões agora</span>
                  <% end %>
                </span>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <div class="tab-pane <%= "active" if @active_tab == "rules" %>" id="rules-pane" role="tabpanel" aria-labelledby="rules-tab">
      <%= ax_operational_panel(eyebrow: "Cadastro", title: "Nova regra de IP", class_name: "tw-mb-4") do %>
        <div class="ax-panel-body">
          <%= form_with model: [:admin, @new_rule], url: admin_access_control_rules_path, local: true do |f| %>
            <%= ax_field_grid do %>
              <div class="ax-span-3">
                <%= f.label :name, "Nome", class: "ax-label" %>
                <%= f.text_field :name, class: "ax-control", placeholder: "Ex: Loja Centro" %>
              </div>
              <div class="ax-span-2">
                <%= f.label :rule_type, "Tipo", class: "ax-label" %>
                <%= f.select :rule_type, AccessControlRule::RULE_TYPES.map { |key, label| [label, key] }, {}, class: "ax-control" %>
              </div>
              <div class="ax-span-2">
                <%= f.label :ip_value, "IP ou CIDR", class: "ax-label" %>
                <%= f.text_field :ip_value, class: "ax-control", placeholder: "189.1.2.3 ou 189.1.2.0/24" %>
              </div>
              <div class="ax-span-2">
                <%= f.label :scope_type, "Aplicar para", class: "ax-label" %>
                <%= f.select :scope_type, @access_scope_types.map { |key, label| [label, key] }, {}, class: "ax-control" %>
              </div>
              <div class="ax-span-3">
                <%= f.label :description, "Observação", class: "ax-label" %>
                <%= f.text_field :description, class: "ax-control", placeholder: "Uso interno, VPN, campanha..." %>
              </div>
              <div class="ax-span-6">
                <%= f.label :profile_id, "Perfil", class: "ax-label" %>
                <%= f.select :profile_id, options_from_collection_for_select(@profiles, :id, ->(profile) { profile_filter_label(profile) }, f.object.profile_id), { prompt: "Somente quando aplicar para Perfil" }, { class: "ax-control", data: { controller: "tom-select", tom_select_options_value: { placeholder: "Buscar perfil..." } } } %>
              </div>
              <div class="ax-span-6">
                <%= f.label :admin_user_id, "Usuário", class: "ax-label" %>
                <%= f.select :admin_user_id, @admin_users.map { |user| ["#{user.name} · #{user.email}", user.id] }, { prompt: "Somente quando aplicar para Usuário" }, { class: "ax-control", data: { controller: "tom-select", tom_select_options_value: { placeholder: "Buscar usuário..." } } } %>
              </div>
              <div class="ax-span-12">
                <%= f.submit "Adicionar regra", class: "ax-btn ax-btn--primary" %>
              </div>
            <% end %>
          <% end %>
        </div>
      <% end %>

      <%= ax_operational_panel(eyebrow: "Governança", title: "Regras cadastradas",
            actions: ax_badge("#{@rules.size} regra#{"s" if @rules.size != 1}", tone: :gray)) do %>
        <div class="ax-panel-body access-security-filter-bar">
          <%= form_with url: admin_access_security_path, method: :get, local: true do %>
            <%= ax_field_grid do %>
              <div class="ax-span-2">
                <%= label_tag :rule_type, "Tipo", class: "ax-label access-security-filter-label" %>
                <%= select_tag :rule_type, options_for_select([["Todos", ""], *AccessControlRule::RULE_TYPES.map { |key, label| [label, key] }], params[:rule_type]), class: "ax-control ax-control--sm" %>
              </div>
              <div class="ax-span-2">
                <%= label_tag :scope_type, "Aplicar para", class: "ax-label access-security-filter-label" %>
                <%= select_tag :scope_type, options_for_select([["Todos", ""], *@access_scope_types.map { |key, label| [label, key] }], params[:scope_type]), class: "ax-control ax-control--sm" %>
              </div>
              <div class="ax-span-2">
                <%= label_tag :rule_enabled, "Status", class: "ax-label access-security-filter-label" %>
                <%= select_tag :rule_enabled, options_for_select([["Todos", ""], ["Ativa", "true"], ["Inativa", "false"]], params[:rule_enabled]), class: "ax-control ax-control--sm" %>
              </div>
              <div class="ax-span-2">
                <%= label_tag :rule_profile_id, "Perfil", class: "ax-label access-security-filter-label" %>
                <%= select_tag :rule_profile_id, options_from_collection_for_select(@profiles, :id, ->(profile) { profile_filter_label(profile) }, params[:rule_profile_id]), include_blank: "Todos", class: "ax-control ax-control--sm", data: { controller: "tom-select", tom_select_options_value: { placeholder: "Buscar perfil..." } } %>
              </div>
              <div class="ax-span-2">
                <%= label_tag :rule_admin_user_id, "Usuário", class: "ax-label access-security-filter-label" %>
                <%= select_tag :rule_admin_user_id, options_from_collection_for_select(@admin_users, :id, ->(user) { "#{user.name} · #{user.email}" }, params[:rule_admin_user_id]), include_blank: "Todos", class: "ax-control ax-control--sm", data: { controller: "tom-select", tom_select_options_value: { placeholder: "Buscar usuário..." } } %>
              </div>
              <div class="ax-span-2">
                <%= label_tag :rule_ip, "IP contém", class: "ax-label access-security-filter-label" %>
                <%= text_field_tag :rule_ip, params[:rule_ip], class: "ax-control ax-control--sm", placeholder: "127.0.0.1" %>
              </div>
              <div class="ax-span-2 tw-grid">
                <%= submit_tag "Filtrar", class: "ax-btn ax-btn--primary ax-btn--sm" %>
              </div>
              <div class="ax-span-2 tw-grid">
                <%= link_to "Limpar", admin_access_security_path(anchor: "rules-pane"), class: "ax-btn ax-btn--ghost ax-btn--sm" %>
              </div>
            <% end %>
          <% end %>
        </div>
        <div class="ax-table-wrap">
          <table class="ax-table">
            <thead>
              <tr>
                <th>Regra</th>
                <th>Tipo</th>
                <th>IP</th>
                <th>Aplicação</th>
                <th>Status</th>
                <th class="tw-text-right">Ações</th>
              </tr>
            </thead>
            <tbody>
              <% @rules.each do |rule| %>
                <tr>
                  <td>
                    <div class="tw-font-semibold"><%= rule.name %></div>
                    <% if rule.description.present? %>
                      <div class="tw-text-sm tw-text-ink-muted"><%= rule.description %></div>
                    <% end %>
                  </td>
                  <td><%= rule.rule_type_label %></td>
                  <td><code><%= rule.ip_value %></code></td>
                  <td><%= rule.scope_label %></td>
                  <td>
                    <%= ax_badge(rule.enabled? ? "Ativa" : "Inativa", tone: rule.enabled? ? :green : :gray, dot: true) %>
                  </td>
                  <td class="tw-text-right">
                    <%= form_with model: [:admin, rule], local: true, class: "access-security-inline-form" do |f| %>
                      <%= f.hidden_field :enabled, value: (!rule.enabled?).to_s %>
                      <%= f.submit(rule.enabled? ? "Desativar" : "Ativar", class: "ax-btn ax-btn--sm ax-btn--ghost") %>
                    <% end %>
                    <%= button_to "Remover", admin_access_control_rule_path(rule), method: :delete, class: "ax-btn ax-btn--sm ax-btn--danger", form: { class: "access-security-inline-form", data: { turbo_confirm: "Remover esta regra?" } } %>
                  </td>
                </tr>
              <% end %>
              <% if @rules.empty? %>
                <tr><td colspan="6" class="access-security-empty-cell">Nenhuma regra cadastrada.</td></tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </div>

    <div class="tab-pane <%= "active" if @active_tab == "devices" %>" id="devices-pane" role="tabpanel" aria-labelledby="devices-tab">
      <%= ax_operational_panel(eyebrow: "Confiança", title: "Aparelhos identificados",
            actions: ax_badge("#{@trusted_devices.size} aparelho#{"s" if @trusted_devices.size != 1}", tone: :gray),
            class_name: "access-security-devices-panel") do %>
        <div class="ax-panel-body access-security-filter-bar" id="devices">
          <%= form_with url: admin_access_security_path, method: :get, local: true do %>
            <%= ax_field_grid do %>
              <div class="ax-span-2">
                <%= label_tag :device_status, "Status", class: "ax-label access-security-filter-label" %>
                <%= select_tag :device_status, options_for_select([["Todos", ""], *TrustedDevice::STATUSES.map { |key, label| [label, key] }], params[:device_status]), class: "ax-control ax-control--sm" %>
              </div>
              <div class="ax-span-2">
                <%= label_tag :device_profile_id, "Perfil", class: "ax-label access-security-filter-label" %>
                <%= select_tag :device_profile_id, options_from_collection_for_select(@profiles, :id, ->(profile) { profile_filter_label(profile) }, params[:device_profile_id]), include_blank: "Todos", class: "ax-control ax-control--sm", data: { controller: "tom-select", tom_select_options_value: { placeholder: "Buscar perfil..." } } %>
              </div>
              <div class="ax-span-3">
                <%= label_tag :device_admin_user_id, "Usuário", class: "ax-label access-security-filter-label" %>
                <%= select_tag :device_admin_user_id, options_from_collection_for_select(@admin_users, :id, ->(user) { "#{user.name} · #{user.email}" }, params[:device_admin_user_id]), include_blank: "Todos", class: "ax-control ax-control--sm", data: { controller: "tom-select", tom_select_options_value: { placeholder: "Buscar usuário..." } } %>
              </div>
              <div class="ax-span-2">
                <%= label_tag :device_type, "Dispositivo", class: "ax-label access-security-filter-label" %>
                <%= select_tag :device_type, options_for_select([["Todos", ""]] + @available_device_types.map { |value| [value, value] }, params[:device_type]), class: "ax-control ax-control--sm", data: { controller: "tom-select", tom_select_options_value: { placeholder: "Buscar dispositivo..." } } %>
              </div>
              <div class="ax-span-2">
                <%= label_tag :device_browser, "Navegador", class: "ax-label access-security-filter-label" %>
                <%= select_tag :device_browser, options_for_select([["Todos", ""]] + @available_browsers.map { |value| [value, value] }, params[:device_browser]), class: "ax-control ax-control--sm", data: { controller: "tom-select", tom_select_options_value: { placeholder: "Buscar navegador..." } } %>
              </div>
              <div class="ax-span-2">
                <%= label_tag :device_ip, "IP", class: "ax-label access-security-filter-label" %>
                <%= text_field_tag :device_ip, params[:device_ip], class: "ax-control ax-control--sm", placeholder: "127.0.0.1" %>
              </div>
              <div class="ax-span-2 tw-grid">
                <%= submit_tag "Filtrar", class: "ax-btn ax-btn--primary ax-btn--sm" %>
              </div>
              <div class="ax-span-2 tw-grid">
                <%= link_to "Limpar", admin_access_security_path(anchor: "devices-pane"), class: "ax-btn ax-btn--ghost ax-btn--sm" %>
              </div>
            <% end %>
          <% end %>
        </div>
        <div class="ax-table-wrap">
          <table class="ax-table">
            <thead>
              <tr>
                <th>Usuário</th>
                <th>Aparelho</th>
                <th>Último IP</th>
                <th>Status</th>
                <th>Último uso</th>
                <th class="tw-text-right">Ações</th>
              </tr>
            </thead>
            <tbody>
              <% @trusted_devices.each do |device| %>
                <tr>
                  <td>
                    <div class="tw-font-semibold"><%= device.admin_user.name %></div>
                    <div class="tw-text-sm tw-text-ink-muted"><%= device.admin_user.notification_email %></div>
                  </td>
                  <td>
                    <div><%= device.name.presence || device.device_label %></div>
                    <div class="tw-text-sm tw-text-ink-muted"><%= device.fingerprint.first(12) %>...</div>
                  </td>
                  <td><code><%= device.last_ip %></code></td>
                  <td>
                    <% badge_tone = { "trusted" => :green, "blocked" => :red, "pending" => :amber }[device.status] || :gray %>
                    <%= ax_badge(device.status_label, tone: badge_tone, dot: true) %>
                  </td>
                  <td><%= l(device.last_seen_at || device.created_at, format: :short) %></td>
                  <td class="tw-text-right">
                    <%= button_to "Aprovar", admin_trusted_device_path(device, status: "trusted"), method: :patch, class: "ax-btn ax-btn--sm ax-btn--primary", form: { class: "access-security-inline-form" } unless device.status == "trusted" %>
                    <%= button_to "Bloquear", admin_trusted_device_path(device, status: "blocked"), method: :patch, class: "ax-btn ax-btn--sm ax-btn--danger", form: { class: "access-security-inline-form" } unless device.status == "blocked" %>
                    <%= button_to "Remover", admin_trusted_device_path(device), method: :delete, class: "ax-btn ax-btn--sm ax-btn--ghost", form: { class: "access-security-inline-form", data: { turbo_confirm: "Remover este aparelho?" } } %>
                  </td>
                </tr>
              <% end %>
              <% if @trusted_devices.empty? %>
                <tr><td colspan="6" class="access-security-empty-cell">Nenhum aparelho identificado ainda.</td></tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </div>
  </div>
</div>
