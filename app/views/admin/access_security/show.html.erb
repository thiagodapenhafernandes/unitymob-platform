<div class="tw-flex tw-items-center tw-justify-between tw-mb-4">
  <div>
    <h1 class="ax-page-title">
      <i class="bi bi-fingerprint" style="color:#2563eb;"></i>Segurança de Acesso
    </h1>
    <p class="ax-page-subtitle">Controle logins administrativos por IP e aparelho, sem bloquear a navegação pública do site.</p>
  </div>
  <%= link_to admin_access_audit_logs_path, class: "ax-btn ax-btn--ghost ax-btn--sm tw-gap-2" do %>
    <i class="bi bi-person-lock"></i> Ver auditoria
  <% end %>
</div>

<%= ax_field_grid do %>
  <div class="ax-span-4">
    <div class="ax-card tw-h-full">
      <div class="ax-card__body">
        <div class="tw-text-sm tw-text-ink-muted text-uppercase tw-font-bold">Regras ativas</div>
        <div class="display-6 tw-font-bold"><%= @rules.select(&:enabled?).size %></div>
        <div class="tw-text-ink-muted tw-text-sm">IPs permitidos, bloqueados ou ignorados nas métricas.</div>
      </div>
    </div>
  </div>
  <div class="ax-span-4">
    <div class="ax-card tw-h-full">
      <div class="ax-card__body">
        <div class="tw-text-sm tw-text-ink-muted text-uppercase tw-font-bold">Aparelhos pendentes</div>
        <div class="display-6 tw-font-bold"><%= @trusted_devices.count { |device| device.status == "pending" } %></div>
        <div class="tw-text-ink-muted tw-text-sm">Aguardando aprovação quando a exigência estiver ativa.</div>
      </div>
    </div>
  </div>
  <div class="ax-span-4">
    <div class="ax-card tw-h-full">
      <div class="ax-card__body">
        <div class="tw-text-sm tw-text-ink-muted text-uppercase tw-font-bold">Modo corretores</div>
        <div class="tw-font-bold tw-mt-2">
          <span class="ax-badge <%= @broker_ip_allowlist_enabled ? 'ax-badge--blue' : 'ax-badge--gray' %>">IP <%= @broker_ip_allowlist_enabled ? 'obrigatório' : 'opcional' %></span>
          <span class="ax-badge <%= @broker_trusted_devices_enabled ? 'ax-badge--blue' : 'ax-badge--gray' %>">Aparelho <%= @broker_trusted_devices_enabled ? 'obrigatório' : 'opcional' %></span>
        </div>
        <div class="tw-text-ink-muted tw-text-sm tw-mt-2">Admin continua podendo ter regra individual.</div>
      </div>
    </div>
  </div>
<% end %>

<ul class="ax-form-tabs tw-mb-4" id="accessSecurityTabs" role="tablist" data-controller="ax-tabs" data-ax-tabs-panel-selector-value="#access-security-panels">
  <li role="presentation">
    <button class="ax-form-tabs__item <%= @active_tab == "settings" ? "active" : "" %>" id="settings-tab" data-ax-tabs-target="tab" data-action="click->ax-tabs#select" data-ax-tabs-target-param="#settings-pane" type="button" role="tab">
      Configurações
    </button>
  </li>
  <li role="presentation">
    <button class="ax-form-tabs__item <%= @active_tab == "rules" ? "active" : "" %>" id="rules-tab" data-ax-tabs-target="tab" data-action="click->ax-tabs#select" data-ax-tabs-target-param="#rules-pane" type="button" role="tab">
      Regras de IP
    </button>
  </li>
  <li role="presentation">
    <button class="ax-form-tabs__item <%= @active_tab == "devices" ? "active" : "" %>" id="devices-tab" data-ax-tabs-target="tab" data-action="click->ax-tabs#select" data-ax-tabs-target-param="#devices-pane" type="button" role="tab">
      Aparelhos
    </button>
  </li>
</ul>

<div class="tab-content" id="access-security-panels">
  <div class="tab-pane fade <%= @active_tab == "settings" ? "show active" : "" %>" id="settings-pane" role="tabpanel" aria-labelledby="settings-tab">
    <div class="ax-card tw-mb-4">
      <div class="ax-card__header">
        <h2 class="ax-card__title">Regras gerais para corretores</h2>
      </div>
      <div class="ax-card__body">
        <%= form_with url: admin_access_security_path, method: :patch, local: true do %>
          <div class="tw-mb-3">
            <%= ax_switch_field(name: :enforce_broker_ip_allowlist, value: "1", checked: @broker_ip_allowlist_enabled, label: "Corretores só podem logar por IP permitido", id: "enforce_broker_ip_allowlist") %>
            <div class="form-text">Use para exigir rede da imobiliária, VPN ou faixas específicas para perfis não administrativos.</div>
          </div>

          <div class="tw-mb-4">
            <%= ax_switch_field(name: :enforce_broker_trusted_devices, value: "1", checked: @broker_trusted_devices_enabled, label: "Corretores só podem logar em aparelhos aprovados", id: "enforce_broker_trusted_devices") %>
            <div class="form-text">Ao tentar logar em aparelho novo, ele fica pendente para aprovação nesta tela.</div>
          </div>

          <%= submit_tag "Salvar configurações", class: "ax-btn ax-btn--primary" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="tab-pane fade <%= @active_tab == "rules" ? "show active" : "" %>" id="rules-pane" role="tabpanel" aria-labelledby="rules-tab">
    <div class="ax-card tw-mb-4">
      <div class="ax-card__header">
        <h2 class="ax-card__title">Nova regra de IP</h2>
      </div>
      <div class="ax-card__body">
        <%= form_with model: [:admin, @new_rule], url: admin_access_control_rules_path, local: true do |f| %>
          <%= ax_field_grid do %>
          <div class="ax-span-3">
            <%= f.label :name, "Nome", class: "ax-label" %>
            <%= f.text_field :name, class: "ax-control", placeholder: "Ex: Loja Centro" %>
          </div>
          <div class="ax-span-2">
            <%= f.label :rule_type, "Tipo", class: "ax-label" %>
            <%= f.select :rule_type, AccessControlRule::RULE_TYPES.map { |key, label| [label, key] }, {}, class: "ax-control" %>
          </div>
          <div class="ax-span-2">
            <%= f.label :ip_value, "IP ou CIDR", class: "ax-label" %>
            <%= f.text_field :ip_value, class: "ax-control", placeholder: "189.1.2.3 ou 189.1.2.0/24" %>
          </div>
          <div class="ax-span-2">
            <%= f.label :scope_type, "Aplicar para", class: "ax-label" %>
            <%= f.select :scope_type, AccessControlRule::SCOPE_TYPES.map { |key, label| [label, key] }, {}, class: "ax-control" %>
          </div>
          <div class="ax-span-3">
            <%= f.label :description, "Observação", class: "ax-label" %>
            <%= f.text_field :description, class: "ax-control", placeholder: "Uso interno, VPN, campanha..." %>
          </div>
          <div class="ax-span-6">
            <%= f.label :profile_id, "Perfil", class: "ax-label" %>
            <%= f.collection_select :profile_id, @profiles, :id, :name, { prompt: "Somente quando aplicar para Perfil" }, { class: "ax-control", data: { controller: "tom-select", tom_select_options_value: { placeholder: "Buscar perfil..." } } } %>
          </div>
          <div class="ax-span-6">
            <%= f.label :admin_user_id, "Usuário", class: "ax-label" %>
            <%= f.select :admin_user_id, @admin_users.map { |user| ["#{user.name} · #{user.email}", user.id] }, { prompt: "Somente quando aplicar para Usuário" }, { class: "ax-control", data: { controller: "tom-select", tom_select_options_value: { placeholder: "Buscar usuário..." } } } %>
          </div>
          <div class="ax-span-12">
            <%= f.submit "Adicionar regra", class: "ax-btn ax-btn--primary" %>
          </div>
          <% end %>
        <% end %>
      </div>
    </div>

    <div class="ax-card">
      <div class="ax-card__header">
        <h2 class="ax-card__title">Regras cadastradas</h2>
      </div>
      <div class="ax-card__body border-bottom">
        <%= form_with url: admin_access_security_path, method: :get, local: true do %>
          <%= ax_field_grid do %>
          <div class="ax-span-2">
            <%= label_tag :rule_type, "Tipo", class: "ax-label tw-text-sm tw-font-bold tw-text-ink-muted text-uppercase" %>
            <%= select_tag :rule_type, options_for_select([["Todos", ""], *AccessControlRule::RULE_TYPES.map { |key, label| [label, key] }], params[:rule_type]), class: "ax-control ax-control--sm" %>
          </div>
          <div class="ax-span-2">
            <%= label_tag :scope_type, "Aplicar para", class: "ax-label tw-text-sm tw-font-bold tw-text-ink-muted text-uppercase" %>
            <%= select_tag :scope_type, options_for_select([["Todos", ""], *AccessControlRule::SCOPE_TYPES.map { |key, label| [label, key] }], params[:scope_type]), class: "ax-control ax-control--sm" %>
          </div>
          <div class="ax-span-2">
            <%= label_tag :rule_enabled, "Status", class: "ax-label tw-text-sm tw-font-bold tw-text-ink-muted text-uppercase" %>
            <%= select_tag :rule_enabled, options_for_select([["Todos", ""], ["Ativa", "true"], ["Inativa", "false"]], params[:rule_enabled]), class: "ax-control ax-control--sm" %>
          </div>
          <div class="ax-span-2">
            <%= label_tag :rule_profile_id, "Perfil", class: "ax-label tw-text-sm tw-font-bold tw-text-ink-muted text-uppercase" %>
            <%= select_tag :rule_profile_id, options_from_collection_for_select(@profiles, :id, :name, params[:rule_profile_id]), include_blank: "Todos", class: "ax-control ax-control--sm", data: { controller: "tom-select", tom_select_options_value: { placeholder: "Buscar perfil..." } } %>
          </div>
          <div class="ax-span-2">
            <%= label_tag :rule_admin_user_id, "Usuário", class: "ax-label tw-text-sm tw-font-bold tw-text-ink-muted text-uppercase" %>
            <%= select_tag :rule_admin_user_id, options_from_collection_for_select(@admin_users, :id, ->(user) { "#{user.name} · #{user.email}" }, params[:rule_admin_user_id]), include_blank: "Todos", class: "ax-control ax-control--sm", data: { controller: "tom-select", tom_select_options_value: { placeholder: "Buscar usuário..." } } %>
          </div>
          <div class="ax-span-2">
            <%= label_tag :rule_ip, "IP contém", class: "ax-label tw-text-sm tw-font-bold tw-text-ink-muted text-uppercase" %>
            <%= text_field_tag :rule_ip, params[:rule_ip], class: "ax-control ax-control--sm", placeholder: "127.0.0.1" %>
          </div>
          <div class="ax-span-2 tw-grid">
            <%= submit_tag "Filtrar", class: "ax-btn ax-btn--primary ax-btn--sm" %>
          </div>
          <div class="ax-span-2 tw-grid">
            <%= link_to "Limpar", admin_access_security_path(anchor: "rules-pane"), class: "ax-btn ax-btn--ghost ax-btn--sm" %>
          </div>
          <% end %>
        <% end %>
      </div>
      <div class="ax-table-wrap">
        <table class="ax-table">
          <thead>
            <tr>
              <th>Regra</th>
              <th>Tipo</th>
              <th>IP</th>
              <th>Aplicação</th>
              <th>Status</th>
              <th class="tw-text-right">Ações</th>
            </tr>
          </thead>
          <tbody>
            <% @rules.each do |rule| %>
              <tr>
                <td>
                  <div class="tw-font-semibold"><%= rule.name %></div>
                  <% if rule.description.present? %>
                    <div class="tw-text-sm tw-text-ink-muted"><%= rule.description %></div>
                  <% end %>
                </td>
                <td><%= rule.rule_type_label %></td>
                <td><code><%= rule.ip_value %></code></td>
                <td><%= rule.scope_label %></td>
                <td>
                  <span class="ax-badge <%= rule.enabled? ? 'ax-badge--green' : 'ax-badge--gray' %>"><%= rule.enabled? ? 'Ativa' : 'Inativa' %></span>
                </td>
                <td class="tw-text-right">
                  <%= form_with model: [:admin, rule], local: true, class: "d-inline" do |f| %>
                    <%= f.hidden_field :enabled, value: (!rule.enabled?).to_s %>
                    <%= f.submit(rule.enabled? ? "Desativar" : "Ativar", class: "ax-btn ax-btn--sm ax-btn--ghost") %>
                  <% end %>
                  <%= button_to "Remover", admin_access_control_rule_path(rule), method: :delete, class: "ax-btn ax-btn--sm ax-btn--danger", form: { class: "d-inline", data: { turbo_confirm: "Remover esta regra?" } } %>
                </td>
              </tr>
            <% end %>
            <% if @rules.empty? %>
              <tr><td colspan="6" class="tw-text-center tw-text-ink-muted py-4">Nenhuma regra cadastrada.</td></tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="tab-pane fade <%= @active_tab == "devices" ? "show active" : "" %>" id="devices-pane" role="tabpanel" aria-labelledby="devices-tab">
    <div class="ax-card" id="devices">
      <div class="ax-card__header">
        <h2 class="ax-card__title">Aparelhos identificados</h2>
      </div>
      <div class="ax-card__body border-bottom">
        <%= form_with url: admin_access_security_path, method: :get, local: true do %>
          <%= ax_field_grid do %>
          <div class="ax-span-2">
            <%= label_tag :device_status, "Status", class: "ax-label tw-text-sm tw-font-bold tw-text-ink-muted text-uppercase" %>
            <%= select_tag :device_status, options_for_select([["Todos", ""], *TrustedDevice::STATUSES.map { |key, label| [label, key] }], params[:device_status]), class: "ax-control ax-control--sm" %>
          </div>
          <div class="ax-span-2">
            <%= label_tag :device_profile_id, "Perfil", class: "ax-label tw-text-sm tw-font-bold tw-text-ink-muted text-uppercase" %>
            <%= select_tag :device_profile_id, options_from_collection_for_select(@profiles, :id, :name, params[:device_profile_id]), include_blank: "Todos", class: "ax-control ax-control--sm", data: { controller: "tom-select", tom_select_options_value: { placeholder: "Buscar perfil..." } } %>
          </div>
          <div class="ax-span-3">
            <%= label_tag :device_admin_user_id, "Usuário", class: "ax-label tw-text-sm tw-font-bold tw-text-ink-muted text-uppercase" %>
            <%= select_tag :device_admin_user_id, options_from_collection_for_select(@admin_users, :id, ->(user) { "#{user.name} · #{user.email}" }, params[:device_admin_user_id]), include_blank: "Todos", class: "ax-control ax-control--sm", data: { controller: "tom-select", tom_select_options_value: { placeholder: "Buscar usuário..." } } %>
          </div>
          <div class="ax-span-2">
            <%= label_tag :device_type, "Dispositivo", class: "ax-label tw-text-sm tw-font-bold tw-text-ink-muted text-uppercase" %>
            <%= select_tag :device_type, options_for_select([["Todos", ""]] + @available_device_types.map { |value| [value, value] }, params[:device_type]), class: "ax-control ax-control--sm", data: { controller: "tom-select", tom_select_options_value: { placeholder: "Buscar dispositivo..." } } %>
          </div>
          <div class="ax-span-2">
            <%= label_tag :device_browser, "Navegador", class: "ax-label tw-text-sm tw-font-bold tw-text-ink-muted text-uppercase" %>
            <%= select_tag :device_browser, options_for_select([["Todos", ""]] + @available_browsers.map { |value| [value, value] }, params[:device_browser]), class: "ax-control ax-control--sm", data: { controller: "tom-select", tom_select_options_value: { placeholder: "Buscar navegador..." } } %>
          </div>
          <div class="ax-span-2">
            <%= label_tag :device_ip, "IP", class: "ax-label tw-text-sm tw-font-bold tw-text-ink-muted text-uppercase" %>
            <%= text_field_tag :device_ip, params[:device_ip], class: "ax-control ax-control--sm", placeholder: "127.0.0.1" %>
          </div>
          <div class="ax-span-2 tw-grid">
            <%= submit_tag "Filtrar", class: "ax-btn ax-btn--primary ax-btn--sm" %>
          </div>
          <div class="ax-span-2 tw-grid">
            <%= link_to "Limpar", admin_access_security_path(anchor: "devices"), class: "ax-btn ax-btn--ghost ax-btn--sm" %>
          </div>
          <% end %>
        <% end %>
      </div>
      <div class="ax-table-wrap">
        <table class="ax-table">
          <thead>
            <tr>
              <th>Usuário</th>
              <th>Aparelho</th>
              <th>Último IP</th>
              <th>Status</th>
              <th>Último uso</th>
              <th class="tw-text-right">Ações</th>
            </tr>
          </thead>
          <tbody>
            <% @trusted_devices.each do |device| %>
              <tr>
                <td>
                  <div class="tw-font-semibold"><%= device.admin_user.name %></div>
                  <div class="tw-text-sm tw-text-ink-muted"><%= device.admin_user.email %></div>
                </td>
                <td>
                  <div><%= device.name.presence || device.device_label %></div>
                  <div class="tw-text-sm tw-text-ink-muted"><%= device.fingerprint.first(12) %>...</div>
                </td>
                <td><code><%= device.last_ip %></code></td>
                <td>
                  <% badge_class = { "trusted" => "ax-badge--green", "blocked" => "ax-badge--red", "pending" => "ax-badge--amber" }[device.status] || "ax-badge--gray" %>
                  <span class="ax-badge <%= badge_class %>"><%= device.status_label %></span>
                </td>
                <td><%= l(device.last_seen_at || device.created_at, format: :short) %></td>
                <td class="tw-text-right">
                  <%= button_to "Aprovar", admin_trusted_device_path(device, status: "trusted"), method: :patch, class: "ax-btn ax-btn--sm ax-btn--primary", form: { class: "d-inline" } unless device.status == "trusted" %>
                  <%= button_to "Bloquear", admin_trusted_device_path(device, status: "blocked"), method: :patch, class: "ax-btn ax-btn--sm ax-btn--danger", form: { class: "d-inline" } unless device.status == "blocked" %>
                  <%= button_to "Remover", admin_trusted_device_path(device), method: :delete, class: "ax-btn ax-btn--sm ax-btn--ghost", form: { class: "d-inline", data: { turbo_confirm: "Remover este aparelho?" } } %>
                </td>
              </tr>
            <% end %>
            <% if @trusted_devices.empty? %>
              <tr><td colspan="6" class="tw-text-center tw-text-ink-muted py-4">Nenhum aparelho identificado ainda.</td></tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
