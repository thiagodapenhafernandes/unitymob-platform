<div class="container-fluid py-3 seo-editor-shell">
  <div class="tw-flex tw-justify-between tw-items-center tw-mb-3 tw-flex-wrap tw-gap-2">
    <div>
      <h1 class="ax-page-title"><i class="bi bi-search tw-text-primary"></i> Editar SEO</h1>
      <p class="ax-page-subtitle"><%= @seo_setting.display_name %></p>
    </div>
    <div class="tw-flex tw-gap-2">
      <%= link_to admin_seo_settings_path, class: "ax-btn ax-btn--ghost ax-btn--sm tw-gap-2" do %>
        <i class="bi bi-arrow-left"></i>Voltar
      <% end %>
      <%= button_to generate_ai_admin_seo_setting_path(@seo_setting),
          method: :post,
          class: "ax-btn ax-btn--ghost ax-btn--sm tw-gap-2",
          data: { turbo_submits_with: "Gerando..." } do %>
        <i class="bi bi-stars"></i>Gerar com IA
      <% end %>
    </div>
  </div>

  <%= render "form", seo_setting: @seo_setting %>
</div>
