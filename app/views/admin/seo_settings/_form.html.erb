<%
  current_base_url = request.base_url
  public_url = seo_setting.public_url(current_base_url)
  effective_og_image = seo_setting.social_image_url(base_url: current_base_url)
  meta_title_value = seo_setting.meta_title.presence || seo_setting.og_title.presence || seo_setting.display_name
  meta_description_value = seo_setting.meta_description.presence || seo_setting.og_description
  title_length = meta_title_value.to_s.length
  description_length = meta_description_value.to_s.length
  intro_word_count = seo_setting.intro_text.to_s.scan(/\S+/).size
  listing_page = seo_setting.page_type.to_s.in?(%w[property_listing property_landing developments_index development_landing])
  readability = local_assigns[:readability] || (defined?(@readability) && @readability) || Seo::ReadabilityAnalyzer.new(seo_setting).call
  internal_link_suggestions = local_assigns[:internal_link_suggestions] || (defined?(@internal_link_suggestions) && @internal_link_suggestions) || []
  change_logs = local_assigns[:change_logs] || (defined?(@change_logs) && @change_logs) || []
%>

<div id="seo-setting-form" class="seo-editor-page">
<%= form_with(model: [:admin, seo_setting], local: true, data: { controller: "seo-editor" }) do |f| %>
  <% if local_assigns[:ai_message].present? %>
    <%= ax_inline_notice(tone: (local_assigns[:ai_message_type].presence || "info").to_sym, icon: "info-circle") do %>
      <%= local_assigns[:ai_message] %>
    <% end %>
  <% end %>

  <%= ax_error_summary(seo_setting) %>

  <div class="seo-editor-grid">
    <div class="seo-editor-main">
      <% technical_actions = ax_badge(seo_setting.auto_discovered? ? "Auto descoberta" : "Manual", tone: seo_setting.auto_discovered? ? :blue : :gray) %>
      <%= ax_operational_panel(eyebrow: "Base técnica", title: "Identificação técnica", actions: technical_actions) do %>
        <p class="seo-editor-section-intro">Chaves, URL canônica e tipo estrutural da página monitorada.</p>

        <%= ax_field_grid do %>
          <div class="ax-span-6">
            <%= f.label :page_name, "Nome interno", class: "ax-label" %>
            <%= f.text_field :page_name, class: "ax-control ax-control--sm" %>
          </div>
          <div class="ax-span-6">
            <%= f.label :canonical_key, "Chave canônica", class: "ax-label" %>
            <%= f.text_field :canonical_key, class: "ax-control ax-control--sm" %>
          </div>
          <div class="ax-span-4">
            <%= f.label :page_type, "Tipo", class: "ax-label" %>
            <%= f.text_field :page_type, class: "ax-control ax-control--sm" %>
          </div>
          <div class="ax-span-8">
            <%= f.label :canonical_url, "Canonical URL", class: "ax-label" %>
            <%= f.text_field :canonical_url, class: "ax-control ax-control--sm", data: { seo_field: "canonical" } %>
          </div>
        <% end %>
      <% end %>

      <%= ax_operational_panel(eyebrow: "Buscadores", title: "Snippet para buscadores", actions: ax_badge("Score #{seo_setting.seo_score.to_i}", tone: :gray)) do %>
        <p class="seo-editor-section-intro">Título, descrição, keywords foco e texto introdutório usados na busca orgânica.</p>

        <%= ax_field_grid do %>
          <div class="ax-span-12">
            <div class="seo-editor-field-head">
              <%= f.label :meta_title, "Meta title", class: "ax-label" %>
              <span class="seo-editor-counter"><span data-seo-count="title"><%= title_length %></span>/65</span>
            </div>
            <%= f.text_field :meta_title, class: "ax-control", data: { seo_field: "title" } %>
          </div>
          <div class="ax-span-12">
            <div class="seo-editor-field-head">
              <%= f.label :meta_description, "Meta description", class: "ax-label" %>
              <span class="seo-editor-counter"><span data-seo-count="description"><%= description_length %></span>/160</span>
            </div>
            <%= f.text_area :meta_description, rows: 3, class: "ax-control", data: { seo_field: "description" } %>
          </div>
          <div class="ax-span-12">
            <%= f.label :meta_keywords, "Keywords e foco", class: "ax-label" %>
            <%= f.text_area :meta_keywords, rows: 2, class: "ax-control", placeholder: "Separe por vírgulas. A primeira keyword será tratada como foco principal.", data: { seo_field: "keywords" } %>
          </div>
          <div class="ax-span-12">
            <%= f.label :focus_keyword_list, "Keywords foco persistidas", class: "ax-label" %>
            <%= f.text_field :focus_keyword_list,
                value: seo_setting.focus_keyword_list.presence || seo_setting.meta_keywords,
                class: "ax-control",
                placeholder: "Até 5 termos, separados por vírgula",
                data: { seo_field: "focusKeywords" } %>
            <div class="seo-editor-note">Essas keywords alimentam a análise, sugestões de links internos e futuras gerações com IA.</div>
          </div>
          <div class="ax-span-12">
            <div class="seo-editor-field-head">
              <%= f.label :intro_text, "Texto introdutório da página", class: "ax-label" %>
              <span class="seo-editor-counter"><span data-seo-count="intro"><%= intro_word_count %></span> palavras</span>
            </div>
            <%= f.text_area :intro_text, rows: 5, class: "ax-control", placeholder: "Use 150 a 250 palavras para páginas de listagem estratégicas. Esse texto aparece acima dos imóveis/empreendimentos.", data: { seo_field: "intro", listing: listing_page } %>
            <div class="seo-editor-note">Para listagens indexáveis, explique intenção da busca, diferenciais da região e caminhos para filtros relacionados.</div>
          </div>
        <% end %>
      <% end %>

      <%= ax_operational_panel(eyebrow: "Social", title: "Compartilhamento social") do %>
        <p class="seo-editor-section-intro">Open Graph e imagem usados nos compartilhamentos externos.</p>

        <%= ax_field_grid do %>
          <div class="ax-span-6">
            <%= f.label :og_title, "Open Graph title", class: "ax-label" %>
            <%= f.text_field :og_title, class: "ax-control", data: { seo_field: "ogTitle" } %>
          </div>
          <div class="ax-span-6">
            <%= f.label :og_image_file, "Imagem OG", class: "ax-label" %>
            <%= f.file_field :og_image_file, class: "ax-control" %>
            <div class="seo-editor-note">Fallback automático: primeira imagem do imóvel ou logo quadrada da Salute.</div>
          </div>
          <div class="ax-span-12">
            <%= f.label :og_description, "Open Graph description", class: "ax-label" %>
            <%= f.text_area :og_description, rows: 2, class: "ax-control", data: { seo_field: "ogDescription" } %>
          </div>
        <% end %>
      <% end %>

      <%= ax_operational_panel(eyebrow: "Publicação", title: "Controle público") do %>
        <p class="seo-editor-section-intro">Flags operacionais que definem ativação, exposição pública e indexação.</p>

        <%= ax_field_grid(class_name: "seo-editor-toggle-grid") do %>
          <% [["active", "Ativo"], ["apply_to_public", "Usar na página pública"], ["manual_mode", "Manual"], ["robots_index", "Index"], ["robots_follow", "Follow"]].each do |field, label| %>
            <div class="ax-span-4">
              <%= ax_toggle_chip(f, field.to_sym, label:, class_name: "ax-toggle-chip--full", input_data: { seo_field: field }) %>
            </div>
          <% end %>
        <% end %>
      <% end %>

      <% if seo_setting.ai_insights.present? %>
        <%= ax_inline_notice(tone: :info, icon: "lightbulb") do %>
          <strong>Insights da IA:</strong>
          <div class="tw-mt-2" style="white-space: pre-line;"><%= seo_setting.ai_insights %></div>
        <% end %>
      <% end %>

      <%= ax_sticky_action_footer(meta: content_tag(:span, "Salvamento aplica SEO público, leitura de score e prévias desta página.", class: "seo-editor-footer-meta")) do %>
        <%= ax_button("Cancelar", admin_seo_settings_path, variant: :ghost) %>
        <%= f.submit "Salvar SEO", class: "ax-btn ax-btn--primary" %>
      <% end %>
    </div>

    <aside class="seo-editor-side">
      <% analysis_actions = ax_badge(seo_setting.score_label, tone: seo_setting.seo_score.to_i >= 80 ? :green : seo_setting.seo_score.to_i >= 60 ? :amber : :red) %>
      <%= ax_operational_panel(eyebrow: "Análise SEO", title: seo_setting.seo_score.to_i.to_s, actions: analysis_actions, class_name: "seo-sticky-panel") do %>
        <div class="seo-checklist">
          <div class="seo-check" data-seo-check="title"><i class="bi bi-circle-fill"></i><span>Título com tamanho competitivo</span></div>
          <div class="seo-check" data-seo-check="description"><i class="bi bi-circle-fill"></i><span>Descrição clara para clique</span></div>
          <div class="seo-check" data-seo-check="keyword"><i class="bi bi-circle-fill"></i><span>Keyword foco presente</span></div>
          <div class="seo-check" data-seo-check="canonical"><i class="bi bi-circle-fill"></i><span>URL canônica definida</span></div>
          <div class="seo-check" data-seo-check="intro"><i class="bi bi-circle-fill"></i><span>Texto introdutório em listagens</span></div>
          <div class="seo-check" data-seo-check="index"><i class="bi bi-circle-fill"></i><span>Página liberada para indexação</span></div>
        </div>

        <div class="seo-editor-divider"></div>

        <div class="seo-editor-readability-head">
          <div>
            <div class="seo-editor-kicker">Legibilidade</div>
            <div class="seo-editor-readability-score"><%= readability.score %> - <%= readability.label %></div>
          </div>
          <i class="bi bi-body-text seo-editor-readability-icon"></i>
        </div>

        <div class="seo-checklist">
          <% readability.checks.each do |_key, item| %>
            <div class="seo-check <%= item[:ok] ? "is-ok" : "is-warning" %>">
              <i class="bi bi-circle-fill"></i>
              <span><%= item[:message] %></span>
            </div>
          <% end %>
        </div>

        <div class="seo-editor-divider"></div>

        <div class="seo-editor-action-stack">
          <%= ax_button("Abrir página pública", public_url, variant: :ghost, size: :sm, icon: "box-arrow-up-right", target: "_blank", rel: "noopener", class_name: "tw-gap-2") %>
          <%= ax_button("Ver sitemap", "#{current_base_url}/sitemap.xml", variant: :ghost, size: :sm, icon: "diagram-3", target: "_blank", rel: "noopener", class_name: "tw-gap-2") %>
        </div>
      <% end %>

      <%= ax_operational_panel(eyebrow: "Preview", title: "Prévia no Google") do %>
        <div class="seo-serp-preview">
          <div class="seo-serp-url"><%= public_url %></div>
          <div class="seo-serp-title" data-seo-preview="title"><%= meta_title_value.presence || "Título da página" %></div>
          <div class="seo-serp-description" data-seo-preview="description"><%= meta_description_value.presence || "Descrição que aparecerá nos resultados de busca." %></div>
        </div>
      <% end %>

      <%= ax_operational_panel(eyebrow: "Preview", title: "Prévia social") do %>
        <div class="seo-social-preview">
          <% if effective_og_image.present? %>
            <%= image_tag effective_og_image, alt: "Imagem atual para compartilhamento", class: "seo-social-image" %>
          <% end %>
          <div class="seo-social-copy">
            <div class="seo-social-domain"><%= URI.parse(current_base_url).host rescue current_base_url %></div>
            <div class="seo-social-title" data-seo-preview="ogTitle"><%= seo_setting.og_title.presence || meta_title_value.presence || "Título social" %></div>
            <div class="seo-social-description" data-seo-preview="ogDescription"><%= seo_setting.og_description.presence || meta_description_value.presence || "Descrição social." %></div>
          </div>
        </div>
      <% end %>

      <%= ax_operational_panel(eyebrow: "Relacionamento", title: "Links internos sugeridos") do %>
        <% if internal_link_suggestions.any? %>
          <div class="seo-link-suggestions">
            <% internal_link_suggestions.each do |suggestion| %>
              <%= link_to suggestion.url, target: "_blank", rel: "noopener", class: "seo-link-suggestion" do %>
                <span class="tw-font-semibold tw-truncate"><%= suggestion.title %></span>
                <small><%= suggestion.reason %></small>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <p class="seo-editor-empty-copy">Adicione keywords foco para receber sugestões melhores.</p>
        <% end %>
      <% end %>

      <%= ax_operational_panel(eyebrow: "Auditoria", title: "Histórico") do %>
        <% if change_logs.any? %>
          <div class="seo-history-list">
            <% change_logs.each do |log| %>
              <div class="seo-history-item">
                <div class="tw-flex tw-justify-between tw-gap-2">
                  <strong><%= log.event_type == "ai_generate" ? "IA" : "Edição" %></strong>
                  <small class="tw-text-ink-muted"><%= l(log.created_at, format: :short) %></small>
                </div>
                <div class="tw-text-sm tw-text-ink-muted">
                  <%= log.admin_user&.try(:name).presence || log.admin_user&.email.presence || "Sistema" %>
                  alterou <%= pluralize(log.changed_fields.keys.size, "campo") %>.
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="seo-editor-empty-copy">Nenhuma alteração registrada ainda.</p>
        <% end %>
      <% end %>
    </aside>
  </div>
<% end %>

</div>
