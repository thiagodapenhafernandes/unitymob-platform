<div class="container-fluid py-3">
  <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
      <h1 class="h3 mb-1 text-gray-800"><i class="bi bi-house-heart me-2 text-primary"></i>Imóveis com Potencial</h1>
      <p class="text-muted small mb-0">Imóveis que merecem campanha, melhoria de foto ou reforço comercial.</p>
    </div>
    <%= link_to admin_marketing_opportunities_path, class: "btn btn-sm btn-outline-primary" do %>
      <i class="bi bi-lightbulb me-1"></i>Oportunidades
    <% end %>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Imóvel</th>
            <th>Local</th>
            <th class="text-center">Interações</th>
            <th class="text-center">Leads</th>
            <th class="text-center">Potencial</th>
            <th>Motivos</th>
            <th class="text-end">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% @property_insights.each do |item| %>
            <% habitation = item.habitation %>
            <tr>
              <td>
                <div class="fw-bold"><%= truncate(habitation.display_title, length: 56) %></div>
                <div class="small text-muted">Cód. <%= habitation.codigo.presence || habitation.id %></div>
              </td>
              <td class="small text-muted"><%= [habitation.bairro, habitation.cidade].compact_blank.join(" - ") %></td>
              <td class="text-center fw-bold"><%= item.page_views %></td>
              <td class="text-center fw-bold"><%= item.lead_count %></td>
              <td class="text-center"><span class="badge bg-success"><%= item.score %></span></td>
              <td>
                <div class="d-flex flex-wrap gap-1">
                  <% item.reasons.each do |reason| %>
                    <span class="badge bg-light text-dark border"><%= reason %></span>
                  <% end %>
                </div>
              </td>
              <td class="text-end">
                <%= link_to "Ver site", habitation_path(habitation), target: "_blank", rel: "noopener", class: "btn btn-sm btn-outline-secondary" %>
                <%= link_to admin_habitation_internal_action_label(habitation), admin_habitation_internal_path(habitation), class: "btn btn-sm btn-outline-primary" %>
              </td>
            </tr>
          <% end %>
          <% if @property_insights.blank? %>
            <tr><td colspan="7" class="text-center text-muted py-5">Nenhum imóvel priorizado agora.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
