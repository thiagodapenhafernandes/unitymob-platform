<%# Imóveis com Potencial — listagem compacta (.ax-*). Original em index.html.erb.bootstrap-bak %>
<div class="marketing-admin-dark">
<%= ax_workspace_heading(
      eyebrow: "Marketing · Priorização",
      icon: "buildings",
      title: "Imóveis com Potencial",
      subtitle: "Imóveis que merecem campanha, melhoria de foto ou reforço comercial.",
      metrics: [{ value: @property_insights.size, label: "priorizados" }],
      actions: ax_button("Oportunidades", admin_marketing_opportunities_path, size: :sm, icon: "lightbulb")
    ) %>

<%= ax_operational_panel(eyebrow: "Desempenho", title: "Prioridades comerciais") do %>
<div class="ax-table-wrap">
  <table class="ax-table">
    <thead>
      <tr>
        <th>Imóvel</th>
        <th class="ax-table__col--w-180">Local</th>
        <th class="ax-num ax-table__col--w-100">Interações</th>
        <th class="ax-num ax-table__col--w-80">Leads</th>
        <th class="ax-num ax-table__col--compact">Potencial</th>
        <th>Motivos</th>
        <th class="ax-num ax-table__col--w-140">Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @property_insights.each do |item| %>
        <% habitation = item.habitation %>
        <tr>
          <td>
            <div class="ax-strong"><%= truncate(habitation.display_title, length: 56) %></div>
            <div class="tw-text-2xs tw-text-ink-faint">Cód. <%= habitation.codigo.presence || habitation.id %></div>
          </td>
          <td><%= [habitation.bairro, habitation.cidade].compact_blank.join(" - ").presence || "—" %></td>
          <td class="ax-num ax-strong"><%= item.page_views %></td>
          <td class="ax-num ax-strong"><%= item.lead_count %></td>
          <td class="ax-num"><span class="ax-badge ax-badge--green"><%= item.score %></span></td>
          <td>
            <div class="tw-flex tw-flex-wrap tw-gap-1">
              <% item.reasons.each do |reason| %><span class="ax-badge ax-badge--gray"><%= reason %></span><% end %>
            </div>
          </td>
          <td class="ax-num">
            <span class="tw-inline-flex tw-gap-1">
              <%= link_to "Site", habitation_path(habitation), target: "_blank", rel: "noopener", class: "ax-btn ax-btn--sm" %>
              <%= link_to admin_habitation_internal_action_label(habitation), admin_habitation_internal_path(habitation), class: "ax-btn ax-btn--sm ax-btn--primary" %>
            </span>
          </td>
        </tr>
      <% end %>
      <% if @property_insights.blank? %>
        <tr><td colspan="7"><%= ax_empty_state(title: "Nenhum imóvel priorizado agora", description: "As prioridades aparecerão quando houver sinais suficientes de tráfego, leads ou oportunidade comercial.", icon: "buildings", compact: true) %></td></tr>
      <% end %>
    </tbody>
  </table>
</div>
<% end %>
</div>
