<%# Eventos da Automação — observabilidade do pipeline horizontal %>
<%= ax_workspace_heading(
      eyebrow: "Automações · Observabilidade",
      icon: "activity",
      title: "Eventos da Automação",
      subtitle: "Acompanhe o que a plataforma observou, processou e disparou nas intervenções horizontais.",
      actions: safe_join([
        ax_button("Voltar para automação", admin_automation_rules_path, size: :sm, icon: "arrow-left"),
        ax_button("Nova intervenção", new_admin_automation_rule_path, variant: :primary, size: :sm, icon: "diagram-3")
      ])
    ) %>

<%= render "admin/shared/module_objective_notice",
      icon: "activity",
      eyebrow: "Observabilidade",
      description: "Use esta tela para entender por que uma automação rodou, ficou pendente ou falhou. Ela mostra eventos da jornada do lead depois que ele existe; regras de fila, destino, responsável, aceite e represamento continuam na Distribuição de Leads." %>

<div class="ax-metric-grid tw-mb-4">
  <%= ax_metric_card(label: "Processados", value: number_with_delimiter(@processed_count)) %>
  <%= ax_metric_card(label: "Pendentes", value: number_with_delimiter(@pending_count)) %>
  <%= ax_metric_card(label: "Erros", value: number_with_delimiter(@failed_count)) %>
  <%= ax_metric_card(label: "Tipos observados", value: number_with_delimiter(@event_counts.keys.size)) %>
</div>

<%= ax_filter_form(url: admin_automation_events_path, reset_path: admin_automation_events_path, submit_label: "Filtrar", class_name: "tw-mb-4") do |_form| %>
  <%= ax_field_grid do %>
    <div class="ax-span-3">
      <label class="ax-label" for="automation_event_q">Buscar</label>
      <%= text_field_tag :q, @q, id: "automation_event_q", class: "ax-control", placeholder: "Lead, telefone, evento ou chave" %>
    </div>
    <div class="ax-span-3">
      <label class="ax-label" for="automation_event_status">Status</label>
      <%= select_tag :status,
            options_for_select([["Todos", ""]] + AutomationEvent::STATUSES.map { |status| [AutomationEvent.new(status: status).status_label, status] }, @status),
            id: "automation_event_status",
            class: "ax-control" %>
    </div>
    <div class="ax-span-3">
      <label class="ax-label" for="automation_event_event">Evento</label>
      <%= select_tag :event,
            options_for_select([["Todos", ""]] + Automation::EventCatalog.names.map { |name| ["#{Automation::EventCatalog.label(name)} (#{@event_counts.fetch(name, 0)})", name] }, @event_name),
            id: "automation_event_event",
            class: "ax-control" %>
    </div>
    <div class="ax-span-3">
      <label class="ax-label" for="automation_event_source">Origem técnica</label>
      <%= select_tag :source,
            options_for_select([["Todas", ""]] + @source_options.map { |source| [AutomationEvent.new(source: source).source_label, source] }, @source),
            id: "automation_event_source",
            class: "ax-control" %>
    </div>
  <% end %>
<% end %>

<% if @events.any? %>
  <%= ax_operational_panel(eyebrow: "Pipeline", title: "Eventos observados") do %>
  <div class="ax-table-wrap">
    <table class="ax-table">
      <thead>
        <tr>
          <th class="ax-table__col--w-150">Quando</th>
          <th>Evento</th>
          <th>Lead</th>
          <th class="ax-table__col--w-120">Status</th>
          <th class="ax-table__col--w-130">Disparos</th>
          <th>Detalhes</th>
          <th class="ax-table__col--w-180">Operação</th>
        </tr>
      </thead>
      <tbody>
        <% @events.each do |event| %>
          <tr>
            <td>
              <strong><%= event.occurred_at.strftime("%d/%m/%Y") %></strong><br>
              <span class="ax-page-subtitle"><%= event.occurred_at.strftime("%H:%M:%S") %></span>
            </td>
            <td>
              <div class="tw-flex tw-flex-wrap tw-items-center tw-gap-2">
                <span class="ax-strong"><%= event.name_label %></span>
                <span class="ax-badge ax-badge--gray"><%= event.source_label %></span>
              </div>
              <div class="ax-page-subtitle tw-mt-1"><%= Automation::EventCatalog.description(event.name).presence || event.name %></div>
            </td>
            <td>
              <% if event.lead %>
                <%= link_to event.lead.display_name, admin_lead_path(event.lead), class: "tw-text-primary ax-strong" %><br>
                <span class="ax-page-subtitle"><%= event.lead.display_phone.presence || event.lead.display_email.presence || "sem contato" %></span>
              <% else %>
                <span class="ax-page-subtitle">Lead removido</span>
              <% end %>
            </td>
            <td>
              <span class="ax-badge ax-badge--<%= event.status_color %>"><%= event.status_label %></span>
              <% if event.processed_at.present? %>
                <div class="ax-page-subtitle tw-mt-1"><%= event.processed_at.strftime("%d/%m %H:%M") %></div>
              <% end %>
            </td>
            <td>
              <span class="ax-badge ax-badge--blue"><%= event.automation_runs.size %> regra(s)</span>
              <span class="ax-badge ax-badge--green tw-mt-1"><%= event.automation_executions.size %> fluxo(s)</span>
            </td>
            <td>
              <% if event.error_message.present? %>
                <%= ax_inline_notice(tone: :danger, icon: "exclamation-triangle", class_name: "tw-mb-2") do %>
                  <%= truncate(event.error_message, length: 180) %>
                <% end %>
              <% end %>
              <% if event.payload_hash.present? || event.idempotency_key.present? %>
                <details>
                  <summary class="tw-text-sm tw-font-semibold tw-cursor-pointer">Ver payload</summary>
                  <% if event.idempotency_key.present? %>
                    <div class="ax-page-subtitle tw-mt-2">Chave: <code><%= event.idempotency_key %></code></div>
                  <% end %>
                  <% if event.payload_hash.present? %>
                    <pre class="tw-mt-2 tw-text-xs tw-overflow-auto"><%= JSON.pretty_generate(event.payload_hash) %></pre>
                  <% end %>
                </details>
              <% else %>
                <span class="ax-page-subtitle">Sem payload adicional</span>
              <% end %>
            </td>
            <td>
              <% if event.lead && event.reprocessable? %>
                <%= button_to reprocess_admin_automation_event_path(event), method: :post, class: "ax-btn ax-btn--sm tw-w-full tw-mb-2" do %>
                  <i class="bi bi-arrow-clockwise ax-ico"></i><span>Reprocessar</span>
                <% end %>
              <% end %>
              <% unless event.ignored? %>
                <details>
                  <summary class="tw-text-sm tw-font-semibold tw-cursor-pointer">Ignorar</summary>
                  <%= form_with url: ignore_admin_automation_event_path(event), method: :patch, local: true, class: "tw-mt-2 tw-grid tw-gap-2" do %>
                    <%= text_field_tag :reason, nil, class: "ax-control", placeholder: "Motivo" %>
                    <%= button_tag type: "submit", class: "ax-btn ax-btn--sm ax-btn--danger", data: { turbo_confirm: "Ignorar este evento?" } do %>
                      <i class="bi bi-slash-circle ax-ico"></i><span>Ignorar evento</span>
                    <% end %>
                  <% end %>
                </details>
              <% else %>
                <span class="ax-page-subtitle">Evento ignorado</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <% end %>

  <%= ax_pagination(@events) %>
<% else %>
  <%= ax_empty_state(
        title: "Nenhum evento encontrado",
        description: "Quando leads, propostas ou rotinas gerarem eventos de acompanhamento, eles aparecerão aqui.",
        icon: "activity",
        action: link_to("Limpar filtros", admin_automation_events_path, class: "ax-btn ax-btn--sm")
      ) %>
<% end %>
