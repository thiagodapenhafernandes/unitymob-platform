<%# Redirects SEO — compacto (.ax-*) com forms inline. Original em index.html.erb.bootstrap-bak %>
<div class="tw-flex tw-flex-wrap tw-items-center tw-justify-between tw-gap-3 tw-mb-4">
  <div>
    <h1 class="ax-page-title">Redirects SEO</h1>
    <p class="ax-page-subtitle">Corrija URLs antigas, evite 404 e preserve autoridade de páginas movidas.</p>
  </div>
  <%= link_to admin_seo_settings_path, class: "ax-btn ax-btn--sm" do %>
    <i class="bi bi-arrow-left ax-ico"></i><span>SEO Técnico</span>
  <% end %>
</div>

<div class="ax-card tw-mb-3">
  <div class="ax-card__body">
    <%= form_with model: [:admin, @seo_redirect], local: true do |f| %>
      <% if @seo_redirect.errors.any? %>
        <div class="tw-mb-2 tw-text-red-600 tw-text-2xs"><%= @seo_redirect.errors.full_messages.to_sentence %></div>
      <% end %>
      <div class="tw-flex tw-flex-wrap tw-items-end tw-gap-3">
        <div class="tw-flex-1 tw-min-w-[180px]">
          <%= f.label :from_path, "URL antiga", class: "ax-label" %>
          <%= f.text_field :from_path, class: "ax-input", placeholder: "/imoveis-antigo" %>
        </div>
        <div class="tw-flex-1 tw-min-w-[180px]">
          <%= f.label :to_path, "URL destino", class: "ax-label" %>
          <%= f.text_field :to_path, class: "ax-input", placeholder: "/imoveis" %>
        </div>
        <div class="tw-w-32">
          <%= f.label :status_code, "Tipo", class: "ax-label" %>
          <%= f.select :status_code, SeoRedirect::VALID_STATUS_CODES, {}, class: "ax-select" %>
        </div>
        <label class="tw-inline-flex tw-items-center tw-gap-1.5 tw-text-sm tw-text-ink-soft tw-h-[34px]">
          <%= f.check_box :active %> Ativo
        </label>
        <%= f.submit "Criar", class: "ax-btn ax-btn--primary" %>
      </div>
    <% end %>
  </div>
</div>

<div class="ax-table-wrap">
  <table class="ax-table">
    <thead>
      <tr>
        <th>Origem</th>
        <th>Destino</th>
        <th style="width:90px">Tipo</th>
        <th class="ax-num" style="width:120px">Hits</th>
        <th style="width:90px">Status</th>
        <th class="ax-num" style="width:140px">Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @seo_redirects.each do |redirect| %>
        <tr>
          <%= form_with model: [:admin, redirect], local: true do |f| %>
            <td><%= f.text_field :from_path, class: "ax-input" %></td>
            <td><%= f.text_field :to_path, class: "ax-input" %></td>
            <td><%= f.select :status_code, SeoRedirect::VALID_STATUS_CODES, {}, class: "ax-select" %></td>
            <td class="ax-num">
              <div class="ax-strong"><%= redirect.hit_count %></div>
              <div class="tw-text-2xs tw-text-ink-faint"><%= redirect.last_hit_at ? l(redirect.last_hit_at, format: :short) : "sem acesso" %></div>
            </td>
            <td>
              <label class="tw-inline-flex tw-items-center tw-gap-1.5 tw-text-2xs tw-text-ink-soft">
                <%= f.check_box :active %> <%= redirect.active? ? "Ativo" : "Off" %>
              </label>
            </td>
            <td class="ax-num">
              <div class="tw-inline-flex tw-gap-1">
                <%= f.submit "Salvar", class: "ax-btn ax-btn--sm" %>
                <%= link_to admin_seo_redirect_path(redirect), class: "ax-ico-btn", data: { turbo_method: :delete, turbo_confirm: "Remover este redirect?" }, title: "Remover" do %><i class="bi bi-trash"></i><% end %>
              </div>
            </td>
          <% end %>
        </tr>
      <% end %>
      <% if @seo_redirects.empty? %>
        <tr><td colspan="6"><div class="ax-empty">Nenhum redirect cadastrado.</div></td></tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if @seo_redirects.respond_to?(:total_pages) && @seo_redirects.total_pages > 1 %>
  <%= ax_pagination @seo_redirects, params: request.query_parameters %>
<% end %>
