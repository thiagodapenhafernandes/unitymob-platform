<% content_for :title, "Auditoria · Apresentações no WhatsApp" %>

<%= ax_workspace_heading(
      eyebrow: "Segurança · Rastreabilidade",
      title: "Adesão de apresentação",
      subtitle: "Envios do cartão de apresentação no atendimento WhatsApp — corretor, conversa/lead, cartão, data e formato. Somente leitura; cobre conversas com e sem lead.",
      icon: "person-badge"
    ) %>

<div class="ax-metric-grid tw-mb-3">
  <%= ax_metric_card(label: "Apresentações enviadas", value: @total_sent) %>
  <%= ax_metric_card(label: "Corretores distintos", value: @distinct_brokers) %>
  <%= ax_metric_card(label: "Com foto", value: @with_photo) %>
  <%= ax_metric_card(label: "Sem lead vinculado", value: @without_lead) %>
</div>

<%= ax_filter_form(
      url: admin_presentation_audit_logs_path,
      reset_path: admin_presentation_audit_logs_path,
      filter_label: "Filtros da auditoria de apresentações",
      class_name: "tw-mb-3",
      data: { controller: "auto-submit" }
    ) do |_form| %>
    <%= ax_field_grid do %>
      <div class="ax-span-4">
        <%= label_tag :admin_user_id, "Corretor", class: "ax-label" %>
        <%= select_tag :admin_user_id,
              options_from_collection_for_select(@available_users, :id, :name, params[:admin_user_id]),
              include_blank: "Todos",
              class: "ax-control ax-control--sm",
              data: { controller: "tom-select", tom_select_options_value: { placeholder: "Buscar corretor..." }, action: "change->auto-submit#submit" } %>
      </div>
      <div class="ax-span-3">
        <%= label_tag :start_date, "De", class: "ax-label" %>
        <%= date_field_tag :start_date, params[:start_date], class: "ax-control ax-control--sm", data: { action: "change->auto-submit#submit" } %>
      </div>
      <div class="ax-span-3">
        <%= label_tag :end_date, "Até", class: "ax-label" %>
        <%= date_field_tag :end_date, params[:end_date], class: "ax-control ax-control--sm", data: { action: "change->auto-submit#submit" } %>
      </div>
    <% end %>
<% end %>

<%= ax_operational_panel(eyebrow: "Histórico", title: "Apresentações registradas") do %>
    <div class="ax-table-wrap">
      <table class="ax-table">
        <caption>Envios de cartões de apresentação no atendimento WhatsApp</caption>
        <thead>
          <tr><th scope="col">Corretor</th><th scope="col">Lead / conversa</th><th scope="col">Cartão</th><th scope="col">Data e hora</th><th scope="col">Formato</th></tr>
        </thead>
        <tbody>
          <% @logs.each do |log| %>
            <% conversation = log.whatsapp_conversation %>
            <tr>
              <td class="ax-strong"><%= log.admin_user&.name || "—" %></td>
              <td>
                <% if conversation&.lead %>
                  <%= link_to conversation.lead.display_name, admin_lead_path(conversation.lead), class: "tw-text-primary" %>
                <% else %>
                  <span class="tw-text-ink-muted">Sem lead</span>
                <% end %>
                <% if conversation %>
                  · <%= link_to (conversation.display_name.presence || "conversa ##{conversation.id}"), admin_whatsapp_conversation_path(conversation), class: "tw-text-primary" %>
                <% end %>
              </td>
              <td>
                <%= log.presentation_card&.label || "—" %>
                <%= ax_badge("Sistema", tone: :blue) if log.presentation_card&.system? %>
              </td>
              <td><%= l(log.created_at, format: "%d/%m/%Y %H:%M") %></td>
              <td><%= log.msg_type == "image" ? ax_badge("Imagem", tone: :blue) : ax_badge("Texto", tone: :gray) %></td>
            </tr>
          <% end %>
          <% if @logs.empty? %>
            <tr>
              <td colspan="5"><%= ax_empty_state(
                    title: "Nenhuma apresentação no período",
                    description: "Ajuste os filtros ou aguarde os corretores se apresentarem nas conversas.",
                    icon: "person-badge",
                    compact: true
                  ) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
<% end %>

<% if @logs.respond_to?(:total_pages) && @logs.total_pages > 1 %>
  <%= ax_pagination @logs, params: request.query_parameters %>
<% end %>
