<style>
  .access-audit-row {
    border-bottom: 1px solid var(--ax-border-soft);
    padding: .9rem 0;
  }
  .access-audit-row:last-child { border-bottom: 0; }
  .access-audit-title { color: var(--admin-ink); font-weight: 700; }
  .access-audit-meta { color: var(--ab-muted); font-size: .82rem; }
  .access-audit-path {
    font-family: monospace;
    font-size: .78rem;
    color: var(--ab-muted);
    word-break: break-all;
  }
</style>

<%= ax_page_header(
      title: "Auditoria de Acessos",
      subtitle: "Log append-only de autenticação, tentativas negadas e acessos a áreas sensíveis. A navegação administrativa comum não é registrada.",
      icon: "person-lock"
    ) %>

<div class="ax-metric-grid tw-mb-3" aria-label="Resumo da auditoria de acessos">
  <%= ax_metric_card(label: "Eventos filtrados", value: @total_events) %>
  <%= ax_metric_card(label: "Permitidos", value: @allowed_events, badge: ax_badge("Permitido", tone: :green, dot: true)) %>
  <%= ax_metric_card(label: "Negados", value: @denied_events, badge: ax_badge(@denied_events.positive? ? "Atenção" : "Nenhum", tone: @denied_events.positive? ? :red : :gray, dot: @denied_events.positive?)) %>
  <%= ax_metric_card(label: "IPs únicos", value: @unique_ips) %>
</div>

<div class="ax-card tw-mb-3">
  <div class="ax-card__body">
    <%= form_with url: admin_access_audit_logs_path, method: :get, local: true, class: "ax-field-grid ax-field-grid--12 tw-items-end", data: { controller: "auto-submit" } do %>
      <div class="ax-span-2">
        <label class="ax-label">Evento</label>
        <%= select_tag :event_type,
	                       options_for_select([["Todos", ""]] + AccessAuditLog::EVENT_TYPES.map { |type| [AccessAuditLog::EVENT_LABELS[type], type] }, params[:event_type]),
	                       class: "ax-control ax-control--sm",
	                       data: { action: "change->auto-submit#submit" } %>
      </div>
      <div class="ax-span-2">
        <label class="ax-label">Resultado</label>
        <%= select_tag :result,
	                       options_for_select([["Todos", ""]] + AccessAuditLog::RESULTS.map { |result| [AccessAuditLog::RESULT_LABELS[result], result] }, params[:result]),
	                       class: "ax-control ax-control--sm",
	                       data: { action: "change->auto-submit#submit" } %>
      </div>
      <div class="ax-span-3">
        <label class="ax-label">Usuário</label>
        <%= select_tag :admin_user_id,
                       options_from_collection_for_select(@available_users, :id, ->(user) { "#{user.name} · #{user.email}" }, params[:admin_user_id]),
	                       include_blank: "Todos",
	                       class: "ax-control ax-control--sm",
	                       data: { controller: "tom-select", tom_select_options_value: { placeholder: "Buscar usuário..." }, action: "change->auto-submit#submit" } %>
      </div>
      <div class="ax-span-2">
        <label class="ax-label">Perfil</label>
        <%= select_tag :profile_id,
                       options_from_collection_for_select(@available_profiles, :id, ->(profile) { profile_filter_label(profile) }, params[:profile_id]),
	                       include_blank: "Todos",
	                       class: "ax-control ax-control--sm",
	                       data: { controller: "tom-select", tom_select_options_value: { placeholder: "Buscar perfil..." }, action: "change->auto-submit#submit" } %>
      </div>
      <div class="ax-span-2">
        <label class="ax-label">IP</label>
        <%= text_field_tag :ip, params[:ip], class: "ax-control ax-control--sm", placeholder: "000.000.000.000" %>
      </div>
      <div class="ax-span-2">
        <label class="ax-label">Dispositivo</label>
        <%= select_tag :device_type,
	                       options_for_select([["Todos", ""]] + @available_device_types.map { |value| [value, value] }, params[:device_type]),
	                       class: "ax-control ax-control--sm",
	                       data: { controller: "tom-select", tom_select_options_value: { placeholder: "Buscar dispositivo..." }, action: "change->auto-submit#submit" } %>
      </div>
      <div class="ax-span-2">
        <label class="ax-label">Navegador</label>
        <%= select_tag :browser,
	                       options_for_select([["Todos", ""]] + @available_browsers.map { |value| [value, value] }, params[:browser]),
	                       class: "ax-control ax-control--sm",
	                       data: { controller: "tom-select", tom_select_options_value: { placeholder: "Buscar navegador..." }, action: "change->auto-submit#submit" } %>
      </div>
      <div class="ax-span-3">
        <label class="ax-label">Controller</label>
        <%= select_tag :access_controller,
	                       options_for_select([["Todos", ""]] + @available_controllers.map { |value| [value, value] }, params[:access_controller]),
	                       class: "ax-control ax-control--sm",
	                       data: { controller: "tom-select", tom_select_options_value: { placeholder: "Buscar controller..." }, action: "change->auto-submit#submit" } %>
      </div>
      <div class="ax-span-2">
        <label class="ax-label">Ação</label>
        <%= select_tag :access_action,
	                       options_for_select([["Todas", ""]] + @available_actions.map { |value| [value, value] }, params[:access_action]),
	                       class: "ax-control ax-control--sm",
	                       data: { controller: "tom-select", tom_select_options_value: { placeholder: "Buscar ação..." }, action: "change->auto-submit#submit" } %>
      </div>
      <div class="ax-span-3">
        <label class="ax-label">Rota contém</label>
        <%= text_field_tag :path, params[:path], class: "ax-control ax-control--sm", placeholder: "/admin/..." %>
      </div>
      <div class="ax-span-2">
        <label class="ax-label">De</label>
        <%= date_field_tag :start_date, params[:start_date], class: "ax-control ax-control--sm" %>
      </div>
      <div class="ax-span-2">
        <label class="ax-label">Até</label>
        <%= date_field_tag :end_date, params[:end_date], class: "ax-control ax-control--sm" %>
      </div>
      <div class="ax-span-3 tw-flex tw-gap-2">
        <%= submit_tag "Filtrar", class: "ax-btn ax-btn--primary ax-btn--sm tw-w-full" %>
        <%= link_to "Limpar", admin_access_audit_logs_path, class: "ax-btn ax-btn--ghost ax-btn--sm" %>
      </div>
    <% end %>
  </div>
</div>

<div class="ax-card">
  <div class="ax-card__body">
    <% if @logs.any? %>
      <% @logs.each do |log| %>
        <div class="access-audit-row">
          <div class="tw-flex tw-justify-between tw-items-start tw-gap-3 tw-flex-wrap">
            <div class="tw-flex-1 tw-min-w-0">
              <div class="access-audit-title tw-flex tw-items-center tw-gap-2">
                <%= ax_badge(log.result_label, tone: log.result == "allowed" ? :green : :red) %>
                <%= log.event_label %> · <%= log.actor_name %>
              </div>
              <div class="access-audit-meta tw-mt-2 tw-flex tw-items-center tw-gap-1">
                <i class="bi bi-clock"></i><%= l(log.created_at, format: "%d/%m/%Y às %H:%M") %>
                <% if log.ip.present? %> · <i class="bi bi-globe2"></i> <%= log.ip %><% end %>
                · <i class="bi bi-phone"></i> <%= log.device_label %>
              </div>
              <% if log.reason.present? %>
                <div class="tw-text-sm tw-mt-2"><strong>Motivo:</strong> <%= log.reason %></div>
              <% end %>
              <% if log.path.present? %>
                <% clean_path, query_string = log.path.to_s.split("?", 2) %>
                <div class="access-audit-path tw-mt-2"><%= log.request_method %> <%= clean_path %></div>
                <% if query_string.present? %>
                  <details class="tw-text-sm tw-mt-2">
                    <summary class="tw-text-ink-muted">Parâmetros</summary>
                    <div class="access-audit-path tw-mt-2"><%= query_string %></div>
                  </details>
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

      <%= ax_pagination @logs, params: request.query_parameters %>
    <% else %>
      <%= ax_empty_state(
            title: "Nenhum acesso encontrado",
            description: "Não há eventos para os filtros atuais.",
            icon: "inbox"
          ) %>
    <% end %>
  </div>
</div>
