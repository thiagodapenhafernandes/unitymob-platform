<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-1 text-gray-800">
      <i class="bi bi-hand-index-thumb-fill text-warning me-2"></i>Solicitações manuais de check-in
    </h1>
    <p class="text-muted small mb-0">Pedidos de corretores cuja GPS falhou — revise com cuidado.</p>
  </div>
  <%= link_to admin_field_check_ins_path, class: "btn btn-sm btn-outline-secondary" do %>
    <i class="bi bi-arrow-left me-1"></i>Voltar para check-ins
  <% end %>
</div>

<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-white">
    <h5 class="fw-bold mb-0">
      <i class="bi bi-hourglass-split text-warning me-2"></i>Pendentes
      <span class="badge bg-warning text-dark ms-2"><%= @pending.size %></span>
    </h5>
  </div>
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light small text-uppercase">
        <tr>
          <th>Corretor</th>
          <th>Loja</th>
          <th>Justificativa</th>
          <th>Criado</th>
          <th class="text-end">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% @pending.each do |req| %>
          <tr>
            <td class="fw-bold"><i class="bi bi-person-circle text-primary me-1"></i><%= req.admin_user.name %></td>
            <td><i class="bi bi-shop text-success me-1"></i><%= req.store.name %></td>
            <td class="text-muted small" style="max-width: 400px;"><%= truncate(req.justification, length: 140) %></td>
            <td class="small text-muted"><%= time_ago_in_words(req.created_at) %> atrás</td>
            <td class="text-end">
              <%= button_to approve_admin_field_manual_checkin_request_path(req), method: :post,
                    class: "btn btn-sm btn-success me-1", data: { turbo_confirm: "Aprovar esta solicitação?" } do %>
                <i class="bi bi-check-circle-fill me-1"></i>Aprovar
              <% end %>
              <%= button_to reject_admin_field_manual_checkin_request_path(req), method: :post,
                    class: "btn btn-sm btn-outline-danger", data: { turbo_confirm: "Rejeitar?" } do %>
                <i class="bi bi-x-circle-fill me-1"></i>Rejeitar
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @pending.empty? %>
          <tr><td colspan="5" class="text-center text-muted py-4"><i class="bi bi-inbox me-1"></i>Nenhum pedido pendente</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-white">
    <h5 class="fw-bold mb-0">
      <i class="bi bi-archive text-muted me-2"></i>Últimas revisadas
    </h5>
  </div>
  <div class="table-responsive">
    <table class="table table-sm mb-0">
      <thead class="table-light small text-uppercase">
        <tr>
          <th>Corretor</th>
          <th>Loja</th>
          <th>Status</th>
          <th>Revisada</th>
        </tr>
      </thead>
      <tbody>
        <% @resolved.each do |req| %>
          <tr>
            <td><%= req.admin_user.name %></td>
            <td><%= req.store.name %></td>
            <td>
              <% if req.approved? %>
                <span class="badge bg-success"><i class="bi bi-check-circle"></i> Aprovada</span>
              <% else %>
                <span class="badge bg-danger"><i class="bi bi-x-circle"></i> Rejeitada</span>
              <% end %>
            </td>
            <td class="small text-muted"><%= l(req.reviewed_at, format: :short) if req.reviewed_at %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
