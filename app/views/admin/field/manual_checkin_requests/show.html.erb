<div class="manual-checkin-requests-admin">
  <% request_tone = @request.pending? ? :amber : @request.approved? ? :green : :red %>
  <% request_status = @request.pending? ? "Pendente" : @request.approved? ? "Aprovada" : "Rejeitada" %>
  <% review_actions = if @request.pending?
                        safe_join([
                          button_to(approve_admin_field_manual_checkin_request_path(@request), method: :post, class: "ax-btn ax-btn--primary") { safe_join([tag.i(class: "bi bi-check-circle-fill ax-ico"), "Aprovar"]) },
                          button_to(reject_admin_field_manual_checkin_request_path(@request), method: :post, class: "ax-btn ax-btn--danger") { safe_join([tag.i(class: "bi bi-x-circle-fill ax-ico"), "Rejeitar"]) }
                        ])
                      end %>

  <%= ax_workspace_heading(
        eyebrow: "Operação · Revisão manual",
        icon: "hand-index-thumb-fill",
        title: "Solicitação ##{@request.id}",
        pills: [request_status],
        subtitle: "Confira a justificativa e o vínculo operacional antes de decidir.",
        actions: ax_button("Voltar", admin_field_manual_checkin_requests_path, size: :sm, icon: "arrow-left")
      ) %>

  <%= ax_operational_panel(
        eyebrow: "Solicitação",
        title: "Dados para revisão",
        actions: review_actions
      ) do %>
    <%= ax_field_grid do %>
      <div class="ax-span-6">
        <%= ax_record_item(title: @request.admin_user.name, eyebrow: "Corretor", meta: @request.admin_user.email, icon: "person-circle") %>
      </div>
      <div class="ax-span-6">
        <%= ax_record_item(title: @request.store.name, eyebrow: "Loja", icon: "shop") %>
      </div>
      <div class="ax-span-4">
        <%= ax_record_item(title: request_status, eyebrow: "Status", icon: "circle-fill", actions: ax_badge(request_status, tone: request_tone, dot: true)) %>
      </div>
      <div class="ax-span-8">
        <%= ax_record_item(title: "Justificativa informada", eyebrow: "Justificativa", icon: "chat-left-text", body: simple_format(@request.justification)) %>
      </div>
      <% if @request.review_notes.present? %>
        <div class="ax-span-12">
          <%= ax_record_item(title: "Notas da revisão", eyebrow: "Revisão", icon: "journal-check", body: simple_format(@request.review_notes)) %>
        </div>
      <% end %>
    <% end %>
  <% end %>
</div>
