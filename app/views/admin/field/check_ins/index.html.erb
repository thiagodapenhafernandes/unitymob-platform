<div class="field-checkins-admin">
  <%= ax_workspace_heading(
        eyebrow: "Operação · Campo",
        icon: "geo-alt",
        title: "Check-ins em campo",
        subtitle: "Monitoramento ao vivo dos corretores em plantão.",
        actions: ax_button("Lojas", admin_stores_path, size: :sm, icon: "shop")
      ) %>

  <div class="ax-metric-grid tw-mb-4" aria-label="Resumo dos check-ins">
    <%= ax_metric_card(
          label: "Ativos agora",
          value: @active_check_ins.size,
          badge: ax_badge("Ao vivo", tone: :green, dot: true)
        ) %>
    <%= ax_metric_card(label: "Fechados hoje", value: @today_closed.size) %>
  </div>

  <%= ax_operational_panel(
        eyebrow: "Monitoramento ao vivo",
        title: "Check-ins ativos",
        actions: ax_badge(@active_check_ins.size, tone: @active_check_ins.any? ? :green : :gray, dot: @active_check_ins.any?),
        class_name: "tw-mb-4"
      ) do %>
    <% if @active_check_ins.any? %>
      <div class="ax-table-wrap">
        <table class="ax-table">
          <thead>
            <tr>
              <th>Corretor</th>
              <th class="ax-table__col--w-170">Loja</th>
              <th class="ax-table__col--w-120">Entrou</th>
              <th class="ax-table__col--md">Duração</th>
              <th class="ax-table__col--w-120">Status</th>
              <th class="ax-num ax-table__col--compact">Ações</th>
            </tr>
          </thead>
          <tbody>
            <% @active_check_ins.each do |check_in| %>
              <tr>
                <td class="ax-strong"><i class="bi bi-person-circle tw-text-ink-faint"></i> <%= check_in.admin_user.name %></td>
                <td><i class="bi bi-shop tw-text-ink-faint"></i> <%= check_in.store.name %></td>
                <td class="tw-text-2xs tw-text-ink-muted"><%= l(check_in.checked_in_at, format: :short) %></td>
                <td class="tw-font-mono tw-text-2xs"><%= distance_of_time_in_words(check_in.checked_in_at, Time.current) %></td>
                <td>
                  <%= ax_badge(
                        check_in.out_of_radius_since? ? "Fora do raio" : "No raio",
                        tone: check_in.out_of_radius_since? ? :amber : :green,
                        dot: true
                      ) %>
                </td>
                <td class="ax-num">
                  <span class="tw-inline-flex tw-gap-0.5">
                    <%= link_to admin_field_check_in_path(check_in), class: "ax-ico-btn", title: "Ver" do %><i class="bi bi-eye"></i><% end %>
                    <% if can?(:manage, :field_checkins) %>
                      <%= button_to force_check_out_admin_field_check_in_path(check_in), method: :post, form_class: "tw-inline", class: "ax-ico-btn", title: "Forçar check-out", form: { data: { turbo_confirm: "Forçar check-out de #{check_in.admin_user.name}?" } } do %><i class="bi bi-power"></i><% end %>
                    <% end %>
                  </span>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <%= ax_empty_state(
            title: "Nenhum corretor ativo",
            description: "Não há check-ins abertos no momento.",
            icon: "person-check"
          ) %>
    <% end %>
  <% end %>

  <%= ax_operational_panel(
        eyebrow: "Histórico do dia",
        title: "Fechados hoje",
        actions: ax_badge(@today_closed.size, tone: :gray)
      ) do %>
    <% if @today_closed.any? %>
      <div class="ax-table-wrap">
        <table class="ax-table">
          <thead>
            <tr>
              <th>Corretor</th>
              <th class="ax-table__col--w-170">Loja</th>
              <th class="ax-table__col--w-120">Entrou</th>
              <th class="ax-table__col--w-120">Saiu</th>
              <th class="ax-table__col--md">Duração</th>
              <th class="ax-table__col--w-140">Motivo</th>
            </tr>
          </thead>
          <tbody>
            <% @today_closed.each do |check_in| %>
              <% icon, tone, label = case check_in.status
                 when "closed_manual" then ["box-arrow-right", :gray, "Manual"]
                 when "closed_auto_shift_end" then ["moon", :blue, "Fim turno"]
                 when "closed_auto_out_of_radius" then ["geo-alt-fill", :amber, "Saiu do raio"]
                 when "closed_auto_no_signal" then ["wifi-off", :gray, "Sem sinal"]
                 when "closed_admin_force" then ["shield-exclamation", :red, "Admin forçou"]
                 else ["question-circle", :gray, check_in.status]
                 end %>
              <tr>
                <td class="ax-strong"><%= check_in.admin_user.name %></td>
                <td><%= check_in.store.name %></td>
                <td class="tw-text-2xs tw-text-ink-muted"><%= l(check_in.checked_in_at, format: :short) %></td>
                <td class="tw-text-2xs tw-text-ink-muted"><%= l(check_in.checked_out_at, format: :short) if check_in.checked_out_at %></td>
                <td class="tw-text-2xs"><%= distance_of_time_in_words(check_in.checked_in_at, check_in.checked_out_at || Time.current) %></td>
                <td><%= ax_badge(safe_join([tag.i(class: "bi bi-#{icon}"), label], " "), tone: tone) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <%= ax_empty_state(
            title: "Nenhum check-in fechado hoje",
            description: "Os encerramentos do dia aparecerão aqui.",
            icon: "clock-history"
          ) %>
    <% end %>
  <% end %>
</div>
