<div class="tw-flex tw-justify-between tw-items-center tw-mb-4">
  <div>
    <h1 class="ax-page-title tw-flex tw-items-center tw-gap-2">
      <i class="bi bi-person-vcard-fill tw-text-primary"></i>Check-in #<%= @check_in.id %>
    </h1>
    <p class="ax-page-subtitle"><%= @check_in.admin_user.name %> • <%= @check_in.store.name %></p>
  </div>
  <%= link_to admin_field_check_ins_path, class: "ax-btn ax-btn--ghost ax-btn--sm tw-inline-flex tw-items-center tw-gap-2" do %>
    <i class="bi bi-arrow-left"></i>Voltar
  <% end %>
</div>

<%= ax_field_grid do %>
  <div class="ax-span-6">
    <div class="ax-card tw-mb-3">
      <div class="ax-card__body">
        <h5 class="tw-font-bold tw-mb-3 tw-flex tw-items-center tw-gap-2"><i class="bi bi-info-circle" style="color:var(--admin-primary)"></i>Detalhes</h5>
        <dl class="tw-text-sm" style="display:grid;grid-template-columns:42% 58%;gap:.25rem .5rem;margin-bottom:0">
          <dt>Status</dt>
          <dd><%= @check_in.status.humanize %></dd>
          <dt>Entrou</dt>
          <dd><%= l(@check_in.checked_in_at, format: :long) %></dd>
          <% if @check_in.checked_out_at %>
            <dt>Saiu</dt>
            <dd><%= l(@check_in.checked_out_at, format: :long) %></dd>
          <% end %>
          <dt>Duração</dt>
          <dd><%= distance_of_time_in_words(@check_in.checked_in_at, @check_in.checked_out_at || Time.current) %></dd>
          <dt>Accuracy entrada</dt>
          <dd><%= @check_in.checkin_accuracy_meters %>m</dd>
          <dt>IP entrada</dt>
          <dd class="font-monospace"><%= @check_in.checkin_ip %></dd>
        </dl>
      </div>
    </div>
  </div>
  <div class="ax-span-6">
    <div class="ax-card tw-mb-3">
      <div class="ax-card__body">
        <h5 class="tw-font-bold tw-mb-3 tw-flex tw-items-center tw-gap-2"><i class="bi bi-geo" style="color:#dc2626"></i>Localização</h5>
        <dl class="tw-text-sm" style="display:grid;grid-template-columns:42% 58%;gap:.25rem .5rem;margin-bottom:0">
          <dt>Entrada</dt>
          <dd class="font-monospace">
            <%= @check_in.checkin_latitude&.round(5) %>, <%= @check_in.checkin_longitude&.round(5) %>
          </dd>
          <% if @check_in.checkout_latitude %>
            <dt>Saída</dt>
            <dd class="font-monospace">
              <%= @check_in.checkout_latitude&.round(5) %>, <%= @check_in.checkout_longitude&.round(5) %>
            </dd>
          <% end %>
        </dl>
      </div>
    </div>
  </div>
<% end %>
