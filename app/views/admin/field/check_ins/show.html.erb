<div class="field-checkins-admin">
  <%= ax_workspace_heading(
        eyebrow: "Operação · Equipe de campo",
        icon: "person-vcard-fill",
        title: "Check-in ##{@check_in.id}",
        pills: [@check_in.status.humanize],
        subtitle: "#{@check_in.admin_user.name} · #{@check_in.store.name}",
        actions: ax_button("Voltar", admin_field_check_ins_path, size: :sm, icon: "arrow-left")
      ) %>

  <%= ax_field_grid do %>
    <div class="ax-span-6">
      <%= ax_operational_panel(eyebrow: "Registro", title: "Detalhes do check-in") do %>
        <div class="ax-record-list">
          <%= ax_record_item(title: @check_in.status.humanize, eyebrow: "Status", icon: "activity") %>
          <%= ax_record_item(title: l(@check_in.checked_in_at, format: :long), eyebrow: "Entrada", icon: "box-arrow-in-right") %>
          <% if @check_in.checked_out_at %>
            <%= ax_record_item(title: l(@check_in.checked_out_at, format: :long), eyebrow: "Saída", icon: "box-arrow-right") %>
          <% end %>
          <%= ax_record_item(
                title: distance_of_time_in_words(@check_in.checked_in_at, @check_in.checked_out_at || Time.current),
                eyebrow: "Duração",
                icon: "clock-history"
              ) %>
          <%= ax_record_item(title: "#{@check_in.checkin_accuracy_meters}m", eyebrow: "Precisão da entrada", icon: "bullseye") %>
          <%= ax_record_item(title: @check_in.checkin_ip, eyebrow: "IP da entrada", icon: "pc-display") %>
        </div>
      <% end %>
    </div>

    <div class="ax-span-6">
      <%= ax_operational_panel(eyebrow: "Geolocalização", title: "Coordenadas registradas") do %>
        <div class="ax-record-list">
          <%= ax_record_item(
                title: "#{@check_in.checkin_latitude&.round(5)}, #{@check_in.checkin_longitude&.round(5)}",
                eyebrow: "Entrada",
                icon: "geo-alt-fill"
              ) %>
          <% if @check_in.checkout_latitude %>
            <%= ax_record_item(
                  title: "#{@check_in.checkout_latitude&.round(5)}, #{@check_in.checkout_longitude&.round(5)}",
                  eyebrow: "Saída",
                  icon: "geo-fill"
                ) %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
