<div class="field-audit-logs-admin">
  <%= ax_workspace_heading(
        eyebrow: "Campo · Rastreabilidade",
        icon: "shield-lock-fill",
        title: "Log ##{@log.id}",
        pills: [@log.action],
        subtitle: l(@log.created_at, format: :long),
        actions: ax_button("Voltar", admin_field_audit_logs_path, size: :sm, icon: "arrow-left")
      ) %>

  <%= ax_operational_panel(eyebrow: "Evento imutável", title: "Detalhes da auditoria") do %>
    <%= ax_field_grid do %>
      <div class="ax-span-4"><%= ax_record_item(title: l(@log.created_at, format: :long), eyebrow: "Quando", icon: "clock-history") %></div>
      <div class="ax-span-4"><%= ax_record_item(title: @log.action, eyebrow: "Ação", icon: "activity") %></div>
      <div class="ax-span-4"><%= ax_record_item(title: @log.ip.presence || "—", eyebrow: "IP", icon: "globe") %></div>
      <div class="ax-span-4"><%= ax_record_item(title: @log.admin_user&.name || "—", eyebrow: "Corretor", icon: "person") %></div>
      <div class="ax-span-4"><%= ax_record_item(title: @log.actor_admin_user&.name || "—", eyebrow: "Ator", icon: "person-badge") %></div>
      <div class="ax-span-4">
        <%= ax_record_item(
              title: @log.check_in_id ? "Check-in ##{@log.check_in_id}" : "—",
              eyebrow: "Vínculo",
              icon: "person-vcard",
              actions: (@log.check_in_id ? ax_button("Abrir", admin_field_check_in_path(@log.check_in_id), size: :sm) : nil)
            ) %>
      </div>
      <div class="ax-span-12">
        <%= ax_record_item(title: "Payload registrado", eyebrow: "Metadata", icon: "braces") do %>
          <%= ax_code_snippet(code: JSON.pretty_generate(@log.metadata), label: "Payload registrado na auditoria") %>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
