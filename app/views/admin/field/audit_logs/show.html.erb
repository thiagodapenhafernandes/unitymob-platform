<div class="mb-3">
  <%= link_to admin_field_audit_logs_path, class: "text-muted small text-decoration-none" do %>
    <i class="bi bi-arrow-left me-1"></i>Voltar
  <% end %>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-white">
    <h4 class="fw-bold mb-0"><i class="bi bi-shield-lock-fill text-danger me-2"></i>Log #<%= @log.id %></h4>
  </div>
  <div class="card-body">
    <dl class="row">
      <dt class="col-sm-3">Quando</dt>
      <dd class="col-sm-9"><%= l(@log.created_at, format: :long) %></dd>
      <dt class="col-sm-3">Ação</dt>
      <dd class="col-sm-9"><code><%= @log.action %></code></dd>
      <dt class="col-sm-3">Corretor</dt>
      <dd class="col-sm-9"><%= @log.admin_user&.name || "—" %></dd>
      <dt class="col-sm-3">Ator</dt>
      <dd class="col-sm-9"><%= @log.actor_admin_user&.name || "—" %></dd>
      <dt class="col-sm-3">IP</dt>
      <dd class="col-sm-9"><%= @log.ip %></dd>
      <dt class="col-sm-3">Check-in</dt>
      <dd class="col-sm-9">
        <% if @log.check_in_id %>
          <%= link_to "##{@log.check_in_id}", admin_field_check_in_path(@log.check_in_id), class: "text-decoration-none" %>
        <% else %>
          —
        <% end %>
      </dd>
      <dt class="col-sm-3">Metadata</dt>
      <dd class="col-sm-9"><pre class="small bg-light p-2 rounded"><%= JSON.pretty_generate(@log.metadata) %></pre></dd>
    </dl>
  </div>
</div>
