<%
  action_meta = {
    "created"                 => { label: "Check-in criado", icon: "plus-circle-fill", tone: :blue },
    "closed"                  => { label: "Check-out", icon: "box-arrow-right", tone: :gray },
    "forced_closed"           => { label: "Fechado pelo admin", icon: "exclamation-octagon", tone: :amber },
    "flagged_suspicious"      => { label: "Flagged suspeito", icon: "exclamation-triangle-fill", tone: :red },
    "manual_request_created"  => { label: "Pedido manual criado", icon: "hand-index-thumb", tone: :blue },
    "manual_request_approved" => { label: "Pedido manual aprovado", icon: "check-circle-fill", tone: :green },
    "manual_request_rejected" => { label: "Pedido manual rejeitado", icon: "x-circle-fill", tone: :gray }
  }
  grouped_logs = @logs.group_by { |log| log.created_at.to_date }
%>

<div class="field-audit-logs-admin">
  <%= ax_workspace_heading(
        eyebrow: "Campo · Rastreabilidade",
        icon: "shield-lock-fill",
        title: "Auditoria de Campo",
        subtitle: "Log append-only de eventos imutáveis de check-in e revisão manual."
      ) %>

  <div class="ax-metric-grid tw-mb-4">
    <%= ax_metric_card(label: "Filtrados", value: @total_events) %>
    <%= ax_metric_card(label: "Hoje", value: @events_today) %>
    <%= ax_metric_card(label: "Suspeitos", value: @flagged_count, badge: (@flagged_count.positive? ? ax_badge("Atenção", tone: :red) : nil)) %>
    <%= ax_metric_card(label: "Forçados", value: @forced_count, badge: (@forced_count.positive? ? ax_badge("Revisar", tone: :amber) : nil)) %>
  </div>

  <%= ax_filter_form(url: admin_field_audit_logs_path, reset_path: admin_field_audit_logs_path, submit_label: "Aplicar", class_name: "tw-mb-3") do |_form| %>
    <%= ax_field_grid do %>
      <div class="ax-span-3"><%= label_tag :action_filter, "Ação", class: "ax-label" %><%= select_tag :action_filter, options_for_select([["Todas", ""]] + @available_actions.map { |action| [action_meta.dig(action, :label) || action.humanize, action] }, params[:action_filter]), class: "ax-control" %></div>
      <div class="ax-span-3"><%= label_tag :admin_user_id, "Corretor", class: "ax-label" %><%= select_tag :admin_user_id, options_from_collection_for_select(@available_users, :id, ->(user) { "#{user.name} · #{user.email}" }, params[:admin_user_id]), class: "ax-control", include_blank: "Todos" %></div>
      <div class="ax-span-3"><%= label_tag :profile_id, "Perfil", class: "ax-label" %><%= select_tag :profile_id, options_from_collection_for_select(@available_profiles, :id, ->(profile) { profile_filter_label(profile) }, params[:profile_id]), class: "ax-control", include_blank: "Todos" %></div>
      <div class="ax-span-3"><%= label_tag :actor_admin_user_id, "Executado por", class: "ax-label" %><%= select_tag :actor_admin_user_id, options_from_collection_for_select(@available_actors, :id, ->(user) { "#{user.name} · #{user.email}" }, params[:actor_admin_user_id]), class: "ax-control", include_blank: "Todos" %></div>
      <div class="ax-span-3"><%= label_tag :store_id, "Loja", class: "ax-label" %><%= select_tag :store_id, options_from_collection_for_select(@available_stores, :id, :name, params[:store_id]), class: "ax-control", include_blank: "Todas" %></div>
      <div class="ax-span-3"><%= label_tag :ip, "IP", class: "ax-label" %><%= text_field_tag :ip, params[:ip], class: "ax-control", placeholder: "000.000.000.000" %></div>
      <div class="ax-span-3"><%= label_tag :start_date, "De", class: "ax-label" %><%= date_field_tag :start_date, params[:start_date], class: "ax-control" %></div>
      <div class="ax-span-3"><%= label_tag :end_date, "Até", class: "ax-label" %><%= date_field_tag :end_date, params[:end_date], class: "ax-control" %></div>
    <% end %>
  <% end %>

  <%= ax_operational_panel(eyebrow: "Linha do tempo", title: "Eventos registrados") do %>
    <% if grouped_logs.any? %>
      <div class="ax-record-list">
        <% grouped_logs.each do |date, logs| %>
          <div class="tw-flex tw-items-center tw-gap-2 tw-my-2">
            <%= ax_badge(l(date, format: :long), tone: :gray) %>
            <span class="ax-page-subtitle"><%= pluralize(logs.size, "evento") %></span>
          </div>

          <% logs.each do |log| %>
            <% meta = action_meta[log.action] || { label: log.action.humanize, icon: "info-circle", tone: :gray } %>
            <% log_meta = safe_join([
                 (safe_join([tag.i(class: "bi bi-person"), tag.strong(log.admin_user.name)], " ") if log.admin_user),
                 ("por #{log.actor_admin_user.name}" if log.actor_admin_user && log.actor_admin_user_id != log.admin_user_id),
                 (safe_join([tag.i(class: "bi bi-shop-window"), log.check_in.store.name], " ") if log.check_in&.store),
                 (safe_join([tag.i(class: "bi bi-globe"), log.ip], " ") if log.ip.present?)
               ].compact, " · ") %>

            <%= ax_record_item(
                  title: meta[:label],
                  eyebrow: l(log.created_at, format: :short).split(" ").last,
                  meta: log_meta,
                  icon: meta[:icon],
                  actions: ax_badge(log.action, tone: meta[:tone])
                ) do %>
              <% if log.metadata.present? && log.metadata.any? %>
                <details>
                  <summary class="tw-text-2xs tw-text-ink-muted tw-cursor-pointer">Metadados</summary>
                  <pre class="tw-mt-1 tw-bg-surface-soft tw-border tw-border-line tw-rounded tw-p-2 tw-font-mono tw-text-2xs tw-overflow-auto"><%= JSON.pretty_generate(log.metadata) %></pre>
                </details>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
      </div>

      <%= ax_pagination @logs, params: request.query_parameters %>
    <% else %>
      <%= ax_empty_state(
            title: "Nenhum evento encontrado",
            description: "Ajuste os filtros ou aguarde novos eventos de check-in.",
            icon: "shield-lock"
          ) %>
    <% end %>
  <% end %>
</div>
