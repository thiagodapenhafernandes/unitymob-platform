<div class="admin-content">
  <div class="tw-flex tw-justify-between tw-items-center tw-mb-4">
    <h1 class="ax-page-title"><%= @home_section_item.persisted? ? "Editar Item" : "Novo Item" %></h1>
    <%= link_to "← Voltar", admin_home_section_path(@home_section), class: "ax-btn ax-btn--ghost" %>
  </div>

  <%= form_with(model: [:admin, @home_section, @home_section_item], local: true, class: "admin-form") do |f| %>
    <%= ax_error_summary(@home_section_item) %>

    <div class="ax-card tw-mb-4">
      <div class="ax-card__body">
        <%= ax_field_grid do %>
          <div class="ax-span-8 tw-mb-3">
            <%= f.label :title, "Título", class: "ax-label" %>
            <%= f.text_field :title, class: "ax-control", required: true %>
          </div>

          <div class="ax-span-4 tw-mb-3">
            <%= f.label :display_order, "Ordem", class: "ax-label" %>
            <%= f.number_field :display_order, class: "ax-control", value: @home_section_item.display_order || 0 %>
          </div>

          <div class="ax-span-12 tw-mb-3">
            <%= f.label :description, "Descrição", class: "ax-label" %>
            <%= f.text_area :description, rows: 3, class: "ax-control" %>
          </div>

          <div class="ax-span-6 tw-mb-3">
            <%= f.label :icon, "Ícone", class: "ax-label" %>
            <%= f.file_field :icon, class: "ax-control", accept: "image/*" %>
            <% if @home_section_item.icon.attached? %>
              <div class="tw-mt-2">
                <%= image_tag @home_section_item.icon, style: "max-height: 80px;" %>
              </div>
            <% end %>
          </div>

          <div class="ax-span-6 tw-mb-3">
            <%= ax_switch_field(label: "Item Ativo", form: f, method: :active, class_name: "tw-mt-3", input_html: { role: "switch" }) %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="tw-flex tw-justify-end tw-gap-2">
      <%= link_to "Cancelar", admin_home_section_path(@home_section), class: "ax-btn ax-btn--ghost" %>
      <%= f.submit @home_section_item.persisted? ? "Atualizar Item" : "Criar Item", class: "ax-btn ax-btn--primary" %>
    </div>
  <% end %>
</div>
