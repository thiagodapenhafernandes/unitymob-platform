<% content_for :title, "Cartões de apresentação" %>

<div class="layout-settings-workspace">
  <%= ax_workspace_heading(
        eyebrow: "WhatsApp · Atendimento",
        icon: "person-badge",
        title: "Cartões de apresentação",
        subtitle: "Modelos de saudação para se apresentar no atendimento WhatsApp — enviados pelo número da empresa, sem expor seu contato pessoal.",
        actions: ax_button("Novo cartão", new_admin_presentation_card_path, variant: :primary, icon: "plus-lg")
      ) %>

  <div class="layout-settings-grid">
    <div class="layout-settings-main">
      <%= ax_operational_panel(eyebrow: "Empresa", title: "Template da empresa") do %>
        <div class="ax-panel-body">
          <p class="ax-field__hint tw-mt-0">Disponível para todos os corretores no atendimento; nome, CRECI e foto entram automaticamente de quem envia (<code>{nome}</code> e <code>{creci}</code> no texto são substituídos). Não pode ser excluído nem desativado.</p>
          <div class="ax-table-wrap">
            <table class="ax-table">
              <caption class="tw-sr-only">Template de apresentação disponível para toda a conta</caption>
              <thead><tr><th scope="col">Rótulo</th><th scope="col">Saudação</th><th scope="col">Formato</th><th scope="col" class="tw-text-right"><%= "Ações" if current_admin_user.tenant_owner? %></th></tr></thead>
              <tbody>
                <% @system_cards.each do |card| %>
                  <tr>
                    <th scope="row" class="ax-strong"><%= card.label %> <%= ax_badge("Sistema", tone: :blue) %></th>
                    <td class="tw-max-w-[340px] tw-truncate" title="<%= card.greeting %>"><%= truncate(card.greeting, length: 80) %></td>
                    <td><%= card.use_photo? ? ax_badge("Foto + texto", tone: :blue) : ax_badge("Só texto", tone: :gray) %></td>
                    <td class="tw-text-right">
                      <% if current_admin_user.tenant_owner? %>
                        <%= ax_icon_button(label: "Editar template #{card.label}", icon: "pencil", url: edit_admin_presentation_card_path(card)) %>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% end %>

      <%= ax_operational_panel(eyebrow: "Atendimento", title: "Meus cartões", class_name: "tw-mt-4") do %>
        <div class="ax-panel-body">
          <% if @cards.any? %>
            <div class="ax-table-wrap">
              <table class="ax-table">
                <caption class="tw-sr-only">Cartões pessoais de <%= current_admin_user.name %></caption>
                <thead>
                  <tr><th scope="col">Rótulo</th><th scope="col">Saudação</th><th scope="col">Formato</th><th scope="col">Status</th><th scope="col" class="tw-text-right">Ações</th></tr>
                </thead>
                <tbody>
                  <% @cards.each do |card| %>
                    <tr>
                      <th scope="row" class="ax-strong"><%= card.label %></th>
                      <td class="tw-max-w-[340px] tw-truncate" title="<%= card.greeting %>"><%= truncate(card.greeting, length: 80) %></td>
                      <td><%= card.use_photo? ? ax_badge("Foto + texto", tone: :blue) : ax_badge("Só texto", tone: :gray) %></td>
                      <td><%= card.active? ? ax_badge("Ativo", tone: :green, dot: true) : ax_badge("Inativo", tone: :gray) %></td>
                      <td class="tw-text-right tw-whitespace-nowrap">
                        <%= ax_icon_button(label: "Editar cartão #{card.label}", icon: "pencil", url: edit_admin_presentation_card_path(card)) %>
                        <%= button_to admin_presentation_card_path(card), method: :delete,
                              form: { data: { turbo_confirm: "Excluir o cartão “#{card.label}”?" }, class: "tw-inline" },
                              class: "ax-btn ax-btn--sm ax-btn--icon ax-btn--danger", title: "Excluir cartão #{card.label}", aria: { label: "Excluir cartão #{card.label}" } do %>
                          <%= ax_icon("trash") %>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <%= ax_empty_state(
                  title: "Nenhum cartão ainda",
                  description: "Crie um modelo por contexto (ex.: Venda, Locação) para se apresentar com um clique no atendimento.",
                  icon: "person-badge"
                ) %>
          <% end %>
        </div>
      <% end %>
    </div>

    <aside class="layout-settings-aside">
      <%= render "profile_preview" %>
    </aside>
  </div>
</div>
