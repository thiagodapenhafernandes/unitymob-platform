<% content_for :title, "Editar cartão de apresentação" %>

<div class="layout-settings-workspace">
  <%= ax_workspace_heading(
        eyebrow: "WhatsApp · Atendimento",
        icon: "person-badge",
        title: "Editar cartão: #{@card.label}",
        subtitle: "A assinatura com nome e CRECI é automática; o telefone pessoal nunca é incluído.",
        actions: link_to("Voltar", admin_presentation_cards_path, class: "ax-btn")
      ) %>
  <%= render "form", card: @card %>
</div>
