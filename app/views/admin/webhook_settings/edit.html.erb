<div class="container-fluid py-4">
  <div class="tw-flex tw-justify-between tw-items-center tw-mb-4">
    <div>
      <h1 class="ax-page-title tw-mb-1"><i class="bi bi-pencil-square"></i> Editar Webhook</h1>
      <p class="ax-page-subtitle">Alterar configurações da integração #<%= @webhook_setting.id %></p>
    </div>
    <%= link_to 'Voltar', admin_webhook_settings_path, class: 'ax-btn ax-btn--ghost' %>
  </div>

  <%= render 'form', webhook_setting: @webhook_setting %>

  <div class="mt-5 pt-4 border-top">
     <h5 class="tw-text-ink-muted tw-mb-3">Zona de Perigo</h5>
     <%= button_to admin_webhook_setting_path(@webhook_setting), method: :delete, class: "ax-btn ax-btn--danger tw-gap-2", data: { confirm: "Tem certeza? Esta ação não pode ser desfeita." } do %>
       <i class="bi bi-trash"></i>Excluir este Webhook
     <% end %>
  </div>
</div>
