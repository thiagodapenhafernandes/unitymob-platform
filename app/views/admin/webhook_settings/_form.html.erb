<%
  sample_webhook_payload = {
    origin_form: "whatsapp_lead",
    timestamp: "2026-05-26T14:30:00-03:00",
    source: {
      page_url: "https://saluteimoveis.com.br/imoveis/apartamento-frente-mar-123",
      request_url: "https://saluteimoveis.com.br/leads",
      referrer_url: "https://google.com/search?q=apartamento+balneario+camboriu",
      user_agent: "Mozilla/5.0",
      utm: {
        utm_source: "google",
        utm_medium: "cpc",
        utm_campaign: "frente-mar-maio",
        utm_term: "apartamento frente mar",
        utm_content: "botao-whatsapp",
        gclid: "EAIaIQobChMI..."
      }
    },
    data: {
      name: "Cliente Exemplo",
      email: "cliente@example.com",
      phone: "(47) 99999-9999",
      lead_type: "whatsapp_modal",
      origin: "Site",
      property_id: 123,
      property_code: "8001",
      property_title: "Apartamento frente mar",
      property_url: "https://saluteimoveis.com.br/imoveis/apartamento-frente-mar-123",
      business_type: "sale",
      business_type_label: "Venda",
      source_url: "https://saluteimoveis.com.br/imoveis/apartamento-frente-mar-123",
      share_token: "abc123"
    }
  }
%>

<%= form_with(model: [:admin, webhook_setting]) do |f| %>
  <%= ax_error_summary(webhook_setting) %>

  <%= ax_field_grid do %>
    <!-- Configuration -->
    <div class="ax-span-8">
      <div class="ax-card">
        <div class="ax-card__header" style="background:rgba(37,99,235,.1)">
          <h5 class="ax-card__title tw-text-primary tw-inline-flex tw-items-center tw-gap-2">
            <i class="bi bi-gear-fill"></i>Detalhes da Integração
          </h5>
        </div>
        <div class="ax-card__body">
          <!-- Webhook URL -->
          <div class="tw-mb-4">
            <%= f.label :webhook_url, class: "ax-label tw-inline-flex tw-items-center tw-gap-2" do %>
              <i class="bi bi-link-45deg tw-text-primary"></i>URL do Webhook (Padrão)
            <% end %>
            <div class="tw-flex tw-items-center tw-gap-2">
              <span class="tw-inline-flex tw-items-center" style="background:rgba(37,99,235,.1); padding:.375rem .5rem; border-radius:.375rem">
                <i class="bi bi-globe tw-text-primary"></i>
              </span>
              <%= f.text_field :webhook_url, class: "ax-control", placeholder: "https://seu-servidor.com/webhook" %>
            </div>
            <small class="tw-text-ink-muted">URL principal para envio de dados (POST).</small>
          </div>

          <!-- WhatsApp Webhook URL -->
          <div class="tw-mb-4">
            <%= f.label :whatsapp_webhook_url, class: "ax-label tw-inline-flex tw-items-center tw-gap-2" do %>
              <i class="fab fa-whatsapp" style="color:#16a34a"></i>URL do Webhook (Específico WhatsApp/Leads)
            <% end %>
            <div class="tw-flex tw-items-center tw-gap-2">
              <span class="tw-inline-flex tw-items-center" style="background:rgba(22,163,74,.1); padding:.375rem .5rem; border-radius:.375rem">
                <i class="bi bi-link-45deg" style="color:#16a34a"></i>
              </span>
              <%= f.text_field :whatsapp_webhook_url, class: "ax-control", placeholder: "https://n8n.seu-servidor.com/webhook/leads" %>
            </div>
            <small class="tw-text-ink-muted">Opcional. Se preenchido, leads de WhatsApp serão enviados para esta URL prioritariamente.</small>
          </div>

          <!-- Enabled Toggles -->
          <%= ax_field_grid(class_name: "tw-mb-4") do %>
            <div class="ax-span-6">
              <%= ax_switch_field(label: tag.span(safe_join([tag.i(class: "bi bi-power", style: "color:#16a34a"), "Habilitar Webhook"]), class: "tw-inline-flex tw-items-center tw-gap-2"), form: f, method: :enabled, id: "webhook_enabled", input_html: { role: "switch" }) %>
            </div>
            <div class="ax-span-6">
              <%= ax_switch_field(label: tag.span(safe_join([tag.i(class: "bi bi-person-badge tw-text-primary"), "Captura de Leads (Modal)"]), class: "tw-inline-flex tw-items-center tw-gap-2"), form: f, method: :lead_capture_enabled, id: "lead_capture_enabled", input_html: { role: "switch" }) %>
            </div>
          <% end %>

          <!-- Description -->
          <div>
            <%= f.label :description, "Descrição / Identificação", class: "ax-label" %>
            <%= f.text_field :description, class: "ax-control", placeholder: "Ex: Integração CRM PipeDrive" %>
          </div>
        </div>
      </div>
    </div>

    <!-- Payload Info (Simplified) -->
    <div class="ax-span-4">
      <div class="ax-card tw-mb-4">
        <div class="ax-card__header" style="background:rgba(37,99,235,.1)">
          <h5 class="ax-card__title tw-inline-flex tw-items-center tw-gap-2" style="color:#2563eb"><i class="bi bi-info-circle"></i>Informações</h5>
        </div>
        <div class="ax-card__body">
          <p class="tw-text-ink-muted tw-text-sm">Este webhook disparará sempre que um formulário for preenchido no site.</p>
          <hr>
          <h6>Formulários Monitorados:</h6>
          <ul class="tw-text-sm tw-text-ink-muted" style="padding-left:1rem; margin-bottom:0">
            <li>Contato Geral</li>
            <li>Agendamento de Visita</li>
            <li>Trabalhe Conosco</li>
            <li>Busca de Imóveis</li>
            <li>Captura de Leads (WhatsApp)</li>
          </ul>
        </div>
      </div>

      <div class="ax-card tw-mb-4">
        <div class="ax-card__header" style="background:rgba(108,117,125,.1)">
          <h5 class="ax-card__title tw-inline-flex tw-items-center tw-gap-2 tw-text-ink-muted"><i class="bi bi-braces"></i>Exemplo de Payload</h5>
        </div>
        <div class="ax-card__body">
          <p class="tw-text-ink-muted tw-text-sm tw-mb-3">Envio via <strong>POST</strong> com <code>Content-Type: application/json</code>.</p>
          <pre class="border rounded tw-text-sm overflow-auto" style="max-height: 420px; background:#f8f9fa; padding:1rem; margin-bottom:0"><code><%= JSON.pretty_generate(sample_webhook_payload) %></code></pre>
        </div>
      </div>

      <div class="tw-grid tw-gap-2">
         <%= f.submit "Salvar Webhook", class: "ax-btn ax-btn--primary" %>
         <%= link_to "Cancelar", admin_webhook_settings_path, class: "ax-btn ax-btn--ghost" %>
      </div>
    </div>
  <% end %>
<% end %>
