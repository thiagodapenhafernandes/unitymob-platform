      referrer_url: "https://google.com/search?q=apartamento+balneario+camboriu",
      user_agent: "Mozilla/5.0",
      utm: {
        utm_source: "google",
        utm_medium: "cpc",
        utm_campaign: "frente-mar-maio",
        utm_term: "apartamento frente mar",
        utm_content: "botao-whatsapp",
        gclid: "EAIaIQobChMI..."
      }
    },
    data: {
