<% active_tab = @active_tab || "outbound" %>
<%
  active_outbound_count = @can_manage_outbound_webhooks ? @webhook_settings.to_a.count(&:active?) : 0
  capture_leads_count = @can_manage_outbound_webhooks ? @webhook_settings.to_a.count(&:lead_capture_enabled?) : 0
  inbound_token = @inbound_webhook_token
%>

<% content_for :admin_contextbar_breadcrumb do %>
  <%= link_to "Plataforma", admin_root_path %>
  <i class="bi bi-chevron-right"></i>
  <strong>Webhooks</strong>
<% end %>

<% content_for :admin_contextbar_actions do %>
  <% if active_tab == "outbound" && @can_manage_outbound_webhooks %>
    <%= link_to new_admin_webhook_setting_path, class: "ax-contextbar__button ax-contextbar__button--primary" do %>
      <i class="bi bi-plus-lg"></i><span>Novo webhook</span>
    <% end %>
  <% end %>
<% end %>

<% tabs_markup = capture do %>
  <nav class="webhook-settings-tabs <%= 'webhook-settings-tabs--single' unless @can_manage_outbound_webhooks %>" aria-label="Tipos de webhook">
    <% if @can_manage_outbound_webhooks %>
      <%= link_to admin_webhook_settings_path(tab: "outbound"),
            class: "webhook-settings-tabs__item #{'is-active' if active_tab == 'outbound'}" do %>
        <i class="bi bi-send"></i>
        <span>
          <strong>Webhook de saída</strong>
          <small>Envio automático para sistemas externos.</small>
        </span>
      <% end %>
    <% end %>

    <%= link_to admin_webhook_settings_path(tab: "inbound"),
          class: "webhook-settings-tabs__item #{'is-active' if active_tab == 'inbound'}" do %>
      <i class="bi bi-box-arrow-in-down"></i>
      <span>
        <strong>Webhook de entrada</strong>
        <small>Recebimento de leads por token de usuário.</small>
      </span>
    <% end %>
  </nav>
<% end %>

<%
  heading_metrics =
    if active_tab == "inbound"
      [
        { value: inbound_token&.enabled? ? "Ativo" : "Inativo", label: "status" },
        { value: inbound_token&.last_received_at ? l(inbound_token.last_received_at, format: :short) : "Nunca", label: "recebimento" }
      ]
    elsif @can_manage_outbound_webhooks
      [
        { value: number_with_delimiter(@webhook_settings.size), label: "configurados" },
        { value: number_with_delimiter(active_outbound_count), label: "ativos" },
        { value: number_with_delimiter(capture_leads_count), label: "capturam leads" }
      ]
    else
      []
    end
%>

<% main_content = capture do %>
  <div class="webhook-settings-main-stack">
    <%= ax_workspace_heading(
          eyebrow: "Integrações",
          icon: "diagram-3",
          title: active_tab == "inbound" ? "Webhook de entrada" : "Webhook de saída",
          pills: [active_tab == "inbound" ? "Token por usuário" : "Envio externo"],
          subtitle: active_tab == "inbound" ? "Receba leads externos em um endpoint público tokenizado e aplique as regras de distribuição." : "Envie eventos e leads para sistemas externos com controle de captura e status.",
          metrics: heading_metrics
        ) %>

    <%= tabs_markup %>

    <% if active_tab == "inbound" %>
      <%= render "admin/webhook_settings/inbound_tokens", inbound_webhook_tokens: [@inbound_webhook_token] %>
    <% else %>
      <%= render "admin/webhook_settings/outbound_settings", webhook_settings: @webhook_settings, lead_share_tracking_days: @lead_share_tracking_days %>
    <% end %>
  </div>
<% end %>

<%
  aside_content =
    if active_tab == "inbound"
      render("admin/webhook_settings/inbound_examples", inbound_webhook_tokens: [@inbound_webhook_token])
    else
      render("admin/webhook_settings/outbound_aside", webhook_settings: @webhook_settings, lead_share_tracking_days: @lead_share_tracking_days)
    end
%>

<%= render "admin/shared/ui/workspace_shell",
      class_name: "webhook-settings-workspace",
      main_class: "webhook-settings-main-pane",
      main_label: "Configurações de webhooks",
      main_body_class: "webhook-settings-main-body",
      main: main_content,
      aside: aside_content,
      aside_class: "webhook-settings-aside",
      aside_label: "Referência do webhook",
      contextbar_class: "webhook-settings-middle-contextbar",
      controller: "ax-aside",
      storage_key: "admin-webhook-settings-aside-collapsed",
      preload_class: "ax-webhook-settings-aside-collapsed-preload" %>
