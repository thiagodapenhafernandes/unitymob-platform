<div class="profiles-admin">
  <%= ax_workspace_heading(
        eyebrow: "Administração · Acesso",
        icon: "shield-lock",
        title: "Perfis de acesso",
        subtitle: "Gerencie hierarquia vertical, funções horizontais, permissões e escopos operacionais.",
        metrics: [
          { value: @vertical_profiles.size, label: "verticais" },
          { value: @horizontal_profiles.size, label: "horizontais" }
        ]
      ) %>

  <%= ax_inline_notice(tone: :info, icon: "diagram-3", class_name: "tw-mb-3") do %>
    <strong>Hierarquia dinâmica:</strong> os níveis de gestão vêm dos <strong>perfis verticais</strong> desta tela.
    Ao criar um perfil acima dos corretores, todos os usuários abaixo <strong>precisam ser vinculados a um gestor</strong>;
    quem ficar sem vínculo sai da hierarquia e <strong>não aparece para seleção nas regras de distribuição</strong>.
  <% end %>

  <%= ax_operational_panel(eyebrow: "Governança", title: "Hierarquia e funções") do %>
    <div class="ax-table-wrap">
      <table class="ax-table">
        <caption class="tw-sr-only">Perfis verticais e horizontais da conta atual</caption>
        <thead>
          <tr>
            <th scope="col">Nome do perfil</th>
            <th scope="col" class="ax-table__col--w-180">Submetido a</th>
            <th scope="col" class="ax-table__col--w-130">Eixo</th>
            <th scope="col" class="ax-table__col--w-180">Vinculado a</th>
            <th scope="col" class="ax-num ax-table__col--md">Usuários</th>
            <th scope="col" class="ax-table__col--sm">Status</th>
            <th scope="col" class="ax-num ax-table__col--compact">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% @ordered_profiles.each do |profile| %>
            <% superior = @superior_profile[profile.id] %>
            <% users_count = @users_count_by_profile_id.fetch(profile.id, 0) %>
            <tr>
              <td class="ax-strong">
                <span class="tw-inline-flex tw-items-center tw-gap-2">
                  <%= profile.name %>
                  <%= ax_badge("fixo", tone: :gray) if profile.locked? %>
                </span>
              </td>
              <td>
                <% if superior %>
                  <%= ax_badge("→ #{superior.name}", tone: profile.horizontal? ? :purple : :blue) %>
                <% else %>
                  <span class="ax-muted">Topo da hierarquia</span>
                <% end %>
              </td>
              <td><%= ax_badge(profile.vertical? ? "Vertical" : "Horizontal", tone: profile.vertical? ? :blue : :purple) %></td>
              <td><%= profile.horizontal? ? profile.vertical_profile&.name : "Hierarquia principal" %></td>
              <td class="ax-num"><%= ax_badge(users_count, tone: :gray) %></td>
              <td><%= ax_badge(profile.active? ? "Ativo" : "Inativo", tone: profile.active? ? :green : :gray, dot: true) %></td>
              <td class="ax-num">
                <span class="tw-inline-flex tw-gap-0.5">
                  <%= ax_icon_button(label: "Editar #{profile.name}", icon: "pencil", url: edit_admin_profile_path(profile)) %>
                  <% unless profile.locked? %>
                    <%= ax_icon_button(
                          label: "Excluir #{profile.name}",
                          icon: "trash",
                          url: admin_profile_path(profile),
                          variant: :danger,
                          data: { turbo_method: :delete, turbo_confirm: "Tem certeza? Isso pode afetar o acesso dos usuários vinculados." }
                        ) %>
                  <% end %>
                </span>
              </td>
            </tr>
          <% end %>

          <% if @profiles.empty? %>
            <tr>
              <td colspan="7">
                <%= ax_empty_state(
                      title: "Nenhum perfil cadastrado",
                      description: "Crie um perfil vertical ou uma função horizontal pela barra de contexto.",
                      icon: "shield-lock"
                    ) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
