<% content_for :admin_contextbar_breadcrumb do %>
  <%= link_to "Admin", admin_root_path %>
  <i class="bi bi-chevron-right"></i>
  <%= link_to "Perfis", admin_profiles_path %>
  <i class="bi bi-chevron-right"></i>
  <strong>Novo perfil</strong>
<% end %>

<% content_for :admin_contextbar_actions do %>
  <%= link_to admin_profiles_path, class: "ax-contextbar__button" do %>
    <i class="bi bi-arrow-left"></i><span>Voltar</span>
  <% end %>
<% end %>

<header class="ax-dashboard-command ax-property-form-command">
  <div class="ax-dashboard-command__main">
    <span class="ax-dashboard-command__eyebrow">Administração</span>
    <h1>Novo perfil de acesso</h1>
    <p>Defina permissões, escopos e disponibilidade do perfil.</p>
  </div>
</header>

<%= render "form", profile: @profile %>
