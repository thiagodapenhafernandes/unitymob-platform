<%= form_with model: [:admin, profile], local: true do |f| %>
  <% if profile.errors.any? %>
    <div class="alert alert-danger">
      <% profile.errors.full_messages.each do |msg| %><div><%= msg %></div><% end %>
    </div>
  <% end %>

  <div class="card shadow-sm border-0 mb-3">
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-8">
          <%= f.label :name, "Nome do perfil", class: "form-label fw-semibold" %>
          <%= f.text_field :name, class: "form-control", placeholder: "Ex: Corretor, Gerente, Diretor, Administrativo" %>
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold">Status</label>
          <div class="form-check form-switch fs-5 mt-1">
            <%= f.check_box :active, class: "form-check-input" %>
            <%= f.label :active, "Perfil ativo", class: "form-check-label" %>
          </div>
        </div>
      </div>

      <hr>

      <div class="alert alert-warning mb-0">
        <div class="form-check form-switch fs-5 mb-0">
          <%= check_box_tag "profile[permissions][admin]", "1", (profile.permissions || {})["admin"] == true, class: "form-check-input", id: "profile_admin_toggle" %>
          <%= label_tag "profile_admin_toggle", class: "form-check-label fw-bold" do %>
            <i class="bi bi-shield-fill-check text-warning me-1"></i>
            Acesso total (Super-administrador)
          <% end %>
        </div>
        <div class="form-text">
          Quando ativado, este perfil tem acesso irrestrito a todos os recursos,
          ignorando as permissões granulares abaixo.
        </div>
      </div>
    </div>
  </div>

  <div class="card shadow-sm border-0 mb-3">
    <div class="card-header bg-white py-3">
      <h5 class="fw-bold mb-0"><i class="bi bi-sliders me-2 text-primary"></i>Permissões por recurso</h5>
      <small class="text-muted">Marque o que este perfil pode fazer. O menu lateral esconde automaticamente o que não for permitido.</small>
    </div>
    <div class="table-responsive">
      <table class="table align-middle mb-0">
        <thead class="bg-light small text-uppercase fw-bold text-muted">
          <tr>
            <th class="px-3" style="min-width: 240px;">Recurso</th>
            <% all_actions = %w[view manage review publish sync] %>
            <% all_actions.each do |a| %>
              <th class="text-center" style="min-width: 90px;"><%= Profile::ACTION_LABELS[a] || a.humanize %></th>
            <% end %>
            <th style="min-width: 200px;">Escopo</th>
          </tr>
        </thead>
        <tbody>
          <% Profile::RESOURCES.each do |res| %>
            <% existing = (profile.permissions || {})[res[:key]] || {} %>
            <tr>
              <td class="px-3">
                <div class="fw-semibold"><i class="bi <%= res[:icon] %> me-2 text-primary"></i><%= res[:label] %></div>
                <div class="text-muted small"><%= res[:description] %></div>
              </td>
              <% all_actions.each do |a| %>
                <td class="text-center">
                  <% if res[:actions].include?(a) %>
                    <div class="form-check form-switch d-inline-block m-0">
                      <%= check_box_tag "profile[permissions][#{res[:key]}][#{a}]", "1",
                                        existing[a] == true,
                                        class: "form-check-input" %>
                    </div>
                  <% else %>
                    <span class="text-muted">—</span>
                  <% end %>
                </td>
              <% end %>
              <td>
                <% if res[:scopeable] %>
                  <%= select_tag "profile[permissions][#{res[:key]}][scope]",
                                 options_for_select([
                                   ["Apenas os próprios", "own"],
                                   ["Todos (sem restrição)", "all"]
                                 ], existing["scope"] || "own"),
                                 class: "form-select form-select-sm" %>
                <% else %>
                  <span class="text-muted small">—</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="d-flex justify-content-end gap-2 mb-4">
    <%= link_to "Cancelar", admin_profiles_path, class: "btn btn-outline-secondary" %>
    <%= f.submit (profile.persisted? ? "Salvar alterações" : "Criar perfil"), class: "btn btn-primary px-4 fw-bold" %>
  </div>
<% end %>
