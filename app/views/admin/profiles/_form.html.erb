<%= form_with model: [:admin, profile], local: true, html: { class: "prof-form" } do |f| %>
  <%= ax_error_summary(profile) %>

  <div class="prof-grid">
    <div class="prof-main">
      <%= ax_operational_panel(eyebrow: "Permissões", title: "Permissões por recurso") do %>
        <div class="prof-body">
          <p class="prof-hint">Marque o que este perfil pode fazer. O menu lateral esconde automaticamente o que não for permitido.</p>

          <% all_actions = %w[view manage review publish sync] %>
          <div class="prof-matrix-wrap">
            <table class="ax-table prof-matrix">
              <thead>
                <tr>
                  <th style="min-width:230px">Recurso</th>
                  <% all_actions.each do |action| %>
                    <th class="ax-num" style="min-width:72px"><%= Profile::ACTION_LABELS[action] || action.humanize %></th>
                  <% end %>
                  <th style="min-width:170px">Escopo</th>
                </tr>
              </thead>
              <tbody>
                <% Profile::RESOURCES.each do |resource| %>
                  <% existing = (profile.permissions || {})[resource[:key]] || {} %>
                  <tr>
                    <td>
                      <div class="prof-res">
                        <span class="prof-res__icon"><i class="bi <%= resource[:icon] %>"></i></span>
                        <div class="prof-res__main">
                          <strong><%= resource[:label] %></strong>
                          <span><%= resource[:description] %></span>
                        </div>
                      </div>
                    </td>

                    <% all_actions.each do |action| %>
                      <td class="ax-num">
                        <% if resource[:actions].include?(action) %>
                          <label class="ax-switch ax-switch--compact" title="<%= Profile::ACTION_LABELS[action] || action.humanize %>">
                            <%= check_box_tag "profile[permissions][#{resource[:key]}][#{action}]",
                                              "1",
                                              existing[action] == true,
                                              class: "ax-switch__input",
                                              aria: { label: "#{resource[:label]}: #{Profile::ACTION_LABELS[action] || action.humanize}" } %>
                            <span class="ax-switch__track"></span>
                          </label>
                        <% else %>
                          <span class="prof-dash">—</span>
                        <% end %>
                      </td>
                    <% end %>

                    <td>
                      <% if resource[:scopeable] %>
                        <%= select_tag "profile[permissions][#{resource[:key]}][scope]",
                                       options_for_select([["Apenas os próprios", "own"], ["Equipe (subárvore)", "team"], ["Todos", "all"]], existing["scope"] || "own"),
                                       class: "ax-control ax-control--sm" %>
                      <% else %>
                        <%= ax_badge("Global", tone: :gray) %>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% end %>
    </div>

    <aside class="prof-side">
      <%= ax_operational_panel(eyebrow: "Identidade", title: "Dados do perfil") do %>
        <div class="prof-body">
          <div class="prof-field">
            <%= ax_field_label(f, :name, text: "Nome do perfil", tooltip: "Ex: Corretor, Gerente, Administrativo") %>
            <%= f.text_field :name, class: "ax-control", placeholder: "Nome do perfil" %>
          </div>

          <div class="prof-field">
            <span class="prof-field__label">Status</span>
            <%= ax_switch_field(label: "Perfil ativo", form: f, method: :active) %>
            <p class="prof-hint">Perfis inativos deixam de ser usados em novos acessos.</p>
          </div>
        </div>
      <% end %>

      <div class="prof-fullaccess">
        <i class="bi bi-shield-fill-check prof-fullaccess__icon"></i>
        <div>
          <%= ax_switch_field(label: tag.strong("Acesso total"), name: "profile[permissions][admin]", value: "1", checked: (profile.permissions || {})["admin"] == true, id: "profile_admin_toggle", class_name: "prof-fullaccess__toggle") %>
          <p>Quando ativado, este perfil ignora permissões granulares e acessa todos os recursos.</p>
        </div>
      </div>
    </aside>
  </div>

  <%= ax_sticky_action_footer do %>
    <%= link_to "Cancelar", admin_profiles_path, class: "ax-btn" %>
    <%= f.submit (profile.persisted? ? "Salvar alterações" : "Criar perfil"), class: "ax-btn ax-btn--primary" %>
  <% end %>
<% end %>

<style id="profiles-form-styles">
  .prof-form { display: grid; gap: 8px; padding-top: 8px; }
  .prof-grid { display: grid; grid-template-columns: minmax(0, 1fr); gap: 8px; align-items: start; }
  @media (min-width: 1080px) { .prof-grid { grid-template-columns: minmax(0, 1fr) 320px; } }
  .prof-main, .prof-side { display: grid; gap: 8px; min-width: 0; }
  .prof-body { padding: 12px; display: grid; gap: 12px; }
  .prof-hint { margin: 0; color: #8a93a3; font-size: 11.5px; line-height: 1.45; }
  .prof-field { display: grid; gap: 5px; min-width: 0; }
  .prof-field__label { color: #1f2733; font-size: 12px; font-weight: 700; }

  .prof-matrix-wrap { overflow-x: auto; border: 1px solid var(--ax-border-soft, #e7ebf2); border-radius: 8px; }
  .prof-matrix { margin: 0; }
  .prof-matrix th, .prof-matrix td { vertical-align: middle; }
  .prof-matrix .ax-control { min-height: 30px; padding: 3px 8px; font-size: 12px; }
  .prof-dash { color: #c2c9d4; }
  .prof-res { display: flex; align-items: center; gap: 8px; min-width: 0; }
  .prof-res__icon { display: inline-flex; align-items: center; justify-content: center; width: 28px; height: 28px; flex: 0 0 auto; border-radius: 7px; background: #eef2f7; color: var(--admin-primary, #365f8f); }
  .prof-res__main { display: grid; gap: 1px; min-width: 0; }
  .prof-res__main strong { color: #1f2733; font-size: 12.5px; }
  .prof-res__main span { color: #8a93a3; font-size: 10.5px; }

  .prof-fullaccess { display: flex; gap: 10px; padding: 12px; border: 1px solid #f4d492; border-left-width: 3px; border-radius: 8px; background: #fffbeb; }
  .prof-fullaccess__icon { color: #d97706; font-size: 16px; flex: 0 0 auto; margin-top: 2px; }
  .prof-fullaccess__toggle { gap: 8px; }
  .prof-fullaccess__toggle strong { color: #92400e; font-size: 13px; }
  .prof-fullaccess p { margin: 4px 0 0; color: #a16207; font-size: 11.5px; line-height: 1.4; }
</style>
