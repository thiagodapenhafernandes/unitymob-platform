<%
  store_location = [@store.address, @store.city, @store.state].compact_blank.join(" • ")
  heading_actions = safe_join([
    ax_button("Voltar", admin_stores_path, variant: :ghost, size: :sm, icon: "arrow-left"),
    (ax_button("Editar", edit_admin_store_path(@store), variant: :primary, size: :sm, icon: "pencil") if can?(:manage, :lojas))
  ].compact)
%>

<%= ax_workspace_heading(
      eyebrow: "Operação · Lojas",
      icon: "geo-alt-fill",
      title: @store.name,
      pills: [@store.active? ? "Ativa" : "Inativa"],
      subtitle: store_location.presence || "Sem endereço informado.",
      actions: heading_actions
    ) %>

<div class="ax-metric-grid tw-mb-3" aria-label="Resumo operacional da loja">
  <%= ax_metric_card(label: "Raio de check-in", value: "#{@store.geofence_radius_meters} m", hint: "Geofence operacional") %>
  <%= ax_metric_card(label: "Tolerância fora", value: "#{@store.out_of_radius_tolerance_minutes} min", hint: "Antes de invalidar presença") %>
  <%= ax_metric_card(label: "Auto check-out", value: "#{@store.auto_checkout_after_minutes} min", hint: "Encerramento automático") %>
</div>

<%= ax_field_grid do %>
  <div class="ax-span-6">
    <%= ax_operational_panel(eyebrow: "Geofence", title: "Localização") do %>
      <% if @store.latitude.present? && @store.longitude.present? %>
        <div data-controller="store-map-picker"
             data-store-map-picker-latitude-value="<%= @store.latitude %>"
             data-store-map-picker-longitude-value="<%= @store.longitude %>"
             data-store-map-picker-radius-value="<%= @store.geofence_radius_meters %>"
             data-store-map-picker-readonly-value="true">
          <div class="store-location-map" data-store-map-picker-target="map"></div>
        </div>
        <div class="tw-text-sm tw-text-ink-muted tw-font-mono">
          <%= @store.latitude %>, <%= @store.longitude %>
        </div>
      <% else %>
        <%= ax_empty_state(
              title: "Sem localização definida",
              description: "Defina as coordenadas para habilitar a geofence desta loja.",
              icon: "map",
              action: ax_button("Definir no mapa", edit_admin_store_path(@store), variant: :ghost, size: :sm)
            ) %>
      <% end %>
    <% end %>
  </div>

  <div class="ax-span-6 tw-grid tw-gap-3">
    <%= ax_operational_panel(eyebrow: "Responsável", title: "Diretor") do %>
      <% if @store.director %>
        <%= ax_record_item(title: @store.director.name, meta: @store.director.email, icon: "person-badge-fill") %>
      <% else %>
        <%= ax_empty_state(
              title: "Sem diretor atribuído",
              description: "Edite a loja para definir o responsável pela unidade.",
              icon: "person-dash"
            ) %>
      <% end %>
    <% end %>

    <%= ax_operational_panel(eyebrow: "Agenda", title: "Turnos operacionais") do %>
      <% operational_shifts = @store.operational_turnos_config %>
      <% active_shift = @store.current_operational_shift %>
      <% configured_shifts = Store::OPERATIONAL_SHIFTS.filter_map { |shift_key| shift_config = operational_shifts[shift_key]; [shift_key, shift_config] if shift_config.present? && ActiveModel::Type::Boolean.new.cast(shift_config["ativo"]) } %>

      <% if configured_shifts.any? %>
        <div class="tw-grid tw-gap-2">
          <% configured_shifts.each do |shift_key, shift_config| %>
            <% title = { "manha" => "Manhã", "tarde" => "Tarde", "unico" => "Único" }.fetch(shift_key) %>
            <%= ax_record_item(
                  title: title,
                  meta: "#{shift_config.dig("entrada", "inicio")} - #{shift_config.dig("fora_roleta", "fim")}",
                  icon: "clock",
                  actions: ax_badge(active_shift == shift_key ? "Agora" : "Configurado", tone: active_shift == shift_key ? :green : :gray, dot: true)
                ) %>
          <% end %>
        </div>
      <% else %>
        <%= ax_empty_state(title: "Sem turnos ativos", description: "Nenhuma janela operacional está configurada para esta loja.", icon: "calendar-x") %>
      <% end %>

      <p class="ax-field__hint tw-mb-0">Corretores participantes são definidos nas regras de distribuição.</p>
    <% end %>

    <%= ax_operational_panel(eyebrow: "Cadastro", title: "Informações") do %>
      <div class="tw-grid tw-gap-2">
        <% if @store.phone.present? %>
          <%= ax_record_item(title: format_phone(@store.phone), eyebrow: "Telefone", icon: "telephone") %>
        <% end %>
        <% if @store.creci.present? %>
          <%= ax_record_item(title: @store.creci, eyebrow: "CRECI", icon: "award") %>
        <% end %>
        <% if @store.zip_code.present? %>
          <%= ax_record_item(title: @store.zip_code, eyebrow: "CEP", icon: "mailbox") %>
        <% end %>
        <%= ax_record_item(title: @store.timezone, eyebrow: "Fuso horário", icon: "clock-history") %>
      </div>
    <% end %>
  </div>
<% end %>
