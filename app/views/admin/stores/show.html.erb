<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-1 text-gray-800">
      <i class="bi bi-geo-alt-fill text-primary me-2"></i><%= @store.name %>
      <% if @store.active? %>
        <span class="badge bg-success-subtle text-success border fs-6 ms-2"><i class="bi bi-check-circle-fill me-1"></i>Ativa</span>
      <% else %>
        <span class="badge bg-secondary-subtle text-secondary border fs-6 ms-2"><i class="bi bi-pause-circle-fill me-1"></i>Inativa</span>
      <% end %>
    </h1>
    <p class="text-muted small mb-0">
      <% if @store.address.present? %>
        <i class="bi bi-pin-map me-1"></i><%= [@store.address, @store.city, @store.state].compact_blank.join(" • ") %>
      <% end %>
    </p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to admin_stores_path, class: "btn btn-outline-secondary btn-sm" do %>
      <i class="bi bi-arrow-left me-1"></i>Voltar
    <% end %>
    <%= link_to edit_admin_store_path(@store), class: "btn btn-primary btn-sm" do %>
      <i class="bi bi-pencil me-1"></i>Editar
    <% end %>
  </div>
</div>

<div class="row g-3">
  <div class="col-md-4">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body text-center">
        <i class="bi bi-bullseye text-info" style="font-size: 2rem;"></i>
        <div class="fw-bold fs-4 mt-2"><%= @store.geofence_radius_meters %>m</div>
        <small class="text-muted text-uppercase">Raio de check-in</small>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body text-center">
        <i class="bi bi-hourglass-split text-warning" style="font-size: 2rem;"></i>
        <div class="fw-bold fs-4 mt-2"><%= @store.out_of_radius_tolerance_minutes %>min</div>
        <small class="text-muted text-uppercase">Tolerância fora</small>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body text-center">
        <i class="bi bi-moon text-primary" style="font-size: 2rem;"></i>
        <div class="fw-bold fs-4 mt-2"><%= @store.auto_checkout_after_minutes %>min</div>
        <small class="text-muted text-uppercase">Auto check-out</small>
      </div>
    </div>
  </div>
</div>

<div class="row g-3 mt-2">
  <div class="col-lg-7">
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-body">
        <h5 class="fw-bold mb-3">
          <i class="bi bi-map text-danger me-2"></i>Localização
        </h5>
        <% if @store.latitude.present? && @store.longitude.present? %>
          <div data-controller="store-map-picker"
               data-store-map-picker-latitude-value="<%= @store.latitude %>"
               data-store-map-picker-longitude-value="<%= @store.longitude %>"
               data-store-map-picker-radius-value="<%= @store.geofence_radius_meters %>"
               data-store-map-picker-readonly-value="true">
            <div data-store-map-picker-target="map" style="height: 350px; border-radius: 8px;" class="border"></div>
          </div>
          <div class="small text-muted mt-2 font-monospace">
            <%= @store.latitude %>, <%= @store.longitude %>
          </div>
        <% else %>
          <div class="text-center text-muted py-4">
            <i class="bi bi-map" style="font-size: 2rem;"></i>
            <p class="mb-0 mt-2">Sem localização definida.</p>
            <%= link_to "Definir no mapa", edit_admin_store_path(@store), class: "btn btn-sm btn-outline-primary mt-2" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-lg-5">
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-body">
        <h5 class="fw-bold mb-3">
          <i class="bi bi-person-badge-fill text-primary me-2"></i>Diretor
        </h5>
        <% if @store.director %>
          <div class="d-flex align-items-center gap-3">
            <i class="bi bi-person-circle text-muted" style="font-size: 2.5rem;"></i>
            <div>
              <div class="fw-semibold"><%= @store.director.name %></div>
              <small class="text-muted"><%= @store.director.email %></small>
            </div>
          </div>
        <% else %>
          <p class="text-muted mb-0"><i class="bi bi-dash-circle me-1"></i>Sem diretor atribuído.</p>
        <% end %>
      </div>
    </div>

    <div class="card border-0 shadow-sm mb-3">
      <div class="card-body">
        <h5 class="fw-bold mb-3">
          <i class="bi bi-info-circle-fill text-info me-2"></i>Informações
        </h5>
        <ul class="list-unstyled small mb-0">
          <% if @store.phone.present? %>
            <li class="mb-2"><i class="bi bi-telephone text-muted me-2"></i><%= @store.phone %></li>
          <% end %>
          <% if @store.creci.present? %>
            <li class="mb-2"><i class="bi bi-award text-muted me-2"></i>CRECI: <strong><%= @store.creci %></strong></li>
          <% end %>
          <% if @store.zip_code.present? %>
            <li class="mb-2"><i class="bi bi-mailbox text-muted me-2"></i>CEP: <%= @store.zip_code %></li>
          <% end %>
          <li class="mb-0"><i class="bi bi-clock text-muted me-2"></i>Fuso: <%= @store.timezone %></li>
        </ul>
      </div>
    </div>
  </div>
</div>

