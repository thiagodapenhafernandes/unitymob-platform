<div class="tw-flex tw-justify-between tw-items-center tw-mb-4">
  <div>
    <h1 class="ax-page-title">
      <i class="bi bi-geo-alt-fill tw-text-primary" style="margin-right:.5rem"></i><%= @store.name %>
      <% if @store.active? %>
        <span class="ax-badge ax-badge--green" style="margin-left:.5rem"><i class="bi bi-check-circle-fill" style="margin-right:.25rem"></i>Ativa</span>
      <% else %>
        <span class="ax-badge ax-badge--gray" style="margin-left:.5rem"><i class="bi bi-pause-circle-fill" style="margin-right:.25rem"></i>Inativa</span>
      <% end %>
    </h1>
    <p class="ax-page-subtitle">
      <% if @store.address.present? %>
        <i class="bi bi-pin-map" style="margin-right:.25rem"></i><%= [@store.address, @store.city, @store.state].compact_blank.join(" • ") %>
      <% end %>
    </p>
  </div>
  <div class="tw-flex tw-gap-2">
    <%= link_to admin_stores_path, class: "ax-btn ax-btn--ghost ax-btn--sm tw-gap-2" do %>
      <i class="bi bi-arrow-left"></i>Voltar
    <% end %>
    <%= link_to edit_admin_store_path(@store), class: "ax-btn ax-btn--primary ax-btn--sm tw-gap-2" do %>
      <i class="bi bi-pencil"></i>Editar
    <% end %>
  </div>
</div>

<%= ax_field_grid do %>
  <div class="ax-span-4">
    <div class="ax-card" style="height:100%">
      <div class="ax-card__body tw-text-center">
        <i class="bi bi-bullseye" style="font-size: 2rem; color:#2563eb"></i>
        <div class="tw-font-bold tw-mt-2"><%= @store.geofence_radius_meters %>m</div>
        <small class="tw-text-ink-muted text-uppercase">Raio de check-in</small>
      </div>
    </div>
  </div>
  <div class="ax-span-4">
    <div class="ax-card" style="height:100%">
      <div class="ax-card__body tw-text-center">
        <i class="bi bi-hourglass-split" style="font-size: 2rem; color:#d97706"></i>
        <div class="tw-font-bold tw-mt-2"><%= @store.out_of_radius_tolerance_minutes %>min</div>
        <small class="tw-text-ink-muted text-uppercase">Tolerância fora</small>
      </div>
    </div>
  </div>
  <div class="ax-span-4">
    <div class="ax-card" style="height:100%">
      <div class="ax-card__body tw-text-center">
        <i class="bi bi-moon tw-text-primary" style="font-size: 2rem;"></i>
        <div class="tw-font-bold tw-mt-2"><%= @store.auto_checkout_after_minutes %>min</div>
        <small class="tw-text-ink-muted text-uppercase">Auto check-out</small>
      </div>
    </div>
  </div>
<% end %>

<div class="tw-mt-3">
<%= ax_field_grid do %>
  <div class="ax-span-6">
    <div class="ax-card tw-mb-3">
      <div class="ax-card__body">
        <h5 class="tw-font-bold tw-mb-3">
          <i class="bi bi-map" style="margin-right:.5rem; color:#dc2626"></i>Localização
        </h5>
        <% if @store.latitude.present? && @store.longitude.present? %>
          <div data-controller="store-map-picker"
               data-store-map-picker-latitude-value="<%= @store.latitude %>"
               data-store-map-picker-longitude-value="<%= @store.longitude %>"
               data-store-map-picker-radius-value="<%= @store.geofence_radius_meters %>"
               data-store-map-picker-readonly-value="true">
            <div data-store-map-picker-target="map" style="height: 350px; border-radius: 8px;" class="border"></div>
          </div>
          <div class="tw-text-sm tw-text-ink-muted tw-mt-2 font-monospace">
            <%= @store.latitude %>, <%= @store.longitude %>
          </div>
        <% else %>
          <div class="tw-text-center tw-text-ink-muted py-4">
            <i class="bi bi-map" style="font-size: 2rem;"></i>
            <p class="tw-mt-2" style="margin-bottom:0">Sem localização definida.</p>
            <%= link_to "Definir no mapa", edit_admin_store_path(@store), class: "ax-btn ax-btn--sm ax-btn--ghost tw-mt-2" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="ax-span-6">
    <div class="ax-card tw-mb-3">
      <div class="ax-card__body">
        <h5 class="tw-font-bold tw-mb-3">
          <i class="bi bi-person-badge-fill tw-text-primary" style="margin-right:.5rem"></i>Diretor
        </h5>
        <% if @store.director %>
          <div class="tw-flex tw-items-center tw-gap-3">
            <i class="bi bi-person-circle tw-text-ink-muted" style="font-size: 2.5rem;"></i>
            <div>
              <div class="tw-font-semibold"><%= @store.director.name %></div>
              <small class="tw-text-ink-muted"><%= @store.director.email %></small>
            </div>
          </div>
        <% else %>
          <p class="tw-text-ink-muted" style="margin-bottom:0"><i class="bi bi-dash-circle" style="margin-right:.25rem"></i>Sem diretor atribuído.</p>
        <% end %>
      </div>
    </div>

    <div class="ax-card tw-mb-3">
      <div class="ax-card__body">
        <h5 class="tw-font-bold tw-mb-3">
          <i class="bi bi-info-circle-fill" style="margin-right:.5rem; color:#2563eb"></i>Informações
        </h5>
        <ul class="list-unstyled tw-text-sm" style="margin-bottom:0">
          <% if @store.phone.present? %>
            <li class="tw-mb-2"><i class="bi bi-telephone tw-text-ink-muted" style="margin-right:.5rem"></i><%= @store.phone %></li>
          <% end %>
          <% if @store.creci.present? %>
            <li class="tw-mb-2"><i class="bi bi-award tw-text-ink-muted" style="margin-right:.5rem"></i>CRECI: <strong><%= @store.creci %></strong></li>
          <% end %>
          <% if @store.zip_code.present? %>
            <li class="tw-mb-2"><i class="bi bi-mailbox tw-text-ink-muted" style="margin-right:.5rem"></i>CEP: <%= @store.zip_code %></li>
          <% end %>
          <li style="margin-bottom:0"><i class="bi bi-clock tw-text-ink-muted" style="margin-right:.5rem"></i>Fuso: <%= @store.timezone %></li>
        </ul>
      </div>
    </div>
  </div>
<% end %>
</div>

