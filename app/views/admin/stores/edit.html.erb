<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-1 text-gray-800">
      <i class="bi bi-pencil-square text-primary me-2"></i>Editar loja
    </h1>
    <p class="text-muted small mb-0"><%= @store.name %></p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to admin_store_path(@store), class: "btn btn-outline-secondary btn-sm" do %>
      <i class="bi bi-eye me-1"></i>Ver
    <% end %>
    <% if current_admin_user&.admin? %>
      <%= button_to admin_store_path(@store),
                    method: :delete,
                    data: { turbo_confirm: "Remover a loja '#{@store.name}'? Esta ação não pode ser desfeita." },
                    class: "btn btn-outline-danger btn-sm" do %>
        <i class="bi bi-trash me-1"></i>Remover
      <% end %>
    <% end %>
  </div>
</div>

<%= render "form", store: @store %>
