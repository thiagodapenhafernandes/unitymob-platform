<div class="tw-flex tw-justify-between tw-items-center tw-mb-4">
  <div>
    <h1 class="ax-page-title">
      <i class="bi bi-pencil-square tw-text-primary" style="margin-right:.5rem"></i>Editar loja
    </h1>
    <p class="ax-page-subtitle"><%= @store.name %></p>
  </div>
  <div class="tw-flex tw-gap-2">
    <%= link_to admin_store_path(@store), class: "ax-btn ax-btn--ghost ax-btn--sm tw-gap-2" do %>
      <i class="bi bi-eye"></i>Ver
    <% end %>
    <% if can?(:manage, :lojas) %>
      <%= button_to admin_store_path(@store),
                    method: :delete,
                    data: { turbo_confirm: "Remover a loja '#{@store.name}'? Esta ação não pode ser desfeita." },
                    class: "ax-btn ax-btn--danger ax-btn--sm tw-gap-2" do %>
        <i class="bi bi-trash"></i>Remover
      <% end %>
    <% end %>
  </div>
</div>

<%= render "form", store: @store %>
