<% store_heading_actions = safe_join([
     ax_button("Ver", admin_store_path(@store), variant: :ghost, size: :sm, icon: "eye"),
     (button_to(admin_store_path(@store), method: :delete,
       data: { turbo_confirm: "Arquivar a loja '#{@store.name}'? Ela deixa de aparecer nos fluxos de check-in, mas o histórico é preservado." },
       class: "ax-btn ax-btn--danger ax-btn--sm tw-gap-2") { safe_join([ax_icon("archive"), "Arquivar"], " ") } if can?(:manage, :lojas))
   ].compact) %>
<%= ax_workspace_heading(
      eyebrow: "Operação · Lojas",
      icon: "pencil-square",
      title: "Editar loja",
      subtitle: @store.name,
      actions: store_heading_actions
    ) %>

<%= render "form", store: @store %>
