<%= form_with model: [:admin, store], local: true do |f| %>
  <%= ax_error_summary(store) %>

  <!-- Card 1: Identificação -->
  <div class="ax-card tw-mb-4">
    <div class="ax-card__body">
      <h5 class="tw-font-bold tw-mb-3">
        <i class="bi bi-tag-fill tw-text-primary" style="margin-right:.5rem"></i>Identificação
      </h5>
      <%= ax_field_grid do %>
        <div class="ax-span-6">
          <%= f.label :name, "Nome da loja", class: "ax-label tw-font-semibold" %>
          <span class="ax-badge ax-badge--red" style="margin-left:.25rem">obrigatório</span>
          <%= f.text_field :name, class: "ax-control", placeholder: "Ex: Loja Centro" %>
        </div>
        <div class="ax-span-4">
          <%= f.label :active, "Status", class: "ax-label tw-font-semibold" %>
          <div class="tw-mt-2">
            <%= ax_switch_field(label: store.active? ? "Ativa" : "Inativa", form: f, method: :active) %>
          </div>
        </div>

        <div class="ax-span-6">
          <%= f.label :director_admin_user_id, "Diretor da loja", class: "ax-label tw-font-semibold" %>
          <%= f.select :director_admin_user_id,
                       options_for_select(current_tenant.admin_users.active.order(:name).map { |u| [u.name, u.id] }, store.director_admin_user_id),
                       { include_blank: "— Sem diretor —" },
                       class: "ax-control",
                       data: { controller: "tom-select", placeholder: "Buscar corretor…" } %>
          <small class="tw-text-ink-muted">Admin responsável por esta unidade.</small>
        </div>
        <div class="ax-span-6">
          <%= f.label :timezone, "Fuso horário", class: "ax-label tw-font-semibold" %>
          <%
            brazil_zones = [
              ["Brasília / São Paulo (GMT-03:00)", "America/Sao_Paulo"],
              ["Manaus / Cuiabá (GMT-04:00)",       "America/Manaus"],
              ["Rio Branco (GMT-05:00)",            "America/Rio_Branco"],
              ["Fernando de Noronha (GMT-02:00)",   "America/Noronha"]
            ]
            americas_zones = ActiveSupport::TimeZone
              .all
              .select { |tz| tz.tzinfo.name.start_with?("America/") }
              .reject { |tz| brazil_zones.any? { |_, iana| iana == tz.tzinfo.name } }
              .map    { |tz| [tz.to_s, tz.tzinfo.name] }
          %>
          <%= f.select :timezone,
                       grouped_options_for_select(
                         { "Brasil" => brazil_zones, "Américas" => americas_zones },
                         store.timezone
                       ),
                       {},
                       class: "ax-control",
                       data: { controller: "tom-select", placeholder: "Buscar fuso…" } %>
        </div>

        <div class="ax-span-6">
          <%= f.label :phone, "Telefone", class: "ax-label tw-font-semibold" %>
          <div class="tw-flex tw-items-center tw-gap-2">
            <span><i class="bi bi-telephone tw-text-ink-muted"></i></span>
            <%= f.text_field :phone,
                             class: "ax-control",
                             placeholder: "(47) 3311-1067",
                             autocomplete: "tel",
                             data: { controller: "mask", mask_type_value: "phone" } %>
          </div>
        </div>
        <div class="ax-span-6">
          <%= f.label :creci, "CRECI da loja", class: "ax-label tw-font-semibold" %>
          <div class="tw-flex tw-items-center tw-gap-2">
            <span><i class="bi bi-award tw-text-ink-muted"></i></span>
            <%= f.text_field :creci, class: "ax-control" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Card 2: Localização e geofence -->
  <div class="ax-card tw-mb-4"
       data-controller="store-map-picker"
       data-store-map-picker-latitude-value="<%= store.latitude %>"
       data-store-map-picker-longitude-value="<%= store.longitude %>"
       data-store-map-picker-radius-value="<%= store.geofence_radius_meters %>">
    <div class="ax-card__body">
      <h5 class="tw-font-bold tw-mb-3">
        <i class="bi bi-geo-alt-fill" style="margin-right:.5rem; color:#dc2626"></i>Localização e geofence
      </h5>
      <p class="tw-text-sm tw-text-ink-muted tw-mb-3">Clique no mapa para definir o centro da loja. Arraste o slider de raio para ajustar.</p>

      <div data-controller="cep-lookup">
        <%= ax_field_grid do %>
          <div class="ax-span-6">
            <%= f.label :zip_code, "CEP", class: "ax-label tw-font-semibold" %>
            <div class="tw-flex tw-items-center tw-gap-2">
              <span><i class="bi bi-mailbox tw-text-ink-muted"></i></span>
              <%= f.text_field :zip_code,
                               class: "ax-control",
                               placeholder: "88330-030",
                               maxlength: 9,
                               data: { cep_lookup_target: "cep", action: "blur->cep-lookup#lookup" } %>
              <button type="button"
                      class="ax-btn ax-btn--ghost tw-gap-2"
                      data-cep-lookup-target="button"
                      data-action="cep-lookup#lookup">
                <i class="bi bi-search"></i>Buscar
              </button>
            </div>
            <small data-cep-lookup-target="status" class="form-text tw-text-sm tw-text-ink-muted">
              Digite o CEP e clique Buscar — preenchemos endereço + mapa automaticamente.
            </small>
          </div>
          <div class="ax-span-6">
            <%= f.label :address, "Endereço", class: "ax-label tw-font-semibold" %>
            <%= f.text_field :address,
                             class: "ax-control",
                             placeholder: "Av. Atlântica",
                             data: { cep_lookup_target: "address" } %>
          </div>
          <div class="ax-span-2">
            <%= f.label :number, "Número", class: "ax-label tw-font-semibold" %>
            <%= f.text_field :number,
                             class: "ax-control",
                             placeholder: "3750",
                             data: {
                               cep_lookup_target: "number",
                               action: "change->cep-lookup#geocodeFromNumber blur->cep-lookup#geocodeFromNumber"
                             } %>
          </div>

          <div class="ax-span-6">
            <%= f.label :neighborhood, "Bairro", class: "ax-label tw-font-semibold" %>
            <%= f.text_field :neighborhood,
                             class: "ax-control",
                             data: { cep_lookup_target: "neighborhood" } %>
          </div>
          <div class="ax-span-6">
            <%= f.label :city, "Cidade", class: "ax-label tw-font-semibold" %>
            <%= f.text_field :city,
                             class: "ax-control",
                             data: { cep_lookup_target: "city" } %>
          </div>
          <div class="ax-span-2">
            <%= f.label :state, "UF", class: "ax-label tw-font-semibold" %>
            <%= f.text_field :state,
                             class: "ax-control text-uppercase",
                             maxlength: 2,
                             data: { cep_lookup_target: "uf" } %>
          </div>
        <% end %>
      </div>

      <hr class="my-4">

      <!-- Mapa -->
      <div data-store-map-picker-target="map"
           style="height: 400px; border-radius: 8px;"
           class="border"></div>

      <div class="tw-mt-3">
      <%= ax_field_grid do %>
        <div class="ax-span-4">
          <%= f.label :latitude, "Latitude", class: "ax-label tw-font-semibold tw-text-sm" %>
          <%= f.text_field :latitude,
                           class: "ax-control ax-control--sm font-monospace",
                           data: { store_map_picker_target: "latitudeInput", action: "change->store-map-picker#updateFromInputs" },
                           readonly: true %>
        </div>
        <div class="ax-span-4">
          <%= f.label :longitude, "Longitude", class: "ax-label tw-font-semibold tw-text-sm" %>
          <%= f.text_field :longitude,
                           class: "ax-control ax-control--sm font-monospace",
                           data: { store_map_picker_target: "longitudeInput", action: "change->store-map-picker#updateFromInputs" },
                           readonly: true %>
        </div>
        <div class="ax-span-4">
          <%= f.label :geofence_radius_meters, "Raio de check-in (m)", class: "ax-label tw-font-semibold tw-text-sm" %>
          <div class="tw-flex tw-items-center tw-gap-2">
            <%= f.number_field :geofence_radius_meters,
                               min: 25, max: 2000, step: 25,
                               class: "ax-control ax-control--sm",
                               data: { store_map_picker_target: "radiusInput", action: "input->store-map-picker#updateRadius" } %>
            <span class="ax-badge ax-badge--blue" data-store-map-picker-target="radiusLabel"><%= store.geofence_radius_meters %>m</span>
          </div>
        </div>
      <% end %>
      </div>
    </div>
  </div>

  <!-- Card 3: Tolerâncias -->
  <div class="ax-card tw-mb-4">
    <div class="ax-card__body">
      <h5 class="tw-font-bold tw-mb-3">
        <i class="bi bi-stopwatch-fill" style="margin-right:.5rem; color:#d97706"></i>Regras de check-out automático
      </h5>
      <%= ax_field_grid do %>
        <div class="ax-span-6">
          <%= f.label :out_of_radius_tolerance_minutes, "Tolerância fora do raio (minutos)", class: "ax-label tw-font-semibold" %>
          <div class="tw-flex tw-items-center tw-gap-2">
            <span><i class="bi bi-hourglass-split" style="color:#d97706"></i></span>
            <%= f.number_field :out_of_radius_tolerance_minutes, min: 1, max: 120, class: "ax-control" %>
            <span>min</span>
          </div>
          <small class="tw-text-ink-muted">Se corretor sair do raio, é avisado e tem esse tempo pra voltar antes de check-out automático.</small>
        </div>
        <div class="ax-span-6">
          <%= f.label :auto_checkout_after_minutes, "Check-out automático após fim do turno", class: "ax-label tw-font-semibold" %>
          <div class="tw-flex tw-items-center tw-gap-2">
            <span><i class="bi bi-moon" style="color:var(--admin-primary)"></i></span>
            <%= f.number_field :auto_checkout_after_minutes, min: 0, max: 240, class: "ax-control" %>
            <span>min</span>
          </div>
          <small class="tw-text-ink-muted">Se esqueceu de fechar, sistema fecha automaticamente após esse tempo do fim do turno.</small>
        </div>
      <% end %>
    </div>
  </div>

  <div class="tw-flex tw-justify-end tw-gap-2" style="margin-bottom:3rem">
    <%= link_to "Cancelar", admin_stores_path, class: "ax-btn ax-btn--ghost" %>
    <%= f.submit class: "ax-btn ax-btn--primary" do %>
      <i class="bi bi-check-lg" style="margin-right:.25rem"></i>Salvar loja
    <% end %>
  </div>
<% end %>
