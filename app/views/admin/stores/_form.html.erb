<%= form_with model: [:admin, store], local: true, html: { class: "admin-entity-dark" } do |f| %>
  <%= ax_error_summary(store) %>

  <%= ax_operational_panel(eyebrow: "Cadastro", title: "Identificação", class_name: "tw-mb-4") do %>
      <%= ax_field_grid do %>
        <div class="ax-span-6">
          <%= ax_text_field(form: f, method: :name, label: "Nome da loja", placeholder: "Ex: Loja Centro") %>
        </div>
        <div class="ax-span-4">
          <%= ax_field_label(f, :active, text: "Status") %>
          <div class="tw-mt-2">
            <%= ax_switch_field(label: store.active? ? "Ativa" : "Inativa", form: f, method: :active) %>
          </div>
        </div>

        <div class="ax-span-6">
          <%= ax_select_field(
                form: f,
                method: :director_admin_user_id,
                label: "Diretor da loja",
                choices: current_tenant.admin_users.active.order(:name).map { |u| [u.name, u.id] },
                select_options: { include_blank: "— Sem diretor —" },
                html_options: { data: { controller: "tom-select", placeholder: "Buscar corretor…" } }
              ) %>
          <small class="tw-text-ink-muted">Admin responsável por esta unidade.</small>
        </div>
        <div class="ax-span-6">
          <%
            brazil_zones = [
              ["Brasília / São Paulo (GMT-03:00)", "America/Sao_Paulo"],
              ["Manaus / Cuiabá (GMT-04:00)",       "America/Manaus"],
              ["Rio Branco (GMT-05:00)",            "America/Rio_Branco"],
              ["Fernando de Noronha (GMT-02:00)",   "America/Noronha"]
            ]
            americas_zones = ActiveSupport::TimeZone
              .all
              .select { |tz| tz.tzinfo.name.start_with?("America/") }
              .reject { |tz| brazil_zones.any? { |_, iana| iana == tz.tzinfo.name } }
              .map    { |tz| [tz.to_s, tz.tzinfo.name] }
          %>
          <%= ax_select_field(
                form: f,
                method: :timezone,
                label: "Fuso horário",
                choices: grouped_options_for_select(
                  { "Brasil" => brazil_zones, "Américas" => americas_zones },
                  store.timezone
                ),
                html_options: { data: { controller: "tom-select", placeholder: "Buscar fuso…" } }
              ) %>
        </div>

        <div class="ax-span-6">
          <%= ax_field_label(f, :phone, text: "Telefone") %>
          <%= ax_input_group(prefix: ax_icon("telephone", class_name: "tw-text-ink-muted")) do %>
            <%= f.text_field :phone,
                             class: "ax-control",
                             placeholder: "(47) 3311-1067",
                             autocomplete: "tel",
                             data: { controller: "phone-input" } %>
          <% end %>
        </div>
        <div class="ax-span-6">
          <%= ax_field_label(f, :creci, text: "CRECI da loja") %>
          <%= ax_input_group(prefix: ax_icon("award", class_name: "tw-text-ink-muted")) do %>
            <%= f.text_field :creci, class: "ax-control" %>
          <% end %>
        </div>
      <% end %>
  <% end %>

  <div class="tw-mb-4"
       data-controller="store-map-picker"
       data-store-map-picker-latitude-value="<%= store.latitude %>"
       data-store-map-picker-longitude-value="<%= store.longitude %>"
       data-store-map-picker-radius-value="<%= store.geofence_radius_meters %>">
    <%= ax_operational_panel(eyebrow: "Geofence", title: "Localização e geofence") do %>
      <p class="tw-text-sm tw-text-ink-muted tw-mb-3">Informe o número para localizar o ponto exato. Quando o mapa não confirmar o número, clique ou arraste o marcador para fazer o ajuste fino.</p>

      <div data-controller="cep-lookup"
           data-cep-lookup-geocode-url-value="<%= geocode_admin_stores_path %>">
        <%= ax_field_grid do %>
          <div class="ax-span-6">
            <%= ax_field_label(f, :zip_code, text: "CEP") %>
            <%= ax_input_group(
                  prefix: ax_icon("mailbox", class_name: "tw-text-ink-muted"),
                  action: capture do %>
              <button type="button"
                      class="ax-btn ax-btn--ghost tw-gap-2"
                      data-cep-lookup-target="button"
                      data-action="cep-lookup#lookup">
                <i class="bi bi-search" aria-hidden="true"></i><span>Buscar</span>
              </button>
            <% end) do %>
              <%= f.text_field :zip_code,
                               class: "ax-control",
                               placeholder: "88330-030",
                               maxlength: 9,
                               data: { cep_lookup_target: "cep", action: "blur->cep-lookup#lookup" } %>
            <% end %>
            <small data-cep-lookup-target="status" class="form-text tw-text-sm tw-text-ink-muted">
              Digite o CEP e clique Buscar — preenchemos endereço + mapa automaticamente.
            </small>
          </div>
          <div class="ax-span-6">
            <%= ax_text_field(form: f, method: :address, label: "Endereço", placeholder: "Av. Atlântica",
                  autocomplete: "address-line1", data: { cep_lookup_target: "address" }) %>
          </div>
          <div class="ax-span-4">
            <%= ax_field_label(f, :number, text: "Número") %>
            <%= ax_input_group(action: capture do %>
              <button type="button"
                      class="ax-btn ax-btn--primary tw-whitespace-nowrap"
                      data-action="cep-lookup#geocodeFromNumber">
                Aplicar
              </button>
            <% end) do %>
              <%= f.text_field :number,
                               class: "ax-control",
                               placeholder: "3750",
                               data: {
                                 cep_lookup_target: "number",
                                 action: "keydown.enter->cep-lookup#geocodeFromNumber"
                               } %>
            <% end %>
            <small class="tw-text-ink-muted">Necessário para ajuste fino do geofence.</small>
          </div>

          <div class="ax-span-6">
            <%= ax_text_field(form: f, method: :neighborhood, label: "Bairro", autocomplete: "address-level3",
                  data: { cep_lookup_target: "neighborhood" }) %>
          </div>
          <div class="ax-span-6">
            <%= ax_text_field(form: f, method: :city, label: "Cidade", autocomplete: "address-level2",
                  data: { cep_lookup_target: "city" }) %>
          </div>
          <div class="ax-span-2">
            <%= ax_text_field(form: f, method: :state, label: "UF", maxlength: 2, class: "text-uppercase",
                  autocomplete: "address-level1", data: { cep_lookup_target: "uf" }) %>
          </div>
        <% end %>
      </div>

      <hr class="my-4">

      <!-- Mapa -->
      <div data-store-map-picker-target="map"
           class="store-location-map store-location-map--editor"></div>

      <div class="tw-mt-3">
      <%= ax_field_grid do %>
        <div class="ax-span-4">
          <%= ax_text_field(form: f, method: :latitude, label: "Latitude", class: "ax-control--sm font-monospace",
                data: { store_map_picker_target: "latitudeInput", action: "change->store-map-picker#updateFromInputs" }, readonly: true) %>
        </div>
        <div class="ax-span-4">
          <%= ax_text_field(form: f, method: :longitude, label: "Longitude", class: "ax-control--sm font-monospace",
                data: { store_map_picker_target: "longitudeInput", action: "change->store-map-picker#updateFromInputs" }, readonly: true) %>
        </div>
        <div class="ax-span-4">
          <%= ax_field_label(f, :geofence_radius_meters, text: "Raio de check-in (m)") %>
          <%= ax_input_group(
                suffix: ax_badge(
                  "#{store.geofence_radius_meters}m",
                  tone: :blue,
                  data: { store_map_picker_target: "radiusLabel" }
                )
              ) do %>
            <%= f.number_field :geofence_radius_meters,
                               min: 25, max: 2000, step: 25,
                               class: "ax-control ax-control--sm",
                               data: { store_map_picker_target: "radiusInput", action: "input->store-map-picker#updateRadius" } %>
          <% end %>
        </div>
      <% end %>
      </div>
    <% end %>
  </div>

  <%= ax_operational_panel(eyebrow: "Presença", title: "Presença e tolerância", class_name: "tw-mb-4") do %>
      <%= ax_field_grid do %>
        <div class="ax-span-6">
          <%= ax_field_label(f, :out_of_radius_tolerance_minutes, text: "Tolerância fora do raio (minutos)") %>
          <%= ax_input_group(prefix: ax_icon("hourglass-split", class_name: "tw-text-amber-600"), suffix: "min") do %>
            <%= f.number_field :out_of_radius_tolerance_minutes, min: 1, max: 120, class: "ax-control" %>
          <% end %>
          <small class="tw-text-ink-muted">Se corretor sair do raio, é avisado e tem esse tempo pra voltar antes de check-out automático.</small>
        </div>
        <div class="ax-span-6">
          <%= ax_field_label(f, :auto_checkout_after_minutes, text: "Fallback de check-out automático") %>
          <%= ax_input_group(prefix: ax_icon("moon", class_name: "tw-text-primary"), suffix: "min") do %>
            <%= f.number_field :auto_checkout_after_minutes, min: 0, max: 240, class: "ax-control" %>
          <% end %>
          <small class="tw-text-ink-muted">Usado como fallback quando o turno operacional não tiver uma regra própria.</small>
        </div>
      <% end %>
  <% end %>

  <%= ax_operational_panel(eyebrow: "Agenda", title: "Turnos operacionais da loja", class_name: "tw-mb-4") do %>
      <%= ax_inline_notice(tone: :neutral, icon: "calendar-week") do %>
        A loja define as janelas de <strong>Entrada</strong>, <strong>Pós-risca</strong> e <strong>Fora da roleta</strong>. Os corretores participantes continuam sendo definidos nas regras de distribuição.
      <% end %>

      <div class="tw-mt-3">
        <% Store::OPERATIONAL_SHIFTS.each do |shift_key| %>
          <%= render "operational_shift_fields", store: store, shift_key: shift_key %>
        <% end %>
      </div>

      <%= ax_inline_notice(tone: :info, icon: "info-circle") do %>
        Quando uma regra exigir turno ativo, o sistema consulta estes horários da loja selecionada no check-in. O checkout automático encerra o ponto; remover da fila é opcional e só acontece quando estiver marcado no turno.
      <% end %>
  <% end %>

  <%= ax_form_actions(cancel_path: admin_stores_path, submit_label: "Salvar loja", form: f) %>
<% end %>
