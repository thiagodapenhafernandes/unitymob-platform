<%= form_with model: [:admin, store], local: true do |f| %>
  <% if store.errors.any? %>
    <div class="alert alert-danger">
      <strong><i class="bi bi-exclamation-triangle-fill me-1"></i>Corrija os seguintes erros:</strong>
      <ul class="mb-0 mt-2">
        <% store.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <!-- Card 1: Identificação -->
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <h5 class="fw-bold mb-3">
        <i class="bi bi-tag-fill text-primary me-2"></i>Identificação
      </h5>
      <div class="row g-3">
        <div class="col-md-8">
          <%= f.label :name, "Nome da loja", class: "form-label fw-semibold" %>
          <span class="badge bg-danger-subtle text-danger ms-1">obrigatório</span>
          <%= f.text_field :name, class: "form-control", placeholder: "Ex: Loja Centro" %>
        </div>
        <div class="col-md-4">
          <%= f.label :active, "Status", class: "form-label fw-semibold" %>
          <div class="form-check form-switch form-switch-lg mt-2">
            <%= f.check_box :active, class: "form-check-input" %>
            <%= f.label :active, (store.active? ? "Ativa" : "Inativa"), class: "form-check-label" %>
          </div>
        </div>

        <div class="col-md-6">
          <%= f.label :director_admin_user_id, "Diretor da loja", class: "form-label fw-semibold" %>
          <%= f.select :director_admin_user_id,
                       options_for_select(AdminUser.active.order(:name).map { |u| [u.name, u.id] }, store.director_admin_user_id),
                       { include_blank: "— Sem diretor —" },
                       class: "form-select",
                       data: { controller: "tom-select", placeholder: "Buscar corretor…" } %>
          <small class="text-muted">Admin responsável por esta unidade.</small>
        </div>
        <div class="col-md-6">
          <%= f.label :timezone, "Fuso horário", class: "form-label fw-semibold" %>
          <%
            brazil_zones = [
              ["Brasília / São Paulo (GMT-03:00)", "America/Sao_Paulo"],
              ["Manaus / Cuiabá (GMT-04:00)",       "America/Manaus"],
              ["Rio Branco (GMT-05:00)",            "America/Rio_Branco"],
              ["Fernando de Noronha (GMT-02:00)",   "America/Noronha"]
            ]
            americas_zones = ActiveSupport::TimeZone
              .all
              .select { |tz| tz.tzinfo.name.start_with?("America/") }
              .reject { |tz| brazil_zones.any? { |_, iana| iana == tz.tzinfo.name } }
              .map    { |tz| [tz.to_s, tz.tzinfo.name] }
          %>
          <%= f.select :timezone,
                       grouped_options_for_select(
                         { "Brasil" => brazil_zones, "Américas" => americas_zones },
                         store.timezone
                       ),
                       {},
                       class: "form-select",
                       data: { controller: "tom-select", placeholder: "Buscar fuso…" } %>
        </div>

        <div class="col-md-6">
          <%= f.label :phone, "Telefone", class: "form-label fw-semibold" %>
          <div class="input-group">
            <span class="input-group-text bg-white"><i class="bi bi-telephone text-muted"></i></span>
            <%= f.text_field :phone,
                             class: "form-control",
                             placeholder: "(47) 3311-1067",
                             autocomplete: "tel",
                             data: { controller: "mask", mask_type_value: "phone" } %>
          </div>
        </div>
        <div class="col-md-6">
          <%= f.label :creci, "CRECI da loja", class: "form-label fw-semibold" %>
          <div class="input-group">
            <span class="input-group-text bg-white"><i class="bi bi-award text-muted"></i></span>
            <%= f.text_field :creci, class: "form-control" %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Card 2: Localização e geofence -->
  <div class="card border-0 shadow-sm mb-4"
       data-controller="store-map-picker"
       data-store-map-picker-latitude-value="<%= store.latitude %>"
       data-store-map-picker-longitude-value="<%= store.longitude %>"
       data-store-map-picker-radius-value="<%= store.geofence_radius_meters %>">
    <div class="card-body">
      <h5 class="fw-bold mb-3">
        <i class="bi bi-geo-alt-fill text-danger me-2"></i>Localização e geofence
      </h5>
      <p class="small text-muted mb-3">Clique no mapa para definir o centro da loja. Arraste o slider de raio para ajustar.</p>

      <div data-controller="cep-lookup">
        <div class="row g-3">
          <div class="col-md-5">
            <%= f.label :zip_code, "CEP", class: "form-label fw-semibold" %>
            <div class="input-group">
              <span class="input-group-text bg-white"><i class="bi bi-mailbox text-muted"></i></span>
              <%= f.text_field :zip_code,
                               class: "form-control",
                               placeholder: "88330-030",
                               maxlength: 9,
                               data: { cep_lookup_target: "cep", action: "blur->cep-lookup#lookup" } %>
              <button type="button"
                      class="btn btn-outline-primary"
                      data-cep-lookup-target="button"
                      data-action="cep-lookup#lookup">
                <i class="bi bi-search me-1"></i>Buscar
              </button>
            </div>
            <small data-cep-lookup-target="status" class="form-text small text-muted">
              Digite o CEP e clique Buscar — preenchemos endereço + mapa automaticamente.
            </small>
          </div>
          <div class="col-md-5">
            <%= f.label :address, "Endereço", class: "form-label fw-semibold" %>
            <%= f.text_field :address,
                             class: "form-control",
                             placeholder: "Av. Atlântica",
                             data: { cep_lookup_target: "address" } %>
          </div>
          <div class="col-md-2">
            <%= f.label :number, "Número", class: "form-label fw-semibold" %>
            <%= f.text_field :number,
                             class: "form-control",
                             placeholder: "3750",
                             data: {
                               cep_lookup_target: "number",
                               action: "change->cep-lookup#geocodeFromNumber blur->cep-lookup#geocodeFromNumber"
                             } %>
          </div>

          <div class="col-md-5">
            <%= f.label :neighborhood, "Bairro", class: "form-label fw-semibold" %>
            <%= f.text_field :neighborhood,
                             class: "form-control",
                             data: { cep_lookup_target: "neighborhood" } %>
          </div>
          <div class="col-md-5">
            <%= f.label :city, "Cidade", class: "form-label fw-semibold" %>
            <%= f.text_field :city,
                             class: "form-control",
                             data: { cep_lookup_target: "city" } %>
          </div>
          <div class="col-md-2">
            <%= f.label :state, "UF", class: "form-label fw-semibold" %>
            <%= f.text_field :state,
                             class: "form-control text-uppercase",
                             maxlength: 2,
                             data: { cep_lookup_target: "uf" } %>
          </div>
        </div>
      </div>

      <hr class="my-4">

      <!-- Mapa -->
      <div data-store-map-picker-target="map"
           style="height: 400px; border-radius: 8px;"
           class="border"></div>

      <div class="row g-3 mt-3">
        <div class="col-md-4">
          <%= f.label :latitude, "Latitude", class: "form-label fw-semibold small" %>
          <%= f.text_field :latitude,
                           class: "form-control form-control-sm font-monospace",
                           data: { store_map_picker_target: "latitudeInput", action: "change->store-map-picker#updateFromInputs" },
                           readonly: true %>
        </div>
        <div class="col-md-4">
          <%= f.label :longitude, "Longitude", class: "form-label fw-semibold small" %>
          <%= f.text_field :longitude,
                           class: "form-control form-control-sm font-monospace",
                           data: { store_map_picker_target: "longitudeInput", action: "change->store-map-picker#updateFromInputs" },
                           readonly: true %>
        </div>
        <div class="col-md-4">
          <%= f.label :geofence_radius_meters, "Raio de check-in (m)", class: "form-label fw-semibold small" %>
          <div class="d-flex align-items-center gap-2">
            <%= f.number_field :geofence_radius_meters,
                               min: 25, max: 2000, step: 25,
                               class: "form-control form-control-sm",
                               data: { store_map_picker_target: "radiusInput", action: "input->store-map-picker#updateRadius" } %>
            <span class="badge bg-info-subtle text-info border" data-store-map-picker-target="radiusLabel"><%= store.geofence_radius_meters %>m</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Card 3: Tolerâncias -->
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <h5 class="fw-bold mb-3">
        <i class="bi bi-stopwatch-fill text-warning me-2"></i>Regras de check-out automático
      </h5>
      <div class="row g-3">
        <div class="col-md-6">
          <%= f.label :out_of_radius_tolerance_minutes, "Tolerância fora do raio (minutos)", class: "form-label fw-semibold" %>
          <div class="input-group">
            <span class="input-group-text bg-white"><i class="bi bi-hourglass-split text-warning"></i></span>
            <%= f.number_field :out_of_radius_tolerance_minutes, min: 1, max: 120, class: "form-control" %>
            <span class="input-group-text">min</span>
          </div>
          <small class="text-muted">Se corretor sair do raio, é avisado e tem esse tempo pra voltar antes de check-out automático.</small>
        </div>
        <div class="col-md-6">
          <%= f.label :auto_checkout_after_minutes, "Check-out automático após fim do turno", class: "form-label fw-semibold" %>
          <div class="input-group">
            <span class="input-group-text bg-white"><i class="bi bi-moon text-info"></i></span>
            <%= f.number_field :auto_checkout_after_minutes, min: 0, max: 240, class: "form-control" %>
            <span class="input-group-text">min</span>
          </div>
          <small class="text-muted">Se esqueceu de fechar, sistema fecha automaticamente após esse tempo do fim do turno.</small>
        </div>
      </div>
    </div>
  </div>

  <div class="d-flex justify-content-end gap-2 mb-5">
    <%= link_to "Cancelar", admin_stores_path, class: "btn btn-outline-secondary" %>
    <%= f.submit class: "btn btn-primary" do %>
      <i class="bi bi-check-lg me-1"></i>Salvar loja
    <% end %>
  </div>
<% end %>
