<%# Lojas — listagem compacta (design system .ax-*). Original em index.html.erb.bootstrap-bak %>
<div class="admin-entity-dark">
<% store_heading_actions = capture do %>
  <div class="tw-flex tw-items-center tw-gap-2">
    <%= form_with url: admin_stores_path, method: :get do %>
      <%= search_field_tag :q, params[:q], class: "ax-search", placeholder: "Buscar por nome...", aria: { label: "Buscar lojas por nome" } %>
    <% end %>
    <% if can?(:manage, :lojas) %>
      <%= ax_button("Nova loja", new_admin_store_path, variant: :primary, size: :sm, icon: "plus-lg") %>
    <% end %>
  </div>
<% end %>
<%= ax_workspace_heading(
      eyebrow: "Operação · Lojas",
      icon: "shop-window",
      title: "Lojas",
      subtitle: "Lojas físicas com geofence e diretor para check-in de corretores.",
      actions: store_heading_actions
    ) %>

<div class="ax-table-wrap">
  <table class="ax-table">
    <caption class="tw-sr-only">Lojas da conta e configurações operacionais de check-in</caption>
    <thead>
      <tr>
        <th scope="col">Loja</th>
        <th scope="col">Localização</th>
        <th scope="col" class="ax-num ax-table__col--compact">Raio</th>
        <th scope="col" class="ax-num ax-table__col--md">Tolerância</th>
        <th scope="col" class="ax-table__col--lg">Diretor</th>
        <th scope="col" class="ax-table__col--sm">Status</th>
        <th scope="col" class="ax-num ax-table__col--xs">Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @stores.each do |store| %>
        <tr>
          <td class="ax-strong">
            <%= link_to store.name, admin_store_path(store) %>
          </td>
          <td><%= [store.address, store.city, store.state].compact_blank.join(" • ").presence || "—" %></td>
          <td class="ax-num"><%= store.geofence_radius_meters %> m</td>
          <td class="ax-num"><%= store.out_of_radius_tolerance_minutes %> min</td>
          <td><%= store.director&.name || "—" %></td>
          <td><%= ax_badge(store.active? ? "Ativa" : "Inativa", tone: store.active? ? :green : :gray, dot: true) %></td>
          <td class="ax-num">
            <span class="tw-inline-flex tw-gap-0.5">
              <%= ax_icon_button(label: "Ver loja #{store.name}", icon: "eye", url: admin_store_path(store)) %>
              <% if can?(:manage, :lojas) %>
                <%= ax_icon_button(label: "Editar loja #{store.name}", icon: "pencil", url: edit_admin_store_path(store)) %>
              <% end %>
            </span>
          </td>
        </tr>
      <% end %>

      <% if @stores.empty? %>
        <tr>
          <td colspan="7">
            <%= ax_empty_state(
                  title: "Nenhuma loja cadastrada",
                  description: "Cadastre uma unidade para configurar geofence, turnos e direção.",
                  icon: "shop-window",
                  action: (ax_button("Cadastrar primeira loja", new_admin_store_path, variant: :primary, size: :sm) if can?(:manage, :lojas)),
                  compact: true
                ) %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
</div>
