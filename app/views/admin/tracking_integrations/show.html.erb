<div class="integration-workspace tracking-workspace">
  <%= ax_workspace_heading(eyebrow: "Integrações · Mensuração", icon: "bullseye", title: "Rastreamento", subtitle: "Gerencie as tags instaladas no site público sem permitir scripts livres.", pills: [@active_tab == "meta_pixel" ? "Meta Pixel" : "Google Tag Manager"], metrics: [{ value: TrackingIntegrationSetting.google_tag_manager_enabled? ? "Ativo" : "Inativo", label: "GTM" }, { value: TrackingIntegrationSetting.meta_pixel_enabled? ? "Ativo" : "Inativo", label: "Meta" }]) %>

  <%= ax_error_summary(@tracking_setting) %>

  <ul class="ax-form-tabs tracking-workspace__tabs" role="tablist" data-controller="ax-tabs" data-ax-tabs-panel-selector-value="#trackingTabsContent">
    <li><a class="ax-form-tabs__item <%= @active_tab == 'google_tag_manager' ? 'active' : '' %>" href="#google-tag-manager" data-ax-tabs-target="tab" data-ax-tabs-target-param="#google-tag-manager" data-action="click->ax-tabs#select" role="tab" aria-controls="google-tag-manager" aria-selected="<%= @active_tab == 'google_tag_manager' %>"><i class="bi bi-google"></i>Google Tag Manager</a></li>
    <li><a class="ax-form-tabs__item <%= @active_tab == 'meta_pixel' ? 'active' : '' %>" href="#meta-pixel" data-ax-tabs-target="tab" data-ax-tabs-target-param="#meta-pixel" data-action="click->ax-tabs#select" role="tab" aria-controls="meta-pixel" aria-selected="<%= @active_tab == 'meta_pixel' %>"><i class="bi bi-meta"></i>Pixel da Meta</a></li>
  </ul>

  <div class="tracking-tab-content" id="trackingTabsContent">
    <section class="tracking-tab-panel" id="google-tag-manager" role="tabpanel" <%= "hidden" unless @active_tab == "google_tag_manager" %>>
      <div class="tracking-workspace__layout">
        <%= ax_panel(title: "Google Tag Manager", subtitle: "Container carregado em todas as páginas públicas.", actions: ax_badge(TrackingIntegrationSetting.google_tag_manager_enabled? ? "ativo" : "inativo", tone: TrackingIntegrationSetting.google_tag_manager_enabled? ? :green : :gray)) do %>
          <%= form_with url: admin_tracking_integration_path(tab: "google_tag_manager"), method: :patch, scope: :tracking, local: true, class: "tracking-settings-form" do |f| %>
            <%= hidden_field_tag "tracking[meta_pixel_enabled]", @tracking_setting.meta_pixel_enabled? ? "true" : "false" %>
            <%= hidden_field_tag "tracking[meta_pixel_id]", @tracking_setting.meta_pixel_id %>
            <%= ax_switch_field(form: f, method: :google_tag_manager_enabled, label: "Ativar no site público", checked: @tracking_setting.google_tag_manager_enabled?, checked_value: "true", unchecked_value: "false", input_html: { checked: @tracking_setting.google_tag_manager_enabled? }) %>
            <div><%= ax_field_label(f, :google_tag_manager_container_id, text: "ID do container", tooltip: "Informe somente o identificador no formato GTM-XXXXXXX.") %><%= f.text_field :google_tag_manager_container_id, class: "ax-control", value: @tracking_setting.google_tag_manager_container_id, placeholder: "GTM-XXXXXXX", autocomplete: "off" %></div>
            <%= f.submit "Salvar Google Tag Manager", class: "ax-btn ax-btn--primary" %>
          <% end %>
        <% end %>
      </div>
    </section>

    <section class="tracking-tab-panel" id="meta-pixel" role="tabpanel" <%= "hidden" unless @active_tab == "meta_pixel" %>>
      <div class="tracking-workspace__layout">
        <%= ax_panel(title: "Pixel da Meta", subtitle: "Pixel base com PageView automático no site público.", actions: ax_badge(TrackingIntegrationSetting.meta_pixel_enabled? ? "ativo" : "inativo", tone: TrackingIntegrationSetting.meta_pixel_enabled? ? :green : :gray)) do %>
          <%= form_with url: admin_tracking_integration_path(tab: "meta_pixel"), method: :patch, scope: :tracking, local: true, class: "tracking-settings-form" do |f| %>
            <%= hidden_field_tag "tracking[google_tag_manager_enabled]", @tracking_setting.google_tag_manager_enabled? ? "true" : "false" %>
            <%= hidden_field_tag "tracking[google_tag_manager_container_id]", @tracking_setting.google_tag_manager_container_id %>
            <%= ax_switch_field(form: f, method: :meta_pixel_enabled, label: "Ativar no site público", checked: @tracking_setting.meta_pixel_enabled?, checked_value: "true", unchecked_value: "false", input_html: { checked: @tracking_setting.meta_pixel_enabled? }) %>
            <div><%= ax_field_label(f, :meta_pixel_id, text: "ID do Pixel", tooltip: "Informe somente o identificador numérico fornecido pela Meta.") %><%= f.text_field :meta_pixel_id, class: "ax-control", value: @tracking_setting.meta_pixel_id, placeholder: "123456789012345", inputmode: "numeric", autocomplete: "off" %></div>
            <%= f.submit "Salvar Pixel da Meta", class: "ax-btn ax-btn--primary" %>
          <% end %>
        <% end %>
      </div>
    </section>
  </div>
</div>
