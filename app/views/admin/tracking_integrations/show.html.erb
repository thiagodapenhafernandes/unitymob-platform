<div class="tw-flex tw-justify-between tw-items-center tw-mb-4">
  <div>
    <h1 class="ax-page-title tw-flex tw-items-center tw-gap-2"><i class="bi bi-bullseye" style="color: #2563eb;"></i>Trackeamento</h1>
    <p class="ax-page-subtitle">Configure tags de mensuração aplicadas no site público.</p>
  </div>
</div>

<%= ax_error_summary(@tracking_setting) %>

<ul class="ax-form-tabs tw-mb-4" role="tablist" data-controller="ax-tabs" data-ax-tabs-panel-selector-value="#trackingTabsContent">
  <li role="presentation">
    <a class="ax-form-tabs__item <%= @active_tab == "google_tag_manager" ? "active" : "" %>"
       href="#google-tag-manager"
       data-ax-tabs-target="tab"
       data-ax-tabs-target-param="#google-tag-manager"
       data-action="click->ax-tabs#select"
       role="tab"
       aria-controls="google-tag-manager"
       aria-selected="<%= @active_tab == "google_tag_manager" %>">
      <i class="bi bi-google"></i>Google Tag Manager
    </a>
  </li>
  <li role="presentation">
    <a class="ax-form-tabs__item <%= @active_tab == "meta_pixel" ? "active" : "" %>"
       href="#meta-pixel"
       data-ax-tabs-target="tab"
       data-ax-tabs-target-param="#meta-pixel"
       data-action="click->ax-tabs#select"
       role="tab"
       aria-controls="meta-pixel"
       aria-selected="<%= @active_tab == "meta_pixel" %>">
      <i class="bi bi-meta"></i>Pixel da Meta
    </a>
  </li>
</ul>

<div class="tab-content" id="trackingTabsContent">
  <div class="tab-pane fade <%= @active_tab == "google_tag_manager" ? "show active" : "" %>" id="google-tag-manager" role="tabpanel">
    <%= ax_field_grid(columns: 12, gap: :compact) do %>
      <div class="ax-span-7">
        <div class="ax-card">
          <div class="ax-card__header">
            <h5 class="ax-card__title tw-flex tw-items-center tw-gap-2"><i class="bi bi-tags" style="color: #2563eb;"></i>Google Tag Manager</h5>
          </div>
          <div class="ax-card__body">
            <%= ax_inline_notice(tone: TrackingIntegrationSetting.google_tag_manager_enabled? ? :success : :warning, icon: TrackingIntegrationSetting.google_tag_manager_enabled? ? "check-circle" : "exclamation-triangle") do %>
              <span>Status: <strong><%= TrackingIntegrationSetting.google_tag_manager_enabled? ? "Ativo no site público" : "Inativo" %></strong></span>
            <% end %>

            <%= form_with url: admin_tracking_integration_path(tab: "google_tag_manager"), method: :patch, scope: :tracking, local: true do |f| %>
              <%= hidden_field_tag "tracking[meta_pixel_enabled]", @tracking_setting.meta_pixel_enabled? ? "true" : "false" %>
              <%= hidden_field_tag "tracking[meta_pixel_id]", @tracking_setting.meta_pixel_id %>

              <div class="tw-mb-3">
                <%= ax_switch_field(form: f, method: :google_tag_manager_enabled,
                      label: "Ativar Google Tag Manager no site público",
                      checked: @tracking_setting.google_tag_manager_enabled?,
                      checked_value: "true", unchecked_value: "false",
                      input_html: { checked: @tracking_setting.google_tag_manager_enabled? }) %>
              </div>

              <div class="tw-mb-3">
                <%= f.label :google_tag_manager_container_id, "ID do container", class: "ax-label" %>
                <%= f.text_field :google_tag_manager_container_id,
                    class: "ax-control",
                    value: @tracking_setting.google_tag_manager_container_id,
                    placeholder: "GTM-XXXXXXX",
                    autocomplete: "off" %>
                <div class="form-text">Informe somente o ID do container. O sistema gera os scripts padrão no site.</div>
              </div>

              <%= f.submit "Salvar Google Tag Manager", class: "ax-btn ax-btn--primary" %>
            <% end %>
          </div>
        </div>
      </div>

      <div class="ax-span-5">
        <div class="ax-card">
          <div class="ax-card__header">
            <h5 class="ax-card__title tw-flex tw-items-center tw-gap-2"><i class="bi bi-shield-check" style="color: #16a34a;"></i>Aplicação</h5>
          </div>
          <div class="ax-card__body">
            <ul class="tw-text-sm tw-text-ink-muted tw-mb-0">
              <li class="tw-mb-2">O script padrão entra no <code>&lt;head&gt;</code> do site público.</li>
              <li class="tw-mb-2">O fallback <code>noscript</code> entra logo após a abertura do <code>&lt;body&gt;</code>.</li>
              <li>O painel administrativo não recebe essas tags.</li>
            </ul>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="tab-pane fade <%= @active_tab == "meta_pixel" ? "show active" : "" %>" id="meta-pixel" role="tabpanel">
    <%= ax_field_grid(columns: 12, gap: :compact) do %>
      <div class="ax-span-7">
        <div class="ax-card">
          <div class="ax-card__header">
            <h5 class="ax-card__title tw-flex tw-items-center tw-gap-2"><i class="bi bi-meta" style="color: #2563eb;"></i>Pixel da Meta</h5>
          </div>
          <div class="ax-card__body">
            <%= ax_inline_notice(tone: TrackingIntegrationSetting.meta_pixel_enabled? ? :success : :warning, icon: TrackingIntegrationSetting.meta_pixel_enabled? ? "check-circle" : "exclamation-triangle") do %>
              <span>Status: <strong><%= TrackingIntegrationSetting.meta_pixel_enabled? ? "Ativo no site público" : "Inativo" %></strong></span>
            <% end %>

            <%= form_with url: admin_tracking_integration_path(tab: "meta_pixel"), method: :patch, scope: :tracking, local: true do |f| %>
              <%= hidden_field_tag "tracking[google_tag_manager_enabled]", @tracking_setting.google_tag_manager_enabled? ? "true" : "false" %>
              <%= hidden_field_tag "tracking[google_tag_manager_container_id]", @tracking_setting.google_tag_manager_container_id %>

              <div class="tw-mb-3">
                <%= ax_switch_field(form: f, method: :meta_pixel_enabled,
                      label: "Ativar Pixel da Meta no site público",
                      checked: @tracking_setting.meta_pixel_enabled?,
                      checked_value: "true", unchecked_value: "false",
                      input_html: { checked: @tracking_setting.meta_pixel_enabled? }) %>
              </div>

              <div class="tw-mb-3">
                <%= f.label :meta_pixel_id, "ID do Pixel", class: "ax-label" %>
                <%= f.text_field :meta_pixel_id,
                    class: "ax-control",
                    value: @tracking_setting.meta_pixel_id,
                    placeholder: "123456789012345",
                    inputmode: "numeric",
                    autocomplete: "off" %>
                <div class="form-text">Informe somente o ID numérico do Pixel. O sistema dispara <code>PageView</code> automaticamente.</div>
              </div>

              <%= f.submit "Salvar Pixel da Meta", class: "ax-btn ax-btn--primary" %>
            <% end %>
          </div>
        </div>
      </div>

      <div class="ax-span-5">
        <div class="ax-card">
          <div class="ax-card__header">
            <h5 class="ax-card__title tw-flex tw-items-center tw-gap-2"><i class="bi bi-shield-check" style="color: #16a34a;"></i>Aplicação</h5>
          </div>
          <div class="ax-card__body">
            <ul class="tw-text-sm tw-text-ink-muted tw-mb-0">
              <li class="tw-mb-2">O script padrão entra no <code>&lt;head&gt;</code> do site público.</li>
              <li class="tw-mb-2">O fallback <code>noscript</code> entra logo após a abertura do <code>&lt;body&gt;</code>.</li>
              <li>O painel salva apenas o ID do Pixel, não scripts livres.</li>
            </ul>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
