<%# Landing Pages — listagem compacta (.ax-*). Original em index.html.erb.bootstrap-bak %>
<div class="public-site-workspace">
<%= ax_workspace_heading(eyebrow: "Site público · Conteúdo", icon: "file-earmark-post", title: @page_title, subtitle: @page_subtitle, metrics: [{ value: @landing_pages.size, label: "páginas" }], actions: ax_button("Nova página", new_admin_landing_page_path, variant: :primary, size: :sm, icon: "plus-lg")) %>

<div class="ax-table-wrap">
  <table class="ax-table">
    <thead>
      <tr>
        <th>Título</th>
        <th class="ax-table__col--w-220">URL (Slug)</th>
        <th class="ax-table__col--sm">Status</th>
        <th>Filtros principais</th>
        <th class="ax-num ax-table__col--compact">Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @landing_pages.each do |page| %>
        <tr>
          <td class="ax-strong"><%= page.title %></td>
          <td><code class="tw-text-primary">/<%= page.slug %></code></td>
          <td>
            <% if page.active? %><span class="ax-badge ax-badge--green ax-badge--dot">Ativa</span>
            <% else %><span class="ax-badge ax-badge--gray ax-badge--dot">Offline</span><% end %>
          </td>
          <td>
            <% filters = page.filter_params || {} %>
            <div class="tw-flex tw-flex-wrap tw-gap-1">
              <% if (cats = Array.wrap(filters['category']).reject(&:blank?)).any? %><span class="ax-badge ax-badge--gray"><%= cats.size %> Cats</span><% end %>
              <% if (cities = Array.wrap(filters['city']).reject(&:blank?)).any? %><span class="ax-badge ax-badge--gray"><%= cities.size %> Cidades</span><% end %>
              <% if (neighborhoods = Array.wrap(filters['neighborhood']).reject(&:blank?)).any? %><span class="ax-badge ax-badge--gray"><%= neighborhoods.size %> Bairros</span><% end %>
              <% if (chars = Array.wrap(filters['characteristics']).reject(&:blank?)).any? %><span class="ax-badge ax-badge--gray"><%= chars.size %> Caracs</span><% end %>
              <% if filters.values.flatten.all?(&:blank?) %><span class="tw-text-ink-faint tw-text-2xs">Sem filtros</span><% end %>
            </div>
          </td>
          <td class="ax-num">
            <span class="tw-inline-flex tw-gap-0.5">
              <% if page.slug.present? %><%= link_to public_landing_page_path(page.slug), target: "_blank", class: "ax-ico-btn", title: "Ver" do %><i class="bi bi-eye"></i><% end %><% end %>
              <%= link_to edit_admin_landing_page_path(page), class: "ax-ico-btn", title: "Editar" do %><i class="bi bi-pencil"></i><% end %>
              <%= button_to admin_landing_page_path(page), method: :delete, form_class: "tw-inline", form: { data: { turbo_confirm: 'Tem certeza que deseja excluir esta página?' } }, class: "ax-ico-btn", title: "Excluir" do %><i class="bi bi-trash"></i><% end %>
            </span>
          </td>
        </tr>
      <% end %>
      <% if @landing_pages.empty? %>
        <tr><td colspan="5"><div class="ax-empty">
          <i class="bi bi-file-earmark-plus tw-text-2xl tw-block tw-mb-2 tw-text-ink-faint"></i>Nenhuma página SEO criada ainda.
        </div></td></tr>
      <% end %>
    </tbody>
  </table>
</div>
</div>

<% if @landing_pages.respond_to?(:total_pages) && @landing_pages.total_pages > 1 %>
  <%= ax_pagination @landing_pages, params: request.query_parameters %>
<% end %>
