<%= form_with(model: [:admin, @landing_page], local: true, class: "ax-field-grid", data: { controller: "property-page-preview", property_page_preview_url_value: "/admin/landing_pages/preview" }) do |f| %>
  <div class="ax-span-12"><%= ax_error_summary(@landing_page) %></div>
  <div class="ax-span-8">
    <%= ax_operational_panel(eyebrow: "Página", title: "Conteúdo e SEO", class_name: "tw-mb-4") do %>
        <%= ax_text_field(form: f, method: :title, label: "Título da Página (H1)", placeholder: "Ex: Apartamentos na Planta em Balneário Camboriú", required: true) %>

        <%= ax_field_grid do %>
          <div class="ax-span-6">
            <%= ax_field_label(f, :slug, text: "URL Amigável (Slug)") %>
            <%= ax_input_group(prefix: "/") do %>
              <%= f.text_field :slug, class: "ax-control", placeholder: "apartamentos-na-planta-bc" %>
            <% end %>
            <p class="ax-field__hint">Deixe em branco para gerar do título.</p>
          </div>
          <div class="ax-span-6">
            <%= ax_text_field(form: f, method: :meta_title, label: "Título SEO (Meta Title)", placeholder: "Título para o Google") %>
          </div>
        <% end %>

        <%= ax_text_field(form: f, method: :meta_description, label: "Descrição SEO (Meta Description)", type: :textarea, rows: 2, placeholder: "Breve resumo para o Google...") %>
        <%= ax_text_field(form: f, method: :description, label: "Descrição de Topo (Introdução)", type: :textarea, rows: 3, placeholder: "Texto que aparece logo abaixo do título na página pública...") %>
        <%= ax_text_field(form: f, method: :content, label: "Texto SEO (Rodapé)", type: :textarea, rows: 6, placeholder: "Conteúdo rico para SEO que aparece após a listagem de imóveis...") %>
    <% end %>

    <%= ax_operational_panel(eyebrow: "Segmentação", title: "Filtros de imóveis", class_name: "tw-mb-4") do %>
        <%= f.fields_for :filter_params do |fp| %>
          <%= ax_field_grid do %>
            <div class="ax-span-6">
              <%= ax_autocomplete_select_field(form: fp, method: :category, label: "Categoria(s)", choices: @property_categories, multiple: true, placeholder: "Selecione categorias", html_options: { data: { action: "change->property-page-preview#refresh" } }) %>
            </div>
            <div class="ax-span-6">
              <%= ax_autocomplete_select_field(form: fp, method: :city, label: "Cidade(s)", choices: @property_cities, multiple: true, placeholder: "Selecione cidades", html_options: { data: { action: "change->property-page-preview#refresh" } }) %>
            </div>
            <div class="ax-span-6">
              <%= ax_autocomplete_select_field(form: fp, method: :neighborhood, label: "Bairro(s)", choices: @property_neighborhoods, multiple: true, placeholder: "Selecione bairros", html_options: { data: { action: "change->property-page-preview#refresh" } }) %>
            </div>
            <div class="ax-span-6">
              <%= ax_select_field(form: fp, method: :transaction_type, label: "Transação", choices: [['Venda', 'venda'], ['Aluguel', 'aluguel']], select_options: { include_blank: "Todas" }, html_options: { data: { action: "change->property-page-preview#refresh" } }) %>
            </div>

            <div class="ax-span-6">
              <%= ax_text_field(form: fp, method: :caracteristica_unica, label: "Característica Única (Tag/Badge)", placeholder: "Ex: Festival Salute 2026", data: { action: "input->property-page-preview#refresh" }) %>
            </div>

            <div class="ax-span-6">
              <%= ax_number_field(form: fp, method: :target_price, label: "Preço Sugerido (Range +/- 20%)", placeholder: "Ex: 1500000", min: 0, data: { action: "input->property-page-preview#refresh" }) %>
            </div>

            <div class="ax-span-4">
              <%= ax_measure_field(form: fp, method: :min_area, label: "Área Mínima", unit: "m²", min: 0, data: { action: "input->property-page-preview#refresh" }) %>
            </div>

            <div class="ax-span-4">
              <%= ax_number_field(form: fp, method: :min_bedrooms, label: "Mín. Dormitórios", min: 0, data: { action: "input->property-page-preview#refresh" }) %>
            </div>
            <div class="ax-span-4">
              <%= ax_number_field(form: fp, method: :min_suites, label: "Mín. Suítes", min: 0, data: { action: "input->property-page-preview#refresh" }) %>
            </div>
            <div class="ax-span-4">
              <%= ax_number_field(form: fp, method: :min_parking, label: "Mín. Vagas", min: 0, data: { action: "input->property-page-preview#refresh" }) %>
            </div>
          <% end %>

          <%= ax_field_group(title: "Características e flags", token: "Opcional", class_name: "ax-field-group--panel tw-mt-4") do %>
            <%= ax_chip_grid do %>
              <% [
                ['frente_mar', 'Frente Mar'],
                ['quadra_mar', 'Quadra Mar'],
                ['vista_mar', 'Vista Mar'],
                ['piscina', 'Piscina'],
                ['mobiliado', 'Mobiliado'],
                ['churrasqueira', 'Churrasqueira'],
                ['cozinha_gourmet_churrasqueira', 'Cozinha gourmet com churrasqueira'],
                ['dependencia_empregada', 'Dependência de empregada'],
                ['sacada', 'Sacada'],
                ['decorado', 'Decorado'],
                ['sol_manha', 'Sol da manhã'],
                ['sol_tarde', 'Sol da tarde'],
                ['sol_dia_todo', 'Sol o dia todo'],
                ['lancamento_flag', 'Lançamento'],
                ['aceita_permuta_flag', 'Aceita Permuta'],
                ['aceita_financiamento_flag', 'Aceita Financiamento'],
                ['garden_flag', 'Garden'],
                ['festival_salute_flag', 'Festival Salute'],
                ['exibir_no_site_salute_flag', 'Exibir no Site Salute'],
                ['opportunity', 'Oportunidade (Preço Reduzido)']
              ].each do |value, label| %>
                <%= ax_toggle_chip(
                      nil,
                      nil,
                      label:,
                      name: "landing_page[filter_params][characteristics][]",
                      checked_value: value,
                      unchecked_value: "",
                      include_hidden: false,
                      checked: (f.object.filter_params["characteristics"] || []).include?(value),
                      id: "char_#{value}",
                      input_data: { action: "change->property-page-preview#refresh" }
                    ) %>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
    <% end %>
  </div>

  <div class="ax-span-4">
    <%= ax_operational_panel(eyebrow: "Preview", title: "Resumo do conjunto", class_name: "landing-page-preview") do %>
        <div class="tw-mb-4">
          <div class="ax-badge ax-badge--blue landing-page-preview__count" data-property-page-preview-target="count">0 imóveis encontrados</div>
          <div id="preview-results" data-property-page-preview-target="results" aria-live="polite" aria-busy="true">
           <div class="landing-page-preview__loading">
              <span class="ax-spinner" role="status" aria-label="Analisando dados"></span>
              <div>Analisando dados...</div>
           </div>
        </div>
        </div>

        <div class="landing-page-preview__actions">
          <div class="tw-mb-4">
            <%= ax_switch_field(form: f, method: :active, label: tag.span("Página Ativa para Indexação", class: "tw-font-bold"), id: "activeSwitch") %>
          </div>

          <%= ax_form_actions(form: f, submit_label: "Salvar Página SEO", cancel_path: admin_landing_pages_path, sticky: false) %>
        </div>
    <% end %>
  </div>
<% end %>
