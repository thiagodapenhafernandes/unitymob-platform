<%= form_with(model: [:admin, @landing_page], local: true, class: "ax-field-grid", data: { controller: "property-page-preview", property_page_preview_url_value: "/admin/landing_pages/preview" }) do |f| %>
  <div class="ax-span-8">
    <div class="ax-card tw-mb-4">
      <div class="ax-card__header">
        <h5 class="mb-0 tw-gap-2"><i class="bi bi-file-earmark-text"></i>Conteúdo e SEO</h5>
      </div>
      <div class="ax-card__body tw-p-4">
        <div class="tw-mb-3">
          <%= f.label :title, "Título da Página (H1)", class: "ax-label tw-font-bold" %>
          <%= f.text_field :title, class: "ax-control", placeholder: "Ex: Apartamentos na Planta em Balneário Camboriú", required: true %>
        </div>

        <%= ax_field_grid do %>
          <div class="ax-span-6">
            <%= f.label :slug, "URL Amigável (Slug)", class: "ax-label tw-font-bold" %>
            <div class="tw-flex tw-items-center">
              <span class="tw-text-ink-muted" style="background:#f8f9fa">/</span>
              <%= f.text_field :slug, class: "ax-control", placeholder: "apartamentos-na-planta-bc" %>
            </div>
            <small class="tw-text-ink-muted">Deixe em branco para gerar do título.</small>
          </div>
          <div class="ax-span-6">
            <%= f.label :meta_title, "Título SEO (Meta Title)", class: "ax-label tw-font-bold" %>
            <%= f.text_field :meta_title, class: "ax-control", placeholder: "Título para o Google" %>
          </div>
        <% end %>
        <div class="tw-mb-3"></div>

        <div class="tw-mb-3">
          <%= f.label :meta_description, "Descrição SEO (Meta Description)", class: "ax-label tw-font-bold" %>
          <%= f.text_area :meta_description, rows: 2, class: "ax-control", placeholder: "Breve resumo para o Google..." %>
        </div>

        <div class="tw-mb-3">
          <%= f.label :description, "Descrição de Topo (Introdução)", class: "ax-label tw-font-bold" %>
          <%= f.text_area :description, rows: 3, class: "ax-control", placeholder: "Texto que aparece logo abaixo do título na página pública..." %>
        </div>

        <div>
          <%= f.label :content, "Texto SEO (Rodapé)", class: "ax-label tw-font-bold" %>
          <%= f.text_area :content, rows: 6, class: "ax-control", placeholder: "Conteúdo rico para SEO que aparece após a listagem de imóveis..." %>
        </div>
      </div>
    </div>

    <div class="ax-card tw-mb-4">
      <div class="ax-card__header">
        <h5 class="mb-0 tw-gap-2"><i class="bi bi-funnel"></i>Atributos (Filtros de Imóveis)</h5>
      </div>
      <div class="ax-card__body tw-p-4">
        <%= f.fields_for :filter_params do |fp| %>
          <%= ax_field_grid do %>
            <div class="ax-span-6">
              <%= fp.label :category, "Categoria(s)", class: "ax-label tw-font-bold" %>
              <%= fp.select :category, Habitation.active.distinct.pluck(:categoria).compact.sort, { }, { multiple: true, class: "ax-control", data: { controller: "tom-select", action: "change->property-page-preview#refresh", tom_select_options_value: { placeholder: "Selecione categorias" } } } %>
            </div>
            <div class="ax-span-6">
              <%= fp.label :city, "Cidade(s)", class: "ax-label tw-font-bold" %>
              <%= fp.select :city, Habitation.active.left_outer_joins(:address).distinct.pluck(Arel.sql("COALESCE(addresses.cidade, habitations.cidade)")).compact.sort, { }, { multiple: true, class: "ax-control", data: { controller: "tom-select", action: "change->property-page-preview#refresh", tom_select_options_value: { placeholder: "Selecione cidades" } } } %>
            </div>
            <div class="ax-span-6">
              <%= fp.label :neighborhood, "Bairro(s)", class: "ax-label tw-font-bold" %>
              <%= fp.select :neighborhood, Habitation.active.left_outer_joins(:address).distinct.pluck(Arel.sql("COALESCE(addresses.bairro, habitations.bairro)")).compact.uniq.sort, { }, { multiple: true, class: "ax-control", data: { controller: "tom-select", action: "change->property-page-preview#refresh", tom_select_options_value: { placeholder: "Selecione bairros" } } } %>
            </div>
            <div class="ax-span-6">
              <%= fp.label :transaction_type, "Transação", class: "ax-label tw-font-bold" %>
              <%= fp.select :transaction_type, [['Venda', 'venda'], ['Aluguel', 'aluguel']], { include_blank: "Todas" }, { class: "ax-control", data: { action: "change->property-page-preview#refresh" } } %>
            </div>

            <div class="ax-span-6">
              <%= fp.label :caracteristica_unica, "Característica Única (Tag/Badge)", class: "ax-label tw-font-bold" %>
              <%= fp.text_field :caracteristica_unica, class: "ax-control", placeholder: "Ex: Festival Salute 2026", data: { action: "input->property-page-preview#refresh" } %>
            </div>

            <div class="ax-span-6">
              <%= fp.label :target_price, "Preço Sugerido (Range +/- 20%)", class: "ax-label tw-font-bold" %>
              <%= fp.number_field :target_price, class: "ax-control", placeholder: "Ex: 1500000", data: { action: "input->property-page-preview#refresh" } %>
            </div>

            <div class="ax-span-4">
              <%= fp.label :min_area, "Área Mínima (m²)", class: "ax-label tw-font-bold" %>
              <%= fp.number_field :min_area, class: "ax-control", min: 0, data: { action: "input->property-page-preview#refresh" } %>
            </div>

            <div class="ax-span-4">
              <%= fp.label :min_bedrooms, "Mín. Dormitórios", class: "ax-label tw-font-bold" %>
              <%= fp.number_field :min_bedrooms, class: "ax-control", min: 0, data: { action: "input->property-page-preview#refresh" } %>
            </div>
            <div class="ax-span-4">
              <%= fp.label :min_suites, "Mín. Suítes", class: "ax-label tw-font-bold" %>
              <%= fp.number_field :min_suites, class: "ax-control", min: 0, data: { action: "input->property-page-preview#refresh" } %>
            </div>
            <div class="ax-span-4">
              <%= fp.label :min_parking, "Mín. Vagas", class: "ax-label tw-font-bold" %>
              <%= fp.number_field :min_parking, class: "ax-control", min: 0, data: { action: "input->property-page-preview#refresh" } %>
            </div>
          <% end %>

          <div style="margin-top:1.5rem">
            <label class="ax-label tw-font-bold tw-mb-3" style="display:block; border-bottom:1px solid var(--ax-border, #e5e7eb); padding-bottom:.5rem">Características e Flags</label>
            <%= ax_field_grid do %>
              <% [
                ['frente_mar', 'Frente Mar'],
                ['quadra_mar', 'Quadra Mar'],
                ['vista_mar', 'Vista Mar'],
                ['piscina', 'Piscina'],
                ['mobiliado', 'Mobiliado'],
                ['churrasqueira', 'Churrasqueira'],
                ['cozinha_gourmet_churrasqueira', 'Cozinha gourmet com churrasqueira'],
                ['dependencia_empregada', 'Dependência de empregada'],
                ['sacada', 'Sacada'],
                ['decorado', 'Decorado'],
                ['sol_manha', 'Sol da manhã'],
                ['sol_tarde', 'Sol da tarde'],
                ['sol_dia_todo', 'Sol o dia todo'],
                ['lancamento_flag', 'Lançamento'],
                ['aceita_permuta_flag', 'Aceita Permuta'],
                ['aceita_financiamento_flag', 'Aceita Financiamento'],
                ['garden_flag', 'Garden'],
                ['festival_salute_flag', 'Festival Salute'],
                ['exibir_no_site_salute_flag', 'Exibir no Site Salute'],
                ['opportunity', 'Oportunidade (Preço Reduzido)']
              ].each do |value, label| %>
                <div class="ax-span-4">
                  <div class="form-check custom-checkbox-card">
                    <%= check_box_tag "landing_page[filter_params][characteristics][]", value, (f.object.filter_params['characteristics'] || []).include?(value), class: "form-check-input", id: "char_#{value}", data: { action: "change->property-page-preview#refresh" } %>
                    <label class="form-check-label w-100 py-1" for="char_<%= value %>">
                      <%= label %>
                    </label>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="ax-span-4">
    <div class="ax-card tw-mb-4 sticky-top" style="top: 80px;">
      <div class="ax-card__header">
        <h5 class="mb-0 tw-gap-2"><i class="bi bi-speedometer2"></i>Resumo do Conjunto</h5>
      </div>
      <div class="ax-card__body tw-p-4">
        <div class="tw-mb-4">
          <div class="ax-badge ax-badge--blue tw-w-full tw-mb-3" data-property-page-preview-target="count" style="font-size: 0.9rem; padding-top:.5rem; padding-bottom:.5rem">0 imóveis encontrados</div>
          <div id="preview-results" data-property-page-preview-target="results">
           <div class="tw-text-center tw-text-ink-muted" style="padding-top:3rem; padding-bottom:3rem">
              <div class="spinner-border spinner-border-sm tw-text-primary tw-mb-2" role="status"></div>
              <div>Analisando dados...</div>
           </div>
        </div>

        <div class="preview-footer-actions">
          <div class="tw-mb-4">
            <%= ax_switch_field(form: f, method: :active, label: tag.span("Página Ativa para Indexação", class: "tw-font-bold"), id: "activeSwitch") %>
          </div>

          <div class="tw-gap-3" style="display:grid">
            <%= f.submit "Salvar Página SEO", class: "ax-btn ax-btn--primary tw-w-full" %>
            <%= link_to "Cancelar", admin_landing_pages_path, class: "ax-btn ax-btn--ghost tw-w-full tw-text-ink-muted" %>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>
