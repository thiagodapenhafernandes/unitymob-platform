<%
  step_titles = {
    "intro"           => "Tipo de imóvel e modalidade",
    "proprietario"    => "Dados do proprietário",
    "endereco"        => "Endereço do imóvel",
    "caracteristicas" => "Características do imóvel",
    "infraestrutura"  => "Edifício e lazer",
    "negociacao"      => "Condições da negociação",
    "visitas"         => "Visitação e chaves",
    "fotos"           => "Fotos e autorização",
    "review"          => "Revisão final"
  }
  current_idx = Captacao::STEPS.index(@step)
  total_steps = @captacao.skip_visitas? ? Captacao::STEPS.size - 1 : Captacao::STEPS.size
  shown_idx   = @captacao.skip_visitas? && current_idx >= Captacao::STEPS.index("visitas") ? current_idx : current_idx
  invalid_fields = @invalid_fields || {}
  field_state = ->(field, base = "ax-control") { [base, ("is-invalid" if invalid_fields[field.to_sym])].compact.join(" ") }
  field_invalid = ->(field) { invalid_fields[field.to_sym] }
%>

<!-- Top bar com progress -->
<div class="wizard-top-bar">
  <div class="wizard-shell">
    <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
      <%= link_to admin_captacoes_path,
                  class: "ax-icon-btn wizard-back-link",
                  title: "Voltar para captações",
                  aria: { label: "Voltar para captações" } do %>
        <i class="bi bi-arrow-left"></i>
      <% end %>
      <div class="tw-text-sm tw-text-ink-muted" style="flex-grow:1;">
        Etapa <%= shown_idx + 1 %> de <%= total_steps %> · <strong class="text-dark"><%= step_titles[@step] %></strong>
      </div>
      <% unless @captacao.completed? %>
        <span class="ax-badge ax-badge--amber">Rascunho</span>
      <% end %>
      <% unless @captacao.intake_published? %>
        <%= button_to admin_captacao_path(@captacao),
                      method: :delete,
                      class: "ax-btn ax-btn--danger ax-btn--sm",
                      form: { data: { turbo_confirm: "Descartar esta captação?" } } do %>
          <i class="bi bi-trash"></i>Descartar
        <% end %>
      <% end %>
    </div>
    <div class="wizard-progress">
      <div class="wizard-progress-bar" style="width: <%= @captacao.progress_percentage %>%;"></div>
    </div>
  </div>
</div>

<main class="wizard-shell wizard-content">
  <%= ax_error_summary(@captacao) %>

  <% if @missing_requirements.present? %>
    <%= ax_inline_notice(tone: :danger, icon: "exclamation-triangle-fill") do %>
      <strong>Complete antes de finalizar:</strong>
      <ul class="tw-mt-1 tw-text-sm">
        <% @missing_requirements.each do |requirement| %><li><%= requirement %></li><% end %>
      </ul>
    <% end %>
  <% end %>

  <% if @captacao.intake_published? && !can?(:manage, :imoveis) %>
    <%= ax_inline_notice(tone: :warning, icon: "lock-fill") do %>
      <strong>Imóvel publicado no site.</strong>
      Nome do empreendimento, endereço, dados do proprietário, título e descrição ficam bloqueados para corretores.
    <% end %>
  <% end %>

  <%= form_with model: @captacao,
                url: admin_captacao_path(@captacao),
                method: :patch,
                multipart: true,
                local: true,
                html: {
                  id: "wizard-form",
                  data: {
                    controller: "habitation-duplicate-check captacao-submit-progress",
                    action: "submit->captacao-submit-progress#submit",
                    habitation_duplicate_check_url_value: check_admin_habitation_duplicate_path,
                    habitation_duplicate_check_ignored_id_value: @captacao.id
                  }
                } do |f| %>
    <%= hidden_field_tag :current_step, @step %>
    <%= hidden_field_tag :duplicate_check_status,
                         @captacao.status,
                         data: { habitation_duplicate_check_target: "commercialStatus" } %>
    <%= hidden_field_tag :duplicate_check_comparison,
                         @captacao.duplicate_identity_scope,
                         data: { habitation_duplicate_check_target: "comparison" } %>

    <%= render "admin/captacoes/steps/#{@step}", f: f, field_state: field_state, field_invalid: field_invalid %>

    <div class="captacao-submit-progress" data-captacao-submit-progress-target="panel" hidden role="status" aria-live="polite">
      <div class="captacao-submit-progress__header">
        <strong data-captacao-submit-progress-target="title">Enviando dados</strong>
        <span data-captacao-submit-progress-target="percent">0%</span>
      </div>
      <div class="captacao-submit-progress__track" aria-hidden="true">
        <div class="captacao-submit-progress__bar" data-captacao-submit-progress-target="bar"></div>
      </div>
      <p data-captacao-submit-progress-target="message">Mantenha esta tela aberta até o avanço concluir.</p>
    </div>

    <div class="wizard-bottom-nav">
      <div class="wizard-shell tw-flex tw-gap-2">
        <% if @captacao.previous_step %>
          <%= button_tag type: :submit, name: :direction, value: "back", class: "ax-btn ax-btn--ghost", style: "flex:1 1 0;" do %>
            <i class="bi bi-arrow-left"></i>Voltar
          <% end %>
        <% end %>
        <% if @step == "review" %>
          <%= button_tag type: :submit, name: :direction, value: "forward", class: "ax-btn ax-btn--primary", style: "flex:1 1 0;", data: { habitation_duplicate_check_target: "submit" } do %>
            <i class="bi bi-send-check"></i>Mandar Análise
          <% end %>
        <% else %>
          <%= button_tag type: :submit, name: :direction, value: "forward", class: "ax-btn ax-btn--primary", style: "flex:1 1 0;", data: { habitation_duplicate_check_target: "submit" } do %>
            Avançar<i class="bi bi-arrow-right"></i>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</main>
