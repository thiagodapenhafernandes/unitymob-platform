<% max_ct = rows.first&.ct || 1 %>
<div class="ax-table-wrap">
  <table class="ax-table">
    <thead class="capt-ranking-table__head">
      <tr>
        <th class="ax-table__col--w-40">Rank</th>
        <th>Corretor</th>
        <th class="capt-ranking-table__col-chart">Captação</th>
        <th class="tw-text-right"><%= value_label %></th>
      </tr>
    </thead>
    <tbody>
      <% rows.each_with_index do |row, i| %>
        <tr class="capt-ranking-row">
          <td class="tw-font-bold tw-text-ink-muted"><%= i + 1 %></td>
          <td><%= row.name %></td>
          <td>
            <div class="bar-cell">
              <%= ax_progress(
                value: (row.ct.to_f / max_ct * 100).to_i,
                class_name: "capt-ranking-row__progress",
                label: "#{row.name}: #{row.ct} captações"
              ) %>
              <span class="label"><%= row.ct %></span>
            </div>
          </td>
          <td class="tw-text-right tw-font-semibold">
            <%= number_to_currency(row.total_value.to_f, unit: "R$ ", precision: 0) %>
          </td>
        </tr>
      <% end %>
      <% if rows.empty? %>
        <tr><td colspan="4" class="tw-text-center tw-text-ink-muted tw-py-2"><i class="bi bi-inbox"></i> Sem dados no período.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
