<%
  capt_dashboard_chart_payload = {
    totalVenda: @total_venda,
    metaVenda: [@meta_venda, 1].max,
    totalLocacao: @total_locacao,
    metaLocacao: [@meta_locacao, 1].max,
    publicadoVenda: @publicado_venda,
    naoPublicadoVenda: @nao_publicado_venda,
    publicadoLocacao: @publicado_locacao,
    naoPublicadoLocacao: @nao_publicado_locacao,
    regiaoFocoVenda: @regiao_foco_venda,
    regiaoFocoLocacao: @regiao_foco_locacao,
    captacaoAdmLocacao: @captacao_adm_locacao
  }
%>


<div id="captDashboard"
     class="capt-tv-shell capt-dashboard-workspace"
     data-controller="captacoes-dashboard"
     data-captacoes-dashboard-chart-url-value="<%= asset_path("chart.umd.min.js") %>"
     data-captacoes-dashboard-data-value="<%= capt_dashboard_chart_payload.to_json %>">
  <div class="capt-tv-transition" data-capt-tv-transition aria-live="polite" hidden>
    <span class="capt-tv-transition__spinner" aria-hidden="true"></span>
    <div>
      <strong>Preparando apresentação</strong>
      <small>Organizando indicadores e gráficos para esta tela.</small>
    </div>
  </div>
<%
  dashboard_actions = capture do
%>
  <% if tenant_owner? %>
    <button type="button" class="ax-workspace-heading__tool captacoes-heading-action" data-ax-modal-open="#dashboardTitleModal" aria-label="Editar título do dashboard">
      <i class="bi bi-gear"></i><span>Título</span>
    </button>
  <% end %>
  <% if current_admin_user.can?(:view, :metas_captacao) %>
    <%= link_to admin_captacao_goals_path, class: "ax-workspace-heading__tool captacoes-heading-action" do %>
      <i class="bi bi-bullseye"></i><span>Metas</span>
    <% end %>
  <% end %>
  <%= link_to admin_captacoes_path, class: "ax-workspace-heading__tool captacoes-heading-action" do %>
    <i class="bi bi-list"></i><span>Ver lista</span>
  <% end %>
<% end %>

<%= ax_workspace_heading(
      title: @dashboard_title,
      eyebrow: @dashboard_eyebrow,
      icon: "bullseye",
      subtitle: "Metas, publicação, foco regional e desempenho por corretor.",
      pills: [@target_month_label],
      metrics: [
        { value: @total_venda, label: "venda" },
        { value: @total_locacao, label: "locação" },
        { value: @pre_cadastro_total, label: "pré-cadastros" }
      ],
      actions: dashboard_actions,
      class_name: "capt-dashboard-heading"
    ) %>

<% if tenant_owner? %>
  <div class="ax-quick-modal ax-quick-modal--md" id="dashboardTitleModal" tabindex="-1" role="presentation" hidden aria-hidden="true" data-controller="ax-modal" data-ax-modal-target="overlay" data-action="click->ax-modal#backdropClose">
    <div class="ax-quick-modal__panel" role="dialog" aria-modal="true">
      <%= form_with url: dashboard_title_admin_captacoes_path, method: :patch, local: true do %>
        <header class="ax-quick-modal__header">
          <h5 class="ax-quick-modal__title">Editar título do dashboard</h5>
          <button type="button" class="ax-icon-btn" data-action="ax-modal#close" aria-label="Fechar"><i class="bi bi-x-lg"></i></button>
        </header>
        <div class="ax-quick-modal__body">
          <div class="tw-mb-3">
            <label class="ax-label">Texto superior</label>
            <%= text_field_tag "dashboard[eyebrow]", @dashboard_eyebrow, class: "ax-control", maxlength: 80, placeholder: "Palavra do Ano" %>
          </div>
          <div>
            <label class="ax-label">Título principal</label>
            <%= text_field_tag "dashboard[title]", @dashboard_title, class: "ax-control", maxlength: 80, placeholder: "Captação" %>
          </div>
        </div>
        <footer class="ax-quick-modal__footer">
          <button type="button" class="ax-btn ax-btn--ghost" data-action="ax-modal#close">Cancelar</button>
          <%= submit_tag "Salvar", class: "ax-btn ax-btn--primary" %>
        </footer>
      <% end %>
    </div>
  </div>
<% end %>

<div class="capt-dashboard-tvbar">
  <span class="capt-dashboard-tvbar__label"><i class="bi bi-display"></i> Apresentação</span>
  <button type="button" class="ax-btn ax-btn--ghost ax-btn--sm tw-gap-2" data-capt-tv-tab="tab-geral" data-action="captacoes-dashboard#enterTv">
    <i class="bi bi-arrows-fullscreen"></i>Geral
  </button>
  <button type="button" class="ax-btn ax-btn--ghost ax-btn--sm tw-gap-2" data-capt-tv-tab="tab-venda" data-action="captacoes-dashboard#enterTv">
    <i class="bi bi-arrows-fullscreen"></i>Venda
  </button>
  <button type="button" class="ax-btn ax-btn--ghost ax-btn--sm tw-gap-2" data-capt-tv-tab="tab-locacao" data-action="captacoes-dashboard#enterTv">
    <i class="bi bi-arrows-fullscreen"></i>Locação
  </button>
  <button type="button" class="ax-btn ax-btn--ghost ax-btn--sm tw-gap-2" data-capt-tv-tab="tab-leads" data-action="captacoes-dashboard#enterTv">
    <i class="bi bi-arrows-fullscreen"></i>Leads
  </button>
  <button type="button" class="ax-btn ax-btn--ghost ax-btn--sm tw-gap-2" data-capt-tv-exit data-action="captacoes-dashboard#exitTv" hidden>
    <i class="bi bi-x-lg"></i><span>Sair</span>
  </button>
</div>

<!-- Filtros -->
<%= form_with url: dashboard_admin_captacoes_path, method: :get, local: true, class: "capt-dashboard-filters capt-filter-card" do %>
  <div class="capt-dashboard-filters__title">
    <span><i class="bi bi-funnel"></i> Período</span>
    <strong><%= @target_month_label %></strong>
  </div>
  <div class="capt-dashboard-filter-field">
    <%= ax_field_label(nil, nil, text: "Início") %>
    <%= date_field_tag :start_date, @period_start, class: "ax-control ax-control--sm" %>
  </div>
  <div class="capt-dashboard-filter-field">
    <%= ax_field_label(nil, nil, text: "Fim") %>
    <%= date_field_tag :end_date, @period_end, class: "ax-control ax-control--sm" %>
  </div>
  <div class="capt-dashboard-filter-field">
    <%= ax_field_label(nil, nil, text: "Mês") %>
    <%= select_tag :month,
                   options_for_select([["Todos", ""]] + (1..12).map { |m| [I18n.l(Date.new(2026, m), format: "%B").capitalize, m] }, @month_filter),
                   class: "ax-control ax-control--sm" %>
  </div>
  <%= submit_tag "Aplicar", class: "ax-btn ax-btn--primary ax-btn--sm capt-dashboard-filters__submit" %>
<% end %>

<section class="capt-dashboard-kpis" aria-label="Resumo dos pré-cadastros">
  <% [
       ["Pré-cadastros", @pre_cadastro_total, "blue"],
       ["Rascunho/devolvido", @pre_cadastro_draft, "amber"],
       ["Em aprovação", @pre_cadastro_review, "cyan"],
       ["Liberados site", @pre_cadastro_published, "green"]
     ].each do |label, value, tone| %>
    <article class="capt-dashboard-kpi capt-dashboard-kpi--<%= tone %>">
      <span><%= label %></span>
      <strong><%= value %></strong>
    </article>
  <% end %>
</section>

<!-- Tabs -->
<div class="capt-dashboard-tabs">
  <ul class="ax-form-tabs tw-flex-1 tw-mb-0" id="captTabs" role="tablist" data-controller="ax-tabs" data-ax-tabs-panel-selector-value="#captTabContent">
    <li><button class="ax-form-tabs__item active" data-ax-tabs-target="tab" data-ax-tabs-target-param="#tab-geral" data-action="click->ax-tabs#select ax:tab-shown->captacoes-dashboard#rerenderVisibleCharts" type="button">Geral</button></li>
    <li><button class="ax-form-tabs__item" data-ax-tabs-target="tab" data-ax-tabs-target-param="#tab-venda" data-action="click->ax-tabs#select ax:tab-shown->captacoes-dashboard#rerenderVisibleCharts" type="button">Venda</button></li>
    <li><button class="ax-form-tabs__item" data-ax-tabs-target="tab" data-ax-tabs-target-param="#tab-locacao" data-action="click->ax-tabs#select ax:tab-shown->captacoes-dashboard#rerenderVisibleCharts" type="button">Locação</button></li>
    <li><button class="ax-form-tabs__item" data-ax-tabs-target="tab" data-ax-tabs-target-param="#tab-leads" data-action="click->ax-tabs#select ax:tab-shown->captacoes-dashboard#rerenderVisibleCharts" type="button">Leads</button></li>
  </ul>
  <button class="ax-btn ax-btn--ghost ax-btn--sm tw-gap-2" type="button" data-capt-active-tv data-action="captacoes-dashboard#enterActiveTv">
    <i class="bi bi-display"></i>TV da aba atual
  </button>
</div>

<div class="tab-content" id="captTabContent">

  <!-- GERAL -->
  <div class="tab-pane fade show active" id="tab-geral">
    <%= ax_field_grid class_name: "capt-dashboard-chart-grid tw-mb-3" do %>
      <div class="ax-span-6">
        <div class="ax-card">
          <div class="ax-card__body">
            <div class="tw-flex tw-justify-between tw-mb-2">
              <div class="capt-panel-title">Captação Venda</div>
              <%= ax_badge("Meta #{@meta_venda}", tone: :blue) %>
            </div>
            <div class="capt-gauge-wrapper">
              <canvas id="gaugeVenda"></canvas>
              <div class="capt-gauge-center">
                <div class="value"><%= @total_venda %></div>
                <div class="meta-label">de <%= @meta_venda %></div>
              </div>
            </div>
            <div class="tw-flex tw-justify-between tw-text-sm tw-text-ink-muted tw-mt-2">
              <span>0</span>
              <span><%= @meta_venda %></span>
            </div>
          </div>
        </div>

      </div>
      <div class="ax-span-6">
        <div class="ax-card">
          <div class="ax-card__body">
            <div class="tw-flex tw-justify-between tw-mb-2">
              <div class="capt-panel-title">Publicado no Site (Venda)</div>
            </div>
            <div class="capt-gauge-wrapper">
              <canvas id="pubVenda"></canvas>
            </div>
          </div>
        </div>

      </div>

      <div class="ax-span-6">
        <div class="ax-card">
          <div class="ax-card__body">
            <div class="tw-flex tw-justify-between tw-mb-2">
              <div class="capt-panel-title">Captação Locação</div>
              <%= ax_badge("Meta #{@meta_locacao}", tone: :amber) %>
            </div>
            <div class="capt-gauge-wrapper">
              <canvas id="gaugeLocacao"></canvas>
              <div class="capt-gauge-center">
                <div class="value"><%= @total_locacao %></div>
                <div class="meta-label">de <%= @meta_locacao %></div>
              </div>
            </div>
            <div class="tw-flex tw-justify-between tw-text-sm tw-text-ink-muted tw-mt-2">
              <span>0</span>
              <span><%= @meta_locacao %></span>
            </div>
          </div>
        </div>

      </div>
      <div class="ax-span-6">
        <div class="ax-card">
          <div class="ax-card__body">
            <div class="tw-flex tw-justify-between tw-mb-2">
              <div class="capt-panel-title">Publicado no Site (Locação)</div>
            </div>
            <div class="capt-gauge-wrapper">
              <canvas id="pubLocacao"></canvas>
            </div>
          </div>
        </div>

      </div>
    <% end %>

    <%= ax_field_grid do %>
      <div class="ax-span-4">
        <div class="ax-card tw-h-full">
          <div class="ax-card__body">
            <div class="capt-mini-stat-label">Região foco Venda</div>
            <div class="tw-flex tw-items-end tw-justify-between tw-mt-2">
              <div class="capt-mini-stat-value capt-mini-stat-value--success"><%= @regiao_foco_venda %></div>
              <div class="capt-mini-stat-percent capt-mini-stat-value--success"><%= @regiao_foco_venda_percent %>%</div>
            </div>
            <div class="tw-text-ink-muted tw-text-sm">de <%= @total_venda %> captações de venda</div>
          </div>
        </div>
      </div>
      <div class="ax-span-4">
        <div class="ax-card tw-h-full">
          <div class="ax-card__body">
            <div class="capt-mini-stat-label">Região foco Locação</div>
            <div class="tw-flex tw-items-end tw-justify-between tw-mt-2">
              <div class="capt-mini-stat-value capt-mini-stat-value--success"><%= @regiao_foco_locacao %></div>
              <div class="capt-mini-stat-percent capt-mini-stat-value--success"><%= @regiao_foco_locacao_percent %>%</div>
            </div>
            <div class="tw-text-ink-muted tw-text-sm">de <%= @total_locacao %> captações de locação</div>
          </div>
        </div>
      </div>
      <div class="ax-span-4">
        <div class="ax-card tw-h-full">
          <div class="ax-card__body">
            <div class="capt-mini-stat-label">Captação com Adm</div>
            <div class="tw-flex tw-items-end tw-justify-between tw-mt-2">
              <div class="capt-mini-stat-value capt-mini-stat-value--primary"><%= @captacao_adm_locacao %></div>
              <div class="capt-mini-stat-percent capt-mini-stat-value--primary"><%= @captacao_adm_locacao_percent %>%</div>
            </div>
            <div class="tw-text-ink-muted tw-text-sm">de <%= @total_locacao %> captações de locação</div>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- VENDA -->
  <div class="tab-pane fade" id="tab-venda">
    <div class="capt-foco-banner tw-mb-3">
      <div>
        <div class="capt-foco-banner__label">Região foco</div>
        <div class="capt-foco-banner__title">Captação Venda</div>
      </div>
      <div class="capt-foco-stat">
        <div class="capt-foco-stat__value"><%= @regiao_foco_venda %></div>
        <div class="capt-foco-stat__meta"><%= @regiao_foco_venda_percent %>% de <%= @total_venda %></div>
      </div>
    </div>

    <%= ax_field_grid do %>
      <div class="ax-span-5">
        <div class="ax-card capt-panel-main">
          <div class="ax-card__body">
            <div class="capt-panel-title capt-panel-title--spaced">Acompanhamento de Meta</div>
            <div class="capt-gauge-wrapper">
              <canvas id="gaugeVendaBig"></canvas>
              <div class="capt-gauge-center">
                <div class="value"><%= @total_venda %></div>
                <div class="meta-label">de <%= @meta_venda %></div>
              </div>
            </div>
            <div class="tw-flex tw-justify-between tw-text-sm tw-text-ink-muted tw-mt-2">
              <span>0</span><span><%= @meta_venda %></span>
            </div>
          </div>
        </div>

        <div class="ax-card tw-mt-3 capt-panel-secondary">
          <div class="ax-card__body">
            <%= ax_field_grid class_name: "tw-items-center" do %>
              <div class="ax-span-6">
                <div class="capt-donut-title">Região Foco Captação</div>
                <div class="capt-donut-wrapper">
                  <canvas id="focusVendaBig"></canvas>
                </div>
              </div>
              <div class="ax-span-6">
                <div class="capt-donut-title">Publicado no Site</div>
                <div class="capt-donut-wrapper">
                  <canvas id="pubVendaBig"></canvas>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <div class="ax-span-7">
        <div class="ax-card capt-ranking-card capt-panel-main">
          <div class="ax-card__body">
            <div class="capt-panel-title capt-panel-title--spaced">Ranking de corretores</div>
            <div class="capt-ranking-scroll">
              <%= render "ranking_table", rows: @ranking_venda, value_key: :total_value, value_label: "Total Venda" %>
            </div>
          </div>
        </div>
        <div class="capt-summary-card tw-mt-3 capt-panel-secondary">
          <%= ax_field_grid class_name: "text-center tw-h-full" do %>
            <div class="ax-span-6">
              <div class="capt-total-card tw-h-full tw-flex tw-flex-col tw-items-center tw-justify-center">
                <div class="summary-label">Total Captação Venda</div>
                <div class="capt-summary-value"><%= @total_venda %></div>
              </div>
            </div>
            <div class="ax-span-6">
              <div class="capt-total-card tw-h-full tw-flex tw-flex-col tw-items-center tw-justify-center">
                <div class="summary-label">Total Venda</div>
                <div class="capt-summary-value"><%= number_to_currency(@total_valor_venda, unit: "R$ ", precision: 0) %></div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- LOCAÇÃO -->
  <div class="tab-pane fade" id="tab-locacao">
    <div class="capt-foco-banner tw-mb-3">
      <div>
        <div class="capt-foco-banner__label">Região foco</div>
        <div class="capt-foco-banner__title">Captação Locação</div>
      </div>
      <div class="capt-foco-stat">
        <div class="capt-foco-stat__value"><%= @regiao_foco_locacao %></div>
        <div class="capt-foco-stat__meta"><%= @regiao_foco_locacao_percent %>% de <%= @total_locacao %></div>
      </div>
    </div>

    <%= ax_field_grid do %>
      <div class="ax-span-5">
        <div class="ax-card capt-panel-main">
          <div class="ax-card__body">
            <div class="capt-panel-title capt-panel-title--spaced">Acompanhamento de Meta</div>
            <div class="capt-gauge-wrapper">
              <canvas id="gaugeLocacaoBig"></canvas>
              <div class="capt-gauge-center">
                <div class="value"><%= @total_locacao %></div>
                <div class="meta-label">de <%= @meta_locacao %></div>
              </div>
            </div>
            <div class="tw-flex tw-justify-between tw-text-sm tw-text-ink-muted tw-mt-2">
              <span>0</span><span><%= @meta_locacao %></span>
            </div>
          </div>
        </div>

        <div class="ax-card tw-mt-3 capt-panel-secondary">
          <div class="ax-card__body">
            <%= ax_field_grid class_name: "tw-items-center" do %>
              <div class="ax-span-4">
                <div class="capt-donut-title">Região Foco Captação</div>
                <div class="capt-donut-wrapper">
                  <canvas id="focusLocacaoBig"></canvas>
                </div>
              </div>
              <div class="ax-span-4">
                <div class="capt-donut-title">Publicado no Site</div>
                <div class="capt-donut-wrapper">
                  <canvas id="pubLocacaoBig"></canvas>
                </div>
              </div>
              <div class="ax-span-4">
                <div class="capt-donut-title">Administração Salute</div>
                <div class="capt-donut-wrapper">
                  <canvas id="admLocacaoBig"></canvas>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <div class="ax-span-7">
        <div class="ax-card capt-ranking-card capt-panel-main">
          <div class="ax-card__body">
            <div class="capt-panel-title capt-panel-title--spaced">Ranking de corretores</div>
            <div class="capt-ranking-scroll">
              <%= render "ranking_table", rows: @ranking_locacao, value_key: :total_value, value_label: "Total Locação" %>
            </div>
          </div>
        </div>
        <div class="capt-summary-card tw-mt-3 capt-panel-secondary">
          <%= ax_field_grid class_name: "text-center tw-h-full" do %>
            <div class="ax-span-6">
              <div class="capt-total-card tw-h-full tw-flex tw-flex-col tw-items-center tw-justify-center">
                <div class="summary-label">Total Captação Locação</div>
                <div class="capt-summary-value"><%= @total_locacao %></div>
              </div>
            </div>
            <div class="ax-span-6">
              <div class="capt-total-card tw-h-full tw-flex tw-flex-col tw-items-center tw-justify-center">
                <div class="summary-label">Total Locação</div>
                <div class="capt-summary-value"><%= number_to_currency(@total_valor_locacao, unit: "R$ ", precision: 0) %></div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- LEADS HEATMAP -->
  <div class="tab-pane fade" id="tab-leads">
    <%= render "leads_heatmap" %>
  </div>
</div>
</div>
