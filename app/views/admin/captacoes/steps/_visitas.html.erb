<h1 class="wizard-section-title"><i class="bi bi-key-fill tw-text-primary" style="margin-right:.5rem;"></i>Visitação e chaves</h1>
<p class="wizard-section-subtitle">Para agendar visitas: onde estão as chaves, senhas, melhores dias.</p>

<div class="wizard-field-group">
  <%= f.label :chaves_com, "Chaves com quem?", class: "ax-label" %>
  <span class="required-star">*</span>
  <%= f.select :chaves_com,
               [["Com o corretor", "corretor"], ["Com o proprietário", "proprietario"], ["Na portaria", "portaria"], ["Outro", "outro"]],
               { include_blank: "—" },
               class: field_state.call(:chaves_com, "ax-control") %>
  <% if field_invalid.call(:chaves_com) %><div class="invalid-feedback d-block">Informe onde estão as chaves.</div><% end %>
</div>

<div class="wizard-field-group">
  <label class="ax-label">Dias / horários melhores para visita</label>
  <span class="required-star">*</span>
  <div class="wizard-choice-panel wizard-choice-panel--boxed <%= 'wizard-invalid-choice' if field_invalid.call(:dias_visitas) %>">
    <% %w[Seg Ter Qua Qui Sex Sáb Dom Manhã Tarde Noite].each do |opt| %>
      <% selected = Array(@captacao.dias_visitas).include?(opt) %>
      <label class="wizard-feature-chip <%= 'selected' if selected %>" data-controller="selectable-chip">
        <%= check_box_tag "captacao[dias_visitas][]", opt, selected, data: { action: "change->selectable-chip#sync" } %>
        <%= opt %>
      </label>
    <% end %>
  </div>
  <% if field_invalid.call(:dias_visitas) %><div class="invalid-feedback d-block">Informe os melhores dias/horários para visita.</div><% end %>
</div>

<%= ax_field_grid do %>
  <div class="ax-span-6">
    <div class="wizard-field-group">
      <%= f.label :senha_imovel, "Senha do imóvel", class: "ax-label" %>
      <%= f.text_field :senha_imovel, class: "ax-control", autocomplete: "off" %>
    </div>
  </div>
  <div class="ax-span-6">
    <div class="wizard-field-group">
      <%= f.label :senha_portaria, "Senha da portaria", class: "ax-label" %>
      <%= f.text_field :senha_portaria, class: "ax-control", autocomplete: "off" %>
    </div>
  </div>
<% end %>

<div class="wizard-field-group">
  <%= f.label :observacoes, "Observações gerais", class: "ax-label" %>
  <%= f.text_area :observacoes, rows: 3, class: "ax-control", placeholder: "Detalhes úteis sobre o imóvel ou a negociação" %>
</div>
