<h1 class="wizard-section-title"><i class="bi bi-key-fill tw-text-primary"></i>Visitação e chaves</h1>
<p class="wizard-section-subtitle">Para agendar visitas: onde estão as chaves, senhas, melhores dias.</p>

<div data-controller="conditional-reveal" data-conditional-reveal-kind-value="select">
<%= ax_select_field(
      form: f,
      method: :chaves_com,
      label: safe_join(["Chaves com quem?", tag.span("*", class: "required-star")], " "),
      choices: Habitation::CAPTACAO_KEY_LOCATION_OPTIONS.map { |value, label| [label, value] },
      select_options: { include_blank: "—" },
      class_name: "wizard-field-group",
      html_options: {
        class: field_state.call(:chaves_com, "ax-control"),
        data: { conditional_reveal_target: "trigger", action: "change->conditional-reveal#sync" }
      }
    ) %>
  <% if field_invalid.call(:chaves_com) %><div class="invalid-feedback d-block">Informe onde estão as chaves.</div><% end %>

<div data-conditional-reveal-target="panel" data-conditional-reveal-values="outro" hidden>
  <%= ax_text_field(form: f, method: :key_location_notes, label: "Onde estão as chaves?",
        field_class: "wizard-field-group", placeholder: "Informe com quem ou onde retirar",
        data: { conditional_required: "true" }) %>
</div>

<div data-conditional-reveal-target="panel" data-conditional-reveal-values="zelador" hidden>
  <%= ax_field_grid do %>
    <div class="ax-span-6"><%= ax_text_field(form: f, method: :zelador_nome, label: "Nome do zelador", field_class: "wizard-field-group") %></div>
    <div class="ax-span-6"><%= ax_text_field(form: f, method: :zelador_telefone, label: "Telefone do zelador", type: :tel, field_class: "wizard-field-group", data: { controller: "phone-input" }) %></div>
  <% end %>
</div>

<div class="wizard-field-group">
  <label class="ax-label">Dias / horários melhores para visita</label>
  <span class="required-star">*</span>
  <div class="wizard-choice-panel wizard-choice-panel--boxed <%= 'wizard-invalid-choice' if field_invalid.call(:dias_visitas) %>">
    <% %w[Seg Ter Qua Qui Sex Sáb Dom Manhã Tarde Noite].each do |opt| %>
      <% selected = Array(@captacao.dias_visitas).include?(opt) %>
      <label class="wizard-feature-chip <%= 'selected' if selected %>" data-controller="selectable-chip">
        <%= check_box_tag "captacao[dias_visitas][]", opt, selected, data: { action: "change->selectable-chip#sync" } %>
        <%= opt %>
      </label>
    <% end %>
  </div>
  <% if field_invalid.call(:dias_visitas) %><div class="invalid-feedback d-block">Informe os melhores dias/horários para visita.</div><% end %>
</div>

<%= ax_field_grid do %>
  <div class="ax-span-6" data-conditional-reveal-target="panel" data-conditional-reveal-values="portaria" hidden>
    <%= ax_text_field(form: f, method: :senha_imovel, label: "Senha do imóvel",
          field_class: "wizard-field-group", autocomplete: "off") %>
  </div>
  <div class="ax-span-6">
    <%= ax_text_field(form: f, method: :senha_portaria, label: "Senha da portaria",
          field_class: "wizard-field-group", autocomplete: "off") %>
  </div>
<% end %>
</div>

<%= ax_text_field(form: f, method: :observacoes, label: "Observações gerais", type: :textarea,
      field_class: "wizard-field-group", rows: 3, placeholder: "Detalhes úteis sobre o imóvel ou a negociação") %>
