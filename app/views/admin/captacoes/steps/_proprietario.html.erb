<h1 class="wizard-section-title"><i class="bi bi-person-vcard-fill text-primary me-2"></i>Dados do proprietário</h1>
<p class="wizard-section-subtitle">Informações básicas de contato para a captação.</p>

<div class="wizard-field-group">
  <%= f.label :proprietario_nome, "Nome completo", class: "form-label" %>
  <span class="required-star">*</span>
  <%= f.text_field :proprietario_nome, class: field_state.call(:proprietario_nome), autocomplete: "name" %>
  <% if field_invalid.call(:proprietario_nome) %><div class="invalid-feedback d-block">Informe o nome completo do proprietário.</div><% end %>
</div>

<div class="wizard-field-group">
  <%= f.label :proprietario_telefone, "Telefone / WhatsApp", class: "form-label" %>
  <span class="required-star">*</span>
  <%= f.telephone_field :proprietario_telefone,
                         class: field_state.call(:proprietario_telefone),
                         placeholder: "(47) 99999-0000",
                         autocomplete: "tel",
                         data: { controller: "mask", mask_type_value: "phone" } %>
  <% if field_invalid.call(:proprietario_telefone) %><div class="invalid-feedback d-block">Informe o telefone/WhatsApp do proprietário.</div><% end %>
</div>

<div class="row g-2">
  <div class="col-md-6">
    <div class="wizard-field-group">
      <%= f.label :proprietario_cpf_cnpj, "CPF ou CNPJ", class: "form-label" %>
      <%= f.text_field :proprietario_cpf_cnpj,
                       class: "form-control",
                       placeholder: "000.000.000-00",
                       data: { controller: "mask", mask_type_value: "cpf_cnpj" } %>
    </div>
  </div>
  <div class="col-md-6">
    <div class="wizard-field-group">
      <%= f.label :proprietario_email, "E-mail", class: "form-label" %>
      <%= f.email_field :proprietario_email, class: "form-control", autocomplete: "email" %>
    </div>
  </div>
</div>

<div class="wizard-field-group">
  <%= f.label :proprietario_cidade, "Cidade do proprietário", class: "form-label" %>
  <span class="required-star">*</span>
  <%= f.text_field :proprietario_cidade, class: field_state.call(:proprietario_cidade), placeholder: "Balneário Camboriú" %>
  <% if field_invalid.call(:proprietario_cidade) %><div class="invalid-feedback d-block">Informe a cidade do proprietário.</div><% end %>
</div>
