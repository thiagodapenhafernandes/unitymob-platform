<% photos_attachment = @captacao.respond_to?(:photos) ? @captacao.photos : @captacao.fotos %>
<% ordered_photos = @captacao.respond_to?(:ordered_photos) ? @captacao.ordered_photos : photos_attachment %>
<% authorization_attachments = @captacao.respond_to?(:autorizacoes_venda) ? @captacao.autorizacoes_venda : @captacao.autorizacao_pdf %>
<% schedule_url = Habitation.photography_schedule_url %>
<% captacao_foto_ambientes = defined?(Habitation::FOTO_AMBIENTES) ? Habitation::FOTO_AMBIENTES : [] %>
<% captacao_ambiente_editable = @captacao.respond_to?(:photo_ambiente) && captacao_foto_ambientes.any? && can?(:manage, :imoveis) %>
<% google_calendar_configured = !!@google_calendar_configured %>
<%
  photo_flow_options = Habitation::PHOTO_FLOW_CHOICES.map { |key, label| [label, key] }
  disabled_photo_flow_options = google_calendar_configured ? [] : ["google_calendar"]
%>

<section data-controller="captacao-photos"
         data-captacao-photos-schedule-url-value="<%= schedule_url %>"
         data-captacao-photos-google-calendar-configured-value="<%= google_calendar_configured %>"
         data-captacao-photos-min-date-value="<%= (@photography_min_date || Date.current + 1.day).iso8601 %>"
         data-captacao-photos-blocked-dates-value="<%= (@photography_blocked_dates || []).to_json %>"
         data-captacao-photos-booked-slots-value="<%= (@photography_booked_slots || []).to_json %>">
  <h1 class="wizard-section-title"><i class="bi bi-camera-fill" style="color:var(--admin-primary);"></i> Fotos e autorização</h1>
  <p class="wizard-section-subtitle">Envie fotos em lote, adicione mais imagens quando precisar e anexe a autorização antes de mandar para análise.</p>

  <div class="wizard-field-group">
    <label class="ax-label">Fotos ou agendamento com fotógrafo</label>
    <%= f.select :photo_flow_choice,
                 options_for_select(
                   photo_flow_options,
                   selected: @captacao.photo_flow_choice,
                   disabled: disabled_photo_flow_options
                 ),
                 { include_blank: "Selecione" },
                 class: field_state.call(:photo_flow_choice, "ax-control"),
                 data: { captacao_photos_target: "flowSelect", action: "change->captacao-photos#refreshFlow" } %>
    <% if field_invalid.call(:photo_flow_choice) %><div class="invalid-feedback d-block">Escolha se vai enviar fotos ou agendar fotógrafo.</div><% end %>
  </div>

  <div class="wizard-field-group" data-captacao-photos-target="uploadPanel" hidden>
    <label class="ax-label">Fotos do imóvel</label>
    <% photo_actions = capture do %>
      <div class="captacao-photo-picker-actions">
        <%= ax_file_upload_button(
              form: f,
              method: (@captacao.is_a?(Habitation) ? :photos : :fotos),
              label: tag.i(class: "bi bi-images") + "Adicionar fotos",
              input_id: "captacao_fotos",
              multiple: true,
              accept: "image/*",
              direct_upload: true,
              input_class: ("is-invalid" if field_invalid.call(:photos)),
              class_name: "ax-btn ax-btn--primary captacao-photo-picker-button tw-mb-0",
              input_data: { captacao_photos_target: "input", action: "change->captacao-photos#filesChanged" }
            ) %>
        <label class="ax-btn ax-btn--ghost captacao-photo-picker-button tw-mb-0">
          <i class="bi bi-camera"></i>
          Câmera
          <input type="file"
                 accept="image/*"
                 capture="environment"
                 class="visually-hidden"
                 data-action="change->captacao-photos#filesChanged"
                 data-captacao-photos-append="true">
        </label>
      </div>
    <% end %>
    <%= ax_media_upload_panel(
          title: "Enviar fotos",
          description: "Selecione em lote e repita para incluir mais antes de avançar.",
          icon: "images",
          actions: photo_actions,
          class_name: "captacao-photo-upload-panel"
        ) %>
    <% if field_invalid.call(:photos) %><div class="invalid-feedback d-block">Envie ao menos uma foto do imóvel.</div><% end %>
  </div>

  <div class="captacao-photo-list captacao-photo-list--new tw-mb-4" data-captacao-photos-target="newPhotosPanel" hidden>
    <div class="captacao-photo-list__header">
      <div>
        <label class="ax-label tw-mb-0">Fotos selecionadas agora</label>
        <span>Você pode adicionar mais antes de avançar.</span>
      </div>
      <strong data-captacao-photos-target="newCount">0 novas</strong>
    </div>
    <div class="captacao-photo-empty" data-captacao-photos-target="emptyState">
      Nenhuma foto nova selecionada.
    </div>
    <div data-captacao-photos-target="newList"></div>
  </div>

  <% if photos_attachment.attached? %>
    <div class="captacao-photo-list captacao-photo-list--existing tw-mb-4" data-captacao-photos-target="existingPhotosPanel">
      <div class="captacao-photo-list__header">
        <div>
          <label class="ax-label tw-mb-0">Fotos já anexadas</label>
          <span>Reordene a capa e adicione mais fotos acima.</span>
        </div>
        <strong><%= pluralize(photos_attachment.count, "foto", "fotos") %></strong>
      </div>
      <%= f.hidden_field :ordered_photo_ids,
                         data: { captacao_photos_target: "orderInput" },
                         value: @captacao.respond_to?(:photo_ids_order) ? @captacao.photo_ids_order.join(",") : "" %>
      <div data-captacao-photos-target="existingList">
        <% ordered_photos.each do |photo| %>
          <% next unless photo.persisted? && photo.blob&.persisted? %>
          <div class="captacao-photo-row" data-photo-id="<%= photo.id %>">
            <div class="captacao-photo-index" data-photo-index>1</div>
            <div class="captacao-photo-preview">
              <%= image_tag photo.representation(resize_to_limit: [240, 240]), class: "captacao-photo-thumb", loading: "lazy" %>
            </div>
            <div class="captacao-photo-meta">
              <strong><%= photo.filename.to_s %></strong>
              <small>Salva no imóvel</small>
              <% if captacao_ambiente_editable %>
                <% current_ambiente = @captacao.photo_ambiente(photo) %>
                <label class="captacao-photo-ambiente ax-label tw-mb-0">
                  <span class="tw-text-xs tw-text-ink-muted">Ambiente</span>
                  <%= select_tag "habitation[photo_ambientes][#{photo.id}]",
                        options_for_select([["Sem ambiente", ""]] + captacao_foto_ambientes.map { |a| [a, a] }, current_ambiente),
                        class: "ax-control ax-control--sm" %>
                </label>
              <% end %>
              <label class="captacao-highlight-choice">
                <input type="radio" name="existing_photo_highlight" data-action="change->captacao-photos#highlightExisting">
                Destaque
              </label>
            </div>
            <div class="captacao-photo-actions">
              <button type="button" class="captacao-photo-action" data-action="captacao-photos#moveExistingUp" aria-label="Subir foto" title="Subir"><i class="bi bi-arrow-up"></i></button>
              <button type="button" class="captacao-photo-action" data-action="captacao-photos#moveExistingDown" aria-label="Descer foto" title="Descer"><i class="bi bi-arrow-down"></i></button>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% elsif @captacao.respond_to?(:ordered_photo_ids) %>
    <%= f.hidden_field :ordered_photo_ids, data: { captacao_photos_target: "orderInput" }, value: "" %>
  <% end %>

  <hr class="my-3">

  <div class="wizard-field-group" data-captacao-photos-target="schedulePanel" hidden>
    <div class="captacao-schedule-box">
      <div>
        <strong data-captacao-photos-target="scheduleTitle">Agendamento com fotógrafo</strong>
        <p class="tw-text-sm tw-text-ink-muted tw-mb-2" data-captacao-photos-target="scheduleDescription">
          <%= schedule_url.present? ? "A agenda integrada será aberta em uma nova aba." : "Escolha um dia e horário disponível no agendador interno." %>
        </p>
      </div>
      <button type="button"
              class="ax-btn ax-btn--ghost ax-btn--sm"
              hidden
              data-captacao-photos-target="externalScheduleButton"
              data-action="captacao-photos#openScheduler">
        <i class="bi bi-box-arrow-up-right"></i>Abrir agenda de fotos
      </button>
      <button type="button"
              class="ax-btn ax-btn--primary ax-btn--sm"
              hidden
              data-captacao-photos-target="internalScheduleButton"
              data-action="captacao-photos#openScheduler">
        <i class="bi bi-calendar2-plus"></i><span data-captacao-photos-target="internalScheduleButtonLabel">Escolher horário</span>
      </button>
    </div>
  </div>

  <div class="wizard-field-group" data-captacao-photos-target="scheduledAtGroup" hidden>
    <%= f.label :photo_session_requested_at, "Data/hora agendada com fotógrafo", class: "ax-label", data: { captacao_photos_target: "scheduledAtLabel" } %>
    <%= f.datetime_local_field :photo_session_requested_at,
                               class: field_state.call(:photo_session_requested_at),
                               data: { captacao_photos_target: "scheduledAtInput" } %>
    <% if field_invalid.call(:photo_session_requested_at) %><div class="invalid-feedback d-block">Informe a data/hora agendada.</div><% end %>
    <small class="tw-text-ink-muted" data-captacao-photos-target="scheduledAtHint">Obrigatório quando a opção for agendar fotógrafo.</small>
  </div>

  <div class="wizard-field-group">
    <label class="ax-label">Autorização do proprietário</label>
    <div class="captacao-authorization-upload">
      <%= ax_file_upload_button(
            form: f,
            method: (@captacao.is_a?(Habitation) ? :autorizacoes_venda : :autorizacao_pdf),
            label: tag.i(class: "bi bi-paperclip") + "Anexar autorização",
            input_id: "captacao_autorizacao",
            multiple: @captacao.is_a?(Habitation),
            accept: "image/*,application/pdf",
            direct_upload: true,
            input_class: field_state.call(:autorizacoes_venda),
            class_name: "ax-btn ax-btn--ghost captacao-authorization-upload__button"
          ) %>
      <span>Print, imagem ou PDF.</span>
    </div>
    <% if field_invalid.call(:autorizacoes_venda) %><div class="invalid-feedback d-block">Anexe a autorização do proprietário.</div><% end %>
  </div>

  <% if authorization_attachments.attached? %>
    <%= ax_inline_notice(tone: :success, icon: "file-earmark-check-fill") do %>
      Autorização anexada.
    <% end %>
  <% end %>

  <div class="ax-quick-modal ax-quick-modal--md" id="captacaoPhotoSchedulerModal" tabindex="-1" role="presentation" hidden aria-hidden="true" data-controller="ax-modal" data-ax-modal-target="overlay" data-action="click->ax-modal#backdropClose">
    <div class="ax-quick-modal__panel" role="dialog" aria-modal="true">
      <header class="ax-quick-modal__header">
        <div>
          <h5 class="ax-quick-modal__title" id="captacaoPhotoSchedulerLabel">Agendar fotografia</h5>
          <small class="tw-text-ink-muted">Horários disponíveis para os próximos dias úteis.</small>
        </div>
        <button type="button" class="ax-icon-btn" data-action="ax-modal#close" aria-label="Fechar"><i class="bi bi-x-lg"></i></button>
      </header>
      <div class="ax-quick-modal__body">
        <div class="captacao-calendar-grid tw-mb-3" data-captacao-photos-target="calendarGrid"></div>
        <div class="captacao-slot-list" data-captacao-photos-target="slotList"></div>
      </div>
    </div>
  </div>
</section>
