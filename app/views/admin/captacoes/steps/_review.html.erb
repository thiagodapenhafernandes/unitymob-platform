<% review_layer_enabled = @property_setting&.broker_capture_layer_enabled? %>

<h1 class="wizard-section-title"><i class="bi bi-check2-circle" style="color:#16a34a;margin-right:.5rem;"></i>Revisão final</h1>
<p class="wizard-section-subtitle">
  Confira antes de mandar para análise.
  <%= review_layer_enabled ? "Depois da revisão administrativa, a captação fica disponível para você publicar." : "Depois da validação, a captação fica disponível para você publicar." %>
</p>

<div class="ax-card wizard-review-card tw-mb-3">
  <div class="ax-card__body">
    <h6 class="tw-font-bold text-uppercase tw-text-sm tw-text-ink-muted tw-mb-2">Imóvel</h6>
    <dl class="tw-grid tw-text-sm" style="grid-template-columns:repeat(12,1fr);gap:.25rem .5rem;">
      <dt class="ax-span-6">Tipo</dt><dd class="ax-span-6"><%= @captacao.property_kind.humanize %></dd>
      <dt class="ax-span-6">Modalidade</dt><dd class="ax-span-6"><%= @captacao.modalidade.humanize %></dd>
      <dt class="ax-span-6">Endereço</dt>
      <dd class="ax-span-6"><%= [@captacao.street, @captacao.street_number].compact_blank.join(", ").presence || "—" %></dd>
      <% if @captacao.edificio_nome.present? %>
        <dt class="ax-span-6">Edifício</dt>
        <dd class="ax-span-6"><%= @captacao.edificio_nome %><%= " · Un. #{@captacao.unidade_numero}" if @captacao.unidade_numero.present? %></dd>
      <% end %>
      <% if @captacao.try(:lote).present? || @captacao.try(:quadra).present? %>
        <dt class="ax-span-6">Lote/Quadra</dt>
        <dd class="ax-span-6"><%= [@captacao.lote.presence && "Lote #{@captacao.lote}", @captacao.quadra.presence && "Quadra #{@captacao.quadra}"].compact_blank.join(" · ") %></dd>
      <% end %>
      <dt class="ax-span-6">Cidade</dt><dd class="ax-span-6"><%= [@captacao.city, @captacao.state].compact_blank.join("/") %></dd>
      <% if @captacao.area_privativa.present? %>
        <dt class="ax-span-6">Área privativa</dt><dd class="ax-span-6"><%= @captacao.area_privativa %> m²</dd>
      <% end %>
      <% if @captacao.area_total.present? %>
        <dt class="ax-span-6">Área total</dt><dd class="ax-span-6"><%= @captacao.area_total %> m²</dd>
      <% end %>
      <% if @captacao.property_kind_residencial? %>
        <dt class="ax-span-6">Dorms / Suítes / Banheiros</dt>
        <dd class="ax-span-6"><%= [@captacao.dormitorios, @captacao.suites, @captacao.banheiros].join(" / ") %></dd>
      <% end %>
    </dl>
  </div>
</div>

<div class="ax-card wizard-review-card tw-mb-3">
  <div class="ax-card__body">
    <h6 class="tw-font-bold text-uppercase tw-text-sm tw-text-ink-muted tw-mb-2">Proprietário</h6>
    <dl class="tw-grid tw-text-sm" style="grid-template-columns:repeat(12,1fr);gap:.25rem .5rem;">
      <dt class="ax-span-6">Nome</dt><dd class="ax-span-6"><%= @captacao.proprietario_nome %></dd>
      <dt class="ax-span-6">Telefone</dt><dd class="ax-span-6"><%= format_phone(@captacao.proprietario_telefone) %></dd>
      <% if @captacao.proprietario_email.present? %>
        <dt class="ax-span-6">E-mail</dt><dd class="ax-span-6"><%= @captacao.proprietario_email %></dd>
      <% end %>
    </dl>
  </div>
</div>

<div class="ax-card wizard-review-card tw-mb-3">
  <div class="ax-card__body">
    <h6 class="tw-font-bold text-uppercase tw-text-sm tw-text-ink-muted tw-mb-2">Negociação</h6>
    <dl class="tw-grid tw-text-sm" style="grid-template-columns:repeat(12,1fr);gap:.25rem .5rem;">
      <% if @captacao.valor_venda.present? %>
        <dt class="ax-span-6">Valor de venda</dt>
        <dd class="ax-span-6"><%= number_to_currency(@captacao.valor_venda, unit: "R$ ", separator: ",", delimiter: ".") %></dd>
      <% end %>
      <% if @captacao.valor_locacao.present? %>
        <dt class="ax-span-6">Valor locação</dt>
        <dd class="ax-span-6"><%= number_to_currency(@captacao.valor_locacao, unit: "R$ ", separator: ",", delimiter: ".") %></dd>
      <% end %>
      <% if @captacao.valor_condominio.present? %>
        <dt class="ax-span-6">Condomínio</dt>
        <dd class="ax-span-6"><%= number_to_currency(@captacao.valor_condominio, unit: "R$ ") %></dd>
      <% end %>
    </dl>
  </div>
</div>

<% if @captacao.fotos.attached? %>
  <div class="ax-card wizard-review-card tw-mb-3">
    <div class="ax-card__body">
      <h6 class="tw-font-bold text-uppercase tw-text-sm tw-text-ink-muted tw-mb-2">
        Fotos (<%= @captacao.fotos.count %>)
      </h6>
      <div class="tw-grid tw-gap-1 wizard-photo-grid" style="grid-template-columns:repeat(6,1fr);">
        <% @captacao.fotos.first(6).each do |photo| %>
          <div>
            <%= image_tag photo.representation(resize_to_limit: [200, 200]), loading: "lazy" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<%= ax_inline_notice(tone: :info, icon: "info-circle-fill") do %>
  <% if review_layer_enabled %>
    Ao mandar análise, a captação vai para revisão administrativa. Depois de aprovada, ela fica disponível para você publicar no site.
  <% else %>
    Ao mandar análise, o sistema valida a captação e ela fica disponível para você publicar no site.
  <% end %>
<% end %>
