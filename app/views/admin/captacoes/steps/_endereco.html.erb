<h1 class="wizard-section-title"><i class="bi bi-geo-alt-fill tw-text-primary" style="margin-right:.5rem;"></i>Endereço do imóvel</h1>
<p class="wizard-section-subtitle">Digite o CEP e nós preenchemos o endereço. Você só precisa completar com o número.</p>

<div data-controller="cep-lookup">
  <div class="wizard-field-group">
    <%= f.label :zip_code, "CEP", class: "ax-label" %>
    <div class="tw-flex tw-items-center tw-gap-2">
      <span><i class="bi bi-mailbox tw-text-ink-muted"></i></span>
      <%= f.text_field :zip_code,
                       class: field_state.call(:zip_code),
                       placeholder: "88330-030",
                       maxlength: 9,
                       inputmode: "numeric",
                       data: { cep_lookup_target: "cep", action: "blur->cep-lookup#lookup" } %>
      <button type="button" class="ax-btn ax-btn--ghost" data-cep-lookup-target="button" data-action="cep-lookup#lookup">
        <i class="bi bi-search"></i>Buscar
      </button>
    </div>
    <% if field_invalid.call(:zip_code) %><div class="invalid-feedback d-block">Informe o CEP.</div><% end %>
    <small data-cep-lookup-target="status" class="tw-text-ink-muted">Toque em Buscar depois de digitar o CEP.</small>
  </div>

  <%= ax_field_grid do %>
    <div class="ax-span-8">
      <div class="wizard-field-group">
        <%= f.label :street, "Rua / Avenida", class: "ax-label" %>
        <span class="required-star">*</span>
        <%= f.text_field :street,
                         class: field_state.call(:street),
                         data: {
                           cep_lookup_target: "address",
                           habitation_duplicate_check_target: "street",
                           action: "input->habitation-duplicate-check#schedule blur->habitation-duplicate-check#check"
                         } %>
        <% if field_invalid.call(:street) %><div class="invalid-feedback d-block">Informe a rua/avenida.</div><% end %>
      </div>
    </div>
    <div class="ax-span-4">
      <div class="wizard-field-group">
        <%= f.label :street_number, "Número", class: "ax-label" %>
        <span class="required-star">*</span>
        <%= f.text_field :street_number,
                         class: field_state.call(:street_number),
                         inputmode: "numeric",
                         data: {
                           cep_lookup_target: "number",
                           habitation_duplicate_check_target: "number",
                           action: "input->habitation-duplicate-check#schedule blur->habitation-duplicate-check#check"
                         } %>
        <% if field_invalid.call(:street_number) %><div class="invalid-feedback d-block">Informe o número.</div><% end %>
      </div>
    </div>
  <% end %>

  <%= ax_field_grid do %>
    <div class="ax-span-6">
      <div class="wizard-field-group">
        <%= f.label :neighborhood, "Bairro", class: "ax-label" %>
        <%= f.text_field :neighborhood, class: field_state.call(:neighborhood), data: { cep_lookup_target: "neighborhood" } %>
        <% if field_invalid.call(:neighborhood) %><div class="invalid-feedback d-block">Informe o bairro.</div><% end %>
      </div>
    </div>
    <div class="ax-span-4">
      <div class="wizard-field-group">
        <%= f.label :city, "Cidade", class: "ax-label" %>
        <span class="required-star">*</span>
        <%= f.text_field :city, class: field_state.call(:city), data: { cep_lookup_target: "city" } %>
        <% if field_invalid.call(:city) %><div class="invalid-feedback d-block">Informe a cidade.</div><% end %>
      </div>
    </div>
    <div class="ax-span-2">
      <div class="wizard-field-group">
        <%= f.label :state, "UF", class: "ax-label" %>
        <%= f.text_field :state, class: field_state.call(:state, "ax-control text-uppercase"), maxlength: 2, data: { cep_lookup_target: "uf" } %>
        <% if field_invalid.call(:state) %><div class="invalid-feedback d-block">Informe a UF.</div><% end %>
      </div>
    </div>
  <% end %>
</div>

<% if @captacao.requires_intake_development_name? || @captacao.requires_unit_number? %>
  <hr class="my-3">
  <%= ax_field_grid do %>
    <div class="<%= @captacao.requires_unit_number? ? 'ax-span-8' : 'ax-span-12' %>">
      <div class="wizard-field-group">
        <%= f.label :edificio_nome, "Edifício / Condomínio", class: "ax-label" %>
        <% if @captacao.requires_intake_development_name? %><span class="required-star">*</span><% end %>
        <%= f.text_field :edificio_nome,
                         class: field_state.call(:edificio_nome),
                         placeholder: "Ex.: Edifício Mirante do Atlântico",
                         data: {
                           habitation_duplicate_check_target: "building",
                           action: "input->habitation-duplicate-check#schedule blur->habitation-duplicate-check#check"
                         } %>
        <% if field_invalid.call(:edificio_nome) %><div class="invalid-feedback d-block">Informe o nome do condomínio/empreendimento.</div><% end %>
      </div>
    </div>
    <% if @captacao.requires_unit_number? %>
      <div class="ax-span-4">
        <div class="wizard-field-group">
          <%= f.label :unidade_numero, "Unidade / Apto", class: "ax-label" %>
          <span class="required-star">*</span>
          <%= f.text_field :unidade_numero,
                           class: field_state.call(:unidade_numero),
                           placeholder: "1203",
                           data: {
                             habitation_duplicate_check_target: "unit",
                             action: "input->habitation-duplicate-check#schedule blur->habitation-duplicate-check#check"
                           } %>
          <% if field_invalid.call(:unidade_numero) %><div class="invalid-feedback d-block">Informe o número da unidade.</div><% end %>
        </div>
      </div>
    <% end %>
  <% end %>
  <div data-habitation-duplicate-check-target="status"></div>
<% else %>
  <div data-habitation-duplicate-check-target="status"></div>
<% end %>
