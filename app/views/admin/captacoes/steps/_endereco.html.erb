<h1 class="wizard-section-title"><i class="bi bi-geo-alt-fill tw-text-primary"></i>Endereço do imóvel</h1>
<p class="wizard-section-subtitle">Digite o CEP e nós preenchemos o endereço. Complete número e complemento quando necessário.</p>

<div data-controller="cep-lookup">
  <div class="wizard-field-group wizard-field-group--cep">
    <%= ax_field_label(f, :zip_code, text: "CEP") %>
    <div class="wizard-cep-row">
      <span class="wizard-cep-icon" aria-hidden="true"><i class="bi bi-mailbox"></i></span>
      <%= f.text_field :zip_code,
                       class: field_state.call(:zip_code, "ax-control wizard-cep-input"),
                       placeholder: "88330-030",
                       maxlength: 9,
                       inputmode: "numeric",
                       data: { cep_lookup_target: "cep", action: "blur->cep-lookup#lookup" } %>
      <button type="button" class="ax-btn ax-btn--ghost wizard-cep-button" data-cep-lookup-target="button" data-action="cep-lookup#lookup">
        <i class="bi bi-search"></i><span>Buscar</span>
      </button>
    </div>
    <% if field_invalid.call(:zip_code) %><div class="invalid-feedback d-block">Informe o CEP.</div><% end %>
    <small data-cep-lookup-target="status" class="tw-text-ink-muted">Toque em Buscar depois de digitar o CEP.</small>
  </div>

  <%= ax_field_grid do %>
    <div class="ax-span-8">
      <%= ax_text_field(form: f, method: :street,
            label: safe_join(["Rua / Avenida", tag.span("*", class: "required-star")], " "),
            field_class: "wizard-field-group", class: field_state.call(:street), autocomplete: "address-line1",
            data: { cep_lookup_target: "address", habitation_duplicate_check_target: "street",
                    action: "input->habitation-duplicate-check#schedule blur->habitation-duplicate-check#check" }) %>
      <% if field_invalid.call(:street) %><div class="invalid-feedback d-block">Informe a rua/avenida.</div><% end %>
    </div>
    <div class="ax-span-4">
      <%= ax_text_field(form: f, method: :street_number,
            label: safe_join(["Número", tag.span("*", class: "required-star")], " "),
            field_class: "wizard-field-group", class: field_state.call(:street_number), inputmode: "numeric",
            autocomplete: "address-line2", data: { cep_lookup_target: "number", habitation_duplicate_check_target: "number",
                    action: "input->habitation-duplicate-check#schedule blur->habitation-duplicate-check#check" }) %>
      <% if field_invalid.call(:street_number) %><div class="invalid-feedback d-block">Informe o número.</div><% end %>
    </div>
  <% end %>

  <%= ax_field_grid(class_name: "wizard-address-locality-grid") do %>
    <div class="ax-span-6">
      <%= ax_text_field(form: f, method: :neighborhood, label: "Bairro", field_class: "wizard-field-group",
            class: field_state.call(:neighborhood), autocomplete: "address-level3", data: { cep_lookup_target: "neighborhood" }) %>
      <% if field_invalid.call(:neighborhood) %><div class="invalid-feedback d-block">Informe o bairro.</div><% end %>
    </div>
    <div class="ax-span-4">
      <%= ax_text_field(form: f, method: :city,
            label: safe_join(["Cidade", tag.span("*", class: "required-star")], " "),
            field_class: "wizard-field-group", class: field_state.call(:city), autocomplete: "address-level2",
            data: { cep_lookup_target: "city" }) %>
      <% if field_invalid.call(:city) %><div class="invalid-feedback d-block">Informe a cidade.</div><% end %>
    </div>
    <div class="ax-span-2">
      <%= ax_text_field(form: f, method: :state, label: "UF", field_class: "wizard-field-group",
            class: field_state.call(:state, "ax-control text-uppercase"), maxlength: 2, autocomplete: "address-level1",
            data: { cep_lookup_target: "uf" }) %>
      <% if field_invalid.call(:state) %><div class="invalid-feedback d-block">Informe a UF.</div><% end %>
    </div>
  <% end %>
</div>

<% if @captacao.requires_intake_development_name? || @captacao.requires_intake_address_complement? %>
  <hr class="my-3">
  <%# Campos condicionais ao tipo do imóvel, empilhados em largura total (mobile-first). %>
  <% if @captacao.requires_intake_development_name? %>
    <%
      captacao_developments = Array(@developments)
      captacao_development_lookup = captacao_developments.each_with_object({}) do |development, hash|
        hash[development.codigo.to_s] = {
          nome_empreendimento: development.nome_empreendimento.presence || development.titulo_anuncio.to_s
        }
      end
    %>
    <div data-controller="habitation-form"
         data-habitation-form-developments-value="<%= json_escape(captacao_development_lookup.to_json) %>">
      <% if captacao_developments.any? %>
        <%= ax_autocomplete_select_field(
              clearable: true,
              form: f,
              method: :codigo_empreendimento,
              label: "Empreendimento cadastrado",
              choices: captacao_developments.map { |development| [development.nome_empreendimento.presence || development.titulo_anuncio.to_s, development.codigo] },
              select_options: { include_blank: "Buscar pelo nome...", selected: @captacao.codigo_empreendimento },
              placeholder: "Buscar pelo nome...",
              html_options: {
                data: {
                  habitation_form_target: "developmentSelect",
                  action: "change->habitation-form#developmentChanged"
                }
              }
            ) %>
      <% end %>

      <%= ax_text_field(form: f, method: :edificio_nome,
            label: safe_join(["Edifício / Condomínio", tag.span("*", class: "required-star")], " "),
            field_class: "wizard-field-group", class: field_state.call(:edificio_nome),
            placeholder: "Ex.: Edifício Mirante do Atlântico", readonly: @captacao.codigo_empreendimento.present?,
            data: { habitation_form_target: "developmentName", habitation_duplicate_check_target: "building",
                    action: "input->habitation-duplicate-check#schedule blur->habitation-duplicate-check#check" }) %>
      <% if field_invalid.call(:edificio_nome) %><div class="invalid-feedback d-block">Informe o nome do condomínio/empreendimento.</div><% end %>
    </div>
  <% end %>
  <% if @captacao.requires_unit_number? %>
    <%= ax_text_field(form: f, method: :unidade_numero,
          label: safe_join([@captacao.intake_address_complement_label, tag.span("*", class: "required-star")], " "),
          field_class: "wizard-field-group", class: field_state.call(:unidade_numero),
          placeholder: @captacao.intake_address_complement_placeholder,
          data: { habitation_duplicate_check_target: "unit",
                  action: "input->habitation-duplicate-check#schedule blur->habitation-duplicate-check#check" }) %>
    <% if field_invalid.call(:unidade_numero) %><div class="invalid-feedback d-block">Informe o número da unidade.</div><% end %>
  <% elsif @captacao.requires_intake_address_complement? %>
    <%= ax_text_field(form: f, method: :complemento,
          label: safe_join([@captacao.intake_address_complement_label, tag.span("*", class: "required-star")], " "),
          field_class: "wizard-field-group", class: field_state.call(:complemento),
          placeholder: @captacao.intake_address_complement_placeholder,
          data: { habitation_duplicate_check_target: "complement",
                  action: "input->habitation-duplicate-check#schedule blur->habitation-duplicate-check#check" }) %>
    <% if field_invalid.call(:complemento) %><div class="invalid-feedback d-block">Informe o complemento.</div><% end %>
  <% end %>
  <% if @captacao.requires_intake_lot_block? %>
    <%= ax_text_field(form: f, method: :lote, label: "Lote", field_class: "wizard-field-group",
          class: field_state.call(:lote), placeholder: "Ex.: 12") %>
    <% if field_invalid.call(:lote) %><div class="invalid-feedback d-block">Informe o lote.</div><% end %>
    <%= ax_text_field(form: f, method: :quadra, label: "Quadra", field_class: "wizard-field-group",
          class: field_state.call(:quadra), placeholder: "Ex.: B") %>
    <% if field_invalid.call(:quadra) %><div class="invalid-feedback d-block">Informe a quadra.</div><% end %>
  <% end %>
  <div data-habitation-duplicate-check-target="status"></div>
<% else %>
  <hr class="my-3">
  <%= ax_field_grid do %>
    <div class="ax-span-12">
      <%= ax_text_field(form: f, method: :complemento, label: "Complemento", field_class: "wizard-field-group",
            class: field_state.call(:complemento), placeholder: @captacao.intake_address_complement_placeholder,
            data: { habitation_duplicate_check_target: "complement",
                    action: "input->habitation-duplicate-check#schedule blur->habitation-duplicate-check#check" }) %>
    </div>
  <% end %>
  <div data-habitation-duplicate-check-target="status"></div>
<% end %>
