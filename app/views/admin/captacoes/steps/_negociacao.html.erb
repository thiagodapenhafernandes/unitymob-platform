<h1 class="wizard-section-title"><i class="bi bi-cash-stack tw-text-primary" style="margin-right:.5rem;"></i>Negociação</h1>
<p class="wizard-section-subtitle">
  Modalidade: <strong><%= @captacao.modalidade.to_s.humanize %></strong>. Preencha conforme aplicável.
</p>

<% if @captacao.requires_sale_price? %>
  <div class="wizard-field-group">
    <%= f.label :valor_venda, "Valor de venda (R$)", class: "ax-label" %>
    <span class="required-star">*</span>
    <%= f.text_field :valor_venda,
                     value: @captacao.valor_venda_formatted,
                     inputmode: "numeric",
                     class: field_state.call(:valor_venda),
                     data: { controller: "mask", mask_type_value: "currency" } %>
    <% if field_invalid.call(:valor_venda) %><div class="invalid-feedback d-block"><%= @captacao.intake_sale_price_requirement_message %></div><% end %>
  </div>

  <div class="wizard-field-group">
    <%= f.label :motivo_venda, "Motivo da venda", class: "ax-label" %>
    <%= f.select :motivo_venda,
                 options_for_select(Array(@sale_reasons), @captacao.motivo_venda),
                 { include_blank: "Selecione" },
                 class: "ax-control" %>
  </div>

  <div class="wizard-field-group">
    <%= f.label :aceita_permuta_answer, "Aceita permuta?", class: "ax-label" %>
    <span class="required-star">*</span>
    <%= f.select :aceita_permuta_answer,
                 Habitation::YES_NO_ANSWERS.map { |key, label| [label, key] },
                 { include_blank: "Selecione" },
                 class: field_state.call(:aceita_permuta_answer, "ax-control") %>
    <% if field_invalid.call(:aceita_permuta_answer) %><div class="invalid-feedback d-block">Informe se aceita permuta.</div><% end %>
  </div>

  <%= ax_field_grid do %>
    <div class="ax-span-6">
      <div class="wizard-field-group">
        <%= f.label :cidade_permuta, "Cidade aceita permuta", class: "ax-label" %>
        <%= f.text_field :cidade_permuta, class: "ax-control" %>
      </div>
    </div>
    <div class="ax-span-6">
      <div class="wizard-field-group">
        <%= f.label :aceita_parcelamento_flag, "Aceita parcelamento?", class: "ax-label" %>
        <span class="required-star">*</span>
        <%= f.select :aceita_parcelamento_flag, [["Sim", true], ["Não", false]], {}, class: "ax-control" %>
      </div>
    </div>
  <% end %>

  <div class="wizard-field-group">
    <%= f.label :numero_prestacoes, "Se aceita parcelamento, em quantas vezes?", class: "ax-label" %>
    <%= f.number_field :numero_prestacoes, min: 1, inputmode: "numeric", class: field_state.call(:numero_prestacoes) %>
    <% if field_invalid.call(:numero_prestacoes) %><div class="invalid-feedback d-block">Informe a quantidade de parcelas.</div><% end %>
  </div>
<% end %>

<% if @captacao.requires_rent_price? %>
  <hr class="my-3">
  <div class="wizard-field-group">
    <%= f.label :valor_locacao, "Valor de locação (R$)", class: "ax-label" %>
    <span class="required-star">*</span>
    <%= f.text_field :valor_locacao,
                     value: @captacao.valor_locacao_formatted,
                     inputmode: "numeric",
                     class: field_state.call(:valor_locacao),
                     data: { controller: "mask", mask_type_value: "currency" } %>
    <% if field_invalid.call(:valor_locacao) %><div class="invalid-feedback d-block"><%= @captacao.intake_rent_price_requirement_message %></div><% end %>
  </div>

  <div class="wizard-field-group">
    <%= f.label :salute_rental_management_answer, "Administração de locação feita pela Salute?", class: "ax-label" %>
    <span class="required-star">*</span>
    <%= f.select :salute_rental_management_answer,
                 Habitation::YES_NO_ANSWERS.map { |key, label| [label, key] },
                 { include_blank: "Selecione" },
                 class: field_state.call(:salute_rental_management_answer, "ax-control") %>
    <% if field_invalid.call(:salute_rental_management_answer) %><div class="invalid-feedback d-block">Informe se a administração será feita pela Salute.</div><% end %>
  </div>

  <div class="wizard-field-group">
    <%= f.label :rental_guarantee_method, "Meio de garantia locatícia", class: "ax-label" %>
    <span class="required-star">*</span>
    <%= f.select :rental_guarantee_method,
                 Habitation::RENTAL_GUARANTEE_METHOD_OPTIONS,
                 { include_blank: "Selecione" },
                 class: field_state.call(:rental_guarantee_method, "ax-control") %>
    <% if field_invalid.call(:rental_guarantee_method) %><div class="invalid-feedback d-block">Informe o meio de garantia locatícia.</div><% end %>
  </div>
<% end %>

<hr class="my-3">
<h6 class="tw-font-bold tw-mb-2 tw-text-ink-muted tw-text-sm text-uppercase">Taxas e despesas</h6>

<%= ax_field_grid do %>
  <div class="ax-span-6">
    <div class="wizard-field-group">
      <%= f.label :valor_condominio, "Condomínio (R$)", class: "ax-label" %>
      <%= f.text_field :valor_condominio,
                       value: @captacao.valor_condominio_formatted,
                       inputmode: "numeric",
                       class: field_state.call(:valor_condominio),
                       data: { controller: "mask", mask_type_value: "currency" } %>
      <% if field_invalid.call(:valor_condominio) %><div class="invalid-feedback d-block">Informe condomínio ou IPTU.</div><% end %>
    </div>
  </div>
  <div class="ax-span-6">
    <div class="wizard-field-group">
      <%= f.label :valor_iptu, "IPTU anual (R$)", class: "ax-label" %>
      <%= f.text_field :valor_iptu,
                       value: @captacao.valor_iptu_formatted,
                       inputmode: "numeric",
                       class: field_state.call(:valor_iptu),
                       data: { controller: "mask", mask_type_value: "currency" } %>
      <% if field_invalid.call(:valor_iptu) %><div class="invalid-feedback d-block">Informe IPTU ou condomínio.</div><% end %>
    </div>
  </div>
<% end %>

<div class="wizard-field-group">
  <%= f.label :saldo_devedor, "Saldo devedor (R$)", class: "ax-label" %>
  <%= f.text_field :saldo_devedor,
                   value: @captacao.saldo_devedor_formatted,
                   inputmode: "numeric",
                   class: "ax-control",
                   data: { controller: "mask", mask_type_value: "currency" } %>
  <small class="tw-text-ink-muted">Se houver financiamento em aberto.</small>
</div>

<div class="wizard-field-group">
  <label class="ax-label">Outras taxas / contribuições</label>
  <% ["Fundo de reserva", "Taxa extra", "Lazer", "Água", "Gás", "Taxa de lixo"].each do |opt| %>
    <% selected = Array(@captacao.outras_taxas).include?(opt) %>
    <label class="wizard-feature-chip <%= 'selected' if selected %>">
      <%= check_box_tag "captacao[outras_taxas][]", opt, selected, onchange: "this.closest('label').classList.toggle('selected', this.checked)" %>
      <%= opt %>
    </label>
  <% end %>
</div>
