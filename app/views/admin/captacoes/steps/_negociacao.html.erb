<h1 class="wizard-section-title"><i class="bi bi-cash-stack tw-text-primary"></i>Negociação</h1>
<p class="wizard-section-subtitle">
  Modalidade: <strong><%= @captacao.modalidade.to_s.humanize %></strong>. Preencha conforme aplicável.
</p>

<% if @captacao.requires_sale_price? %>
  <%= ax_currency_field(form: f, method: :valor_venda,
        label: safe_join(["Valor de venda", tag.span("*", class: "required-star")], " "),
        class_name: "wizard-field-group", input_class: field_state.call(:valor_venda, nil),
        value: @captacao.valor_venda_formatted, inputmode: "numeric",
        data: { controller: "mask", mask_type_value: "currency" }) %>
  <% if field_invalid.call(:valor_venda) %><div class="invalid-feedback d-block"><%= @captacao.intake_sale_price_requirement_message %></div><% end %>

  <%= ax_select_field(form: f, method: :motivo_venda, label: "Motivo da venda",
        choices: Array(@sale_reasons), select_options: { include_blank: "Selecione" }, class_name: "wizard-field-group") %>

  <%= ax_select_field(form: f, method: :aceita_permuta_answer,
        label: "Aceita permuta?",
        choices: Habitation::YES_NO_ANSWERS.map { |key, label| [label, key] },
        select_options: { include_blank: "Não" }, class_name: "wizard-field-group",
        html_options: { class: field_state.call(:aceita_permuta_answer, "ax-control") }) %>

  <%= ax_field_grid do %>
    <div class="ax-span-6">
      <%= ax_text_field(form: f, method: :cidade_permuta, label: "Cidade aceita permuta",
            field_class: "wizard-field-group", autocomplete: "address-level2") %>
    </div>
    <div class="ax-span-6">
      <%= ax_select_field(form: f, method: :aceita_parcelamento_flag,
            label: safe_join(["Aceita parcelamento?", tag.span("*", class: "required-star")], " "),
            choices: [["Sim", true], ["Não", false]], class_name: "wizard-field-group") %>
    </div>
  <% end %>

  <%= ax_number_field(form: f, method: :numero_prestacoes, label: "Se aceita parcelamento, em quantas vezes?",
        min: 1, inputmode: "numeric", class_name: "wizard-field-group", input_class: field_state.call(:numero_prestacoes, nil)) %>
  <% if field_invalid.call(:numero_prestacoes) %><div class="invalid-feedback d-block">Informe a quantidade de parcelas.</div><% end %>
<% end %>

<% if @captacao.requires_rent_price? %>
  <hr class="my-3">
  <%= ax_currency_field(form: f, method: :valor_locacao,
        label: safe_join(["Valor de locação", tag.span("*", class: "required-star")], " "),
        class_name: "wizard-field-group", input_class: field_state.call(:valor_locacao, nil),
        value: @captacao.valor_locacao_formatted, inputmode: "numeric",
        data: { controller: "mask", mask_type_value: "currency" }) %>
  <% if field_invalid.call(:valor_locacao) %><div class="invalid-feedback d-block"><%= @captacao.intake_rent_price_requirement_message %></div><% end %>

  <%= ax_select_field(form: f, method: :salute_rental_management_answer,
        label: safe_join(["Administração de locação feita pela Salute?", tag.span("*", class: "required-star")], " "),
        choices: Habitation::YES_NO_ANSWERS.map { |key, label| [label, key] },
        select_options: { include_blank: "Selecione" }, class_name: "wizard-field-group",
        html_options: { class: field_state.call(:salute_rental_management_answer, "ax-control") }) %>
  <% if field_invalid.call(:salute_rental_management_answer) %><div class="invalid-feedback d-block">Informe se a administração será feita pela Salute.</div><% end %>

  <div class="wizard-field-group">
    <%= ax_field_label(f, :rental_guarantee_method,
          text: safe_join(["Meios de garantia locatícia", tag.span("*", class: "required-star")], " ")) %>
    <% rental_guarantee_field_name = "#{f.object_name}[rental_guarantee_method][]" %>
    <%= hidden_field_tag rental_guarantee_field_name, "" %>
    <div class="ax-filter-checks <%= 'is-invalid' if field_invalid.call(:rental_guarantee_method) %>">
      <% selected_guarantees = @captacao.rental_guarantee_methods %>
      <% Habitation::RENTAL_GUARANTEE_METHOD_OPTIONS.each do |option| %>
        <%= ax_filter_check(
              name: rental_guarantee_field_name,
              value: option,
              checked: selected_guarantees.include?(option),
              label: option,
              id: "captacao_rental_guarantee_method_#{option.parameterize}"
            ) %>
      <% end %>
    </div>
    <% if field_invalid.call(:rental_guarantee_method) %><div class="invalid-feedback d-block">Informe ao menos um meio de garantia locatícia.</div><% end %>
  </div>
<% end %>

<hr class="my-3">
<h6 class="tw-font-bold tw-mb-2 tw-text-ink-muted tw-text-sm text-uppercase">Taxas e despesas</h6>

<%= ax_field_grid do %>
  <div class="ax-span-6">
    <%= ax_currency_field(form: f, method: :valor_condominio, label: "Condomínio",
          class_name: "wizard-field-group", input_class: field_state.call(:valor_condominio, nil),
          value: @captacao.valor_condominio_formatted, inputmode: "numeric",
          data: { controller: "mask", mask_type_value: "currency" }) %>
    <% if field_invalid.call(:valor_condominio) %><div class="invalid-feedback d-block">Informe condomínio ou IPTU.</div><% end %>
  </div>
  <div class="ax-span-6">
    <%= ax_currency_field(form: f, method: :valor_iptu, label: "IPTU anual",
          class_name: "wizard-field-group", input_class: field_state.call(:valor_iptu, nil),
          value: @captacao.valor_iptu_formatted, inputmode: "numeric",
          data: { controller: "mask", mask_type_value: "currency" }) %>
    <% if field_invalid.call(:valor_iptu) %><div class="invalid-feedback d-block">Informe IPTU ou condomínio.</div><% end %>
  </div>
<% end %>

<%= ax_currency_field(form: f, method: :saldo_devedor, label: "Saldo devedor",
      class_name: "wizard-field-group", value: @captacao.saldo_devedor_formatted,
      inputmode: "numeric", data: { controller: "mask", mask_type_value: "currency" }) %>
<small class="tw-text-ink-muted">Se houver financiamento em aberto.</small>

<div class="wizard-field-group">
  <label class="ax-label">Outras taxas / contribuições</label>
  <div class="wizard-choice-panel wizard-choice-panel--boxed">
    <% ["Fundo de reserva", "Taxa extra", "Lazer", "Água", "Gás", "Taxa de lixo"].each do |opt| %>
      <% selected = Array(@captacao.outras_taxas).include?(opt) %>
      <label class="wizard-feature-chip <%= 'selected' if selected %>" data-controller="selectable-chip">
        <%= check_box_tag "captacao[outras_taxas][]", opt, selected, data: { action: "change->selectable-chip#sync" } %>
        <%= opt %>
      </label>
    <% end %>
  </div>
</div>
