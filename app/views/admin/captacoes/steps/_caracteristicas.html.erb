<%
  kind = @captacao.property_kind.to_s
  fallback_features_imovel = case kind
                             when "residencial"
                               ["Armários nos quartos", "Cozinha planejada", "Ar-condicionado", "Aquecimento a gás",
                                "Fechadura digital", "Lavabo", "Piscina", "Churrasqueira", "Área de serviço"]
                             when "sala_comercial"
                               ["Ar-condicionado", "Recepção", "Sanitários", "Copa/cozinha", "Piso elevado", "Sprinklers",
                                "Sistema de segurança", "Divisórias prontas"]
                             else  # terreno
                               ["Murado", "Cercado", "Aterrado", "Com edificação", "Esquina", "Frente para mar"]
                             end

  features_imovel = captacao_feature_options(@internal_features, fallback_features_imovel, @captacao.caracteristicas_imovel)
%>

<h1 class="wizard-section-title"><i class="bi bi-rulers tw-text-primary" style="margin-right:.5rem;"></i>Características do imóvel</h1>
<p class="wizard-section-subtitle">Campos variam por tipo de imóvel (<strong><%= kind.humanize %></strong>).</p>

<!-- Áreas (comum a todos) -->
<%= ax_field_grid do %>
  <div class="ax-span-6">
    <div class="wizard-field-group">
      <%= f.label :area_total, "Área total (m²)", class: "ax-label" %>
      <% if @captacao.property_kind_terreno? %>
        <span class="required-star">*</span>
      <% end %>
      <%= f.number_field :area_total, step: 0.01, inputmode: "decimal", class: field_state.call(:area_total) %>
      <% if @captacao.property_kind_terreno? %>
        <% if field_invalid.call(:area_total) %><div class="invalid-feedback d-block">Informe a área total maior que zero.</div><% end %>
      <% end %>
    </div>
  </div>
  <% unless @captacao.property_kind_terreno? %>
    <div class="ax-span-6">
      <div class="wizard-field-group">
        <%= f.label :area_privativa, "Área privativa (m²)", class: "ax-label" %>
        <span class="required-star">*</span>
        <%= f.number_field :area_privativa, step: 0.01, inputmode: "decimal", class: field_state.call(:area_privativa) %>
        <% if field_invalid.call(:area_privativa) %><div class="invalid-feedback d-block">Informe a área privativa maior que zero.</div><% end %>
      </div>
    </div>
  <% end %>
<% end %>

<% if @captacao.property_kind_residencial? %>
  <%= ax_field_grid do %>
    <% [[:dormitorios, "Dormitórios", true], [:suites, "Suítes"], [:demi_suites, "Demi-suítes"]].each do |field, label, req| %>
      <div class="ax-span-4">
        <div class="wizard-field-group">
          <%= f.label field, label, class: "ax-label" %>
          <% if req %><span class="required-star">*</span><% end %>
          <%= f.number_field field, min: 0, inputmode: "numeric", class: field_state.call(field) %>
          <% if field_invalid.call(field) %><div class="invalid-feedback d-block">Campo obrigatório.</div><% end %>
        </div>
      </div>
    <% end %>
  <% end %>

  <%= ax_field_grid do %>
    <div class="ax-span-4">
      <div class="wizard-field-group">
        <%= f.label :banheiros, "Banheiros", class: "ax-label" %>
        <span class="required-star">*</span>
        <%= f.number_field :banheiros, min: 0, inputmode: "numeric", class: field_state.call(:banheiros) %>
        <% if field_invalid.call(:banheiros) %><div class="invalid-feedback d-block">Informe a quantidade de banheiros.</div><% end %>
      </div>
    </div>
    <div class="ax-span-4">
      <div class="wizard-field-group">
        <%= f.label :vagas_garagem, "Vagas", class: "ax-label" %>
        <span class="required-star">*</span>
        <%= f.number_field :vagas_garagem, min: 0, inputmode: "numeric", class: field_state.call(:vagas_garagem) %>
        <% if field_invalid.call(:vagas_garagem) %><div class="invalid-feedback d-block">Informe a quantidade de vagas.</div><% end %>
      </div>
    </div>
    <div class="ax-span-4">
      <div class="wizard-field-group">
        <%= f.label :salas, "Salas", class: "ax-label" %>
        <%= f.number_field :salas, min: 0, inputmode: "numeric", class: field_state.call(:salas) %>
        <% if field_invalid.call(:salas) %><div class="invalid-feedback d-block">Informe a quantidade de salas/ambientes.</div><% end %>
      </div>
    </div>
  <% end %>

  <%= ax_field_grid do %>
    <div class="ax-span-4">
      <div class="wizard-field-group">
        <%= f.label :ocupacao, "Ocupação", class: "ax-label" %>
        <span class="required-star">*</span>
        <%= f.select :ocupacao, [["Desocupado", "Desocupado"], ["Inquilino", "Inquilino"], ["Proprietário", "Proprietário"]], { include_blank: "—" }, class: field_state.call(:ocupacao, "ax-control") %>
        <% if field_invalid.call(:ocupacao) %><div class="invalid-feedback d-block">Informe a ocupação.</div><% end %>
      </div>
    </div>
    <div class="ax-span-4">
      <div class="wizard-field-group">
        <%= f.label :estado_imovel, "Estado", class: "ax-label" %>
        <%= f.select :estado_imovel, [["Ótimo", "otimo"], ["Bom", "bom"], ["Regular", "regular"]], { include_blank: "—" }, class: "ax-control" %>
      </div>
    </div>
    <div class="ax-span-4">
      <div class="wizard-field-group">
        <%= f.label :situacao_imovel, "Situação", class: "ax-label" %>
        <span class="required-star">*</span>
        <%= f.select :situacao_imovel, [["Em construção", "Em construção"], ["Novo", "Novo"], ["Usado", "Usado"]], { include_blank: "—" }, class: field_state.call(:situacao_imovel, "ax-control") %>
        <% if field_invalid.call(:situacao_imovel) %><div class="invalid-feedback d-block">Informe a situação.</div><% end %>
      </div>
    </div>
  <% end %>

  <%= ax_field_grid do %>
    <% [[:sacada, "Sacada"], [:terraco, "Terraço"], [:dependencia_empregada, "Dep. empregada"], [:precisa_reforma, "Precisa reforma"]].each do |field, label| %>
      <div class="ax-span-3">
        <%= ax_switch_field(label: label, form: f, method: field, class_name: "tw-py-2") %>
      </div>
    <% end %>
  <% end %>

<% elsif @captacao.property_kind_sala_comercial? %>
  <%= ax_field_grid do %>
    <div class="ax-span-4">
      <div class="wizard-field-group">
        <%= f.label :salas, "Salas/Ambientes", class: "ax-label" %>
        <%= f.number_field :salas, min: 0, inputmode: "numeric", class: "ax-control" %>
      </div>
    </div>
    <div class="ax-span-4">
      <div class="wizard-field-group">
        <%= f.label :banheiros, "Banheiros", class: "ax-label" %>
        <%= f.number_field :banheiros, min: 0, inputmode: "numeric", class: "ax-control" %>
      </div>
    </div>
    <div class="ax-span-4">
      <div class="wizard-field-group">
        <%= f.label :vagas_garagem, "Vagas", class: "ax-label" %>
        <span class="required-star">*</span>
        <%= f.number_field :vagas_garagem, min: 0, inputmode: "numeric", class: field_state.call(:vagas_garagem) %>
        <% if field_invalid.call(:vagas_garagem) %><div class="invalid-feedback d-block">Informe a quantidade de vagas.</div><% end %>
      </div>
    </div>
  <% end %>

  <%= ax_field_grid do %>
    <div class="ax-span-6">
      <div class="wizard-field-group">
        <%= f.label :ocupacao, "Ocupação", class: "ax-label" %>
        <span class="required-star">*</span>
        <%= f.select :ocupacao, [["Desocupado", "Desocupado"], ["Inquilino", "Inquilino"], ["Proprietário", "Proprietário"]], { include_blank: "—" }, class: field_state.call(:ocupacao, "ax-control") %>
        <% if field_invalid.call(:ocupacao) %><div class="invalid-feedback d-block">Informe a ocupação.</div><% end %>
      </div>
    </div>
    <div class="ax-span-6">
      <div class="wizard-field-group">
        <%= f.label :situacao_imovel, "Situação", class: "ax-label" %>
        <span class="required-star">*</span>
        <%= f.select :situacao_imovel, [["Novo", "Novo"], ["Usado", "Usado"], ["Em construção", "Em construção"]], { include_blank: "—" }, class: field_state.call(:situacao_imovel, "ax-control") %>
        <% if field_invalid.call(:situacao_imovel) %><div class="invalid-feedback d-block">Informe a situação.</div><% end %>
      </div>
    </div>
  <% end %>

<% else  # terreno %>
  <%= ax_field_grid do %>
    <div class="ax-span-6">
      <div class="wizard-field-group">
        <%= f.label "extras[frente_metros]", "Frente (m)", class: "ax-label" %>
        <%= number_field_tag "captacao[extras][frente_metros]", @captacao.extras["frente_metros"], step: 0.1, inputmode: "decimal", class: "ax-control" %>
      </div>
    </div>
    <div class="ax-span-6">
      <div class="wizard-field-group">
        <%= f.label "extras[topografia]", "Topografia", class: "ax-label" %>
        <%= select_tag "captacao[extras][topografia]", options_for_select([["Plano", "plano"], ["Aclive", "aclive"], ["Declive", "declive"], ["Irregular", "irregular"]], @captacao.extras["topografia"]), include_blank: "—", class: "ax-control" %>
      </div>
    </div>
  <% end %>
  <div class="wizard-field-group">
    <%= f.label "extras[face]", "Face predominante", class: "ax-label" %>
    <%= select_tag "captacao[extras][face]", options_for_select(%w[Norte Sul Leste Oeste Nordeste Noroeste Sudeste Sudoeste], @captacao.extras["face"]), include_blank: "—", class: "ax-control" %>
  </div>
<% end %>

<% if features_imovel.any? %>
  <hr class="my-3">
  <div class="wizard-field-group">
    <label class="ax-label">Características do imóvel</label>
    <div class="<%= 'wizard-invalid-choice' if field_invalid.call(:caracteristicas_imovel) %>">
      <% features_imovel.each do |feat| %>
        <% selected = captacao_feature_selected?(@captacao.caracteristicas_imovel, feat) %>
        <label class="wizard-feature-chip <%= 'selected' if selected %>" data-controller="selectable-chip">
          <%= check_box_tag "captacao[caracteristicas_imovel][]", feat, selected, data: { action: "change->selectable-chip#sync" } %>
          <%= feat %>
        </label>
      <% end %>
    </div>
    <% if field_invalid.call(:caracteristicas_imovel) %><div class="invalid-feedback d-block">Marque ao menos uma característica.</div><% end %>
  </div>
<% end %>
