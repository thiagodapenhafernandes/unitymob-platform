<%
  kind = @captacao.property_kind.to_s
  fallback_features_imovel = case kind
                             when "residencial"
                               ["Armários nos quartos", "Cozinha planejada", "Ar-condicionado", "Aquecimento a gás",
                                "Fechadura digital", "Lavabo", "Piscina", "Churrasqueira", "Área de serviço"]
                             when "sala_comercial"
                               ["Ar-condicionado", "Recepção", "Sanitários", "Copa/cozinha", "Piso elevado", "Sprinklers",
                                "Sistema de segurança", "Divisórias prontas"]
                             else  # terreno
                               ["Murado", "Cercado", "Aterrado", "Com edificação", "Esquina", "Frente para mar"]
                             end

  features_imovel = captacao_feature_options(@internal_features, fallback_features_imovel, @captacao.caracteristicas_imovel)
%>

<h1 class="wizard-section-title"><i class="bi bi-rulers tw-text-primary"></i>Características do imóvel</h1>
<p class="wizard-section-subtitle">Campos variam por tipo de imóvel (<strong><%= kind.humanize %></strong>).</p>

<!-- Áreas (comum a todos) -->
<%= ax_field_grid do %>
  <div class="ax-span-6">
    <%= ax_number_field(form: f, method: :area_total,
          label: safe_join(["Área total (m²)", (tag.span("*", class: "required-star") if @captacao.property_kind_terreno?)].compact, " "),
          step: 0.01, inputmode: "decimal", class_name: "wizard-field-group", input_class: field_state.call(:area_total, nil)) %>
    <% if @captacao.property_kind_terreno? && field_invalid.call(:area_total) %><div class="invalid-feedback d-block">Informe a área total maior que zero.</div><% end %>
  </div>
  <% unless @captacao.property_kind_terreno? %>
    <div class="ax-span-6">
      <%= ax_number_field(form: f, method: :area_privativa,
            label: safe_join(["Área privativa (m²)", tag.span("*", class: "required-star")], " "),
            step: 0.01, inputmode: "decimal", class_name: "wizard-field-group", input_class: field_state.call(:area_privativa, nil)) %>
      <% if field_invalid.call(:area_privativa) %><div class="invalid-feedback d-block">Informe a área privativa maior que zero.</div><% end %>
    </div>
  <% end %>
<% end %>

<% if @captacao.property_kind_residencial? %>
  <%= ax_field_grid do %>
    <% [[:dormitorios, "Dormitórios", true], [:suites, "Suítes"], [:demi_suites, "Demi-suítes"]].each do |field, label, req| %>
      <div class="ax-span-4">
        <%= ax_number_field(form: f, method: field,
              label: safe_join([label, (tag.span("*", class: "required-star") if req)].compact, " "),
              min: 0, inputmode: "numeric", class_name: "wizard-field-group", input_class: field_state.call(field, nil)) %>
        <% if field_invalid.call(field) %><div class="invalid-feedback d-block">Campo obrigatório.</div><% end %>
      </div>
    <% end %>
  <% end %>

  <%= ax_field_grid do %>
    <div class="ax-span-4">
      <%= ax_number_field(form: f, method: :banheiros,
            label: safe_join(["Banheiros", tag.span("*", class: "required-star")], " "), min: 0, inputmode: "numeric",
            class_name: "wizard-field-group", input_class: field_state.call(:banheiros, nil)) %>
      <% if field_invalid.call(:banheiros) %><div class="invalid-feedback d-block">Informe a quantidade de banheiros.</div><% end %>
    </div>
    <div class="ax-span-4">
      <%= ax_number_field(form: f, method: :vagas_garagem,
            label: safe_join(["Vagas", tag.span("*", class: "required-star")], " "), min: 0, inputmode: "numeric",
            class_name: "wizard-field-group", input_class: field_state.call(:vagas_garagem, nil)) %>
      <% if field_invalid.call(:vagas_garagem) %><div class="invalid-feedback d-block">Informe a quantidade de vagas.</div><% end %>
    </div>
    <div class="ax-span-4">
      <%= ax_number_field(form: f, method: :salas, label: "Salas", min: 0, inputmode: "numeric",
            class_name: "wizard-field-group", input_class: field_state.call(:salas, nil)) %>
      <% if field_invalid.call(:salas) %><div class="invalid-feedback d-block">Informe a quantidade de salas/ambientes.</div><% end %>
    </div>
  <% end %>

  <% if @captacao.requires_parking_info? %>
    <%= ax_field_grid do %>
      <div class="ax-span-6">
        <%= ax_select_field(form: f, method: :tipo_vaga, label: "Tipo de vaga", choices: Habitation::VAGA_TYPES,
              select_options: { include_blank: "—" }, class_name: "wizard-field-group",
              html_options: { class: field_state.call(:tipo_vaga, "ax-control") }) %>
        <% if field_invalid.call(:tipo_vaga) %><div class="invalid-feedback d-block">Informe o tipo de vaga.</div><% end %>
      </div>
      <div class="ax-span-6">
        <%= ax_text_field(form: f, method: :numero_box, label: "Box", field_class: "wizard-field-group",
              class: field_state.call(:numero_box), placeholder: "Ex.: 12") %>
        <% if field_invalid.call(:numero_box) %><div class="invalid-feedback d-block">Informe o box da vaga.</div><% end %>
      </div>
    <% end %>
  <% end %>

  <%= ax_field_grid do %>
    <div class="ax-span-4">
      <%= ax_select_field(form: f, method: :ocupacao,
            label: safe_join(["Ocupação", tag.span("*", class: "required-star")], " "),
            choices: [["Desocupado", "Desocupado"], ["Inquilino", "Inquilino"], ["Proprietário", "Proprietário"]],
            select_options: { include_blank: "—" }, class_name: "wizard-field-group",
            html_options: { class: field_state.call(:ocupacao, "ax-control") }) %>
      <% if field_invalid.call(:ocupacao) %><div class="invalid-feedback d-block">Informe a ocupação.</div><% end %>
    </div>
    <div class="ax-span-4">
      <%= ax_select_field(form: f, method: :estado_imovel, label: "Estado",
            choices: [["Ótimo", "otimo"], ["Bom", "bom"], ["Regular", "regular"]],
            select_options: { include_blank: "—" }, class_name: "wizard-field-group") %>
    </div>
    <div class="ax-span-4">
      <%= ax_select_field(form: f, method: :situacao_imovel,
            label: safe_join(["Situação", tag.span("*", class: "required-star")], " "),
            choices: [["Em construção", "Em construção"], ["Novo", "Novo"], ["Usado", "Usado"]],
            select_options: { include_blank: "—" }, class_name: "wizard-field-group",
            html_options: { class: field_state.call(:situacao_imovel, "ax-control") }) %>
      <% if field_invalid.call(:situacao_imovel) %><div class="invalid-feedback d-block">Informe a situação.</div><% end %>
    </div>
  <% end %>

  <%= ax_field_grid(class_name: "wizard-switch-grid") do %>
    <% [[:sacada, "Sacada"], [:terraco, "Terraço"], [:dependencia_empregada, "Dep. empregada"], [:precisa_reforma, "Precisa reforma"]].each do |field, label| %>
      <div class="ax-span-6">
        <%= ax_switch_field(label: label, form: f, method: field, class_name: "wizard-switch") %>
      </div>
    <% end %>
  <% end %>

<% elsif @captacao.property_kind_sala_comercial? %>
  <%= ax_field_grid do %>
    <div class="ax-span-4">
      <%= ax_number_field(form: f, method: :salas, label: "Salas/Ambientes", min: 0,
            inputmode: "numeric", class_name: "wizard-field-group") %>
    </div>
    <div class="ax-span-4">
      <%= ax_number_field(form: f, method: :banheiros, label: "Banheiros", min: 0,
            inputmode: "numeric", class_name: "wizard-field-group") %>
    </div>
    <div class="ax-span-4">
      <%= ax_number_field(form: f, method: :vagas_garagem, label: "Vagas", min: 0,
            inputmode: "numeric", class_name: "wizard-field-group", input_class: field_state.call(:vagas_garagem, nil)) %>
    </div>
  <% end %>

  <%= ax_field_grid do %>
    <div class="ax-span-6">
      <%= ax_select_field(form: f, method: :ocupacao,
            label: safe_join(["Ocupação", tag.span("*", class: "required-star")], " "),
            choices: [["Desocupado", "Desocupado"], ["Inquilino", "Inquilino"], ["Proprietário", "Proprietário"]],
            select_options: { include_blank: "—" }, class_name: "wizard-field-group",
            html_options: { class: field_state.call(:ocupacao, "ax-control") }) %>
      <% if field_invalid.call(:ocupacao) %><div class="invalid-feedback d-block">Informe a ocupação.</div><% end %>
    </div>
    <div class="ax-span-6">
      <%= ax_select_field(form: f, method: :situacao_imovel,
            label: safe_join(["Situação", tag.span("*", class: "required-star")], " "),
            choices: [["Novo", "Novo"], ["Usado", "Usado"], ["Em construção", "Em construção"]],
            select_options: { include_blank: "—" }, class_name: "wizard-field-group",
            html_options: { class: field_state.call(:situacao_imovel, "ax-control") }) %>
      <% if field_invalid.call(:situacao_imovel) %><div class="invalid-feedback d-block">Informe a situação.</div><% end %>
    </div>
  <% end %>

<% else  # terreno %>
  <%= ax_field_grid do %>
    <div class="ax-span-6">
      <%= ax_standalone_field(name: "captacao[extras][frente_metros]", id: "captacao_extras_frente_metros",
            label: "Frente (m)", value: @captacao.extras["frente_metros"], type: :number,
            class_name: "wizard-field-group", step: 0.1, inputmode: "decimal") %>
    </div>
    <div class="ax-span-6">
      <%= ax_standalone_select_field(name: "captacao[extras][topografia]", id: "captacao_extras_topografia",
            label: "Topografia", choices: [["Plano", "plano"], ["Aclive", "aclive"], ["Declive", "declive"], ["Irregular", "irregular"]],
            selected: @captacao.extras["topografia"], include_blank: "—", class_name: "wizard-field-group") %>
    </div>
  <% end %>
  <%= ax_standalone_select_field(name: "captacao[extras][face]", id: "captacao_extras_face",
        label: "Face predominante", choices: %w[Norte Sul Leste Oeste Nordeste Noroeste Sudeste Sudoeste],
        selected: @captacao.extras["face"], include_blank: "—", class_name: "wizard-field-group") %>
<% end %>

<% if features_imovel.any? %>
  <hr class="my-3">
  <div class="wizard-field-group">
    <label class="ax-label">Características do imóvel</label>
    <div class="wizard-choice-panel wizard-choice-panel--boxed wizard-choice-panel--scroll <%= 'wizard-invalid-choice' if field_invalid.call(:caracteristicas_imovel) %>">
      <% features_imovel.each do |feat| %>
        <% selected = captacao_feature_selected?(@captacao.caracteristicas_imovel, feat) %>
        <label class="wizard-feature-chip <%= 'selected' if selected %>" data-controller="selectable-chip">
          <%= check_box_tag "captacao[caracteristicas_imovel][]", feat, selected, data: { action: "change->selectable-chip#sync" } %>
          <%= feat %>
        </label>
      <% end %>
    </div>
    <% if field_invalid.call(:caracteristicas_imovel) %><div class="invalid-feedback d-block">Marque ao menos uma característica.</div><% end %>
  </div>
<% end %>
