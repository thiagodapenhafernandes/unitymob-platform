<div class="wizard-top-bar">
  <div class="wizard-shell wizard-start-shell">
    <div class="d-flex align-items-center gap-2 mb-2">
      <%= link_to admin_captacoes_path, class: "btn btn-sm btn-link text-muted p-0 text-decoration-none" do %>
        <i class="bi bi-arrow-left"></i>
      <% end %>
      <div class="small text-muted flex-grow-1">
        Nova captação · <strong class="text-dark">Definição inicial</strong>
      </div>
      <span class="badge bg-light text-dark border">Sem rascunho criado</span>
    </div>
    <div class="wizard-progress">
      <div class="wizard-progress-bar" style="width: 0%;"></div>
    </div>
  </div>
</div>

<main class="wizard-shell wizard-content wizard-start-page">
  <div class="alert alert-info border-0 shadow-sm small">
    <i class="bi bi-info-circle-fill me-1"></i>
    O rascunho e o código do imóvel só serão criados quando você clicar em <strong>Iniciar captação</strong>.
  </div>

  <%= form_with model: @captacao,
                url: admin_captacoes_path,
                method: :post,
                local: true,
                html: { id: "wizard-form", class: "wizard-start-form" } do |f| %>
    <%= render "admin/captacoes/steps/intro", f: f %>

    <div class="wizard-bottom-nav">
      <div class="wizard-shell wizard-start-shell d-flex gap-2">
        <%= link_to admin_captacoes_path, class: "btn btn-outline-secondary flex-fill" do %>
          Cancelar
        <% end %>
        <%= button_tag type: :submit, class: "btn btn-primary flex-fill" do %>
          Iniciar captação<i class="bi bi-arrow-right ms-1"></i>
        <% end %>
      </div>
    </div>
  <% end %>
</main>
