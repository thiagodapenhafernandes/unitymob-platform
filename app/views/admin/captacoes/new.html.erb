<div class="wizard-top-bar">
  <div class="wizard-shell wizard-start-shell">
    <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
      <%= link_to admin_captacoes_path,
                  class: "ax-icon-btn wizard-back-link",
                  title: "Voltar para captações",
                  aria: { label: "Voltar para captações" } do %>
        <i class="bi bi-arrow-left"></i>
      <% end %>
      <div class="wizard-top-bar__summary tw-text-sm tw-text-ink-muted">
        Nova captação · <strong class="text-dark">Definição inicial</strong>
      </div>
      <span class="ax-badge ax-badge--gray">Sem rascunho criado</span>
    </div>
    <%= ax_progress(value: 0, class_name: "wizard-progress", label: "Progresso da captação: 0%") %>
  </div>
</div>

<main class="wizard-shell wizard-content wizard-start-page">
  <%= ax_inline_notice(tone: :info, icon: "info-circle-fill") do %>
    O rascunho e o código do imóvel só serão criados quando você clicar em <strong>Iniciar captação</strong>.
  <% end %>

  <%= form_with model: @captacao,
                url: admin_captacoes_path,
                method: :post,
                local: true,
                html: { id: "wizard-form", class: "wizard-start-form" } do |f| %>
    <%= render "admin/captacoes/steps/intro", f: f %>

    <div class="wizard-bottom-nav">
      <div class="wizard-shell wizard-start-shell tw-flex tw-gap-2">
        <%= link_to admin_captacoes_path, class: "ax-btn ax-btn--ghost wizard-nav-action" do %>
          Cancelar
        <% end %>
        <%= button_tag type: :submit, class: "ax-btn ax-btn--primary wizard-nav-action" do %>
          Iniciar captação<i class="bi bi-arrow-right"></i>
        <% end %>
      </div>
    </div>
  <% end %>
</main>
