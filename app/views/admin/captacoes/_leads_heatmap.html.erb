<div class="ax-card capt-heatmap-card">
  <div class="ax-card__body">
    <div class="capt-heatmap-toolbar">
      <h6 class="tw-font-bold tw-flex tw-items-center tw-gap-2"><i class="bi bi-grid-3x3-gap-fill tw-text-primary"></i>Leads por Corretor</h6>
      <%= form_with url: dashboard_admin_captacoes_path, method: :get, local: true, class: "capt-heatmap-filters", data: { controller: "auto-submit" } do %>
        <%= hidden_field_tag :start_date, @period_start %>
        <%= hidden_field_tag :end_date,   @period_end %>
        <%= hidden_field_tag :month,      @month_filter %>
        <div class="capt-heatmap-date-field">
          <%= ax_field_label(nil, nil, text: "Início") %>
          <%= date_field_tag :heatmap_start_date, @heatmap_start_date, class: "ax-control ax-control--sm" %>
        </div>
        <div class="capt-heatmap-date-field">
          <%= ax_field_label(nil, nil, text: "Fim") %>
          <%= date_field_tag :heatmap_end_date, @heatmap_end_date, class: "ax-control ax-control--sm" %>
        </div>
        <%= select_tag :lead_category,
                       options_for_select([["Categoria: Todos", ""]] + @lead_categories.map { |c| [c.to_s.humanize, c] }, params[:lead_category]),
                       class: "ax-control ax-control--sm", data: { action: "change->auto-submit#submit" } %>
        <%= select_tag :lead_source,
                       options_for_select([["Fonte: Todos", ""]] + @lead_sources.map { |s| [s.to_s, s] }, params[:lead_source]),
                       class: "ax-control ax-control--sm", data: { action: "change->auto-submit#submit" } %>
        <%= submit_tag "Aplicar", class: "ax-btn ax-btn--primary ax-btn--sm" %>
        <% if params[:lead_category].present? || params[:lead_source].present? || params[:heatmap_start_date].present? || params[:heatmap_end_date].present? %>
          <%= link_to "Limpar", dashboard_admin_captacoes_path(start_date: @period_start, end_date: @period_end, month: @month_filter), class: "ax-btn ax-btn--ghost ax-btn--sm" %>
        <% end %>
      <% end %>
    </div>

    <% if @heatmap_corretores.any? %>
      <div class="heatmap-wrap">
        <table class="heatmap-table">
          <thead>
            <tr>
              <th class="broker-col">Corretor</th>
              <% @heatmap_dates.each do |d| %>
                <th><%= d.strftime("%d/%m") %></th>
              <% end %>
              <th>Total</th>
            </tr>
          </thead>
          <tbody>
            <% @heatmap_corretores.each do |user| %>
              <% user_total = @heatmap_matrix[user.id].values.sum %>
              <tr>
                <th class="broker-col"><%= user.name %></th>
                <% @heatmap_dates.each do |d| %>
                  <% count = @heatmap_matrix[user.id][d] %>
                  <% if count.zero? %>
                    <td class="tw-text-ink-muted">·</td>
                  <% else %>
                    <% intensity = @heatmap_max.positive? ? (count.to_f / @heatmap_max) : 0 %>
                    <% alpha = 0.25 + (intensity * 0.75) %>
                    <td class="hc" style="background-color: rgba(245,130,32,<%= alpha.round(2) %>);">
                      <%= count %>
                    </td>
                  <% end %>
                <% end %>
                <td class="tw-font-bold"><%= user_total %></td>
              </tr>
            <% end %>
          </tbody>
          <tfoot>
            <tr>
              <td class="broker-col">Total</td>
              <% @heatmap_dates.each do |d| %>
                <% col_total = @heatmap_corretores.sum { |u| @heatmap_matrix[u.id][d] } %>
                <td><%= col_total.zero? ? "·" : col_total %></td>
              <% end %>
              <% grand_total = @heatmap_corretores.sum { |u| @heatmap_matrix[u.id].values.sum } %>
              <td class="tw-text-primary"><%= grand_total %></td>
            </tr>
          </tfoot>
        </table>
      </div>
    <% else %>
      <div class="capt-heatmap-empty">
        <i class="bi bi-inbox"></i>
        <p class="tw-mt-2">Nenhum lead atribuído a corretor no período.</p>
      </div>
    <% end %>
  </div>
</div>
