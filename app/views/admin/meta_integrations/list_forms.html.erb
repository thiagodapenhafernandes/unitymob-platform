<turbo-frame id="<%= @frame_id %>">
  <% if @forms.any? %>
    <% if @page_number == 1 %>
      <div class="tw-flex tw-justify-between tw-items-center tw-mt-2 tw-mb-1">
        <span class="tw-text-2xs tw-text-ink-muted">
          Exibindo <strong><%= [@forms_per_page, @forms_total_count].min %></strong> de <strong><%= @forms_total_count %></strong> formulários
        </span>
      </div>
    <% end %>

    <div class="ax-record-list tw-mt-2">
      <% @forms.each do |form| %>
        <%= ax_record_item(
              title: form.name,
              meta: form.facebook_created_at&.strftime("%d/%m, %H:%M"),
              icon: "file-earmark-text"
            ) %>
      <% end %>
    </div>

    <% if @next_page %>
      <% next_frame_id = "page_forms_#{@page.id}_page_#{@next_page}" %>
      <turbo-frame id="<%= next_frame_id %>"
                   src="<%= list_forms_admin_meta_integrations_path(page_id: @page.id, page: @next_page) %>"
                   loading="lazy">
        <div class="tw-flex tw-items-center tw-justify-center tw-gap-2 tw-py-3 tw-text-primary" role="status" aria-live="polite">
          <span class="ax-spinner" aria-hidden="true"></span>
          <span class="tw-text-2xs">Carregando mais formulários...</span>
        </div>
      </turbo-frame>
    <% end %>
  <% else %>
    <%= ax_empty_state(
          title: "Nenhum formulário encontrado",
          description: "Esta página ainda não possui formulários sincronizados.",
          icon: "file-earmark-x",
          compact: true
        ) %>
  <% end %>
</turbo-frame>
