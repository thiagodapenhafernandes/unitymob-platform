<div id="meta_sync_status" class="w-100">
  <% if integration&.sync_status == 'processing' %>
    <div class="mb-4">
      <div class="d-flex justify-content-between align-items-center mb-2">
        <span class="small fw-bold text-primary">
          <i class="bi bi-arrow-repeat fa-spin me-1"></i> <%= integration.sync_message || "Sincronizando Páginas e Formulários..." %>
        </span>
        <span class="badge bg-primary rounded-pill"><%= integration.sync_progress || 0 %>%</span>
      </div>
      <div class="progress" style="height: 10px; border-radius: 5px; background-color: #e9ecef;">
        <div class="progress-bar progress-bar-striped progress-bar-animated shadow-sm" 
             role="progressbar" 
             style="width: <%= integration.sync_progress || 0 %>%; background-color: #6366f1;" 
             aria-valuenow="<%= integration.sync_progress || 0 %>" 
             aria-valuemin="0" 
             aria-valuemax="100"></div>
      </div>
      <p class="extra-small text-muted mt-2 mb-0">Esta operação pode levar alguns minutos. Não feche esta página para acompanhar o progresso.</p>
    </div>
  <% elsif integration&.sync_status == 'completed' %>
    <div class="alert alert-success d-flex align-items-center mb-4 py-2 px-3 border-0 shadow-sm" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i>
      <div class="small fw-bold">Sincronização concluída com sucesso!</div>
    </div>
  <% elsif integration&.sync_status == 'failed' %>
    <div class="alert alert-danger d-flex align-items-center mb-4 py-2 px-3 border-0 shadow-sm" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i>
      <div class="small fw-bold">Erro na sincronização. Tente novamente em instantes.</div>
    </div>
  <% end %>
</div>
