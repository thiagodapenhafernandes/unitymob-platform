<div id="meta_sync_status" class="tw-w-full">
  <% if integration&.sync_status == 'processing' %>
    <div class="tw-mb-4">
      <div class="tw-flex tw-justify-between tw-items-center tw-mb-2">
        <span class="tw-text-sm tw-font-bold tw-text-primary tw-gap-1 tw-inline-flex tw-items-center">
          <i class="bi bi-arrow-repeat fa-spin"></i> <%= integration.sync_message || "Sincronizando Páginas e Formulários..." %>
        </span>
        <span class="ax-badge ax-badge--blue"><%= integration.sync_progress || 0 %>%</span>
      </div>
      <div class="progress" style="height: 10px; border-radius: 5px; background-color: #e9ecef;">
        <div class="progress-bar progress-bar-striped progress-bar-animated"
             role="progressbar" 
             style="width: <%= integration.sync_progress || 0 %>%; background-color: #6366f1;" 
             aria-valuenow="<%= integration.sync_progress || 0 %>" 
             aria-valuemin="0" 
             aria-valuemax="100"></div>
      </div>
      <p class="extra-small tw-text-ink-muted tw-mt-2">Esta operação pode levar alguns minutos. Não feche esta página para acompanhar o progresso.</p>
    </div>
  <% elsif integration&.sync_status == 'completed' %>
    <%= ax_inline_notice(tone: :success, icon: "check-circle-fill") do %>
      <div class="tw-text-sm tw-font-bold">Sincronização concluída com sucesso!</div>
    <% end %>
  <% elsif integration&.sync_status == 'failed' %>
    <%= ax_inline_notice(tone: :danger, icon: "exclamation-triangle-fill") do %>
      <div class="tw-text-sm tw-font-bold">Erro na sincronização. Tente novamente em instantes.</div>
    <% end %>
  <% end %>
</div>
