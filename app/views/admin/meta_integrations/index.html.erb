<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-1 text-gray-800">Integração Meta Ads</h1>
    <p class="text-muted small mb-0">Conecte sua conta do Facebook para receber leads automaticamente.</p>
  </div>
  <% if @integration %>
    <%= turbo_stream_from "meta_sync_#{@integration.id}" %>
    
    <%= button_to disconnect_admin_meta_integrations_path, method: :delete, class: "btn btn-outline-danger", data: { confirm: "Tem certeza? Isso irá parar a importação de leads." } do %>
      <i class="bi bi-box-arrow-right me-1"></i> Desconectar Conta
    <% end %>
  <% end %>
</div>

<div class="row g-4">
  <div class="col-lg-8">
    <%= render "sync_status", integration: @integration %>
    <div class="card shadow-sm border-0 mb-4">
      <div class="card-header bg-white py-3">
        <h5 class="card-title mb-0 fw-bold"><i class="bi bi-facebook me-2 text-primary"></i>Conexão Facebook</h5>
      </div>
      <div class="card-body p-4">
        <% if @integration %>
          <div class="d-flex align-items-center mb-4 p-3 bg-light rounded-3 border border-success border-opacity-25">
             <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
               <i class="bi bi-person-fill fs-4"></i>
             </div>
             <div>
               <h6 class="fw-bold mb-0">Conectado como <%= @integration.name %></h6>
               <small class="text-muted"><%= @integration.email %></small>
             </div>
             <div class="ms-auto text-end">
               <div class="text-success fw-bold small d-flex align-items-center justify-content-end mb-1">
                 <i class="bi bi-check-circle-fill me-1"></i> Ativo
               </div>
               <span class="badge bg-success-subtle text-success border-0 rounded-pill px-2 py-1" style="font-size: 0.65rem;">
                 Token de Longo Prazo
               </span>
             </div>
          </div>

          <div class="d-flex justify-content-between align-items-center mb-3">
            <h6 class="fw-bold text-muted text-uppercase small mb-0">Suas Páginas</h6>
            <%= button_to sync_pages_admin_meta_integrations_path, class: "btn btn-sm btn-premium rounded-pill px-3" do %>
              <i class="bi bi-arrow-repeat me-1"></i> Sincronizar Páginas
            <% end %>
          </div>

          <div class="card-body p-0">
            <div class="list-group list-group-flush">
              <% @pages.each do |page| %>
                <div class="list-group-item p-3 border-bottom">
                  <details class="meta-page-details">
                    <summary class="d-flex justify-content-between align-items-center cursor-pointer list-unstyled" style="cursor: pointer;">
                      <div class="d-flex align-items-center">
                        <div class="bg-light rounded-circle p-2 me-3">
                          <i class="bi bi-facebook text-primary fs-5"></i>
                        </div>
                        <div>
                          <h6 class="mb-0 fw-bold"><%= page.name %></h6>
                          <span class="extra-small text-muted"><%= page.category %></span>
                        </div>
                      </div>
                      <div class="d-flex align-items-center gap-2">
                        <% if page.active %>
                          <span class="badge badge-soft-success">Webhook Ativo</span>
                        <% end %>
                        <i class="bi bi-chevron-down text-muted small transition-icon"></i>
                      </div>
                    </summary>

                    <div class="mt-3 bg-light p-3 rounded-3 border-dashed-info">
                      <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="small fw-bold"><i class="bi bi-file-earmark-text me-1"></i> Formulários Vinculados</span>
                      </div>
                      
                      <turbo-frame id="page_forms_<%= page.id %>" src="<%= list_forms_admin_meta_integrations_path(page_id: page.id) %>" loading="lazy">
                        <div class="d-flex justify-content-center py-3">
                          <div class="spinner-border spinner-border-sm text-primary" role="status">
                            <span class="visually-hidden">Carregando...</span>
                          </div>
                        </div>
                      </turbo-frame>
                    </div>
                  </details>
                </div>
              <% end %>
              
              <% if @pages.empty? %>
                <div class="p-5 text-center">
                  <div class="mb-3">
                    <i class="bi bi-journal-x fs-1 text-muted"></i>
                  </div>
                  <h6 class="text-muted">Nenhuma página sincronizada.</h6>
                  <p class="small text-muted mb-0">Clique em "Sincronizar Páginas" para buscar suas páginas do Facebook.</p>
                </div>
              <% end %>
            </div>
          </div>

        <% else %>
          <div class="text-center py-5">
            <div class="mb-4">
              <i class="bi bi-facebook text-primary" style="font-size: 3.5rem;"></i>
            </div>
            <h5 class="fw-bold mb-3">Conecte sua conta do Facebook</h5>
            <p class="text-muted mb-4 col-md-8 mx-auto">
              Integre suas Páginas e Formulários de Lead Ads para receber leads automaticamente no CRM e distribuí-los para sua equipe.
            </p>
            
            <%= button_to admin_user_facebook_omniauth_authorize_path, method: :post, data: { turbo: false }, class: "btn btn-premium btn-lg rounded-pill px-5 fw-bold shadow-sm d-inline-flex align-items-center" do %>
              <i class="bi bi-facebook me-2"></i> Continuar com Facebook
            <% end %>
            
            <p class="mt-3 text-muted small" style="font-size: 0.75rem;">
              Se não conseguir conectar, fale com o suporte técnico para revisar as credenciais da integração.
            </p>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card shadow-sm border-0 mb-4 bg-primary text-white">
      <div class="card-body p-4">
        <h5 class="fw-bold mb-3"><i class="bi bi-info-circle me-2"></i>Como funciona?</h5>
        <ol class="small ps-3 mb-0">
          <li class="mb-2">Clique em "Continuar com Facebook" e autorize as permissões.</li>
          <li class="mb-2">Sincronize as páginas que você deseja monitorar.</li>
          <li class="mb-2">Sincronize os formulários de cada página.</li>
          <li>Configure as <strong>Regras de Distribuição</strong> selecionando a fonte "Meta Ads".</li>
        </ol>
      </div>
    </div>

    <div class="card shadow-sm border-0">
      <div class="card-body p-4">
        <h6 class="fw-bold mb-3"><i class="bi bi-shield-check me-2 text-success"></i>Segurança</h6>
        <p class="small text-muted mb-0">
          Utilizamos tokens de acesso oficiais da Meta Graph API. Seus dados de login não são armazenados em nossos servidores, apenas o token de integração.
        </p>
      </div>
    </div>
  </div>
</div>
