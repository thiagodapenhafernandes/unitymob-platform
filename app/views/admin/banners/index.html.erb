<%# Banners — listagem compacta (.ax-*). Original em index.html.erb.bootstrap-bak %>
<div class="public-site-workspace">
<%= ax_workspace_heading(eyebrow: "Site público · Conteúdo", icon: "image", title: "Banners", subtitle: "Gerencie mídia, posição e publicação dos banners.", metrics: [{ value: (@banners.total_entries rescue @banners.count), label: "banners" }], actions: ax_button("Novo banner", new_admin_banner_path, variant: :primary, size: :sm, icon: "plus-lg")) %>

<div class="ax-table-wrap">
  <table class="ax-table">
    <caption>Banners configurados para o site público desta conta</caption>
    <thead>
      <tr>
        <th scope="col" class="ax-table__col--md">Preview</th>
        <th scope="col">Informações</th>
        <th scope="col" class="ax-table__col--w-220">Localização</th>
        <th scope="col" class="ax-num ax-table__col--w-80">Ordem</th>
        <th scope="col" class="ax-table__col--sm">Status</th>
        <th scope="col" class="ax-num ax-table__col--compact">Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @banners.each do |banner| %>
        <tr>
          <td>
            <%= ax_media_preview(
                  image: (banner.image_desktop if banner.image_desktop.attached?),
                  size: :thumbnail,
                  empty_text: nil
                ) %>
          </td>
          <td>
            <div class="ax-strong"><%= banner.title %></div>
            <% if banner.description.present? %><div class="tw-text-2xs tw-text-ink-faint"><%= truncate(banner.description, length: 70) %></div><% end %>
          </td>
          <td>
            <% if banner.positions.present? %>
              <div class="tw-flex tw-flex-wrap tw-gap-1">
                <% banner.positions.each do |pos| %><%= ax_badge(Banner::POSITIONS[pos] || pos.humanize, tone: :blue) %><% end %>
              </div>
            <% else %><%= ax_badge("Não definido", tone: :gray) %><% end %>
          </td>
          <td class="ax-num ax-strong">#<%= banner.display_order %></td>
          <td>
            <%= ax_badge(banner.active? ? "Ativo" : "Inativo", tone: banner.active? ? :green : :gray, dot: true) %>
          </td>
          <td class="ax-num">
            <span class="tw-inline-flex tw-gap-0.5">
              <%= ax_icon_button(label: "Ver banner #{banner.title}", icon: "eye", url: admin_banner_path(banner), variant: :ghost) %>
              <%= ax_icon_button(label: "Editar banner #{banner.title}", icon: "pencil", url: edit_admin_banner_path(banner), variant: :ghost) %>
              <%= ax_icon_button(label: "Remover banner #{banner.title}", icon: "trash", url: admin_banner_path(banner), variant: :ghost, data: { turbo_method: :delete, turbo_confirm: "Confirmar exclusão deste banner?" }) %>
            </span>
          </td>
        </tr>
      <% end %>

      <% if @banners.empty? %>
        <tr>
          <td colspan="6"><%= ax_empty_state(title: "Nenhum banner encontrado", description: "Cadastre um banner para começar a publicar mídia no site.", icon: "image-fill", compact: true) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
</div>

<% if @banners.respond_to?(:total_pages) && @banners.total_pages > 1 %>
  <%= ax_pagination @banners, params: request.query_parameters %>
<% end %>
