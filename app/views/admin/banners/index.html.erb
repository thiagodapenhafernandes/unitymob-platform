<%# Banners — listagem compacta (.ax-*). Original em index.html.erb.bootstrap-bak %>
<div class="tw-flex tw-flex-wrap tw-items-center tw-justify-between tw-gap-3 tw-mb-4">
  <div>
    <h1 class="ax-page-title">Banners Institucionais</h1>
    <p class="ax-page-subtitle">Gerencie os banners rotativos e de destaque das páginas. Total: <%= @banners.total_entries rescue @banners.count %>.</p>
  </div>
  <%= link_to new_admin_banner_path, class: "ax-btn ax-btn--sm ax-btn--primary" do %>
    <i class="bi bi-plus-lg ax-ico"></i><span>Novo banner</span>
  <% end %>
</div>

<div class="ax-table-wrap">
  <table class="ax-table">
    <thead>
      <tr>
        <th style="width:110px">Preview</th>
        <th>Informações</th>
        <th style="width:220px">Localização</th>
        <th class="ax-num" style="width:80px">Ordem</th>
        <th style="width:96px">Status</th>
        <th class="ax-num" style="width:90px">Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @banners.each do |banner| %>
        <tr>
          <td>
            <% if banner.image_desktop.attached? %>
              <img src="<%= url_for(banner.image_desktop) %>" class="tw-rounded tw-border tw-border-line" style="width:88px;height:50px;object-fit:cover;">
            <% else %>
              <div class="tw-flex tw-items-center tw-justify-center tw-rounded tw-border tw-border-line tw-bg-surface-soft tw-text-ink-faint" style="width:88px;height:50px;"><i class="bi bi-image"></i></div>
            <% end %>
          </td>
          <td>
            <div class="ax-strong"><%= banner.title %></div>
            <% if banner.description.present? %><div class="tw-text-2xs tw-text-ink-faint"><%= truncate(banner.description, length: 70) %></div><% end %>
          </td>
          <td>
            <% if banner.positions.present? %>
              <div class="tw-flex tw-flex-wrap tw-gap-1">
                <% banner.positions.each do |pos| %><span class="ax-badge ax-badge--blue"><%= Banner::POSITIONS[pos] || pos.humanize %></span><% end %>
              </div>
            <% else %><span class="ax-badge ax-badge--gray">Não definido</span><% end %>
          </td>
          <td class="ax-num ax-strong">#<%= banner.display_order %></td>
          <td>
            <% if banner.active? %><span class="ax-badge ax-badge--green ax-badge--dot">Ativo</span>
            <% else %><span class="ax-badge ax-badge--gray ax-badge--dot">Inativo</span><% end %>
          </td>
          <td class="ax-num">
            <span class="tw-inline-flex tw-gap-0.5">
              <%= link_to admin_banner_path(banner), class: "ax-ico-btn", title: "Ver" do %><i class="bi bi-eye"></i><% end %>
              <%= link_to edit_admin_banner_path(banner), class: "ax-ico-btn", title: "Editar" do %><i class="bi bi-pencil"></i><% end %>
              <%= link_to admin_banner_path(banner), data: { turbo_method: :delete, turbo_confirm: "Confirmar exclusão deste banner?" }, class: "ax-ico-btn", title: "Remover" do %><i class="bi bi-trash"></i><% end %>
            </span>
          </td>
        </tr>
      <% end %>

      <% if @banners.empty? %>
        <tr><td colspan="6"><div class="ax-empty">
          <i class="bi bi-image-fill tw-text-2xl tw-block tw-mb-2 tw-text-ink-faint"></i>Nenhum banner encontrado.
        </div></td></tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if @banners.respond_to?(:total_pages) && @banners.total_pages > 1 %>
  <%= ax_pagination @banners, params: request.query_parameters %>
<% end %>
