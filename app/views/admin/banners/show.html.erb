<div class="public-site-workspace">
  <%= ax_workspace_heading(
        eyebrow: "Site público · Banners",
        icon: "eye",
        title: @banner.title,
        pills: [@banner.active? ? "Ativo" : "Inativo"],
        subtitle: "Mídia, destino e posições de exibição.",
        actions: safe_join([
          ax_button("Voltar", admin_banners_path, variant: :ghost, size: :sm, icon: "arrow-left"),
          ax_button("Editar", edit_admin_banner_path(@banner), variant: :primary, size: :sm, icon: "pencil-square")
        ])
      ) %>

  <%= ax_operational_panel(eyebrow: "Mídia", title: "Pré-visualização do banner") do %>
    <div class="ax-media-preview-grid">
      <%= ax_media_preview(
            label: "Preview desktop",
            icon: "pc-display",
            image: (@banner.image_desktop if @banner.image_desktop.attached?),
            variant: :desktop,
            empty_text: "Sem imagem desktop"
          ) %>
      <%= ax_media_preview(
            label: "Preview mobile",
            icon: "phone",
            image: (@banner.image_mobile if @banner.image_mobile.attached?),
            variant: :mobile,
            empty_text: "Sem imagem mobile"
          ) %>
    </div>
  <% end %>

  <div class="tw-mt-3">
    <%= ax_operational_panel(eyebrow: "Cadastro", title: "Dados detalhados") do %>
      <%= ax_field_grid do %>
        <div class="ax-span-3">
          <%= ax_record_item(title: @banner.title, eyebrow: "Título", icon: "type") %>
        </div>
        <div class="ax-span-3">
          <%= ax_record_item(
                title: @banner.active? ? "Banner ativo" : "Banner inativo",
                eyebrow: "Status",
                icon: @banner.active? ? "check-circle" : "pause-circle",
                actions: ax_badge(@banner.active? ? "Ativo" : "Inativo", tone: @banner.active? ? :green : :gray, dot: true)
              ) %>
        </div>
        <div class="ax-span-3">
          <%= ax_record_item(title: "Posição ##{@banner.display_order}", eyebrow: "Ordem", icon: "sort-numeric-down") %>
        </div>
        <div class="ax-span-3">
          <% link_action = if @banner.link_url.present?
                             ax_button(@banner.link_text.presence || "Acessar link", @banner.link_url, variant: :ghost, size: :sm, icon: "box-arrow-up-right", target: "_blank", rel: "noopener")
                           end %>
          <%= ax_record_item(
                title: @banner.link_url.presence || "Nenhum configurado",
                eyebrow: "Link externo",
                icon: "link-45deg",
                actions: link_action
              ) %>
        </div>
        <div class="ax-span-6">
          <%= ax_record_item(
                title: @banner.description.presence || "Sem descrição",
                eyebrow: "Descrição",
                icon: "text-paragraph"
              ) %>
        </div>
        <div class="ax-span-6">
          <%= ax_record_item(
                title: @banner.positions.present? ? "#{@banner.positions.size} posição(ões)" : "Nenhuma posição definida",
                eyebrow: "Posições de exibição",
                icon: "geo-alt-fill",
                body: safe_join(Array(@banner.positions).map { |position| ax_badge(Banner::POSITIONS[position] || position.humanize, tone: :blue) }, " ")
              ) %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
