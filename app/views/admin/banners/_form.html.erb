<div class="public-site-workspace">
<%= ax_workspace_heading(eyebrow: "Site público · Banners", icon: "image", title: @banner.persisted? ? "Editar banner" : "Novo banner", pills: [(@banner.active? ? "Ativo" : "Inativo")], subtitle: "Gerencie mídia, destino, posição e publicação.", actions: ax_button("Voltar", admin_banners_path, variant: :ghost, size: :sm, icon: "arrow-left")) %>

<%= form_with(model: [:admin, @banner], local: true, class: "admin-form") do |f| %>
  <%= ax_error_summary(@banner) %>

  <%= ax_field_grid do %>
    <div class="ax-span-8">
      <%= ax_operational_panel(eyebrow: "Mídia", title: "Cadastro de mídia") do %>
          <div class="ax-media-preview-grid tw-mb-4">
            <%= ax_media_preview(
                  label: "Imagem desktop",
                  icon: "pc-display",
                  image: (@banner.image_desktop if @banner.image_desktop.attached?),
                  variant: :desktop,
                  size: :compact,
                  empty_text: "Sem imagem desktop"
                ) do %>
              <%= ax_file_field(form: f, method: :image_desktop, label: "Alterar desktop", accept: "image/*", button_label: "Escolher imagem") %>
            <% end %>
            <%= ax_media_preview(
                  label: "Imagem mobile",
                  icon: "phone",
                  image: (@banner.image_mobile if @banner.image_mobile.attached?),
                  variant: :mobile,
                  size: :compact,
                  empty_text: "Sem imagem mobile"
                ) do %>
              <%= ax_file_field(form: f, method: :image_mobile, label: "Alterar mobile", accept: "image/*", button_label: "Escolher imagem") %>
            <% end %>
          </div>

          <%= ax_field_grid do %>
            <div class="ax-span-12">
              <%= ax_text_field(form: f, method: :title, label: "Título principal", placeholder: "Ex.: Lançamento em Balneário Camboriú", required: true) %>
            </div>
            <div class="ax-span-12">
              <%= ax_text_field(form: f, method: :description, label: "Subtítulo ou descrição curta", type: :textarea, rows: 2, placeholder: "Breve texto para atrair atenção") %>
            </div>
            <div class="ax-span-6">
              <%= ax_text_field(form: f, method: :link_url, label: "URL do botão", placeholder: "https://exemplo.com.br/imoveis") %>
            </div>
            <div class="ax-span-6">
              <%= ax_text_field(form: f, method: :link_text, label: "Texto do botão", placeholder: "Ex.: Saiba mais") %>
            </div>
          <% end %>
      <% end %>
    </div>

    <div class="ax-span-4">
      <%= ax_operational_panel(eyebrow: "Entrega", title: "Publicação", class_name: "tw-mb-4") do %>
          <div class="tw-mb-4">
            <%= ax_field_label(nil, nil, text: "Onde exibir este banner?") %>
            <%= ax_chip_grid(class_name: "tw-mt-2") do %>
              <% Banner::POSITIONS.each do |value, label| %>
                <%= ax_toggle_chip(
                      nil,
                      nil,
                      name: "banner[positions][]",
                      checked_value: value,
                      checked: @banner.positions&.include?(value),
                      include_hidden: false,
                      id: "banner_positions_#{value}",
                      label: label
                    ) %>
              <% end %>
            <% end %>
          </div>

          <%= ax_number_field(form: f, method: :display_order, label: "Ordem de exibição", min: 0, value: @banner.display_order || 0, class_name: "tw-mb-4", tooltip: "Use 0, 1, 2 e assim por diante para ordenar os banners.") %>

          <div class="tw-mb-4">
            <%= ax_switch_field(label: tag.span(safe_join([tag.i(class: "bi bi-circle-fill tw-text-sm tw-text-green-600"), " Banner ativo"], " "), class: "tw-font-bold"), form: f, method: :active, id: "banner_active", input_html: { role: "switch" }) %>
          </div>

          <%= ax_form_actions(sticky: false, class_name: "layout-settings-actions") do %>
            <%= link_to "Cancelar", admin_banners_path, class: "ax-btn" %>
            <%= f.submit(@banner.persisted? ? "Salvar alterações" : "Publicar banner", class: "ax-btn ax-btn--primary") %>
          <% end %>
      <% end %>
    </div>
  <% end %>
<% end %>
</div>
