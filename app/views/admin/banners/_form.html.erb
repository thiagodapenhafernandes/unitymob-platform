<div class="public-site-workspace">
<%= ax_workspace_heading(eyebrow: "Site público · Banners", icon: "image", title: @banner.persisted? ? "Editar banner" : "Novo banner", pills: [(@banner.active? ? "Ativo" : "Inativo")], subtitle: "Gerencie mídia, destino, posição e publicação.", actions: ax_button("Voltar", admin_banners_path, variant: :ghost, size: :sm, icon: "arrow-left")) %>

<%= form_with(model: [:admin, @banner], local: true, class: "admin-form") do |f| %>
  <%= ax_error_summary(@banner) %>

  <%= ax_field_grid do %>
    <div class="ax-span-8">
      <div class="ax-card">
        <div class="ax-card__header">
          <i class="bi bi-card-image"></i> Cadastro de Mídia
        </div>
        <div class="ax-card__body tw-p-4">
          <div class="preview-container tw-mb-4">
            <div class="preview-desktop">
              <span class="preview-title tw-inline-flex tw-items-center tw-gap-2"><i class="bi bi-pc-display"></i> Imagem Desktop</span>
              <div class="tw-mb-2">
                <% if @banner.image_desktop.attached? %>
                  <img src="<%= url_for(@banner.image_desktop) %>" class="rounded border tw-w-full" style="max-height: 120px; object-fit: cover;">
                <% else %>
                  <div class="border rounded tw-text-ink-muted tw-text-center tw-text-sm" style="padding-top:1.5rem; padding-bottom:1.5rem; background:#fff">Sem imagem desktop</div>
                <% end %>
              </div>
              <%= f.label :image_desktop, "Alterar Desktop", class: "ax-label tw-text-sm tw-font-bold tw-mt-2" %>
              <%= f.file_field :image_desktop, class: "ax-control ax-control--sm", accept: "image/*" %>
            </div>
            <div class="preview-mobile">
              <span class="preview-title tw-inline-flex tw-items-center tw-gap-2"><i class="bi bi-phone"></i> Imagem Mobile</span>
              <div class="tw-mb-2">
                <% if @banner.image_mobile.attached? %>
                  <img src="<%= url_for(@banner.image_mobile) %>" class="rounded border" style="height: 120px; max-width: 100%; object-fit: cover;">
                <% else %>
                  <div class="border rounded tw-text-ink-muted tw-text-center tw-text-sm tw-w-full" style="height: 120px; padding-top:1.5rem; padding-bottom:1.5rem; background:#fff">Sem imagem mobile</div>
                <% end %>
              </div>
              <%= f.label :image_mobile, "Alterar Mobile", class: "ax-label tw-text-sm tw-font-bold tw-mt-2" %>
              <%= f.file_field :image_mobile, class: "ax-control ax-control--sm", accept: "image/*" %>
            </div>
          </div>

          <%= ax_field_grid do %>
            <div class="ax-span-12">
              <%= f.label :title, "Título Principal (Título do Banner)", class: "ax-label tw-font-bold" %>
              <%= f.text_field :title, class: "ax-control", placeholder: "Ex: Lançamento em Balneário Camboriú", required: true %>
            </div>
            <div class="ax-span-12">
              <%= f.label :description, "Subtítulo / Descrição Curta", class: "ax-label tw-font-bold" %>
              <%= f.text_area :description, rows: 2, class: "ax-control", placeholder: "Breve texto para atrair atenção" %>
            </div>
            <div class="ax-span-6">
              <%= f.label :link_url, "URL do Botão (Link)", class: "ax-label tw-font-bold" %>
              <%= f.text_field :link_url, class: "ax-control", placeholder: "https://saluteimoveis.com.br/detalhes" %>
            </div>
            <div class="ax-span-6">
              <%= f.label :link_text, "Texto no Botão", class: "ax-label tw-font-bold" %>
              <%= f.text_field :link_text, class: "ax-control", placeholder: "Ex: Saiba Mais" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="ax-span-4">
      <div class="ax-card tw-mb-4">
        <div class="ax-card__header">
          <i class="bi bi-gear-fill"></i> Publicação
        </div>
        <div class="ax-card__body tw-p-4">
          <div class="tw-mb-4">
            <label class="ax-label tw-font-bold tw-mb-3" style="display:block">Onde exibir este banner?</label>
            <div class="tw-p-2 border tw-rounded-lg" style="background:#f8f9fa">
              <% Banner::POSITIONS.each do |value, label| %>
                <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
                  <%= check_box_tag 'banner[positions][]', value,
                      @banner.positions&.include?(value),
                      id: "banner_positions_#{value}" %>
                  <label class="tw-text-sm" for="banner_positions_<%= value %>"><%= label %></label>
                </div>
              <% end %>
            </div>
          </div>

          <div class="tw-flex tw-items-center tw-mb-4 tw-gap-2">
            <div style="flex:0 0 66.66%; max-width:66.66%">
              <%= f.label :display_order, "Ordem de Exibição", class: "ax-label tw-font-bold", style: "margin-bottom:0" %>
              <small class="tw-text-ink-muted tw-text-sm tw-mt-1" style="display:block">Ex: 0, 1, 2...</small>
            </div>
            <div style="flex:0 0 33.33%; max-width:33.33%">
              <%= f.number_field :display_order, class: "ax-control", value: @banner.display_order || 0 %>
            </div>
          </div>

          <div class="tw-p-2 border tw-rounded-lg tw-flex tw-justify-between tw-items-center tw-mb-4" style="background:#f8f9fa">
            <%= ax_switch_field(label: tag.span(safe_join([tag.i(class: "bi bi-circle-fill tw-text-sm", style: "margin-right:.25rem; color:#16a34a"), " Banner Ativo"]), class: "tw-font-bold"), form: f, method: :active, id: "banner_active", input_html: { role: "switch" }) %>
          </div>

          <button type="submit" class="ax-btn ax-btn--primary tw-w-full tw-mb-2">
            <i class="bi bi-cloud-arrow-up-fill" style="margin-right:.5rem"></i> <%= @banner.persisted? ? "Salvar Alterações" : "Publicar Banner" %>
          </button>
          <%= link_to "Cancelar", admin_banners_path, class: "ax-btn ax-btn--danger tw-w-full" %>
        </div>
      </div>
    </div>
  <% end %>
<% end %>
</div>
