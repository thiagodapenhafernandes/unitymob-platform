<%# Alertas de Marketing — compacto (.ax-*). Original em index.html.erb.bootstrap-bak %>
<% bs_to_ax = { "success" => "green", "danger" => "red", "warning" => "amber", "info" => "blue", "primary" => "blue", "secondary" => "gray" } %>
<div class="marketing-admin-dark">
<%= ax_workspace_heading(
      eyebrow: "Marketing · Monitoramento",
      icon: "exclamation-diamond",
      title: "Alertas de Marketing",
      subtitle: "Sinais automáticos para evitar campanha sem estoque, SEO fraco ou página sem tráfego.",
      actions: ax_button("Dashboard SEO", admin_seo_dashboard_path, size: :sm, icon: "graph-up-arrow")
    ) %>

<div class="tw-grid tw-grid-cols-1 xl:tw-grid-cols-12 tw-gap-4">
  <div class="xl:tw-col-span-5">
    <%= ax_operational_panel(eyebrow: "Monitoramento", title: "Alertas ativos", class_name: "tw-h-full") do %>
      <div class="tw-grid tw-gap-2">
        <% @alerts.each do |alert| %>
          <%= ax_record_item(
                title: alert.title,
                meta: alert.description,
                icon: "exclamation-triangle",
                body: tag.span(alert.level, class: "ax-badge ax-badge--#{bs_to_ax[alert.level.to_s] || 'gray'}"),
                actions: ax_button(alert.action_label, alert.action_path, size: :sm)
              ) %>
        <% end %>
        <% if @alerts.blank? %><%= ax_empty_state(title: "Nenhum alerta crítico agora", description: "Estoque, tráfego e SEO não exigem intervenção imediata.", icon: "check-circle") %><% end %>
      </div>
    <% end %>
  </div>

  <div class="xl:tw-col-span-7">
    <%= ax_operational_panel(eyebrow: "Prontidão", title: "Checklist das páginas estratégicas", class_name: "tw-h-full") do %>
      <div class="ax-table-wrap">
        <table class="ax-table">
          <thead>
            <tr>
              <th>Página</th>
              <th class="ax-num ax-table__col--compact">Estoque</th>
              <th class="ax-num ax-table__col--w-80">Únicos</th>
              <th class="ax-num ax-table__col--w-80">SEO</th>
              <th class="ax-table__col--w-100">Status</th>
            </tr>
          </thead>
          <tbody>
            <% @strategic_pages.each do |row| %>
              <% status_ok = row[:stock].to_i.positive? && row[:score].to_i >= 70 %>
              <tr>
                <td><%= link_to row[:path], row[:path], target: "_blank", rel: "noopener" %></td>
                <td class="ax-num ax-strong"><%= row[:stock] %></td>
                <td class="ax-num"><%= row[:unique_visitors] %></td>
                <td class="ax-num"><span class="ax-badge ax-badge--<%= row[:score] >= 80 ? 'green' : row[:score] >= 60 ? 'amber' : 'red' %>"><%= row[:score] %></span></td>
                <td><span class="ax-badge ax-badge--<%= status_ok ? 'green' : 'amber' %>"><%= status_ok ? "pronta" : "atenção" %></span></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
</div>
</div>
