<div class="container-fluid py-3">
  <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
      <h1 class="h3 mb-1 text-gray-800"><i class="bi bi-exclamation-triangle me-2 text-warning"></i>Alertas de Marketing</h1>
      <p class="text-muted small mb-0">Sinais automáticos para evitar campanha sem estoque, SEO fraco ou página sem tráfego.</p>
    </div>
    <%= link_to admin_seo_dashboard_path, class: "btn btn-sm btn-outline-primary" do %>
      <i class="bi bi-graph-up-arrow me-1"></i>Dashboard SEO
    <% end %>
  </div>

  <div class="row g-3">
    <div class="col-xl-5">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <h2 class="h5 fw-bold mb-3">Alertas ativos</h2>
          <div class="list-group list-group-flush">
            <% @alerts.each do |alert| %>
              <div class="list-group-item px-0">
                <div class="d-flex justify-content-between gap-3">
                  <div>
                    <span class="badge bg-<%= alert.level %> mb-2"><%= alert.level %></span>
                    <div class="fw-bold"><%= alert.title %></div>
                    <div class="small text-muted"><%= alert.description %></div>
                  </div>
                  <div class="flex-shrink-0">
                    <%= link_to alert.action_label, alert.action_path, class: "btn btn-sm btn-outline-primary" %>
                  </div>
                </div>
              </div>
            <% end %>
            <% if @alerts.blank? %>
              <div class="text-center text-muted py-4">Nenhum alerta crítico agora.</div>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <div class="col-xl-7">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <h2 class="h5 fw-bold mb-3">Checklist das páginas estratégicas</h2>
          <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th>Página</th>
                  <th class="text-center">Estoque</th>
                  <th class="text-center">Únicos</th>
                  <th class="text-center">SEO</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% @strategic_pages.each do |row| %>
                  <% status_ok = row[:stock].to_i.positive? && row[:score].to_i >= 70 %>
                  <tr>
                    <td><%= link_to row[:path], row[:path], target: "_blank", rel: "noopener", class: "text-decoration-none" %></td>
                    <td class="text-center fw-bold"><%= row[:stock] %></td>
                    <td class="text-center"><%= row[:unique_visitors] %></td>
                    <td class="text-center"><span class="badge <%= row[:score] >= 80 ? "bg-success" : row[:score] >= 60 ? "bg-warning text-dark" : "bg-danger" %>"><%= row[:score] %></span></td>
                    <td><span class="badge <%= status_ok ? "bg-success" : "bg-warning text-dark" %>"><%= status_ok ? "pronta" : "atenção" %></span></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
