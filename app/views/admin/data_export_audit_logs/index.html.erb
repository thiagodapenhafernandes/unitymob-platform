<%# Auditoria de Exportações — compacto (.ax-*). Original em index.html.erb.bootstrap-bak %>
<div class="tw-mb-4">
  <h1 class="ax-page-title">Auditoria de Exportações</h1>
  <p class="ax-page-subtitle">Registro de CSVs, relatórios e impressões que retiram dados da plataforma.</p>
</div>

<div class="tw-grid tw-grid-cols-2 md:tw-grid-cols-4 tw-gap-3 tw-mb-4">
  <div class="ax-card ax-card--stat"><div class="ax-stat-label">Eventos</div><div class="ax-stat-value"><%= @total_exports %></div></div>
  <div class="ax-card ax-card--stat"><div class="ax-stat-label">CSVs</div><div class="ax-stat-value"><%= @csv_exports %></div></div>
  <div class="ax-card ax-card--stat"><div class="ax-stat-label">Relatórios</div><div class="ax-stat-value"><%= @print_reports %></div></div>
  <div class="ax-card ax-card--stat"><div class="ax-stat-label">Registros expostos</div><div class="ax-stat-value"><%= number_with_delimiter(@total_records) %></div></div>
</div>

<%= form_with url: admin_data_export_audit_logs_path, method: :get, local: true do %>
  <div class="ax-card tw-mb-4">
    <div class="ax-card__body tw-grid tw-grid-cols-2 md:tw-grid-cols-4 lg:tw-grid-cols-6 tw-gap-3 tw-items-end">
      <div><%= label_tag :export_type, "Tipo", class: "ax-label" %><%= select_tag :export_type, options_for_select([["Todos", ""], *DataExportAuditLog::EXPORT_TYPES.map { |k, l| [l, k] }], params[:export_type]), class: "ax-select" %></div>
      <div><%= label_tag :resource_name, "Dados", class: "ax-label" %><%= select_tag :resource_name, options_for_select([["Todos", ""], *DataExportAuditLog::RESOURCE_NAMES.map { |k, l| [l, k] }], params[:resource_name]), class: "ax-select" %></div>
      <div><%= label_tag :admin_user_id, "Usuário", class: "ax-label" %><%= select_tag :admin_user_id, options_from_collection_for_select(@available_users, :id, ->(u) { "#{u.name} · #{u.email}" }, params[:admin_user_id]), include_blank: "Todos", class: "ax-select" %></div>
      <div><%= label_tag :profile_id, "Perfil", class: "ax-label" %><%= select_tag :profile_id, options_from_collection_for_select(@available_profiles, :id, ->(profile) { profile_filter_label(profile) }, params[:profile_id]), include_blank: "Todos", class: "ax-select" %></div>
      <div><%= label_tag :ip, "IP", class: "ax-label" %><%= text_field_tag :ip, params[:ip], class: "ax-input", placeholder: "127.0.0.1" %></div>
      <div><%= label_tag :data_format, "Formato", class: "ax-label" %><%= select_tag :data_format, options_for_select([["Todos", ""]] + @available_formats.map { |f| [f.to_s.upcase, f] }, params[:data_format]), class: "ax-select" %></div>
      <div class="tw-col-span-2"><%= label_tag :filename, "Arquivo contém", class: "ax-label" %><%= text_field_tag :filename, params[:filename], class: "ax-input", placeholder: "nome do arquivo" %></div>
      <div><%= label_tag :start_date, "De", class: "ax-label" %><%= date_field_tag :start_date, params[:start_date], class: "ax-input" %></div>
      <div><%= label_tag :end_date, "Até", class: "ax-label" %><%= date_field_tag :end_date, params[:end_date], class: "ax-input" %></div>
      <div class="tw-flex tw-gap-1">
        <%= submit_tag "Filtrar", class: "ax-btn ax-btn--primary" %>
        <%= link_to "Limpar", admin_data_export_audit_logs_path, class: "ax-btn ax-btn--ghost" %>
      </div>
    </div>
  </div>
<% end %>

<div class="ax-table-wrap">
  <table class="ax-table">
    <thead><tr><th style="width:130px">Quando</th><th>Usuário</th><th style="width:120px">Tipo</th><th style="width:120px">Dados</th><th class="ax-num" style="width:100px">Registros</th><th style="width:90px">Formato</th><th style="width:120px">IP</th><th>Detalhes</th></tr></thead>
    <tbody>
      <% @logs.each do |log| %>
        <tr>
          <td class="tw-text-2xs tw-text-ink-muted"><%= l(log.created_at, format: :short) %></td>
          <td>
            <div class="ax-strong"><%= log.actor_name %></div>
            <div class="tw-text-2xs tw-text-ink-faint"><%= log.admin_user&.email %></div>
          </td>
          <td><span class="ax-badge ax-badge--blue"><%= log.export_type_label %></span></td>
          <td><%= log.resource_label %></td>
          <td class="ax-num">
            <div class="ax-strong"><%= number_with_delimiter(log.record_count) %></div>
            <% if log.selected_count.positive? %><div class="tw-text-2xs tw-text-ink-faint"><%= log.selected_count %> selec.</div><% end %>
          </td>
          <td><%= log.format.upcase %></td>
          <td><code><%= log.ip %></code></td>
          <td class="tw-whitespace-normal">
            <% if log.filename.present? %><div class="tw-text-2xs"><%= log.filename %></div><% end %>
            <% if log.fields.present? %><div class="tw-text-2xs tw-text-ink-faint"><%= pluralize(log.fields.size, "campo", "campos") %></div><% end %>
            <% if log.filters.present? %>
              <details class="tw-text-2xs tw-mt-1"><summary class="tw-cursor-pointer">Filtros</summary><pre class="tw-bg-surface-soft tw-border tw-border-line tw-rounded tw-p-2 tw-mt-1 tw-overflow-auto"><%= JSON.pretty_generate(log.filters) %></pre></details>
            <% end %>
          </td>
        </tr>
      <% end %>
      <% if @logs.empty? %><tr><td colspan="8"><div class="ax-empty">Nenhuma exportação registrada.</div></td></tr><% end %>
    </tbody>
  </table>
</div>

<% if @logs.respond_to?(:total_pages) && @logs.total_pages > 1 %>
  <%= ax_pagination @logs, params: request.query_parameters %>
<% end %>
