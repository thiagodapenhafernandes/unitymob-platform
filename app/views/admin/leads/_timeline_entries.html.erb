<%# Entradas da linha do tempo do lead. locals: entries (coleção de LeadActivity) %>
<div class="tw-grid tw-gap-0">
  <% entries.each_with_index do |act, i| %>
    <% e = timeline_entry(act) %>
    <div class="tw-flex tw-gap-3">
      <div class="tw-flex tw-flex-col tw-items-center">
        <span class="lead-timeline-marker"><i class="bi <%= e[:icon] %>"></i></span>
        <% unless i == entries.size - 1 %><span class="lead-timeline-rail"></span><% end %>
      </div>
      <div class="tw-pb-4 tw-flex-1">
        <div class="tw-flex tw-items-center tw-gap-2">
          <span class="ax-strong"><%= e[:label] %></span>
          <span class="ax-page-subtitle"><%= time_ago_in_words(act.created_at) %> atrás</span>
        </div>
        <% if e[:detail].present? %><div class="ax-page-subtitle"><%= e[:detail] %></div><% end %>
      </div>
    </div>
  <% end %>
</div>
