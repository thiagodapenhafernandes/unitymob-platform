<%
  lead_audit_modal_body = capture do %>
    <% if audit_logs.present? %>
      <div class="lead-audit-timeline">
        <% audit_logs.each do |log| %>
          <div class="ax-card lead-audit-item">
            <div class="lead-audit-item__header">
              <div class="tw-flex tw-items-start tw-justify-between tw-gap-2 tw-flex-wrap">
                <div>
                  <div class="ax-strong"><%= log.title %></div>
                  <div class="ax-page-subtitle">
                    <%= l(log.created_at, format: :short) %>
                    <span class="tw-mx-1">|</span>
                    <%= log.source_label %>
                    <% if log.ip.present? %>
                      <span class="tw-mx-1">|</span> IP <%= log.ip %>
                    <% end %>
                  </div>
                </div>
                <span class="ax-badge ax-badge--gray"><%= log.action_label %></span>
              </div>
            </div>
            <% if log.change_summaries.any? %>
              <div class="tw-grid tw-gap-0">
                <% log.change_summaries.each do |change| %>
                  <div class="lead-audit-change">
                    <div class="lead-audit-change__label ax-page-subtitle"><%= change[:label] %></div>
                    <div class="lead-audit-change__row">
                      <span class="lead-audit-change__before"><%= change[:before] %></span>
                      <span class="lead-audit-change__arrow">→</span>
                      <span class="lead-audit-change__after"><%= change[:after] %></span>
                    </div>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="ax-empty tw-py-6 tw-text-center">
        <p>Nenhuma alteração registrada para este lead.</p>
      </div>
    <% end %>
  <% end %>

<%= ax_quick_modal(
      id: "leadAuditHistoryModal",
      title: "Histórico do Lead",
      size: :lg,
      body: lead_audit_modal_body
    ) %>
