<% content_for :admin_contextbar_breadcrumb do %>
  <%= link_to "Leads", @return_to_path.presence || admin_leads_path %>
  <i class="bi bi-chevron-right"></i>
  <strong><%= @lead.display_name %></strong>
<% end %>

<div class="lead-show-workspace" data-controller="attribute-manager" data-attribute-manager-modal-id-value="attributeManagerModalLead">

<%# ===== Cabeçalho ===== %>
<% sla = lead_sla(@lead) %>
<% open_tasks = (@actionable_tasks || @tasks).reject(&:concluida?) %>

<% @lead_heading_actions = capture do %>
    <%= link_to @return_to_path.presence || admin_leads_path, class: "ax-btn ax-btn--sm" do %>
      <i class="bi bi-arrow-left ax-ico"></i><span>Voltar</span>
    <% end %>
    <button type="button" class="ax-btn ax-btn--sm" data-ax-modal-open="#leadAuditHistoryModal">
      <i class="bi bi-clock-history ax-ico"></i><span>Histórico</span>
    </button>
  <% end %>

<%
  lead_heading_subtitle = [
    @lead.display_email.presence,
    @lead.display_phone.presence,
    @lead.admin_user&.name.presence
  ].compact.join(" · ")
%>

<%= ax_workspace_heading(
      title: @lead.display_name,
      eyebrow: "Contato",
      icon: "person",
      subtitle: lead_heading_subtitle,
      pills: [sla[:label], @lead.status.presence || Lead.default_status],
      actions: @lead_heading_actions
    ) %>

<%= render "admin/leads/origin_line", lead: @lead %>

<%# ===== Barra de funil (bate o olho e entende a etapa) ===== %>
<div class="ax-card tw-mb-3">
  <div class="ax-card__body">
    <div class="tw-flex tw-items-center tw-gap-1 tw-overflow-x-auto tw-pb-1 tw-whitespace-nowrap">
      <% funnel_progress(@lead, @funnel_statuses).each_with_index do |step, i| %>
        <% if i > 0 %>
          <span class="lead-funnel-step-separator lead-funnel-step-separator--<%= step[:state] %>"></span>
        <% end %>
        <%= button_to admin_lead_path(@lead, lead: { status: step[:status] }), method: :patch,
              form_class: "tw-inline-flex", class: "lead-funnel-step lead-funnel-step--#{step[:state]}" do %>
          <i class="bi <%= step[:state] == :done ? 'bi-check-circle-fill' : (step[:state] == :current ? 'bi-record-circle-fill' : 'bi-circle') %>"></i>
          <%= step[:status] %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<%
  # Timeline: mensagens cruas de WhatsApp ficam fora do padrão (já vivem no
  # painel de conversa acima); aqui entram só os marcos.
  wa_timeline_kinds = %w[whatsapp_in whatsapp_out]
  timeline_milestones = @timeline.reject do |act|
    wa_timeline_kinds.include?(act.kind.to_s) ||
      # "Lead atribuído" (automação) é espelho do "Distribuído" — não duplicar
      (act.kind.to_s == "automation_event" && act.metadata.to_h["event"].to_s == "lead_assigned")
  end
  timeline_wa_events = @timeline.select { |act| wa_timeline_kinds.include?(act.kind.to_s) }
  timeline_visible = timeline_milestones.first(15)
  timeline_rest = timeline_milestones.drop(15)
%>

<div class="tw-grid tw-grid-cols-1 lg:tw-grid-cols-[minmax(0,1fr)_380px] tw-gap-4">
  <%# ===== Coluna esquerda ===== %>
  <div>
    <%# Imóvel de interesse: pin principal + vínculos de interesse (add/remover). %>
    <div class="ax-card tw-mb-4 lead-property-card">
      <div class="ax-card__header"><span class="ax-card__title"><i class="bi bi-house ax-ico"></i> Imóvel de interesse</span></div>
      <div class="ax-card__body">
        <% if @property %>
          <div class="lead-property-summary">
            <% property_image_url = catalog_property_image_urls(@property, limit: 1).first %>
            <% if property_image_url.present? %>
              <div class="lead-property-summary__media">
                <%= image_tag property_image_url,
                      class: "lead-property-image",
                      alt: "Imagem principal do imóvel",
                      loading: "lazy" %>
              </div>
            <% end %>
            <div class="lead-property-summary__content">
              <div>
                <div class="ax-strong"><%= @property.display_title %></div>
                <div class="ax-page-subtitle"><%= @property.bairro %>, <%= @property.cidade %></div>
              </div>
              <div class="lead-property-summary__actions">
                <%= link_to "Gerenciar imóvel", admin_habitation_path(@property, return_to: request.fullpath), class: "ax-btn ax-btn--sm" %>
                <%= link_to "Ver no site", habitation_path(@property), target: "_blank", class: "ax-btn ax-btn--sm" %>
              </div>
            </div>
          </div>
        <% elsif @lead.property_id.present? %>
          <div class="lead-property-empty">
            <i class="bi bi-house-slash"></i>
            <div>
              <strong>Imóvel não disponível</strong>
              <p>Este lead possui referência de imóvel, mas o cadastro não está acessível no catálogo atual.</p>
            </div>
          </div>
        <% else %>
          <div class="lead-property-empty">
            <i class="bi bi-megaphone"></i>
            <div>
              <strong>Lead sem imóvel específico</strong>
              <p>Este contato veio de uma origem geral, campanha, webhook ou atendimento sem propriedade atrelada.</p>
            </div>
          </div>
        <% end %>

        <div class="lead-view-divider"></div>
        <div class="ax-stat-label tw-mb-2">Imóveis de interesse</div>
        <%= render "admin/whatsapp_inbox/thread_property_interests",
              lead: @lead, show_empty: false %>
      </div>
    </div>

    <% if can?(:view, :whatsapp_inbox) %>
      <%= render "admin/shared/ui/lead_whatsapp_panel",
            lead: @lead,
            conversation: @whatsapp_conversation,
            templates: @whatsapp_templates,
            summary: @whatsapp_summary,
            thread_context_locals: @whatsapp_thread_context_locals,
            messages: @whatsapp_messages,
            return_to: request.fullpath %>
    <% end %>

    <%# Linha do tempo — colapsada; só marcos por padrão (WhatsApp tem toggle) %>
    <%= ax_collapsible_card(
          title: "Linha do tempo",
          icon: "activity",
          badge: "#{timeline_milestones.size} atividade#{'s' if timeline_milestones.size != 1}",
          collapsed: true,
          collapse_id: "leadTimelineSection",
          class_name: "lead-timeline-card"
        ) do %>
      <% if timeline_milestones.any? %>
        <%= render "admin/leads/timeline_entries", entries: timeline_visible %>

        <% if timeline_rest.any? %>
          <div data-controller="ax-disclosure" data-ax-disclosure-open-value="false">
            <div hidden data-ax-disclosure-target="content">
              <%= render "admin/leads/timeline_entries", entries: timeline_rest %>
            </div>
            <button type="button" class="ax-btn ax-btn--sm ax-btn--ghost"
                    data-action="ax-disclosure#toggle" data-ax-disclosure-target="trigger" aria-expanded="false">
              <i class="bi bi-chevron-expand ax-ico"></i><span>Ver mais (<%= timeline_rest.size %>)</span>
            </button>
          </div>
        <% end %>
      <% else %>
        <%= ax_empty_state(
              title: "Sem atividades ainda",
              description: "Registre um contato, crie uma tarefa ou envie uma proposta — tudo aparece aqui.",
              icon: "activity"
            ) %>
      <% end %>

      <% if timeline_wa_events.any? %>
        <div class="tw-mt-2 tw-pt-2" style="border-top: 1px dashed #e6e8eb" data-controller="ax-disclosure" data-ax-disclosure-open-value="false">
          <button type="button" class="ax-btn ax-btn--sm ax-btn--ghost"
                  data-action="ax-disclosure#toggle" data-ax-disclosure-target="trigger" aria-expanded="false">
            <i class="bi bi-whatsapp ax-ico"></i><span>Mostrar mensagens do WhatsApp (<%= timeline_wa_events.size %>)</span>
          </button>
          <div hidden data-ax-disclosure-target="content" class="tw-mt-3">
            <%= render "admin/leads/timeline_entries", entries: timeline_wa_events %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <%# ===== Coluna direita ===== %>
  <div>
    <%# ===== Card único: atendimento & contexto (seções com divisor) ===== %>
    <%
      interest_signals = ((@interest_profile || {}).with_indifferent_access[:signals] || {})
      interest_signal_count = interest_signals.values.sum(&:to_i)
      interest_enabled = @interest_settings&.enabled?
      interest_badge = if !interest_enabled
        "Desativada"
      elsif interest_signal_count.positive?
        "#{(@interest_profile || {}).with_indifferent_access[:confidence].to_i}% confiança · #{interest_signal_count} sinais"
      else
        "Sem sinais"
      end
    %>
    <div class="ax-card lead-next-action-card">
      <div class="ax-card__header">
        <span class="ax-card__title"><i class="bi bi-flag-fill ax-ico"></i> Próxima ação</span>
      </div>
      <div class="ax-card__body">
        <% if @next_task %>
          <div class="ax-strong"><%= @next_task.title %>
            <% b = task_badge(@next_task) %><span class="ax-badge ax-badge--<%= b[:color] %> tw-ml-1"><%= b[:label] %></span>
          </div>
        <% else %>
          <div class="ax-page-subtitle">Nenhuma tarefa pendente. Defina o próximo passo →</div>
        <% end %>
        <div class="tw-flex tw-flex-wrap tw-items-center tw-gap-2 tw-mt-2">
          <%= render "admin/lead_labels/chips", lead: @lead, labels: @lead.labels_for(current_admin_user) %>
          <%= render "admin/lead_labels/button", lead: @lead, trigger_label: "Etiquetas", trigger_class: "ax-btn ax-btn--sm" %>
          <%= render "admin/leads/log_contact_modal", lead: @lead %>
          <% if can?(:manage, :comercial) %>
            <%= render "admin/tasks/form_modal", modal_id: "newTaskLead", lead: @lead, trigger_label: "Tarefa", trigger_class: "ax-btn ax-btn--sm" %>
            <%= render "admin/appointments/form_modal", lead: @lead, trigger_label: "Agendar visita", trigger_class: "ax-btn ax-btn--sm" %>
            <%= link_to new_admin_lead_proposal_path(@lead), class: "ax-btn ax-btn--sm ax-btn--primary" do %>
              <i class="bi bi-file-earmark-text ax-ico"></i><span>Nova proposta</span>
            <% end %>
          <% end %>
        </div>


        <div class="lead-view-divider"></div>

        <div class="ax-stat-label tw-mb-2">Corretor & observações</div>
        <%= form_with(model: [:admin, @lead], local: true) do |f| %>
          <div class="mb-3">
            <%= f.label :notes, "Observações internas", class: "ax-label" %>
            <%= f.text_area :notes, rows: 3, class: "ax-textarea", placeholder: "Histórico de conversas, preferências do cliente..." %>
          </div>
          <div class="tw-grid tw-gap-3">
            <%# Status sai daqui: o funil no topo da página já troca a etapa. %>
            <% if can?(:manage, :leads) && current_admin_user.scope_for(:leads) != "own" %>
              <div>
                <label class="ax-label">Corretor</label>
                <%= f.select :admin_user_id, @broker_options, { include_blank: "Sem corretor" }, class: "ax-select" %>
              </div>
            <% else %>
              <div>
                <span class="ax-label">Corretor</span>
                <div class="lead-readonly-field"><%= @lead.admin_user&.name.presence || "Sem corretor" %></div>
              </div>
            <% end %>
            <div class="tw-flex tw-justify-end">
              <%= f.submit "Salvar", class: "ax-btn ax-btn--sm ax-btn--primary" %>
            </div>
          </div>
        <% end %>

        <div class="lead-view-divider"></div>

        <div class="tw-flex tw-items-center tw-justify-between tw-mb-2">
          <span class="ax-stat-label">Inteligência de Interesse</span>
          <span class="ax-badge ax-badge--gray"><%= interest_badge %></span>
        </div>
        <%= render "admin/leads/interest_intelligence",
              lead: @lead,
              profile: @interest_profile,
              profile_incomplete: @interest_profile_incomplete,
              matches: @interest_matches,
              navigation_events: @interest_navigation_events,
              property_interests: @interest_property_interests,
              settings: @interest_settings,
              simulation: @interest_simulation,
              embedded: true %>

        <div class="lead-view-divider"></div>

        <div class="tw-flex tw-items-center tw-justify-between tw-mb-2">
          <span class="ax-stat-label">Propostas</span>
          <span class="tw-inline-flex tw-items-center tw-gap-1">
            <span class="ax-badge ax-badge--gray"><%= @proposals.size %></span>
            <% if can?(:manage, :comercial) %>
              <%= link_to new_admin_lead_proposal_path(@lead), class: "ax-ico-btn", title: "Nova proposta" do %><i class="bi bi-plus-lg"></i><% end %>
            <% end %>
          </span>
        </div>
        <div class="tw-grid tw-gap-2">
          <% if @proposals.any? %>
            <% @proposals.each do |p| %>
              <div class="lead-proposal-item">
                <div class="tw-min-w-0">
                  <div class="ax-strong tw-truncate">R$ <%= number_with_precision(p.valor, precision: 2, delimiter: ".", separator: ",") %></div>
                  <div><span class="ax-badge ax-badge--<%= proposal_badge_color(p) %>"><%= p.status_label %></span></div>
                </div>
                <div class="tw-flex tw-gap-1">
                  <%= link_to public_proposal_path(p.public_token), target: "_blank", class: "ax-ico-btn", title: "Abrir link" do %><i class="bi bi-box-arrow-up-right"></i><% end %>
                  <%= link_to pdf_admin_proposal_path(p), target: "_blank", class: "ax-ico-btn", title: "PDF" do %><i class="bi bi-filetype-pdf"></i><% end %>
                  <% if can?(:manage, :comercial) && p.status == "rascunho" %>
                    <%= button_to send_proposal_admin_proposal_path(p), method: :patch, form_class: "tw-inline", class: "ax-ico-btn", title: "Marcar enviada" do %><i class="bi bi-send"></i><% end %>
                  <% end %>
                </div>
              </div>
            <% end %>
          <% else %>
            <p class="ax-page-subtitle tw-m-0">Nenhuma proposta. <%= link_to "Criar a primeira", new_admin_lead_proposal_path(@lead), class: "tw-text-primary" if can?(:manage, :comercial) %></p>
          <% end %>
        </div>

        <div class="lead-view-divider"></div>

        <div class="tw-flex tw-items-center tw-justify-between tw-mb-2">
          <span class="ax-stat-label">Tarefas</span>
          <span class="ax-badge ax-badge--gray"><%= open_tasks.size %></span>
        </div>
        <div class="tw-grid tw-gap-2">
          <% if open_tasks.any? %>
            <% open_tasks.first(6).each do |t| %>
              <% b = task_badge(t) %>
              <div class="tw-flex tw-items-center tw-gap-2">
                <%= button_to complete_admin_task_path(t), method: :patch, form_class: "tw-inline", class: "ax-ico-btn", title: "Concluir" do %><i class="bi bi-circle"></i><% end %>
                <span class="tw-flex-1 tw-truncate"><%= t.title %></span>
                <span class="ax-badge ax-badge--<%= b[:color] %>"><%= b[:label] %></span>
              </div>
            <% end %>
          <% else %>
            <p class="ax-page-subtitle tw-m-0">Nenhuma tarefa pendente.</p>
          <% end %>
        </div>

        <div class="lead-view-divider"></div>

        <div class="tw-flex tw-items-center tw-justify-between tw-mb-2">
          <span class="ax-stat-label">Próximos compromissos</span>
          <span class="ax-badge ax-badge--gray"><%= @appointments.size %></span>
        </div>
        <div class="tw-grid tw-gap-2">
          <% if @appointments.any? %>
            <% @appointments.first(6).each do |a| %>
              <div class="tw-flex tw-items-center tw-justify-between tw-gap-2">
                <span class="tw-truncate"><%= a.title %></span>
                <span class="ax-page-subtitle tw-whitespace-nowrap"><%= a.starts_at.strftime("%d/%m %H:%M") %></span>
              </div>
            <% end %>
          <% else %>
            <p class="ax-page-subtitle tw-m-0">Nada agendado.</p>
          <% end %>
        </div>

        <div class="lead-view-divider"></div>

        <div class="tw-flex tw-items-center tw-justify-between tw-mb-2">
          <span class="ax-stat-label">Provas do push</span>
          <span class="ax-badge ax-badge--gray"><%= @push_delivery_events.size %> tentativa<%= 's' if @push_delivery_events.size != 1 %></span>
        </div>
        <div class="tw-grid tw-gap-2">
          <% if @push_delivery_events.any? %>
            <% @push_delivery_events.each do |event| %>
              <div class="tw-flex tw-items-start tw-justify-between tw-gap-3">
                <div class="tw-min-w-0">
                  <div class="tw-flex tw-flex-wrap tw-items-center tw-gap-2">
                    <span class="ax-badge ax-badge--<%= push_delivery_event_tone(event.event_type) %>">
                      <%= push_delivery_event_label(event.event_type) %>
                    </span>
                    <span class="ax-page-subtitle"><%= l(event.created_at, format: :short) %></span>
                  </div>
                  <div class="tw-mt-1 tw-text-sm tw-text-slate-600 tw-truncate">
                    <%= push_delivery_event_device(event) %>
                    <% if event.endpoint_host.present? %>
                      · <%= event.endpoint_host %>
                    <% end %>
                    <% if event.push_subscription_id.present? %>
                      · sub #<%= event.push_subscription_id %>
                    <% end %>
                  </div>
                  <% if event.error_message.present? %>
                    <div class="tw-mt-1 tw-text-xs tw-text-red-600 tw-truncate">
                      <%= [event.error_class, event.error_message].compact.join(": ") %>
                    </div>
                  <% end %>
                </div>
                <div class="tw-flex tw-shrink-0 tw-flex-col tw-items-end tw-gap-1 tw-text-xs tw-text-slate-500">
                  <% if event.provider_status.present? %>
                    <span>HTTP <%= event.provider_status %></span>
                  <% end %>
                  <% if event.urgency.present? || event.ttl.present? %>
                    <span><%= [event.urgency.presence, ("TTL #{event.ttl}" if event.ttl.present?)].compact.join(" · ") %></span>
                  <% end %>
                </div>
              </div>
            <% end %>
          <% else %>
            <p class="ax-page-subtitle tw-m-0">Nenhuma tentativa de push registrada para este lead ainda.</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<%= render "admin/shared/attribute_manager_modal", modal_id: "attributeManagerModalLead" %>
<%= render "admin/leads/audit_history_modal", lead: @lead, audit_logs: @lead_audit_logs %>
</div>
