<div data-controller="attribute-manager" data-attribute-manager-modal-id-value="attributeManagerModalLead">
<div class="mb-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Leads", admin_leads_path %></li>
      <li class="breadcrumb-item active" aria-current="page">Detalhes do Lead</li>
    </ol>
  </nav>
  <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-2">
    <h1 class="h3 mb-0 text-gray-800">Detalhes do Lead: <%= @lead.name %></h1>
    <button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#leadAuditHistoryModal">
      <i class="bi bi-clock-history me-1"></i> Histórico
    </button>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-8">
    <div class="card shadow-sm border-0 mb-4">
      <div class="card-header bg-white py-3">
        <h5 class="card-title mb-0 fw-bold"><i class="bi bi-person me-2 text-primary"></i>Informações de Contato</h5>
      </div>
      <div class="card-body">
        <div class="row mb-4">
          <div class="col-sm-3 text-muted">Nome Completo:</div>
          <div class="col-sm-9 fw-bold"><%= @lead.name %></div>
        </div>
        <div class="row mb-4">
          <div class="col-sm-3 text-muted">E-mail:</div>
          <div class="col-sm-9"><%= @lead.email %></div>
        </div>
        <div class="row mb-4">
          <div class="col-sm-3 text-muted">Telefone:</div>
          <div class="col-sm-9">
            <%= @lead.phone %>
            <a href="https://wa.me/55<%= @lead.phone.gsub(/\D/, '') %>" target="_blank" class="btn btn-sm btn-success ms-2">
              <i class="bi bi-whatsapp"></i> Chamar no WhatsApp
            </a>
          </div>
        </div>
        <div class="row mb-4">
          <div class="col-sm-3 text-muted">Data do Contato:</div>
          <div class="col-sm-9"><%= @lead.created_at.strftime("%d/%m/%Y às %H:%M") %></div>
        </div>
        <div class="row">
          <div class="col-sm-3 text-muted">URL de Origem:</div>
          <div class="col-sm-9 small"><%= link_to @lead.source_url, @lead.source_url, target: "_blank", class: "text-break" if @lead.source_url.present? %></div>
        </div>
      </div>
    </div>

    <div class="card shadow-sm border-0">
      <div class="card-header bg-white py-3">
        <h5 class="card-title mb-0 fw-bold"><i class="bi bi-sticky me-2 text-primary"></i>Notas de Atendimento</h5>
      </div>
      <div class="card-body">
        <%= form_with(model: [:admin, @lead], local: true) do |f| %>
          <div class="mb-3">
            <%= f.label :notes, "Observações internas", class: "form-label" %>
            <%= f.text_area :notes, rows: 6, class: "form-control", placeholder: "Histórico de conversas, preferências do cliente..." %>
          </div>
          <div class="d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-2 flex-wrap">
              <%= f.label :status, "Status:", class: "mb-0" %>
              <%= f.select :status, @status_options, {}, class: "form-select form-select-sm", style: "width: auto;", id: "lead_status" %>
              <% if defined?(can?) && can?(:manage, :catalogos) %>
                <button type="button" class="btn btn-sm btn-outline-primary"
                        data-attribute-manager-context-value="lead"
                        data-attribute-manager-category-value="status"
                        data-attribute-manager-field-name-value="lead[status]"
                        data-attribute-manager-modal-id-value="attributeManagerModalLead"
                        data-action="click->attribute-manager#open"
                        data-title="Gerenciar Status de Lead"
                        data-select-id="lead_status">
                  <i class="bi bi-sliders me-1"></i>Status
                </button>
              <% end %>
              <%= f.label :origin, "Origem:", class: "mb-0 ms-2" %>
              <%= f.select :origin, @origin_options, { include_blank: "Selecione..." }, class: "form-select form-select-sm", style: "width: auto; min-width: 180px;", data: { controller: "tom-select", tom_select_create_value: true }, id: "lead_origin" %>
              <% if can?(:manage, :leads) || owns_all_resource?(:leads) %>
                <%= f.label :admin_user_id, "Corretor:", class: "mb-0 ms-2" %>
                <%= f.select :admin_user_id, @broker_options, { include_blank: "Sem corretor" }, class: "form-select form-select-sm", style: "width: auto; min-width: 220px;" %>
              <% else %>
                <span class="small text-muted ms-2">
                  <i class="bi bi-person-badge me-1"></i><%= @lead.admin_user&.name.presence || "Sem corretor atribuído" %>
                </span>
              <% end %>
              <button type="button" class="btn btn-sm btn-outline-primary"
                      data-attribute-manager-context-value="lead"
                      data-attribute-manager-category-value="source"
                      data-attribute-manager-field-name-value="lead[origin]"
                      data-attribute-manager-modal-id-value="attributeManagerModalLead"
                      data-action="click->attribute-manager#open"
                      data-title="Gerenciar Origens de Lead"
                      data-select-id="lead_origin">
                <i class="bi bi-gear me-1"></i>Gerenciar
              </button>
            </div>
            <%= f.submit "Salvar Alterações", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <% if @property %>
      <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3">
          <h5 class="card-title mb-0 fw-bold"><i class="bi bi-house me-2 text-primary"></i>Imóvel de Interesse</h5>
        </div>
        <div class="card-body">
          <% if @property.primary_image.present? %>
            <img src="<%= @property.primary_image['url'] %>" class="img-fluid rounded mb-3" alt="">
          <% end %>
          <h6 class="fw-bold mb-1"><%= @property.display_title %></h6>
          <p class="text-muted small mb-3"><%= @property.bairro %>, <%= @property.cidade %></p>
          
          <div class="d-grid gap-2">
            <%= link_to admin_habitation_path(@property), class: "btn btn-outline-primary btn-sm" do %>
              <i class="bi bi-pencil me-1"></i> Gerenciar Imóvel
            <% end %>
            <%= link_to habitation_path(@property), target: "_blank", class: "btn btn-outline-secondary btn-sm" do %>
              <i class="bi bi-eye me-1"></i> Ver no Site
            <% end %>
          </div>
        </div>
      </div>
    <% else %>
      <div class="alert alert-light border shadow-none">
        <i class="bi bi-info-circle me-1"></i> Este lead foi gerado através de um contato geral, sem imóvel específico vinculado.
      </div>
    <% end %>
  </div>
</div>
<%= render "admin/shared/attribute_manager_modal", modal_id: "attributeManagerModalLead" %>
<%= render "admin/leads/audit_history_modal", lead: @lead, audit_logs: @lead_audit_logs %>
</div>
