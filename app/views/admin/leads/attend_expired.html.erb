<div class="layout-settings-workspace">
  <% taken = (@attend_reason == :taken) %>
  <%= ax_empty_state(
        title: taken ? "Lead já atendido" : "Tempo esgotado",
        description: taken ?
          "Outro corretor aceitou este lead primeiro. Fique de olho — o próximo é seu!" :
          "O prazo para atender este lead expirou e ele foi redistribuído para outro corretor.",
        icon: taken ? "person-check" : "hourglass-bottom",
        action: ax_button("Ver meus leads", admin_leads_path, variant: :primary, icon: "list-ul")
      ) %>
</div>
