<% current_integration = @integrations[@active_portal] %>
<% current_preview = @previews[@active_portal] || {} %>
<% current_readiness = @readiness[@active_portal] || {} %>
<% current_status = current_readiness[:status] %>
<% current_checklist = current_readiness[:checklist] || [] %>

<%= ax_workspace_heading(eyebrow: "Integrações · Distribuição", icon: "building", title: "Portais", pills: [current_integration.title], subtitle: "Configure publicação, elegibilidade e retorno operacional por portal.", metrics: [{ value: current_preview[:eligible_count].to_i, label: "elegíveis" }]) %>

<%= ax_field_grid(columns: 12, gap: :compact) do %>
  <!-- Sidebar de portais com status visual -->
  <div class="ax-span-3">
    <div class="ax-card">
      <ul class="portal-integrations-nav">
        <% PortalIntegration::PORTALS.each do |portal_key| %>
          <% integration = @integrations[portal_key] %>
          <% portal_status = @readiness.dig(portal_key, :status) || :disabled %>
          <% portal_color = integration.readiness_color(portal_status) %>
          <% portal_label = integration.readiness_label(portal_status) %>
          <% portal_eligible = @previews.dig(portal_key, :eligible_count).to_i %>
          <li class="portal-integrations-nav__item">
          <a href="<%= admin_portal_integrations_path(portal: portal_key) %>"
             class="portal-integrations-nav__link <%= 'is-active' if @active_portal == portal_key %>">
            <div class="tw-flex tw-justify-between tw-items-start tw-gap-2">
              <div>
                <div class="tw-font-semibold"><%= integration.title %></div>
                <small class="portal-integrations-nav__meta <%= 'is-active' if @active_portal == portal_key %>">
                  <%= portal_eligible %> imóveis elegíveis
                </small>
              </div>
              <span class="ax-badge ax-badge--<%= portal_color == 'success' ? 'green' : portal_color == 'danger' ? 'red' : portal_color == 'warning' ? 'amber' : portal_color == 'primary' ? 'blue' : 'gray' %>">
                <%= portal_label %>
              </span>
            </div>
          </a>
          </li>
        <% end %>
      </ul>
    </div>
  </div>

  <!-- Painel principal -->
  <div class="ax-span-9">
    <% banner_color = current_integration.readiness_color(current_status) %>
    <% pending_items = current_checklist.reject { |item| item[:ok] } %>
    <div class="portal-integrations-commandbar">
      <div class="portal-integrations-commandbar__identity">
        <strong><%= current_integration.title %></strong>
        <span class="ax-badge ax-badge--<%= banner_color == 'success' ? 'green' : banner_color == 'danger' ? 'red' : banner_color == 'warning' ? 'amber' : banner_color == 'primary' ? 'blue' : 'gray' %>"><%= current_integration.readiness_label(current_status) %></span>
      </div>
      <div class="portal-integrations-commandbar__metrics">
        <span><strong><%= current_preview[:eligible_count].to_i %></strong> elegíveis</span>
        <span><strong><%= current_preview[:rejected_count].to_i %></strong> rejeitados</span>
        <span><strong><%= current_integration.last_feed_at.present? ? l(current_integration.last_feed_at, format: :short) : "Nunca" %></strong> último acesso</span>
      </div>
      <% if current_integration.docs_url.present? %><%= ax_button("Documentação", current_integration.docs_url, variant: :ghost, size: :sm, icon: "box-arrow-up-right", target: "_blank", rel: "noopener") %><% end %>
    </div>

    <% if pending_items.any? %>
      <%= ax_inline_notice(tone: :warning, icon: "exclamation-triangle", class_name: "tw-mb-3") do %>
        <strong><%= pending_items.size %> <%= pending_items.size == 1 ? "pendência" : "pendências" %>:</strong>
        <%= pending_items.map { |item| item[:label] }.to_sentence %>.
      <% end %>
    <% end %>

    <!-- Configuração -->
    <div class="ax-card tw-mb-3">
      <div class="ax-card__header">
        <h6 class="ax-card__title tw-flex tw-items-center tw-gap-2"><i class="bi bi-gear"></i>Configuração</h6>
      </div>
      <div class="ax-card__body">
        <%= form_with model: current_integration,
                      url: admin_portal_integration_path(@active_portal),
                      method: :patch,
                      local: true do |f| %>
          <div class="tw-mb-4">
            <%= ax_switch_field(form: f, method: :enabled, label: "Integração ativa") %>
            <small class="portal-integrations-help">Quando ativa, o feed começa a ser disponibilizado para o portal.</small>
          </div>

          <%= ax_field_grid(columns: 12, gap: :compact) do %>
            <% if current_integration.requires_account_id? %>
              <div class="ax-span-6">
                <%= f.label :account_id, "Account ID", class: "ax-label" %>
                <span class="ax-badge ax-badge--red tw-ml-1">obrigatório</span>
                <%= f.text_field :account_id, class: "ax-control", placeholder: "Ex: 12345" %>
                <small class="portal-integrations-help">ID da sua conta no portal. Solicite ao gerente comercial.</small>
              </div>
              <div class="ax-span-6">
                <%= f.label :publisher_id, "Publisher ID", class: "ax-label" %>
                <span class="ax-badge ax-badge--red tw-ml-1">obrigatório</span>
                <%= f.text_field :publisher_id, class: "ax-control", placeholder: "Ex: 67890" %>
                <small class="portal-integrations-help">ID do publicador (geralmente igual ao Account ID).</small>
              </div>
            <% else %>
              <div class="ax-span-6">
                <%= f.label :account_id, "Account ID", class: "ax-label" %>
                <small class="portal-integrations-help portal-integrations-help--inline">(opcional)</small>
                <%= f.text_field :account_id, class: "ax-control" %>
              </div>
              <div class="ax-span-6">
                <%= f.label :publisher_id, "Publisher ID", class: "ax-label" %>
                <small class="portal-integrations-help portal-integrations-help--inline">(opcional)</small>
                <%= f.text_field :publisher_id, class: "ax-control" %>
              </div>
            <% end %>

            <div class="ax-span-6">
              <%= f.label :feed_token, "Token do Feed", class: "ax-label" %>
              <%= f.password_field :feed_token, class: "ax-control",
                                   autocomplete: "off",
                                   placeholder: (current_integration.feed_token.present? ? "Já configurado. Preencha para substituir." : "Gerado automaticamente ao salvar") %>
              <small class="portal-integrations-help">Senha que protege a URL do feed. Deixe em branco para gerar automaticamente.</small>
            </div>
            <div class="ax-span-6">
              <%= f.label :webhook_secret, "Webhook Secret", class: "ax-label" %>
              <small class="portal-integrations-help portal-integrations-help--inline">(opcional)</small>
              <%= f.password_field :webhook_secret, class: "ax-control",
                                   autocomplete: "off",
                                   placeholder: (current_integration.webhook_secret.present? ? "Já configurado. Preencha para substituir." : "Defina se for usar webhook do portal") %>
              <small class="portal-integrations-help">Usado para validar eventos enviados pelo portal de volta para nós.</small>
            </div>

            <div class="ax-span-6">
              <%= f.label :allowed_business_types, "Tipos de negócio", class: "ax-label" %>
              <%= f.select :allowed_business_types,
                           options_for_select(@business_type_options, current_integration.allowed_business_types),
                           {},
                           multiple: true,
                           class: "ax-control",
                           data: { controller: "tom-select", tom_select_tags_value: true } %>
              <small class="portal-integrations-help">Quais tipos de transação serão enviados.</small>
            </div>

            <div class="ax-span-6">
              <%= f.label :allowed_statuses, "Status permitidos", class: "ax-label" %>
              <%= f.select :allowed_statuses,
                           options_for_select(@status_options, current_integration.allowed_statuses),
                           {},
                           multiple: true,
                           class: "ax-control",
                           data: { controller: "tom-select", tom_select_tags_value: true } %>
              <small class="portal-integrations-help">Apenas imóveis nestes status entram no feed.</small>
            </div>

            <div class="ax-span-12">
              <%= ax_switch_field(form: f, method: :require_exibir_no_site, label: "Enviar apenas imóveis exibidos no site") %>
              <small class="portal-integrations-help">Recomendado. Evita publicar imóveis ocultos do site público.</small>
            </div>
          <% end %>

          <div class="tw-flex tw-justify-end tw-gap-2 tw-mt-4">
            <%= f.submit "Salvar Configuração", class: "ax-btn ax-btn--primary" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- URL do Feed em destaque (ação principal) -->
    <% feed_url = integrations_portals_feed_token_url(portal: @active_portal, token: current_integration.feed_token, format: current_integration.feed_format) %>
    <div class="ax-card portal-integrations-feed-card tw-mb-3" data-controller="clipboard" data-clipboard-success-content-value="✓ Copiado!">
      <div class="ax-card__body">
        <div class="tw-flex tw-items-center tw-gap-2 tw-mb-2">
          <i class="bi bi-link-45deg portal-integrations-feed-card__icon"></i>
          <div class="portal-integrations-feed-card__title">URL do Feed para o portal</div>
        </div>
        <p class="tw-text-sm tw-text-ink-muted tw-mb-3">
          <strong>Esta é a URL que você deve enviar ao <%= current_integration.title %>.</strong>
          O portal vai ler seus imóveis automaticamente a partir dela.
        </p>
        <%= ax_input_group(action: capture { %>
          <button type="button" class="ax-btn ax-btn--primary tw-gap-1"
                  data-action="clipboard#copy"
                  data-clipboard-target="button">
            <i class="bi bi-clipboard"></i>
            <span data-clipboard-target="content">Copiar</span>
          </button>
        <% }) do %>
          <input type="text" class="ax-control font-monospace tw-text-sm" readonly
                 value="<%= feed_url %>"
                 data-clipboard-target="source"
                 data-action="focus->clipboard#select click->clipboard#select">
        <% end %>
        <div class="tw-flex tw-flex-wrap tw-gap-2 tw-mt-3">
          <%= link_to preview_feed_admin_portal_integration_path(@active_portal),
                      target: "_blank", rel: "noopener",
                      class: "ax-btn ax-btn--ghost ax-btn--sm tw-gap-1" do %>
            <i class="bi bi-eye"></i> Visualizar amostra (3 imóveis)
          <% end %>
          <%= button_to test_feed_admin_portal_integration_path(@active_portal),
                        method: :post, class: "ax-btn ax-btn--ghost ax-btn--sm tw-gap-1" do %>
            <i class="bi bi-arrow-clockwise"></i> Testar feed completo
          <% end %>
        </div>
      </div>
    </div>

    <!-- Webhook (secundário) -->
    <div class="ax-card tw-mb-3" data-controller="ax-disclosure">
      <div class="ax-card__header">
        <button class="ax-btn ax-btn--ghost portal-integrations-disclosure-button"
                type="button" data-action="ax-disclosure#toggle" data-ax-disclosure-target="trigger"
                aria-expanded="false" aria-controls="webhookSection">
          <span class="tw-flex tw-items-center tw-gap-2"><i class="bi bi-arrow-down-circle"></i>Webhook (opcional — eventos do portal)</span>
          <i class="bi bi-chevron-down"></i>
        </button>
      </div>
      <div id="webhookSection" data-ax-disclosure-target="content" hidden>
        <div class="ax-card__body">
          <p class="tw-text-sm tw-text-ink-muted tw-mb-2">
            Alguns portais conseguem nos enviar de volta avisos de aprovação, rejeição ou alterações.
            Configure essa URL no painel do portal se ele suportar webhooks.
          </p>
          <div class="portal-integrations-webhook-url">
            <%= webhooks_portal_events_url(portal: @active_portal) %>
          </div>
          <small class="portal-integrations-help">Use o Webhook Secret configurado acima para assinatura HMAC-SHA256.</small>
        </div>
      </div>
    </div>

    <% if current_preview[:top_reasons].present? %>
      <details class="portal-integrations-rejections tw-mb-3">
        <summary>Ver principais motivos de rejeição</summary>
        <ul><% current_preview[:top_reasons].each do |reason, count| %><li><span><%= reason.humanize %></span><strong><%= count %></strong></li><% end %></ul>
      </details>
    <% end %>

    <!-- Tabela de retornos -->
    <div class="ax-card">
      <div class="ax-card__header">
        <h6 class="ax-card__title tw-flex tw-items-center tw-gap-2"><i class="bi bi-clock-history"></i>Últimos retornos do portal</h6>
      </div>
      <div class="ax-table-wrap">
        <table class="ax-table">
          <thead>
            <tr>
              <th>Código</th>
              <th>ID Externo</th>
              <th>Evento</th>
              <th>Status</th>
              <th>Atualizado em</th>
            </tr>
          </thead>
          <tbody>
            <% if @listing_states.any? %>
              <% @listing_states.each do |state| %>
                <tr>
                  <td><%= state.habitation_code.presence || "—" %></td>
                  <td><%= state.external_listing_id.presence || "—" %></td>
                  <td><%= state.last_event_type %></td>
                  <td><%= state.last_status.presence || "—" %></td>
                  <td><%= state.last_received_at.present? ? l(state.last_received_at, format: :short) : "—" %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="5" class="portal-integrations-empty-cell">
                  Sem eventos recebidos ainda. Eles aparecem aqui após o portal começar a sincronizar.
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
<% end %>
