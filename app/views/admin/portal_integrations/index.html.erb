<% current_integration = @integrations[@active_portal] %>
<% current_preview = @previews[@active_portal] || {} %>
<% current_readiness = @readiness[@active_portal] || {} %>
<% current_status = current_readiness[:status] %>
<% current_checklist = current_readiness[:checklist] || [] %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-1 text-gray-800">Integrações de Portais</h1>
    <p class="text-muted small mb-0">
      Envie automaticamente seus imóveis para os principais portais imobiliários do Brasil.
    </p>
  </div>
</div>

<div class="row g-3">
  <!-- Sidebar de portais com status visual -->
  <div class="col-lg-3">
    <div class="card border-0 shadow-sm">
      <div class="list-group list-group-flush">
        <% PortalIntegration::PORTALS.each do |portal_key| %>
          <% integration = @integrations[portal_key] %>
          <% portal_status = @readiness.dig(portal_key, :status) || :disabled %>
          <% portal_color = integration.readiness_color(portal_status) %>
          <% portal_label = integration.readiness_label(portal_status) %>
          <% portal_eligible = @previews.dig(portal_key, :eligible_count).to_i %>
          <a href="<%= admin_portal_integrations_path(portal: portal_key) %>"
             class="list-group-item list-group-item-action <%= 'active' if @active_portal == portal_key %> py-3">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <div class="fw-semibold"><%= integration.title %></div>
                <small class="<%= @active_portal == portal_key ? 'text-white-50' : 'text-muted' %>">
                  <%= portal_eligible %> imóveis elegíveis
                </small>
              </div>
              <span class="badge bg-<%= portal_color %>-subtle text-<%= portal_color %> border ms-2">
                <%= portal_label %>
              </span>
            </div>
          </a>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Painel principal -->
  <div class="col-lg-9">
    <!-- Banner de status agregado -->
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <h4 class="fw-bold mb-1"><%= current_integration.title %></h4>
            <p class="text-muted small mb-0">
              <%= current_integration.summary || "Configure o envio automático dos imóveis para este portal." %>
            </p>
          </div>
          <span class="badge bg-<%= current_integration.readiness_color(current_status) %>-subtle text-<%= current_integration.readiness_color(current_status) %> border fs-6 px-3 py-2">
            <i class="bi bi-circle-fill me-1" style="font-size: 0.6rem;"></i>
            <%= current_integration.readiness_label(current_status) %>
          </span>
        </div>

        <% if current_integration.docs_url.present? %>
          <div class="mt-3">
            <a href="<%= current_integration.docs_url %>" target="_blank" rel="noopener" class="text-decoration-none small">
              <i class="bi bi-box-arrow-up-right me-1"></i>
              Documentação oficial do <%= current_integration.title %>
            </a>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Como ativar (passo a passo expansível) -->
    <% if current_integration.setup_steps.any? %>
      <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-white">
          <button class="btn btn-link p-0 text-decoration-none fw-semibold w-100 text-start d-flex justify-content-between align-items-center"
                  type="button" data-bs-toggle="collapse" data-bs-target="#setupSteps"
                  aria-expanded="false" aria-controls="setupSteps">
            <span><i class="bi bi-lightbulb me-2"></i>Como ativar este portal</span>
            <i class="bi bi-chevron-down"></i>
          </button>
        </div>
        <div class="collapse" id="setupSteps">
          <div class="card-body">
            <ol class="mb-0">
              <% current_integration.setup_steps.each do |step| %>
                <li class="mb-2"><%= step %></li>
              <% end %>
            </ol>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Checklist de pré-requisitos -->
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white">
        <h6 class="fw-semibold mb-0"><i class="bi bi-check2-square me-2"></i>Checklist de configuração</h6>
      </div>
      <div class="card-body">
        <ul class="list-unstyled mb-0">
          <% current_checklist.each do |item| %>
            <li class="mb-2 d-flex align-items-start">
              <% if item[:ok] %>
                <i class="bi bi-check-circle-fill text-success me-2 mt-1"></i>
              <% else %>
                <i class="bi bi-exclamation-circle-fill text-warning me-2 mt-1"></i>
              <% end %>
              <div class="flex-grow-1">
                <div class="<%= 'text-decoration-line-through text-muted' if item[:ok] %>">
                  <%= item[:label] %>
                </div>
                <% if item[:hint] %>
                  <small class="text-muted d-block"><%= item[:hint] %></small>
                <% end %>
              </div>
            </li>
          <% end %>
        </ul>
      </div>
    </div>

    <!-- Configuração -->
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white">
        <h6 class="fw-semibold mb-0"><i class="bi bi-gear me-2"></i>Configuração</h6>
      </div>
      <div class="card-body">
        <%= form_with model: current_integration,
                      url: admin_portal_integration_path(@active_portal),
                      method: :patch,
                      local: true do |f| %>
          <div class="form-check form-switch form-switch-lg mb-4">
            <%= f.check_box :enabled, class: "form-check-input" %>
            <%= f.label :enabled, "Integração ativa", class: "form-check-label fw-semibold" %>
            <small class="d-block text-muted">Quando ativa, o feed começa a ser disponibilizado para o portal.</small>
          </div>

          <div class="row g-3">
            <% if current_integration.requires_account_id? %>
              <div class="col-md-6">
                <%= f.label :account_id, "Account ID", class: "form-label fw-semibold" %>
                <span class="badge bg-danger-subtle text-danger ms-1">obrigatório</span>
                <%= f.text_field :account_id, class: "form-control", placeholder: "Ex: 12345" %>
                <small class="text-muted">ID da sua conta no portal. Solicite ao gerente comercial.</small>
              </div>
              <div class="col-md-6">
                <%= f.label :publisher_id, "Publisher ID", class: "form-label fw-semibold" %>
                <span class="badge bg-danger-subtle text-danger ms-1">obrigatório</span>
                <%= f.text_field :publisher_id, class: "form-control", placeholder: "Ex: 67890" %>
                <small class="text-muted">ID do publicador (geralmente igual ao Account ID).</small>
              </div>
            <% else %>
              <div class="col-md-6">
                <%= f.label :account_id, "Account ID", class: "form-label fw-semibold" %>
                <small class="text-muted ms-1">(opcional)</small>
                <%= f.text_field :account_id, class: "form-control" %>
              </div>
              <div class="col-md-6">
                <%= f.label :publisher_id, "Publisher ID", class: "form-label fw-semibold" %>
                <small class="text-muted ms-1">(opcional)</small>
                <%= f.text_field :publisher_id, class: "form-control" %>
              </div>
            <% end %>

            <div class="col-md-6">
              <%= f.label :feed_token, "Token do Feed", class: "form-label fw-semibold" %>
              <%= f.password_field :feed_token, class: "form-control",
                                   autocomplete: "off",
                                   placeholder: (current_integration.feed_token.present? ? "Já configurado. Preencha para substituir." : "Gerado automaticamente ao salvar") %>
              <small class="text-muted">Senha que protege a URL do feed. Deixe em branco para gerar automaticamente.</small>
            </div>
            <div class="col-md-6">
              <%= f.label :webhook_secret, "Webhook Secret", class: "form-label fw-semibold" %>
              <small class="text-muted ms-1">(opcional)</small>
              <%= f.password_field :webhook_secret, class: "form-control",
                                   autocomplete: "off",
                                   placeholder: (current_integration.webhook_secret.present? ? "Já configurado. Preencha para substituir." : "Defina se for usar webhook do portal") %>
              <small class="text-muted">Usado para validar eventos enviados pelo portal de volta para nós.</small>
            </div>

            <div class="col-md-6">
              <%= f.label :allowed_business_types, "Tipos de negócio", class: "form-label fw-semibold" %>
              <%= f.select :allowed_business_types,
                           options_for_select(@business_type_options, current_integration.allowed_business_types),
                           {},
                           multiple: true,
                           class: "form-select",
                           data: { controller: "tom-select", tom_select_tags_value: true } %>
              <small class="text-muted">Quais tipos de transação serão enviados.</small>
            </div>

            <div class="col-md-6">
              <%= f.label :allowed_statuses, "Status permitidos", class: "form-label fw-semibold" %>
              <%= f.select :allowed_statuses,
                           options_for_select(@status_options, current_integration.allowed_statuses),
                           {},
                           multiple: true,
                           class: "form-select",
                           data: { controller: "tom-select", tom_select_tags_value: true } %>
              <small class="text-muted">Apenas imóveis nestes status entram no feed.</small>
            </div>

            <div class="col-12">
              <div class="form-check">
                <%= f.check_box :require_exibir_no_site, class: "form-check-input" %>
                <%= f.label :require_exibir_no_site, "Enviar apenas imóveis exibidos no site", class: "form-check-label" %>
                <small class="d-block text-muted">Recomendado. Evita publicar imóveis ocultos do site público.</small>
              </div>
            </div>
          </div>

          <div class="d-flex justify-content-end gap-2 mt-4">
            <%= f.submit "Salvar Configuração", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- URL do Feed em destaque (ação principal) -->
    <% feed_url = integrations_portals_feed_token_url(portal: @active_portal, token: current_integration.feed_token, format: current_integration.feed_format) %>
    <div class="card border-primary shadow-sm mb-3" data-controller="clipboard" data-clipboard-success-content-value="✓ Copiado!">
      <div class="card-body">
        <div class="d-flex align-items-center mb-2">
          <i class="bi bi-link-45deg text-primary me-2 fs-4"></i>
          <h5 class="fw-bold mb-0">URL do Feed para o portal</h5>
        </div>
        <p class="small text-muted mb-3">
          <strong>Esta é a URL que você deve enviar ao <%= current_integration.title %>.</strong>
          O portal vai ler seus imóveis automaticamente a partir dela.
        </p>
        <div class="input-group input-group-lg">
          <input type="text" class="form-control font-monospace small" readonly
                 value="<%= feed_url %>"
                 data-clipboard-target="source"
                 onclick="this.select()">
          <button type="button" class="btn btn-primary"
                  data-action="clipboard#copy"
                  data-clipboard-target="button">
            <i class="bi bi-clipboard me-1"></i>
            <span data-clipboard-target="content">Copiar</span>
          </button>
        </div>
        <div class="d-flex flex-wrap gap-2 mt-3">
          <%= link_to preview_feed_admin_portal_integration_path(@active_portal),
                      target: "_blank", rel: "noopener",
                      class: "btn btn-sm btn-outline-primary" do %>
            <i class="bi bi-eye me-1"></i> Visualizar amostra (3 imóveis)
          <% end %>
          <%= button_to test_feed_admin_portal_integration_path(@active_portal),
                        method: :post, class: "btn btn-sm btn-outline-secondary" do %>
            <i class="bi bi-arrow-clockwise me-1"></i> Testar feed completo
          <% end %>
        </div>
      </div>
    </div>

    <!-- Webhook (secundário) -->
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white">
        <button class="btn btn-link p-0 text-decoration-none fw-semibold w-100 text-start d-flex justify-content-between align-items-center"
                type="button" data-bs-toggle="collapse" data-bs-target="#webhookSection"
                aria-expanded="false" aria-controls="webhookSection">
          <span><i class="bi bi-arrow-down-circle me-2"></i>Webhook (opcional — eventos do portal)</span>
          <i class="bi bi-chevron-down"></i>
        </button>
      </div>
      <div class="collapse" id="webhookSection">
        <div class="card-body">
          <p class="small text-muted mb-2">
            Alguns portais conseguem nos enviar de volta avisos de aprovação, rejeição ou alterações.
            Configure essa URL no painel do portal se ele suportar webhooks.
          </p>
          <div class="border rounded p-2 bg-light small text-break" style="word-break: break-all;">
            <%= webhooks_portal_events_url(portal: @active_portal) %>
          </div>
          <small class="text-muted d-block mt-2">Use o Webhook Secret configurado acima para assinatura HMAC-SHA256.</small>
        </div>
      </div>
    </div>

    <!-- Resumo do Feed -->
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white">
        <h6 class="fw-semibold mb-0"><i class="bi bi-bar-chart me-2"></i>Resumo do Feed</h6>
      </div>
      <div class="card-body">
        <div class="row g-3 text-center mb-3">
          <div class="col-md-4">
            <div class="border rounded p-3">
              <div class="display-6 fw-bold text-success"><%= current_preview[:eligible_count].to_i %></div>
              <small class="text-muted text-uppercase">Imóveis elegíveis</small>
            </div>
          </div>
          <div class="col-md-4">
            <div class="border rounded p-3">
              <div class="display-6 fw-bold text-warning"><%= current_preview[:rejected_count].to_i %></div>
              <small class="text-muted text-uppercase">Rejeitados</small>
            </div>
          </div>
          <div class="col-md-4">
            <div class="border rounded p-3">
              <div class="fw-bold mt-3">
                <%= current_integration.last_feed_at.present? ? l(current_integration.last_feed_at, format: :short) : "—" %>
              </div>
              <small class="text-muted text-uppercase">Último acesso</small>
            </div>
          </div>
        </div>

        <% if current_preview[:top_reasons].present? %>
          <div class="border-top pt-3">
            <small class="text-muted d-block mb-2 fw-semibold">Principais motivos de rejeição</small>
            <ul class="small mb-0">
              <% current_preview[:top_reasons].each do |reason, count| %>
                <li><%= reason.humanize %>: <strong><%= count %></strong> imóveis</li>
              <% end %>
            </ul>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Tabela de retornos -->
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white">
        <h6 class="fw-semibold mb-0"><i class="bi bi-clock-history me-2"></i>Últimos retornos do portal</h6>
      </div>
      <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
          <thead>
            <tr>
              <th>Código</th>
              <th>ID Externo</th>
              <th>Evento</th>
              <th>Status</th>
              <th>Atualizado em</th>
            </tr>
          </thead>
          <tbody>
            <% if @listing_states.any? %>
              <% @listing_states.each do |state| %>
                <tr>
                  <td><%= state.habitation_code.presence || "—" %></td>
                  <td><%= state.external_listing_id.presence || "—" %></td>
                  <td><%= state.last_event_type %></td>
                  <td><%= state.last_status.presence || "—" %></td>
                  <td><%= state.last_received_at.present? ? l(state.last_received_at, format: :short) : "—" %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="5" class="text-center text-muted py-4">
                  Sem eventos recebidos ainda. Eles aparecem aqui após o portal começar a sincronizar.
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
