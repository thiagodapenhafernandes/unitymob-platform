<%= ax_workspace_heading(eyebrow: "Integrações · Google", icon: "google", title: "Google", pills: [@active_tab.to_s.humanize], subtitle: "Configure os produtos Google usados pelos fluxos administrativos.") %>

<ul class="ax-form-tabs tw-mb-4">
  <li>
    <%= link_to admin_google_integration_path(tab: "sheets"), class: ["ax-form-tabs__item", ("active" if @active_tab == "sheets")].compact.join(" "), aria: { current: ("page" if @active_tab == "sheets") } do %>
      <i class="bi bi-table" aria-hidden="true"></i>Google Sheets
    <% end %>
  </li>
  <li>
    <%= link_to admin_google_integration_path(tab: "calendar"), class: ["ax-form-tabs__item", ("active" if @active_tab == "calendar")].compact.join(" "), aria: { current: ("page" if @active_tab == "calendar") } do %>
      <i class="bi bi-calendar2-week" aria-hidden="true"></i>Agenda
    <% end %>
  </li>
  <li>
    <%= link_to admin_google_integration_path(tab: "maps"), class: ["ax-form-tabs__item", ("active" if @active_tab == "maps")].compact.join(" "), aria: { current: ("page" if @active_tab == "maps") } do %>
      <i class="bi bi-map" aria-hidden="true"></i>Maps
    <% end %>
  </li>
</ul>

<div id="google-sheets" <%= "hidden" unless @active_tab == "sheets" %>>
  <%= ax_field_grid do %>
  <div class="ax-span-12">
    <%= ax_operational_panel(eyebrow: "Google Sheets", title: "Captações para planilha") do %>
      <div class="ax-panel-body">
        <%= ax_error_summary(@google_sheets_setting) %>

        <%= ax_inline_notice(tone: @google_sheets_setting.connected? ? :success : :warning, icon: @google_sheets_setting.connected? ? "check-circle" : "exclamation-triangle", class_name: "google-integration-status") do %>
          <span>
            Status:
            <strong><%= @google_sheets_setting.connected? ? "Credenciais configuradas" : "Aguardando configuração" %></strong>
          </span>
        <% end %>

        <%= form_with url: admin_google_integration_path, method: :patch, scope: :google_sheets, local: true do |f| %>
          <%= ax_switch_field(label: tag.span("Ativar sincronização de captações com Google Sheets", class: "tw-font-semibold"), form: f, method: :enabled, checked_value: "true", unchecked_value: "false", class_name: "tw-mb-3", input_html: { checked: @google_sheets_setting.enabled? }) %>

          <%= ax_text_field(form: f, method: :web_app_url, label: "URL do Web App do Apps Script", type: :url, value: @google_sheets_setting.web_app_url, placeholder: "https://script.google.com/macros/s/.../exec", hint: "URL publicada no Google Apps Script para receber e atualizar as captações.", field_class: "tw-mb-3") %>

          <%= ax_text_field(form: f, method: :token, label: "Token de segurança", type: :password, autocomplete: "off", placeholder: (@google_sheets_setting.token_configured? ? "Token já configurado. Preencha apenas para substituir." : "Crie um token simples para o Apps Script validar"), hint: "Este valor será enviado junto do payload e validado pelo Apps Script.", field_class: "tw-mb-3") %>

          <%= ax_field_grid do %>
            <div class="ax-span-6">
              <%= ax_text_field(form: f, method: :worksheet_name, label: "Nome da aba", value: @google_sheets_setting.worksheet_name, placeholder: GoogleSheetsIntegrationSetting::DEFAULT_WORKSHEET_NAME) %>
            </div>
            <div class="ax-span-6">
              <%= ax_text_field(form: f, method: :key_column, label: "Coluna-chave para atualização", value: @google_sheets_setting.key_column, placeholder: GoogleSheetsIntegrationSetting::DEFAULT_KEY_COLUMN, hint: "Padrão recomendado: Cód. imóvel CRM.") %>
            </div>
          <% end %>

          <%= ax_form_actions(sticky: false) do %><%= f.submit "Salvar configurações", class: "ax-btn ax-btn--primary" %><% end %>
        <% end %>
      </div>
    <% end %>
  </div>

  <% end %>
</div>

<div id="google-maps" <%= "hidden" unless @active_tab == "maps" %>>
  <%= render "maps", setting: @google_maps_setting %>
</div>

<div id="google-calendar" <%= "hidden" unless @active_tab == "calendar" %>>
  <%= ax_field_grid do %>
  <div class="ax-span-12">
    <%= ax_operational_panel(eyebrow: "Google Calendar", title: "Agenda de fotografia") do %>
      <div class="ax-panel-body">
        <%= ax_error_summary(@google_calendar_setting) %>

        <%= ax_inline_notice(tone: @google_calendar_setting.configured? ? :success : :warning, icon: @google_calendar_setting.configured? ? "check-circle" : "exclamation-triangle", class_name: "google-integration-status") do %>
          <span>
            Status:
            <strong><%= @google_calendar_setting.configured? ? "Agenda pronta para sincronizar" : "Aguardando configuração" %></strong>
            <% if @google_calendar_setting.missing_configuration_items.any? %>
              <span class="tw-text-ink-muted">(<%= @google_calendar_setting.missing_configuration_items.to_sentence %>)</span>
            <% end %>
          </span>
        <% end %>

        <%= form_with url: admin_google_integration_path, method: :patch, scope: :google_calendar, local: true do |f| %>
          <%= ax_switch_field(label: tag.span("Criar evento no Google Calendar quando a captação agendar fotógrafo", class: "tw-font-semibold"), form: f, method: :enabled, checked_value: "true", unchecked_value: "false", class_name: "tw-mb-3", input_html: { checked: @google_calendar_setting.enabled? }) %>

          <%= ax_text_field(form: f, method: :calendar_id, label: "ID da agenda", value: @google_calendar_setting.calendar_id.presence || GoogleCalendarIntegrationSetting::DEFAULT_CALENDAR_ID, placeholder: GoogleCalendarIntegrationSetting::DEFAULT_CALENDAR_ID, hint: "Use o e-mail ou Calendar ID e compartilhe a agenda com o client_email da service account.", field_class: "tw-mb-3") %>

          <%= ax_number_field(form: f, method: :default_duration_minutes, label: "Duração padrão do evento", value: @google_calendar_setting.default_duration_minutes.presence || GoogleCalendarIntegrationSetting::DEFAULT_DURATION_MINUTES, min: GoogleCalendarIntegrationSetting::MIN_DURATION_MINUTES, max: GoogleCalendarIntegrationSetting::MAX_DURATION_MINUTES, step: 15, class_name: "tw-mb-3") %>

          <%= ax_text_field(form: f, method: :service_account_json, label: "JSON da service account", type: :textarea, rows: 8, autocomplete: "off", placeholder: (@google_calendar_setting.service_account_configured? ? "Credencial já configurada. Cole um novo JSON apenas para substituir." : "{\"type\":\"service_account\",...}"), hint: "A chave privada fica criptografada no banco e o conteúdo salvo não é exibido novamente.", field_class: "tw-mb-3") %>

          <%= ax_form_actions(sticky: false) do %><%= f.submit "Salvar agenda", class: "ax-btn ax-btn--primary" %><% end %>
        <% end %>

        <hr class="tw-my-4">

        <%= button_to test_calendar_admin_google_integration_path,
              method: :post,
              class: "ax-btn ax-btn--ghost",
              disabled: !@google_calendar_setting.configured? do %>
          <i class="bi bi-calendar-check me-2"></i>Criar evento de teste
        <% end %>
      </div>
    <% end %>
  </div>

  <% end %>
</div>
