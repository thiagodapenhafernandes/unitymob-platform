<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
<%
  content = case @reason
  when :expired
    { icon: "⏳", title: "Link expirado",
      text: "Este link atingiu o prazo configurado e expirou. Acesse o lead diretamente pela plataforma." }
  when :inactive
    { icon: "🚫", title: "Link desativado",
      text: "Este link foi desativado e não é mais válido. Acesse o lead diretamente pela plataforma." }
  else
    { icon: "🔍", title: "Link não encontrado",
      text: "Este link não existe ou foi removido — o lead pode ter sido recriado. Acesse o lead diretamente pela plataforma." }
  end
%>
  <meta name="robots" content="noindex, nofollow">
  <title><%= content[:title] %></title>
  <style>
    body { margin:0; font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif; background:#f1f5f9; color:#0f172a; }
    .wrap { max-width:420px; margin:0 auto; padding:64px 20px; text-align:center; }
    .icon { font-size:44px; color:#d97706; }
    h1 { font-size:20px; margin:12px 0 6px; }
    p { color:#64748b; font-size:15px; line-height:1.5; }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="icon"><%= content[:icon] %></div>
    <h1><%= content[:title] %></h1>
    <p><%= content[:text] %></p>
  </div>
</body>
</html>
