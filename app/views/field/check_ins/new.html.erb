<style>
  .field-status-banner {
    border-radius: 16px;
    padding: 1.5rem;
    text-align: center;
    margin-bottom: 1rem;
  }
  .status-ok      { background: #d1e7dd; color: #0a3622; }
  .status-warn    { background: #fff3cd; color: #664d03; }
  .status-error   { background: #f8d7da; color: #58151c; }
  .status-info    { background: #cff4fc; color: #055160; }
  .status-neutral { background: #e9ecef; color: #495057; }
</style>

<div class="d-flex align-items-center mb-3">
  <%= link_to field_root_path, class: "btn btn-sm btn-light border me-2" do %>
    <i class="bi bi-arrow-left"></i>
  <% end %>
  <h5 class="fw-bold mb-0">Check-in</h5>
</div>

<% if @active_check_in %>
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
      <div class="small text-muted">
        <i class="bi bi-broadcast-pin text-success me-1"></i>Você já está em check-in
      </div>
      <div class="fw-bold fs-5 mt-1"><%= @active_check_in.store.name %></div>
      <div class="small text-muted mt-1">
        Iniciado <%= time_ago_in_words(@active_check_in.checked_in_at) %> atrás
      </div>
      <%= button_to check_out_field_check_in_path(@active_check_in),
                    method: :patch,
                    class: "btn btn-outline-danger w-100 mt-3",
                    data: { turbo_confirm: "Confirmar check-out?" } do %>
        <i class="bi bi-box-arrow-left me-1"></i>Fazer check-out
      <% end %>
    </div>
  </div>
<% else %>
  <div id="field-status" class="field-status-banner status-neutral"
       data-controller="field-geolocation"
       data-field-geolocation-discover-url-value="<%= field_stores_discover_path %>">
    <div data-field-geolocation-target="statusIcon" class="mb-2">
      <i class="bi bi-geo-alt" style="font-size: 2.5rem;"></i>
    </div>
    <div data-field-geolocation-target="statusTitle" class="fw-bold fs-5 mb-1">Procurando sua localização…</div>
    <div data-field-geolocation-target="statusDescription" class="small">
      Permita o acesso ao GPS para continuar.
    </div>
  </div>

  <div data-controller="field-checkin"
       data-field-checkin-mode-value="new"
       data-field-checkin-create-url-value="<%= field_check_ins_path %>"
       data-field-checkin-csrf-value="<%= form_authenticity_token %>">
    <button class="btn btn-primary w-100 py-3 fw-bold"
            disabled
            data-field-geolocation-target="checkinButton"
            data-field-checkin-target="actionButton"
            data-action="click->field-checkin#checkIn">
      <i class="bi bi-box-arrow-in-right me-2"></i>Fazer Check-in
    </button>
  </div>

  <div class="text-center mt-3">
    <%= link_to new_field_manual_checkin_request_path, class: "small text-muted text-decoration-none" do %>
      <i class="bi bi-hand-index-thumb me-1"></i>Não consegui fazer check-in (pedir revisão manual)
    <% end %>
  </div>
<% end %>
