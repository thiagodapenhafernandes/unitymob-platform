<%
  hour = Time.current.hour
  greeting = if hour < 12 then "Bom dia"
             elsif hour < 18 then "Boa tarde"
             else "Boa noite"
             end
  first_name = @admin_user.name.to_s.split.first.presence || @admin_user.email.to_s.split("@").first
  pending_count = @field_priorities.size
%>

<style>
  .field-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .75rem;
    margin-bottom: .75rem;
  }
  .field-header__greeting { color: #667085; font-size: .78rem; line-height: 1.2; }
  .field-header__name { color: #111827; font-size: 1.08rem; font-weight: 800; line-height: 1.2; margin: .1rem 0 0; }
  .field-logout {
    align-items: center;
    background: #fff;
    border: 1px solid #d8dee8;
    border-radius: 10px;
    color: #475467;
    display: inline-flex;
    height: 42px;
    justify-content: center;
    width: 42px;
  }

  .field-hero {
    background: linear-gradient(135deg, #0f6bf2 0%, #0b56c5 100%);
    border-radius: 16px;
    color: #fff;
    display: grid;
    gap: .7rem;
    margin-bottom: .75rem;
    padding: 1rem;
  }
  .field-hero__top {
    align-items: center;
    display: flex;
    gap: .5rem;
    justify-content: space-between;
  }
  .field-hero__date { font-size: .78rem; font-weight: 700; opacity: .86; }
  .field-hero__status {
    background: rgba(255,255,255,.16);
    border: 1px solid rgba(255,255,255,.22);
    border-radius: 999px;
    font-size: .68rem;
    font-weight: 800;
    padding: .22rem .55rem;
    white-space: nowrap;
  }
  .field-hero__title { font-size: 1.16rem; font-weight: 850; line-height: 1.15; }
  .field-hero__subtitle { font-size: .82rem; line-height: 1.35; opacity: .86; }

  .field-checkin-cta {
    align-items: center;
    background: #fff;
    border: 1px solid #dbe4f0;
    border-radius: 16px;
    box-shadow: 0 8px 18px rgba(15, 23, 42, .08);
    color: inherit;
    display: flex;
    gap: .8rem;
    margin: -.15rem 0 .75rem;
    padding: .9rem 1rem;
    text-decoration: none;
  }
  .field-checkin-cta--primary {
    background: linear-gradient(135deg, #16a34a 0%, #0f8a3d 100%);
    border-color: #0f8a3d;
    color: #fff;
  }
  .field-checkin-cta--active {
    background: linear-gradient(135deg, #0f6bf2 0%, #0b56c5 100%);
    border-color: #0b56c5;
    color: #fff;
  }
  .field-checkin-cta--paused {
    background: #fff7ed;
    border-color: #fed7aa;
    color: #9a3412;
  }
  .field-checkin-cta__icon {
    align-items: center;
    background: rgba(255, 255, 255, .18);
    border-radius: 14px;
    display: inline-flex;
    flex: 0 0 48px;
    height: 48px;
    justify-content: center;
    width: 48px;
  }
  .field-checkin-cta--paused .field-checkin-cta__icon {
    background: #ffedd5;
  }
  .field-checkin-cta__icon i { font-size: 1.55rem; }
  .field-checkin-cta__copy {
    display: grid;
    gap: .18rem;
    min-width: 0;
  }
  .field-checkin-cta__title {
    font-size: 1rem;
    font-weight: 900;
    line-height: 1.1;
  }
  .field-checkin-cta__subtitle {
    font-size: .74rem;
    line-height: 1.25;
    opacity: .85;
  }
  .field-checkin-cta__chevron {
    font-size: 1.15rem;
    margin-left: auto;
    opacity: .8;
  }

  .field-kpi-grid {
    display: grid;
    gap: .5rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-bottom: .75rem;
  }
  .field-kpi {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    color: inherit;
    display: grid;
    gap: .28rem;
    min-height: 82px;
    padding: .75rem .55rem;
    text-align: center;
    text-decoration: none;
  }
  .field-kpi__value { font-size: 1.42rem; font-weight: 850; line-height: 1; }
  .field-kpi__label {
    color: #64748b;
    font-size: .64rem;
    font-weight: 850;
    letter-spacing: .02em;
    line-height: 1.15;
    text-transform: uppercase;
  }
  .field-kpi__hint { color: #98a2b3; font-size: .64rem; line-height: 1.15; }

  .field-panel {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    box-shadow: 0 2px 8px rgba(15,23,42,.05);
    margin-bottom: .75rem;
    overflow: hidden;
  }
  .field-panel__header {
    align-items: center;
    border-bottom: 1px solid #eef2f7;
    display: flex;
    gap: .75rem;
    justify-content: space-between;
    padding: .9rem 1rem .75rem;
  }
  .field-panel__title { color: #111827; font-size: .98rem; font-weight: 850; line-height: 1.2; margin: 0; }
  .field-panel__link { font-size: .76rem; font-weight: 800; text-decoration: none; white-space: nowrap; }
  .field-panel__body { padding: .35rem 1rem 1rem; }

  .field-priority-list { display: grid; gap: .55rem; }
  .field-priority {
    align-items: center;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    color: inherit;
    display: flex;
    gap: .75rem;
    padding: .72rem;
    text-decoration: none;
  }
  .field-priority__icon {
    align-items: center;
    border-radius: 12px;
    display: inline-flex;
    flex: 0 0 38px;
    height: 38px;
    justify-content: center;
    width: 38px;
  }
  .field-priority__copy { min-width: 0; }
  .field-priority__title { color: #111827; font-size: .86rem; font-weight: 850; line-height: 1.18; }
  .field-priority__desc { color: #667085; font-size: .72rem; line-height: 1.25; margin-top: .12rem; }
  .field-priority__chevron { color: #cbd5e1; margin-left: auto; }

  .field-action-grid {
    display: grid;
    gap: .5rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-bottom: .75rem;
  }
  .field-action-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    color: inherit;
    display: grid;
    gap: .55rem;
    min-height: 112px;
    padding: .85rem;
    text-decoration: none;
  }
  .field-action-card:active, .field-priority:active, .field-kpi:active { transform: scale(.985); }
  .field-action-card__icon {
    align-items: center;
    border-radius: 12px;
    display: inline-flex;
    height: 38px;
    justify-content: center;
    width: 38px;
  }
  .field-action-card__title { color: #111827; font-size: .9rem; font-weight: 850; line-height: 1.12; }
  .field-action-card__subtitle { color: #667085; font-size: .7rem; line-height: 1.22; margin-top: .14rem; }

  .field-lead-list, .field-captacao-list { display: grid; gap: .65rem; }
  .field-lead {
    border-bottom: 1px solid #eef2f7;
    display: grid;
    gap: .55rem;
    padding-bottom: .65rem;
  }
  .field-lead:last-child, .field-captacao:last-child { border-bottom: 0; padding-bottom: 0; }
  .field-lead__main {
    align-items: flex-start;
    display: flex;
    gap: .75rem;
    justify-content: space-between;
  }
  .field-lead__name {
    color: #111827;
    display: inline-block;
    font-size: .92rem;
    font-weight: 850;
    line-height: 1.18;
    text-decoration: none;
  }
  .field-lead__meta {
    color: #667085;
    display: flex;
    flex-wrap: wrap;
    font-size: .7rem;
    gap: .3rem;
    line-height: 1.2;
    margin-top: .25rem;
  }
  .field-lead__time { color: #667085; flex: 0 0 auto; font-size: .68rem; line-height: 1.2; text-align: right; }
  .field-lead__actions { display: flex; gap: .45rem; }
  .min-w-0 { min-width: 0; }
  .field-contact-btn {
    align-items: center;
    border: 1px solid #d8dee8;
    border-radius: 9px;
    color: #334155;
    display: inline-flex;
    flex: 1 1 0;
    font-size: .72rem;
    font-weight: 850;
    gap: .35rem;
    justify-content: center;
    min-height: 34px;
    text-decoration: none;
  }
  .field-contact-btn--whatsapp { background: #ecfdf3; border-color: #bbf7d0; color: #047857; }

  .field-captacao {
    align-items: center;
    border-bottom: 1px solid #eef2f7;
    display: flex;
    gap: .75rem;
    justify-content: space-between;
    padding-bottom: .65rem;
  }
  .field-captacao__title { color: #111827; font-size: .86rem; font-weight: 850; line-height: 1.18; }
  .field-captacao__meta { color: #667085; font-size: .7rem; line-height: 1.25; margin-top: .15rem; }
  .field-empty { color: #667085; font-size: .8rem; line-height: 1.35; margin: .45rem 0 0; }

  @media (max-width: 360px) {
    .field-action-grid { grid-template-columns: minmax(0, 1fr); }
    .field-kpi { padding-left: .35rem; padding-right: .35rem; }
  }
</style>

<div class="field-header">
  <div>
    <div class="field-header__greeting"><i class="bi bi-sun-fill text-warning me-1"></i><%= greeting %>,</div>
    <h1 class="field-header__name"><%= @admin_user.name.presence || @admin_user.email %></h1>
  </div>
  <%= button_to destroy_admin_user_session_path, method: :delete, class: "field-logout", title: "Sair" do %>
    <i class="bi bi-box-arrow-right"></i>
  <% end %>
</div>

<%# Multi-conta no PWA: mesma regra do admin — SÓ Admin de Contas alterna. %>
<% if (@admin_user.login_identity.tenant_owner? rescue false) %>
  <% accounts = (@admin_user.switchable_accounts rescue []) %>
  <% if accounts.size > 1 %>
    <section style="margin:0 0 10px;background:#fff;border:1px solid #e6e8eb;border-radius:10px;padding:10px 12px;">
      <div style="font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.05em;color:#697586;margin-bottom:6px;">
        <i class="bi bi-arrow-left-right"></i> Minhas contas
      </div>
      <div style="display:flex;flex-wrap:wrap;gap:6px;">
        <% accounts.each do |entry| %>
          <% if entry[:admin_user].id == @admin_user.id %>
            <span class="ax-badge ax-badge--blue"><i class="bi bi-check2"></i> <%= entry[:tenant].name %></span>
          <% else %>
            <%= button_to admin_account_switch_path(tenant_id: entry[:tenant].id, context: "field"), method: :post,
                  form: { data: { turbo: false }, style: "display:inline" },
                  style: "border:1px solid #d2d6db;background:#fff;border-radius:999px;padding:3px 10px;font-size:11px;font-weight:700;color:#344054;" do %>
              <%= entry[:tenant].name %>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </section>
  <% end %>
<% end %>

<section class="field-hero">
  <div class="field-hero__top">
    <span class="field-hero__date"><i class="bi bi-calendar3 me-1"></i><%= l(Date.current, format: :long) %></span>
    <span class="field-hero__status"><%= pending_count.positive? ? "#{pending_count} prioridade(s)" : "Sem prioridade crítica" %></span>
  </div>
  <div>
    <div class="field-hero__title">Olá, <%= first_name %>!</div>
    <div class="field-hero__subtitle">
      <% if @active_check_in %>
        <i class="bi bi-broadcast-pin me-1"></i>Check-in ativo em <strong><%= @active_check_in.store.name %></strong>
      <% elsif @pending_leads_count.positive? %>
        Comece pelos leads novos e finalize as captações abertas.
      <% else %>
        Você está sem leads novos pendentes agora.
      <% end %>
    </div>
  </div>
</section>

<% if @active_check_in %>
  <%= link_to new_field_check_in_path, class: "field-checkin-cta field-checkin-cta--active" do %>
    <span class="field-checkin-cta__icon"><i class="bi bi-broadcast-pin"></i></span>
    <span class="field-checkin-cta__copy">
      <span class="field-checkin-cta__title">Check-in ativo</span>
      <span class="field-checkin-cta__subtitle"><%= @active_check_in.store.name %> · toque para ver ou fazer check-out</span>
    </span>
    <i class="bi bi-chevron-right field-checkin-cta__chevron"></i>
  <% end %>
<% elsif @field_enabled && @field_agent_allowed %>
  <%= link_to new_field_check_in_path, class: "field-checkin-cta field-checkin-cta--primary" do %>
    <span class="field-checkin-cta__icon"><i class="bi bi-geo-alt-fill"></i></span>
    <span class="field-checkin-cta__copy">
      <span class="field-checkin-cta__title">Fazer check-in agora</span>
      <span class="field-checkin-cta__subtitle">Usar GPS para entrar na loja mais próxima</span>
    </span>
    <i class="bi bi-chevron-right field-checkin-cta__chevron"></i>
  <% end %>
<% elsif !@field_enabled %>
  <div class="field-checkin-cta field-checkin-cta--paused" role="status">
    <span class="field-checkin-cta__icon"><i class="bi bi-pause-circle"></i></span>
    <span class="field-checkin-cta__copy">
      <span class="field-checkin-cta__title">Check-in indisponível</span>
      <span class="field-checkin-cta__subtitle">A operação de check-in não está aberta no momento.</span>
    </span>
  </div>
<% else %>
  <div class="field-checkin-cta field-checkin-cta--paused" role="status">
    <span class="field-checkin-cta__icon"><i class="bi bi-person-lock"></i></span>
    <span class="field-checkin-cta__copy">
      <span class="field-checkin-cta__title">Check-in indisponível</span>
      <span class="field-checkin-cta__subtitle">Sua operação ainda não está liberada para check-in.</span>
    </span>
  </div>
<% end %>

<div class="field-kpi-grid">
  <%= link_to admin_leads_path(status: Lead.status_value(:novo)), class: "field-kpi" do %>
    <span class="field-kpi__value text-warning"><%= @pending_leads_count %></span>
    <span class="field-kpi__label"><i class="bi bi-megaphone me-1"></i>Leads a atender</span>
    <span class="field-kpi__hint"><%= @my_leads_today %> hoje</span>
  <% end %>

  <%= link_to admin_captacoes_path(status: "draft"), class: "field-kpi" do %>
    <span class="field-kpi__value text-primary"><%= @my_active_captacoes %></span>
    <span class="field-kpi__label"><i class="bi bi-journal me-1"></i>Captações abertas</span>
    <span class="field-kpi__hint"><%= @my_pending_review_captacoes %> em revisão</span>
  <% end %>

  <%= link_to admin_habitations_path(ownership: "all", exibir_no_site: "1"), class: "field-kpi" do %>
    <span class="field-kpi__value text-info"><%= @my_published_habitations %></span>
    <span class="field-kpi__label"><i class="bi bi-building me-1"></i>Imóveis no site</span>
    <span class="field-kpi__hint"><%= @my_total_habitations %> no total</span>
  <% end %>
</div>

<section class="field-panel">
  <div class="field-panel__header">
    <h2 class="field-panel__title"><i class="bi bi-lightning-charge text-primary me-1"></i>Prioridades</h2>
    <%= link_to "Ver leads", admin_leads_path, class: "field-panel__link" %>
  </div>
  <div class="field-panel__body">
    <% if @field_priorities.any? %>
      <div class="field-priority-list">
        <% @field_priorities.each do |item| %>
          <%= link_to item[:path], class: "field-priority" do %>
            <span class="field-priority__icon bg-<%= item[:tone] %>-subtle text-<%= item[:tone] %>">
              <i class="bi bi-<%= item[:icon] %>"></i>
            </span>
            <span class="field-priority__copy">
              <span class="field-priority__title"><%= item[:title] %></span>
              <span class="field-priority__desc"><%= item[:description] %></span>
            </span>
            <i class="bi bi-chevron-right field-priority__chevron"></i>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <p class="field-empty">Nenhuma pendência crítica para agora.</p>
    <% end %>
  </div>
</section>

<div class="field-action-grid">
  <%= link_to new_admin_captacao_path, class: "field-action-card" do %>
    <span class="field-action-card__icon bg-success-subtle text-success"><i class="bi bi-journal-plus"></i></span>
    <span>
      <span class="field-action-card__title">Nova captação</span>
      <span class="field-action-card__subtitle d-block">Residencial, comercial ou terreno</span>
    </span>
  <% end %>

  <%= link_to admin_captacoes_path, class: "field-action-card" do %>
    <span class="field-action-card__icon bg-primary-subtle text-primary"><i class="bi bi-journals"></i></span>
    <span>
      <span class="field-action-card__title">Minhas captações</span>
      <span class="field-action-card__subtitle d-block"><%= @my_active_captacoes %> abertas</span>
    </span>
  <% end %>

  <%= link_to admin_leads_path, class: "field-action-card" do %>
    <span class="field-action-card__icon bg-warning-subtle text-warning"><i class="bi bi-megaphone-fill"></i></span>
    <span>
      <span class="field-action-card__title">Meus leads</span>
      <span class="field-action-card__subtitle d-block"><%= @in_service_leads_count %> em atendimento</span>
    </span>
  <% end %>

  <%= link_to admin_habitations_path(ownership: "all"), class: "field-action-card" do %>
    <span class="field-action-card__icon bg-info-subtle text-info"><i class="bi bi-buildings"></i></span>
    <span>
      <span class="field-action-card__title">Imóveis</span>
      <span class="field-action-card__subtitle d-block">Portfólio geral</span>
    </span>
  <% end %>

  <% if @field_enabled && @field_agent_allowed %>
    <%= link_to new_field_check_in_path, class: "field-action-card" do %>
      <span class="field-action-card__icon bg-danger-subtle text-danger"><i class="bi bi-geo-alt-fill"></i></span>
      <span>
        <span class="field-action-card__title"><%= @active_check_in ? "Check-in ativo" : "Fazer check-in" %></span>
        <span class="field-action-card__subtitle d-block">GPS e loja próxima</span>
      </span>
    <% end %>
  <% end %>
</div>

<% if @recent_my_leads.any? %>
  <section class="field-panel">
    <div class="field-panel__header">
      <h2 class="field-panel__title"><i class="bi bi-clock-history text-primary me-1"></i>Leads recentes</h2>
      <%= link_to "Ver todos", admin_leads_path, class: "field-panel__link" %>
    </div>
    <div class="field-panel__body">
      <div class="field-lead-list">
        <% @recent_my_leads.each do |lead| %>
          <%
            property = @lead_properties_by_id[lead.property_id]
            phone_digits = lead.display_phone.to_s.gsub(/[^0-9+]/, "")
          %>
          <article class="field-lead">
            <div class="field-lead__main">
              <div class="min-w-0">
                <%= link_to lead.display_name, admin_lead_path(lead), class: "field-lead__name" %>
                <div class="field-lead__meta">
                  <span><i class="bi bi-circle-fill text-<%= Lead.status_badge_class(lead.status) %> me-1" style="font-size:.45rem;"></i><%= lead.status.presence || Lead.default_status %></span>
                  <span><i class="bi bi-bullseye me-1"></i><%= lead.origin.presence || "Origem não informada" %></span>
                  <% if property %>
                    <span><i class="bi bi-house-door me-1"></i><%= property.codigo.presence || property.titulo_anuncio %></span>
                  <% end %>
                </div>
              </div>
              <div class="field-lead__time"><%= time_ago_in_words(lead.created_at) %></div>
            </div>
            <div class="field-lead__actions">
              <% if whatsapp_inbox_attendance? && lead.whatsapp_recipient.present? %>
                <%= link_to admin_lead_path(lead, anchor: "whatsapp"), class: "field-contact-btn field-contact-btn--whatsapp" do %>
                  <i class="bi bi-whatsapp"></i>WhatsApp
                <% end %>
              <% elsif lead.direct_whatsapp_url.present? %>
                <%= link_to lead.direct_whatsapp_url, target: "_blank", rel: "noopener", class: "field-contact-btn field-contact-btn--whatsapp" do %>
                  <i class="bi bi-whatsapp"></i>WhatsApp
                <% end %>
              <% end %>
              <% if phone_digits.present? %>
                <%= link_to "tel:#{phone_digits}", class: "field-contact-btn" do %>
                  <i class="bi bi-telephone"></i>Ligar
                <% end %>
              <% end %>
              <%= link_to admin_lead_path(lead), class: "field-contact-btn" do %>
                <i class="bi bi-kanban"></i>Atender
              <% end %>
            </div>
          </article>
        <% end %>
      </div>
    </div>
  </section>
<% end %>

<% if @recent_open_captacoes.any? %>
  <section class="field-panel">
    <div class="field-panel__header">
      <h2 class="field-panel__title"><i class="bi bi-journal-check text-primary me-1"></i>Captações abertas</h2>
      <%= link_to "Ver todas", admin_captacoes_path, class: "field-panel__link" %>
    </div>
    <div class="field-panel__body">
      <div class="field-captacao-list">
        <% @recent_open_captacoes.each do |captacao| %>
          <article class="field-captacao">
            <div>
              <div class="field-captacao__title"><%= captacao.titulo_anuncio.presence || [captacao.categoria, captacao.bairro, captacao.cidade].compact_blank.join(" · ").presence || "Captação sem título" %></div>
              <div class="field-captacao__meta"><%= captacao.intake_status_label %> · atualizada <%= time_ago_in_words(captacao.updated_at) %></div>
            </div>
            <%= link_to edit_admin_captacao_path(captacao), class: "field-contact-btn flex-grow-0 px-3" do %>
              Continuar
            <% end %>
          </article>
        <% end %>
      </div>
    </div>
  </section>
<% end %>

<div class="text-center mt-4">
  <%= link_to new_field_manual_checkin_request_path, class: "small text-muted text-decoration-none d-none" do %>
    <i class="bi bi-hand-index-thumb me-1"></i>Precisa de check-in manual?
  <% end %>
</div>
