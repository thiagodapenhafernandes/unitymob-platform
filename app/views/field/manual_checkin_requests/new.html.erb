<div class="min-h-screen p-4">
  <div class="flex items-center justify-between mb-4">
    <h1 class="text-lg font-bold flex items-center gap-2">
      <i class="bi bi-hand-index-thumb-fill text-yellow-500"></i>
      Check-in manual
    </h1>
    <%= link_to field_root_path, class: "text-sm text-gray-500 hover:text-gray-700" do %>
      <i class="bi bi-x-lg"></i>
    <% end %>
  </div>

  <div class="rounded-lg bg-yellow-50 border border-yellow-200 p-3 mb-4 text-sm text-yellow-800">
    <i class="bi bi-info-circle-fill me-1"></i>
    Use somente quando o GPS falhou. Todo pedido é auditado e revisado pelo admin.
  </div>

  <%= form_with model: @request, url: field_manual_checkin_requests_path, local: true, class: "space-y-4" do |f| %>
    <% if @request.errors.any? %>
      <div class="rounded bg-red-50 border border-red-200 p-3 text-sm text-red-700">
        <% @request.errors.full_messages.each do |msg| %>
          <div><i class="bi bi-exclamation-triangle-fill me-1"></i><%= msg %></div>
        <% end %>
      </div>
    <% end %>

    <div>
      <label class="block text-sm font-semibold mb-1">
        <i class="bi bi-shop text-green-600 me-1"></i>Loja
      </label>
      <%= f.collection_select :store_id, @stores, :id, :name,
            { prompt: "Selecione a loja" },
            class: "w-full rounded border-gray-300 text-sm" %>
    </div>

    <div>
      <label class="block text-sm font-semibold mb-1">
        <i class="bi bi-pencil-fill text-blue-600 me-1"></i>Justificativa
      </label>
      <%= f.text_area :justification, rows: 6,
            class: "w-full rounded border-gray-300 text-sm",
            placeholder: "Descreva por que não foi possível fazer check-in normal (mínimo 10 caracteres)." %>
      <p class="text-xs text-gray-500 mt-1">
        Entre 10 e 1000 caracteres. Seja específico — o admin usa isso para aprovar.
      </p>
    </div>

    <div class="pt-2 flex gap-2">
      <%= link_to "Cancelar", field_root_path, class: "flex-1 text-center py-3 rounded border border-gray-300 text-sm font-semibold" %>
      <%= f.submit "Enviar solicitação", class: "flex-1 py-3 rounded bg-yellow-500 text-white text-sm font-semibold" %>
    </div>
  <% end %>
</div>
