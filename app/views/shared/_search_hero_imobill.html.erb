<!-- Imobill-Style Search Component (Tabs Outside) -->
<% search_filter_style = [
  "--search-filter-bg: #{@home_setting.search_filter_background_rgba}",
  "--search-filter-border: #{@home_setting.search_filter_border_style}",
  "--search-filter-text: #{@home_setting.search_filter_text_color_value}",
  "--search-filter-field-bg: #{@home_setting.search_filter_field_background_rgba}",
  "--search-filter-blur: #{@home_setting.search_filter_backdrop_blur_value}px",
  "--search-filter-radius: #{@home_setting.search_filter_border_radius_value}px"
].join("; ") %>
<% search_filter_field_style = "background-color: var(--search-filter-field-bg); border: var(--search-filter-border);" %>
<% search_filter_divider_style = "border-top: var(--search-filter-border);" %>
<% search_filter_right_border_style = "border-right: var(--search-filter-border);" %>
<% search_filter_chip_border_style = "border: var(--search-filter-border);" %>

<div class="w-full max-w-5xl mx-auto mt-4 md:mt-8 relative z-20"
     data-controller="search-tabs"
     data-search-tabs-sale-price-options-value="<%= json_escape(public_price_range_options("venda").to_json) %>"
     data-search-tabs-rent-price-options-value="<%= json_escape(public_price_range_options("aluguel").to_json) %>">

  <!-- Tabs (Comprar / Alugar) - Outside and Centered -->
  <div class="flex justify-center mb-3 md:mb-4">
    <div class="inline-flex rounded-full border border-white/40 bg-white/85 p-1.5 shadow-[0_12px_34px_rgba(8,31,48,0.18)] backdrop-blur-xl">
      <button type="button"
              class="px-6 sm:px-8 py-2 rounded-full text-sm font-bold text-hero-button-text bg-hero-button shadow-sm transition-all active-tab"
              data-search-tabs-target="tab"
              data-action="click->search-tabs#switch"
              data-value="venda">
        Comprar
      </button>
      <button type="button"
              class="px-6 sm:px-8 py-2 rounded-full text-sm font-bold text-gray-600 hover:text-blue-three transition-all"
              data-search-tabs-target="tab"
              data-action="click->search-tabs#switch"
              data-value="aluguel">
        Alugar
      </button>
    </div>
  </div>

  <!-- Search Form Container -->
  <div class="relative z-30 shadow-[0_24px_80px_rgba(8,31,48,0.24)]"
       style="<%= search_filter_style %>; background-color: var(--search-filter-bg); border: var(--search-filter-border); border-radius: var(--search-filter-radius); color: var(--search-filter-text); backdrop-filter: blur(var(--search-filter-blur)); -webkit-backdrop-filter: blur(var(--search-filter-blur));">
    <%= form_with url: habitations_path, method: :get, class: "p-3 sm:p-4" do |f| %>

      <input type="hidden" name="transaction_type" id="transaction_type_input" value="<%= params[:transaction_type] || 'venda' %>" data-search-tabs-target="input">
      <% selected_characteristics = Array(params[:characteristics]).map(&:to_s) %>
      <% price_range_options = public_price_range_options(params[:transaction_type]) %>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-3 md:gap-4 items-center">
        
        <!-- Tipo de Imóvel (Checklist Dropdown) -->
        <div class="md:col-span-3" data-controller="category-filter">
          <label class="sr-only">Tipos de imóveis</label>
          <% selected_categories = Array(params[:category]).reject(&:blank?) %>
          <div class="relative">
            <button type="button"
                    class="relative flex w-full min-h-[48px] items-center rounded-full border border-gray-200/80 bg-white/85 pl-10 pr-10 py-3 text-left text-sm font-medium text-gray-700 shadow-sm transition-colors focus:border-blue-three focus:ring-1 focus:ring-blue-three"
                    style="<%= search_filter_field_style %>"
                    data-category-filter-target="trigger"
                    data-action="click->category-filter#toggle">
              <i class="bi bi-building absolute left-3 top-1/2 -translate-y-1/2 text-current opacity-45"></i>
              <span class="truncate" data-category-filter-target="summary">Tipos de imóveis</span>
              <i class="bi bi-chevron-down absolute right-3 top-1/2 -translate-y-1/2 text-current opacity-45"></i>
            </button>

            <div class="hidden absolute top-full left-0 right-0 mt-1 bg-white border border-gray-200 rounded-xl shadow-xl z-[70] max-h-[300px] overflow-y-auto overscroll-contain p-2"
                 style="-webkit-overflow-scrolling: touch;"
                 data-category-filter-target="panel">
              <label class="flex items-center gap-2 px-2 py-2 rounded-md hover:bg-gray-50 cursor-pointer border-b border-gray-100 mb-1">
                <input type="checkbox" class="form-check-input mt-0" data-category-filter-target="allCheckbox" data-action="change->category-filter#toggleAll">
                <span class="text-sm font-semibold text-gray-700">Todos</span>
              </label>

              <% (@property_types || []).each do |type| %>
                <% checked = selected_categories.include?(type) %>
                <label class="flex items-center gap-2 px-2 py-2 rounded-md hover:bg-gray-50 cursor-pointer">
                  <input type="checkbox"
                         value="<%= type %>"
                         class="form-check-input mt-0"
                         data-category-filter-target="checkbox"
                         data-action="change->category-filter#sync"
                         <%= "checked" if checked %>>
                  <span class="text-sm text-gray-700"><%= type %></span>
                </label>
              <% end %>
            </div>
          </div>

          <div data-category-filter-target="hiddenContainer">
            <% selected_categories.each do |category| %>
              <input type="hidden" name="category[]" value="<%= category %>">
            <% end %>
          </div>
        </div>
        
        <!-- Localização (Checklist Multiseleção) -->
        <div class="md:col-span-4" data-controller="location-filter">
          <label class="sr-only">Localização</label>
          <% selected_locations = Array(params[:city]).reject(&:blank?) %>
          <div class="relative">
            <button type="button"
                    class="relative flex w-full min-h-[48px] items-center rounded-full border border-gray-200/80 bg-white/85 pl-10 pr-10 py-3 text-left text-sm font-medium text-gray-700 shadow-sm transition-colors focus:border-blue-three focus:ring-1 focus:ring-blue-three"
                    style="<%= search_filter_field_style %>"
                    data-location-filter-target="trigger"
                    data-action="click->location-filter#toggle">
              <i class="bi bi-geo-alt absolute left-3 top-1/2 -translate-y-1/2 text-current opacity-45"></i>
              <span class="truncate" data-location-filter-target="summary">Selecione bairros ou cidades</span>
              <i class="bi bi-chevron-down absolute right-3 top-1/2 -translate-y-1/2 text-current opacity-45"></i>
            </button>

            <div class="hidden absolute top-full left-0 right-0 mt-1 bg-white border border-gray-200 rounded-xl shadow-xl z-[70] max-h-[320px] overflow-y-auto overscroll-contain p-2"
                 style="-webkit-overflow-scrolling: touch;"
                 data-location-filter-target="panel">
              <div class="sticky top-0 z-10 bg-white pb-2 space-y-2">
                <div class="flex items-center justify-between px-1 pt-1">
                  <span class="text-[11px] font-semibold uppercase tracking-wide text-gray-500">Localização</span>
                  <div class="flex items-center gap-2">
                    <span class="text-[11px] text-gray-500" data-location-filter-target="count">0 selecionados</span>
                    <button type="button"
                            class="text-[11px] font-semibold text-blue-three hover:underline"
                            data-action="click->location-filter#clear">
                      Limpar
                    </button>
                  </div>
                </div>
                <input type="text"
                       placeholder="Filtrar bairros/cidades"
                       class="w-full px-3 py-2 border border-gray-200 rounded-md text-sm focus:ring-1 focus:ring-blue-three focus:border-blue-three"
                       data-location-filter-target="search"
                       data-action="input->location-filter#filter">
              </div>

              <label class="flex items-center gap-2 px-2 py-2 rounded-md hover:bg-gray-50 cursor-pointer border-b border-gray-100 mb-1">
                <input type="checkbox" class="form-check-input mt-0" data-location-filter-target="allCheckbox" data-action="change->location-filter#toggleAll">
                <span class="text-sm font-semibold text-gray-700">Todos</span>
              </label>

              <% (@location_options || []).each do |option| %>
                <% checked = selected_locations.include?(option[:value]) %>
                <label class="flex items-center gap-2 px-2 py-2 rounded-md hover:bg-gray-50 cursor-pointer"
                       data-location-filter-row="true">
                  <input type="checkbox"
                         value="<%= option[:value] %>"
                         data-label="<%= option[:label].to_s.downcase %>"
                         class="form-check-input mt-0"
                         data-location-filter-target="checkbox"
                         data-action="change->location-filter#sync"
                         <%= "checked" if checked %>>
                  <span class="text-sm text-gray-700"><%= option[:label] %></span>
                </label>
              <% end %>
            </div>
          </div>

          <div data-location-filter-target="hiddenContainer">
            <% selected_locations.each do |city| %>
              <input type="hidden" name="city[]" value="<%= city %>">
            <% end %>
          </div>
        </div>
        
        <!-- Valores -->
        <div class="md:col-span-2">
          <label class="sr-only">Valores</label>
          <div class="relative">
            <i class="bi bi-chevron-down absolute right-3 top-1/2 -translate-y-1/2 text-current opacity-45 pointer-events-none"></i>
            <%= f.select :price_range,
                options_for_select(price_range_options, params[:price_range]),
                {},
                class: "w-full min-h-[48px] appearance-none rounded-full border border-gray-200/80 bg-white/85 px-4 pr-10 py-3 text-sm font-medium text-gray-700 shadow-sm transition-colors focus:border-blue-three focus:ring-1 focus:ring-blue-three",
                style: search_filter_field_style,
                data: { search_tabs_target: "priceSelect" } %>
          </div>
        </div>

        <div class="md:col-span-3">
          <%= button_tag type: 'submit', name: nil, class: "flex min-h-[48px] w-full items-center justify-center gap-2 rounded-full bg-hero-button py-3 text-sm font-bold uppercase tracking-wide text-hero-button-text shadow-[0_10px_24px_rgba(190,139,38,0.28)] transition-all duration-200 hover:-translate-y-0.5 hover:opacity-95 hover:shadow-[0_14px_30px_rgba(190,139,38,0.34)]" do %>
            <i class="bi bi-search"></i>
            <%= @home_setting.hero_cta_text.presence || "Buscar" %>
          <% end %>
        </div>
        
      </div>

      <div class="overflow-hidden max-h-0 opacity-0 pointer-events-none transition-all duration-500 ease-out"
           data-search-tabs-target="advancedPanel">
        <div class="mt-5 pt-5" style="<%= search_filter_divider_style %>">
          <% metric_groups = [
            [:min_bedrooms, "Quartos", [["1", "1"], ["2", "2"], ["3", "3"], ["4+", "4"]]],
            [:min_suites, "Suítes", [["1+", "1"], ["2+", "2"], ["3+", "3"], ["4+", "4"]]],
            [:min_bathrooms, "Banheiros", [["1+", "1"], ["2+", "2"], ["3+", "3"], ["4+", "4"]]],
            [:min_parking, "Vagas", [["1+", "1"], ["2+", "2"], ["3+", "3"], ["4+", "4"]]]
          ] %>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <% metric_groups.each do |field, label, options| %>
              <div>
                <div class="mb-1 text-xs font-bold uppercase tracking-wide text-current opacity-70"><%= label %></div>
                <div class="grid grid-cols-4 overflow-hidden rounded-lg bg-white" style="<%= search_filter_field_style %>">
                  <% options.each do |text, value| %>
                    <label class="cursor-pointer last:border-r-0" style="<%= search_filter_right_border_style unless options.last == [text, value] %>">
                      <%= radio_button_tag field, value, params[field].to_s == value, class: "peer sr-only" %>
                      <span class="flex h-9 items-center justify-center text-xs font-semibold text-gray-600 transition-colors peer-checked:bg-blue-three peer-checked:text-white hover:bg-gray-50">
                        <%= text %>
                      </span>
                    </label>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>

          <div class="mt-5 grid grid-cols-1 gap-4 lg:grid-cols-2">
            <div>
              <div class="mb-2 text-xs font-bold uppercase tracking-wide text-current opacity-70">Buscas rápidas</div>
              <% quick_filters = [
                ['frente_mar', 'Frente Mar', 'bi-water'],
                ['quadra_mar', 'Quadra Mar', 'bi-building'],
                ['mobiliado', 'Mobiliado', 'bi-house-heart'],
                ['pronto', 'Pronto Morar', 'bi-check2-circle'],
                ['na_planta', 'Na Planta', 'bi-map'],
                ['opportunity', 'Ofertas', 'bi-tag-fill'],
                ['lancamento', 'Lançamento', 'bi-stars'],
                ['churrasqueira', 'Churrasqueira', 'bi-fire'],
                ['sacada', 'Sacada', 'bi-door-open']
              ] %>
              <div class="flex flex-wrap gap-2">
                <% quick_filters.each do |value, label, icon| %>
                  <label class="cursor-pointer">
                    <%= check_box_tag "characteristics[]", value, selected_characteristics.include?(value), class: "peer sr-only" %>
                    <span class="inline-flex h-9 items-center gap-2 rounded-full bg-white px-3 text-xs font-semibold text-gray-600 transition-all peer-checked:bg-blue-three peer-checked:text-white hover:text-blue-three" style="<%= search_filter_chip_border_style %>">
                      <i class="bi <%= icon %>"></i>
                      <%= label %>
                    </span>
                  </label>
                <% end %>

                <label class="cursor-pointer">
                  <%= check_box_tag :accepts_exchange, "1", params[:accepts_exchange].to_s == "1", class: "peer sr-only" %>
                  <span class="inline-flex h-9 items-center gap-2 rounded-full bg-white px-3 text-xs font-semibold text-gray-600 transition-all peer-checked:bg-blue-three peer-checked:text-white hover:text-blue-three" style="<%= search_filter_chip_border_style %>">
                    <i class="bi bi-arrow-left-right"></i>
                    Permuta
                  </span>
                </label>
              </div>
            </div>

            <div>
              <div class="mb-2 text-xs font-bold uppercase tracking-wide text-current opacity-70">Mais características</div>
              <% extra_filters = [
                ['cozinha_gourmet_churrasqueira', 'Cozinha gourmet com churrasqueira', 'bi-fire'],
                ['dependencia_empregada', 'Dependência', 'bi-door-closed'],
                ['sol_manha', 'Sol da manhã', 'bi-sunrise'],
                ['sol_tarde', 'Sol da tarde', 'bi-sunset'],
                ['sol_dia_todo', 'Sol o dia todo', 'bi-sun']
              ] %>
              <div class="flex flex-wrap gap-2">
                <% extra_filters.each do |value, label, icon| %>
                  <label class="cursor-pointer">
                    <%= check_box_tag "characteristics[]", value, selected_characteristics.include?(value), class: "peer sr-only" %>
                    <span class="inline-flex h-9 items-center gap-2 rounded-full bg-white px-3 text-xs font-semibold text-gray-600 transition-all peer-checked:bg-golden-one peer-checked:text-blue-three hover:text-blue-three" style="<%= search_filter_chip_border_style %>">
                      <i class="bi <%= icon %>"></i>
                      <%= label %>
                    </span>
                  </label>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>

    <% end %>
  </div>

  <div class="relative z-10 mt-3 flex justify-center">
    <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 px-4 py-2 text-center text-xs font-semibold text-current shadow-[0_12px_34px_rgba(8,31,48,0.16)] sm:text-sm"
         style="<%= search_filter_style %>; background-color: var(--search-filter-bg); border: var(--search-filter-border); border-radius: var(--search-filter-radius); color: var(--search-filter-text); backdrop-filter: blur(var(--search-filter-blur)); -webkit-backdrop-filter: blur(var(--search-filter-blur));">
      <button type="button"
              class="inline-flex items-center justify-center gap-1.5 transition-colors hover:text-golden-one"
              data-action="click->search-tabs#toggleAdvanced">
        <i class="bi bi-list text-[0.95em]" data-search-tabs-target="advancedIcon"></i>
        <span data-search-tabs-target="advancedLabel">Avançado</span>
      </button>

      <button type="button"
              onclick="document.dispatchEvent(new CustomEvent('open-code-search'))"
              class="inline-flex items-center justify-center gap-1.5 transition-colors hover:text-golden-one">
        <i class="bi bi-upc-scan text-[0.95em]"></i>
        Por código
      </button>

      <%= link_to empreendimentos_path, class: "inline-flex items-center justify-center gap-1.5 transition-colors hover:text-golden-one" do %>
        <i class="bi bi-buildings text-[0.95em]"></i>
        Empreendimentos
      <% end %>
    </div>
  </div>
</div>
