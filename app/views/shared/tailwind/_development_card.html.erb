<%
  image = development.primary_image_source || development.primary_image_url || development.image_urls.first
  title = development.nome_empreendimento.presence || development.titulo_anuncio.presence || development.display_title
  location = [development.bairro, development.cidade].compact_blank.join(" - ")
  units_count = local_assigns[:unit_count].presence || development.available_units_count
  area_label = development.card_area_text
  suites_label = development.card_suites_text
  dorms_label = development.card_dormitorios_text
  vagas_label = development.card_vagas_text
  metrics = [
    area_label,
    suites_label.present? ? "#{suites_label} suítes" : (dorms_label.present? ? "#{dorms_label} quartos" : nil),
    vagas_label.present? ? "#{vagas_label} vagas" : nil
  ].compact
  logo_url = development.effective_constructor&.dynamic_logo_url || development.effective_constructor&.favicon_url
%>

<%= link_to habitation_path(development),
    class: "group block h-full rounded-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-golden-one focus-visible:ring-offset-2",
    aria: { label: title } do %>
  <article class="relative min-h-[430px] overflow-hidden rounded-xl bg-blue-three shadow-[0_18px_40px_rgba(2,43,58,0.18)] transition-all duration-500 group-hover:-translate-y-1 group-hover:shadow-[0_26px_56px_rgba(2,43,58,0.24)]">
    <% if image.present? %>
      <%= image_tag public_image_url(image, resize_to_fill: [720, 860]),
          alt: title,
          class: "absolute inset-0 z-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105",
          loading: "lazy",
          decoding: "async",
          width: 720,
          height: 860,
          sizes: "(min-width: 1280px) 410px, (min-width: 768px) 50vw, 100vw" %>
    <% else %>
      <div class="absolute inset-0 z-0 flex items-center justify-center bg-blue-three text-white/40">
        <i class="bi bi-building text-6xl"></i>
      </div>
    <% end %>

    <div class="absolute inset-0 z-10 bg-gradient-to-t from-black/75 via-black/30 to-transparent"></div>
    <div class="absolute inset-x-0 bottom-0 z-10 h-2/3 bg-gradient-to-t from-black/80 via-black/55 to-transparent"></div>
    <div class="absolute inset-x-0 bottom-0 z-10 h-1/2 bg-gradient-to-t from-blue-three/55 via-blue-three/20 to-transparent"></div>
    <div class="absolute inset-0 z-10 bg-black/5 transition-colors duration-500 group-hover:bg-black/0"></div>

    <% if logo_url.present? %>
      <div class="absolute right-5 top-5 z-20 flex h-20 w-20 items-center justify-center rounded-lg bg-white/10 p-3 backdrop-blur-md">
        <img src="<%= logo_url %>"
             alt="<%= development.constructor_name %>"
             class="max-h-full max-w-full object-contain brightness-0 invert">
      </div>
    <% end %>

    <div class="absolute left-5 top-5 z-20">
      <span class="inline-flex items-center gap-2 rounded-full bg-white/20 px-3 py-1.5 text-xs font-bold uppercase tracking-[0.16em] text-white backdrop-blur-md">
        <i class="bi bi-building"></i>
        <%= units_count %> <%= units_count.to_i == 1 ? "unidade" : "unidades" %>
      </span>
    </div>

    <div class="absolute inset-x-0 bottom-0 z-20 p-6 text-white">
      <h3 class="font-serif text-3xl font-bold leading-none drop-shadow-sm">
        <%= title %>
      </h3>

      <% if metrics.any? %>
        <p class="mt-3 text-sm font-bold leading-relaxed text-white">
          <%= metrics.join(" | ") %>
        </p>
      <% end %>

      <div class="my-4 h-px w-full bg-white/55"></div>

      <% if location.present? %>
        <p class="flex items-center gap-2 text-base font-bold text-white">
          <i class="bi bi-geo-alt text-golden-one"></i>
          <%= location %>
        </p>
      <% end %>
    </div>
  </article>
<% end %>
