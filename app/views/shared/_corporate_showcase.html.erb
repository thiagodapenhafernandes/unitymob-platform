<section class="py-14 bg-[#f3f6f9]">
  <div class="container-custom">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-5 lg:gap-6">
      <div class="lg:col-span-5 rounded-2xl bg-[#dfeaf5] border border-white/70 p-7 lg:p-9 min-h-[320px] flex flex-col justify-between">
        <div>
          <span class="inline-flex items-center gap-2 text-[11px] tracking-[0.2em] uppercase bg-white/60 text-blue-three px-3 py-1 rounded-full font-semibold">
            <i class="bi bi-briefcase"></i>
            Corporate
          </span>
          <h3 class="mt-4 text-3xl lg:text-4xl font-semibold text-blue-three" style="font-family: 'Cormorant Garamond', Georgia, serif; letter-spacing: .02em;">
            Private Corporate
          </h3>
          <p class="mt-2 text-gray-600 text-sm lg:text-base">
            Onde a sofisticação encontra o mundo dos negócios.
          </p>
        </div>

        <div class="mt-8">
          <%= link_to corporativos_path, class: "inline-flex items-center gap-3 text-blue-three hover:text-blue-one transition-colors" do %>
            <span class="text-sm">ver todos imóveis</span>
            <span class="inline-flex items-center justify-center w-14 h-8 rounded-full border border-blue-three/70">
              <i class="bi bi-arrow-right"></i>
            </span>
          <% end %>
        </div>
      </div>

      <div class="lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
        <% properties.each do |property| %>
          <% badge = property.valor_locacao_cents.to_i > 0 ? 'ALUGUEL' : 'VENDA' %>
          <% image = property.primary_image_source || property.primary_image_url %>
          <%= link_to habitation_path(property), class: "group relative block rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-all min-h-[320px]" do %>
            <% if image.present? %>
              <%= image_tag public_image_url(image, resize_to_fill: [560, 640]),
                    alt: property.display_title,
                    class: "absolute inset-0 w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300",
                    loading: "lazy",
                    decoding: "async",
                    width: 560,
                    height: 640,
                    sizes: "(min-width: 1280px) 300px, (min-width: 640px) 50vw, 100vw" %>
            <% else %>
              <div class="absolute inset-0 bg-gradient-to-br from-slate-300 to-slate-400"></div>
            <% end %>
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/15 to-black/20"></div>

            <div class="relative p-4 h-full flex flex-col justify-between text-white">
              <div class="flex items-start justify-between gap-2">
                <span class="inline-flex items-center rounded-full bg-black/45 px-2.5 py-1 text-[11px] font-semibold tracking-wide"><%= badge %></span>
                <span class="inline-flex items-center rounded-full bg-white/85 text-gray-800 px-2.5 py-1 text-[11px] font-semibold">
                  CÓD <%= property.codigo %>
                </span>
              </div>

              <div>
                <h4 class="text-xl leading-tight font-semibold mb-2" style="font-family: 'Cormorant Garamond', Georgia, serif;">
                  <%= property.display_title.to_s.truncate(42) %>
                </h4>
                <div class="h-px bg-white/40 mb-2"></div>
                <div class="text-xl font-bold">
                  <%= property.preco_principal %>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</section>
