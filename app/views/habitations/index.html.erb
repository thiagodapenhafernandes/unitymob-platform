<!-- Listing Page with Horizontal Filters (Image Replica) -->
<div data-controller="sidebar advanced-filters" class="public-habitations-index mt-[72px]"> <!-- Added margin-top to compensate for fixed header -->

  <!-- Advanced Filters Sidebar (Off-canvas) -->
  <div data-advanced-filters-target="overlay" class="fixed inset-0 bg-black/50 z-50 hidden transition-opacity duration-300" data-action="click->advanced-filters#close"></div>
  
  <div data-advanced-filters-target="sidebar" role="dialog" aria-modal="true" aria-labelledby="public-filters-title" class="public-habitations-index__drawer fixed top-[calc(72px+env(safe-area-inset-top))] right-0 h-[calc(100svh-72px-env(safe-area-inset-top))] w-full max-w-md bg-white z-50 hidden transform translate-x-full transition-transform duration-300 shadow-2xl overflow-y-auto overscroll-contain">
    <div class="public-habitations-index__drawer-body p-6">
      <div class="public-habitations-index__drawer-header flex justify-between items-center mb-6">
        <h3 id="public-filters-title" class="public-habitations-index__drawer-title text-xl font-bold text-blue-three">Filtrar imóveis</h3>
        <button type="button" data-action="click->advanced-filters#close" class="public-habitations-index__icon-button text-gray-400 hover:text-red-500 transition-colors" aria-label="Fechar filtros">
          <i class="bi bi-x-lg text-xl"></i>
        </button>
      </div>
      
      <%= form_with url: habitations_path, method: :get, id: "advanced-filters-form" do |f| %>
        <%= hidden_field_tag :target_price, params[:target_price] %>

        <div class="public-habitations-index__drawer-main-filters space-y-3 mb-6">
          <%= render 'horizontal_filters_fields', f: f %>
        </div>

        <%= render 'advanced_filters_fields', f: f %>

        <div class="public-habitations-index__drawer-footer sticky bottom-0 bg-white pt-4 pb-2 border-t border-gray-100">
          <button type="submit" class="public-habitations-index__primary-button w-full py-3 bg-blue-three text-white font-bold rounded-lg hover:bg-blue-one transition-colors shadow-lg">
            Aplicar filtros
          </button>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Floating Filter Button (Mobile/Scroll) -->
  <button type="button" 
          data-action="click->advanced-filters#open"
          class="public-habitations-index__floating-filter fixed z-40 bg-blue-three text-white shadow-2xl flex items-center justify-center gap-2 transition-all duration-300 hover:scale-105 hover:bg-blue-one group"
          aria-label="Abrir filtros de imóveis">
    <i class="bi bi-sliders text-lg" aria-hidden="true"></i>
    <span>Filtros</span>
  </button>

  <!-- Horizontal Filter Bar (TOP) -->
  <div class="public-habitations-index__filterbar bg-white border-b border-gray-200 z-30 shadow-sm py-3">
    <div class="container-custom">
      <%= form_with url: habitations_path, method: :get, class: "public-habitations-index__filter-form flex flex-col gap-3" do |f| %>
        
        <!-- Row 1: Main Filters -->
        <div class="public-habitations-index__filter-row flex flex-wrap lg:flex-nowrap items-center gap-3 w-full">
          <%= render 'horizontal_filters_fields', f: f %>

          <!-- Submit Button -->
          <button type="submit" class="public-habitations-index__apply-button bg-blue-three hover:bg-blue-one text-white px-8 py-2.5 rounded-lg text-sm font-bold transition-colors flex items-center gap-2 shadow-sm whitespace-nowrap">
            <i class="bi bi-search"></i>
            Aplicar filtros
          </button>
          
          <!-- Plus Button (Advanced Filters) -->
          <button type="button" 
                  data-action="click->advanced-filters#open"
                  class="public-habitations-index__more-filters w-10 h-10 flex items-center justify-center bg-white border border-gray-200 rounded-lg hover:border-blue-three hover:text-blue-three text-gray-500 transition-colors shadow-sm flex-shrink-0"
                  aria-label="Abrir filtros avançados">
            <i class="bi bi-plus-lg text-lg" aria-hidden="true"></i>
          </button>
        </div>

        <!-- Row 2: Quick Filter Chips -->
        <div class="public-habitations-index__quick-row flex items-center gap-2 pt-1">
          <div class="public-habitations-index__quick-scroll flex min-w-0 flex-1 items-center gap-2">
            <%= render 'quick_filter_chips' %>
          </div>

          <!-- Clear Filters -->
          <% if params.except(:controller, :action, :page).present? %>
            <%= link_to habitations_path, class: "public-habitations-index__clear-link flex flex-none items-center gap-1 px-3 py-1.5 text-xs font-medium text-gray-400 hover:text-red-500 transition-colors" do %>
              <i class="bi bi-x-circle"></i>
              Limpar filtros
            <% end %>
          <% end %>
        </div>

      <% end %>
    </div>
  </div>

  <!-- Header & Breadcrumbs (MOVED BELOW FILTERS) -->
  <div class="public-habitations-index__heading bg-white border-b border-gray-100 py-4">
    <div class="container-custom">
      <div class="public-habitations-index__breadcrumb flex items-center gap-2 text-xs text-gray-400 mb-2 uppercase tracking-wide">
        <%= link_to "Início", root_path, class: "hover:text-blue-three" %>
        <i class="bi bi-chevron-right text-[10px]"></i>
        <span class="text-blue-three font-bold">Imóveis</span>
      </div>
      
      <div class="public-habitations-index__heading-row flex justify-between items-end">
        <h1 class="public-habitations-index__title text-2xl font-bold text-blue-three">
          <span class="public-habitations-index__title-desktop">Imóveis encontrados</span>
          <span class="public-habitations-index__title-mobile">Imóveis</span>
        </h1>
        
        <div class="public-habitations-index__sort flex items-center gap-2">
          <label for="public-habitations-sort" class="public-habitations-index__sort-label text-sm text-gray-500">Ordenar por:</label>
          <select id="public-habitations-sort" class="public-habitations-index__sort-select border-none text-sm font-bold text-blue-three focus:ring-0 cursor-pointer bg-transparent py-0 pl-0 pr-8" onchange="window.location.href = this.value">
            <option value="<%= habitations_path(request.query_parameters.merge(sort: 'newest', page: nil).compact_blank) %>" <%= 'selected' if params[:sort] == 'newest' || params[:sort].blank? %>>Mais recentes</option>
            <option value="<%= habitations_path(request.query_parameters.merge(sort: 'price_desc', page: nil).compact_blank) %>" <%= 'selected' if params[:sort] == 'price_desc' %>>Maior valor</option>
            <option value="<%= habitations_path(request.query_parameters.merge(sort: 'price_asc', page: nil).compact_blank) %>" <%= 'selected' if params[:sort] == 'price_asc' %>>Menor valor</option>
          </select>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="public-habitations-index__content bg-gray-50 min-h-screen py-8">
    <div class="container-custom">
  
  <!-- Banner Resultados de Busca -->
  <div class="public-habitations-index__banner"><%= display_banner('search_results') %></div>
  
  <div class="public-habitations-index__results results-section mt-8">
      
      <% if @habitations.any? %>
        <div class="public-habitations-index__grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12 items-start">
          <% @habitations.each do |property| %>
            <%= render 'shared/tailwind/property_card', property: property %>
          <% end %>
        </div>
        
        <!-- Pagination -->
        <div class="public-habitations-index__pagination flex justify-center mt-8">
          <%= will_paginate @habitations, 
              renderer: WillPaginate::ActionView::TailwindLinkRenderer,
              path_helper: ->(page) { habitations_path(request.query_parameters.merge(page: page).compact_blank) },
              inner_window: 2,
              outer_window: 0,
              previous_label: '<i class="bi bi-chevron-left"></i>',
              next_label: '<i class="bi bi-chevron-right"></i>' %>
        </div>

        <% listing_seo = current_public_seo_setting %>
        <div class="public-habitations-index__supporting-content">
          <% if listing_seo&.public_applicable? && listing_seo.intro_text.present? %>
            <section class="public-habitations-index__seo-intro bg-white border border-gray-100 rounded-xl p-6 md:p-8 shadow-sm">
              <div class="prose prose-slate max-w-none text-gray-600 leading-relaxed">
                <%= simple_format(listing_seo.intro_text) %>
              </div>
            </section>
          <% end %>

          <nav class="public-habitations-index__strategic-links bg-white border border-gray-100 rounded-xl p-5 shadow-sm" aria-label="Buscas estratégicas">
            <h2 class="public-habitations-index__section-title text-sm font-bold text-blue-three uppercase tracking-wide mb-3">Buscas relacionadas</h2>
            <div class="public-habitations-index__strategic-list flex flex-wrap gap-2">
              <% Seo::StrategicLanding.property_links.each do |link| %>
                <%= link_to link[:label], link[:path], class: "public-habitations-index__strategic-link inline-flex items-center rounded-full border border-gray-200 bg-gray-50 px-4 py-2 text-sm font-semibold text-gray-600 hover:border-golden-one hover:text-blue-three transition-colors" %>
              <% end %>
            </div>
          </nav>
        </div>
      <% else %>
        <!-- Empty State -->
        <div class="public-habitations-index__empty bg-white rounded-xl border border-gray-200 p-16 text-center max-w-2xl mx-auto">
          <div class="public-habitations-index__empty-icon w-20 h-20 mx-auto mb-6 bg-gray-50 rounded-full flex items-center justify-center">
            <i class="bi bi-search text-3xl text-gray-400"></i>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Nenhum imóvel encontrado</h3>
          <p class="text-gray-500 mb-8">
            Tente remover alguns filtros ou navegar por buscas próximas para encontrar oportunidades semelhantes.
          </p>
          <div class="flex flex-wrap justify-center gap-2">
            <%= link_to "Limpar filtros", habitations_path, class: "public-habitations-index__primary-link btn-primary inline-flex items-center gap-2" %>
            <% Seo::StrategicLanding.property_links.first(4).each do |link| %>
              <%= link_to link[:label], link[:path], class: "public-habitations-index__empty-link inline-flex items-center rounded-lg border border-gray-200 px-4 py-2 text-sm font-semibold text-gray-600 hover:border-blue-three hover:text-blue-three transition-colors" %>
            <% end %>
          </div>
        </div>
      <% end %>

    </div>
  </div>
</div>

<!-- JSON-LD Structured Data for Listing Page (ItemList) -->
<script type="application/ld+json">
  <%= raw({
    "@context" => "https://schema.org",
    "@type" => "ItemList",
    "name" => @page_title.presence || "Imóveis #{@layout_setting&.site_name.presence || 'Unitymob'}",
    "numberOfItems" => @habitations.size,
    "itemListElement" => @habitations.each_with_index.map do |property, index|
      item = {
        "@type" => "ListItem",
        "position" => index + 1,
        "url" => habitation_url(property),
        "name" => property.display_title
      }
      item["image"] = property.primary_image_url if property.primary_image_url.present?
      item
    end
  }.to_json) %>
</script>
