<% images = @habitation.public_image_sources %>
<% image_url = ->(photo) { public_image_url(photo) } %>
<% title = @habitation.display_title %>
<% address_parts = [@habitation.endereco, @habitation.bairro, @habitation.cidade].compact_blank %>
<% address_text = address_parts.join(" - ") %>
<% area_text = (@habitation.area_total_m2.presence || @habitation.area_privativa_m2.presence) %>
<% has_sale_price = @habitation.valor_venda_cents.to_i.positive? %>
<% has_rent_price = @habitation.valor_locacao_cents.to_i.positive? %>
<% has_discount = @habitation.sale_discount? %>
<% has_rent_discount = @habitation.rent_discount? %>
<% public_media_url = public_property_media_url(@habitation) %>
<% map_coordinates = @public_map.center_coordinates if @public_map.visible? %>
<% street_view_coordinates = @public_map.street_view_coordinates if @public_map.street_view_enabled? %>
<% primary_image_source = images.first %>
<% primary_image_url = public_image_url(primary_image_source, resize_to_limit: [1200, 900], format: :webp, representation_proxy: true) if primary_image_source %>
<% primary_image_srcset = public_image_srcset(primary_image_source, widths: [480, 800, 1200], aspect_ratio: 4.0 / 3, format: :webp, representation_proxy: true) if primary_image_source %>

<% content_for :head do %>
  <%= json_ld_tag(real_estate_listing_schema(@habitation)) %>
  <% if primary_image_url.present? %>
    <link rel="preload"
          as="image"
          href="<%= primary_image_url %>"
          imagesrcset="<%= primary_image_srcset %>"
          imagesizes="(min-width: 1024px) 52vw, 100vw"
          fetchpriority="high">
  <% end %>
<% end %>

<div class="public-habitations-show bg-gray-50 min-h-screen pb-14 habitation-details"
     data-property-id="<%= @habitation.id %>"
     data-controller="<%= "public-property-map" if @public_map.visible? %>"
     data-public-property-map-provider-value="<%= @public_map.provider if @public_map.visible? %>"
     data-public-property-map-api-key-value="<%= @public_map.api_key if @public_map.visible? %>"
     data-public-property-map-latitude-value="<%= format('%.7f', map_coordinates.first) if map_coordinates %>"
     data-public-property-map-longitude-value="<%= format('%.7f', map_coordinates.last) if map_coordinates %>"
     data-public-property-map-street-latitude-value="<%= format('%.7f', street_view_coordinates.first) if street_view_coordinates %>"
     data-public-property-map-street-longitude-value="<%= format('%.7f', street_view_coordinates.last) if street_view_coordinates %>"
     data-public-property-map-radius-value="<%= @public_map.radius_meters if @public_map.visible? %>"
     data-public-property-map-zoom-value="<%= @public_map.zoom if @public_map.visible? %>"
     data-public-property-map-satellite-enabled-value="<%= @public_map.satellite_enabled? if @public_map.visible? %>"
     data-public-property-map-street-view-enabled-value="<%= @public_map.street_view_enabled? if @public_map.visible? %>">
  <div class="public-habitations-show__breadcrumb public-habitations-show__breadcrumb--desktop bg-white border-b border-gray-100 py-3 mt-[72px]">
    <div class="container-custom">
      <div class="public-habitations-show__breadcrumb-list flex items-center gap-2 text-xs text-gray-400 uppercase tracking-wide">
        <%= link_to "Início", root_path, class: "hover:text-blue-three" %>
        <i class="bi bi-chevron-right text-[10px]"></i>
        <%= link_to "Imóveis", habitations_path, class: "hover:text-blue-three" %>
        <i class="bi bi-chevron-right text-[10px]"></i>
        <span class="text-blue-three font-bold"><%= @habitation.codigo %></span>
      </div>
    </div>
  </div>

  <div class="container-custom pt-8" data-controller="fancybox-gallery">
    <section class="public-habitations-show__gallery relative overflow-hidden rounded-2xl bg-white shadow-[0_18px_45px_rgba(15,23,42,0.12)]"
             data-controller="public-gallery-mobile"
             data-public-gallery-mobile-property-id-value="<%= @habitation.id %>"
             data-public-gallery-mobile-property-url-value="<%= habitation_path(@habitation) %>"
             data-public-gallery-mobile-property-title-value="<%= title %>"
             data-public-gallery-mobile-property-image-url-value="<%= image_url.call(images.first) if images.any? %>"
             data-public-gallery-mobile-property-price-value="<%= number_to_currency((has_rent_price ? @habitation.valor_locacao_cents : @habitation.valor_venda_cents).to_i / 100.0, unit: 'R$ ', separator: ',', delimiter: '.') if (has_rent_price || has_sale_price) %>"
             data-public-gallery-mobile-property-location-value="<%= address_text %>">
      <% if images.any? %>
        <div class="public-habitations-show__gallery-badges">
          <% @habitation.display_badges.each do |badge| %>
            <span class="public-habitations-show__gallery-badge bg-<%= badge[:tailwind_color] %>"><%= badge[:text] %></span>
          <% end %>
        </div>
        <div class="public-habitations-show__gallery-grid grid h-[360px] grid-cols-1 gap-2 md:h-[400px] lg:grid-cols-[1.08fr_1fr]">
          <a href="<%= image_url.call(images.first) %>"
             data-fancybox="property-gallery"
             data-caption="<%= title %> - Foto 1"
             class="public-habitations-show__gallery-primary relative block h-full overflow-hidden bg-gray-100">
            <%= image_tag primary_image_url,
                alt: "#{title} - Foto 1",
                class: "h-full w-full object-cover transition-transform duration-700 hover:scale-105 #{public_gallery_image_class(images.first)}",
                data: { public_gallery_mobile_target: "primaryImage" },
                style: public_gallery_image_style(images.first, primary: true),
                fetchpriority: "high",
                loading: "eager",
                decoding: "async",
                width: 960,
                height: 720,
                srcset: primary_image_srcset,
                sizes: "(min-width: 1024px) 52vw, 100vw" %>
          </a>

          <div class="public-habitations-show__gallery-thumbs hidden grid-cols-2 gap-2 lg:grid">
            <% images.drop(1).first(4).each_with_index do |photo, index| %>
              <a href="<%= image_url.call(photo) %>"
                 data-fancybox="property-gallery"
                 data-caption="<%= title %> - Foto <%= index + 2 %>"
                 class="public-habitations-show__gallery-thumb relative block overflow-hidden bg-gray-100">
                <%= image_tag public_image_url(photo, resize_to_fill: [720, 520], format: :webp),
                    alt: "#{title} - Foto #{index + 2}",
                    class: "h-full w-full object-cover transition-transform duration-700 hover:scale-105 #{public_gallery_image_class(photo)}",
                    style: public_gallery_image_style(photo),
                    loading: "lazy",
                    decoding: "async",
                    width: 520,
                    height: 360,
                    srcset: public_image_srcset(photo, widths: [360, 520, 720], aspect_ratio: 720.0 / 520, crop: true, format: :webp),
                    sizes: "24vw" %>
              </a>
            <% end %>
          </div>
        </div>

        <% images.drop(5).each_with_index do |photo, index| %>
          <a href="<%= image_url.call(photo) %>"
             data-fancybox="property-gallery"
             data-caption="<%= title %> - Foto <%= index + 6 %>"
             class="hidden"></a>
        <% end %>

        <div class="public-habitations-show__gallery-mobile-toolbar" aria-label="Ações da galeria">
          <button type="button" class="public-habitations-show__gallery-control" data-action="click->public-gallery-mobile#toggleFavorite" data-public-gallery-mobile-target="favorite" aria-label="Favoritar imóvel" aria-pressed="false">
            <i class="bi bi-bookmark"></i>
          </button>
          <button type="button" class="public-habitations-show__gallery-control" data-action="click->public-gallery-mobile#share" aria-label="Compartilhar imóvel">
            <i class="bi bi-share"></i>
          </button>
        <button type="button" class="public-habitations-show__gallery-control" data-gallery-open aria-label="Abrir galeria em tela cheia">
            <i class="bi bi-arrows-fullscreen"></i>
        </button>
        <span class="public-habitations-show__gallery-status" data-public-gallery-mobile-target="status" aria-live="polite"></span>
        </div>

        <span class="public-habitations-show__gallery-counter" data-public-gallery-mobile-target="counter">1 / <%= images.size %></span>

        <div class="public-habitations-show__share absolute bottom-4 left-4 z-20">
          <%= render "shared/broker_share_menu", property: @habitation %>
        </div>

      <% else %>
        <div class="public-habitations-show__gallery-empty flex h-[360px] items-center justify-center bg-gray-100">
          <div class="text-center text-gray-400">
            <i class="bi bi-image text-6xl"></i>
            <p class="mt-3">Sem fotos disponíveis</p>
          </div>
        </div>
      <% end %>
    </section>

    <% if public_media_url.present? || @public_map.visible? || images.any? %>
      <nav class="public-habitations-show__media-actions" aria-label="Recursos do imóvel">
        <% if public_media_url.present? %>
          <%= link_to public_media_url,
              target: "_blank",
              rel: "noopener noreferrer",
              class: "public-habitations-show__media-action" do %>
            <i class="bi bi-play-circle"></i>
            <span><%= @habitation.tour_virtual.present? && public_media_url == @habitation.tour_virtual ? "Tour 360" : "Vídeo" %></span>
          <% end %>
        <% end %>

        <% if @public_map.visible? %>
          <button type="button" class="public-habitations-show__media-action" data-action="click->public-property-map#showMap">
            <i class="bi bi-map"></i>
            <span>Mapa</span>
          </button>
        <% end %>

        <% if @public_map.street_view_enabled? %>
          <button type="button" class="public-habitations-show__media-action" data-action="click->public-property-map#showStreetView">
            <i class="bi bi-person-standing"></i>
            <span>Rua</span>
          </button>
        <% end %>

        <% if images.any? %>
          <button type="button" class="public-habitations-show__media-action public-habitations-show__gallery-open-action" data-gallery-open>
            <i class="bi bi-images"></i>
            <span>Ver <%= images.size %> fotos</span>
          </button>
        <% end %>
      </nav>
    <% end %>

    <nav class="public-habitations-show__breadcrumb public-habitations-show__breadcrumb--mobile" aria-label="Navegação estrutural">
      <%= link_to "Início", root_path %>
      <% [@habitation.cidade, @habitation.bairro, @habitation.categoria].compact_blank.each do |breadcrumb_item| %>
        <i class="bi bi-chevron-right"></i>
        <span><%= breadcrumb_item %></span>
      <% end %>
      <i class="bi bi-chevron-right"></i>
      <strong><%= @habitation.codigo %></strong>
    </nav>

    <div class="public-habitations-show__body mt-6">
      <main class="public-habitations-show__main min-w-0">
        <section class="public-habitations-show__header">
        <div class="public-habitations-show__identity mb-4 flex flex-wrap items-center gap-2">
          <span class="public-habitations-show__code rounded bg-blue-three/10 px-2 py-1 text-[11px] font-bold uppercase tracking-widest text-blue-three">
            <%= @habitation.codigo %>
          </span>
          <% @habitation.display_badges.each do |badge| %>
            <span class="public-habitations-show__badge rounded bg-<%= badge[:tailwind_color] %> px-2.5 py-1 text-[10px] font-bold uppercase tracking-widest text-white">
              <%= badge[:text] %>
            </span>
          <% end %>
        </div>

        <h1 class="public-habitations-show__title text-3xl font-extrabold leading-tight text-gray-950 lg:text-4xl">
          <%= title %>
        </h1>

        <% if address_text.present? %>
          <p class="public-habitations-show__address mt-3 flex items-start gap-2 text-sm text-gray-500">
            <i class="bi bi-geo-alt text-golden-one"></i>
            <span><%= address_text %><%= "/#{@habitation.uf}" if @habitation.uf.present? %></span>
          </p>
        <% end %>
        </section>

        <div class="public-habitations-show__mobile-price">
          <%= render "price_card",
              habitation: @habitation,
              title: title,
              has_sale_price: has_sale_price,
              has_rent_price: has_rent_price,
              has_discount: has_discount,
              has_rent_discount: has_rent_discount %>
        </div>

        <% feature_items = [] %>
        <% feature_items << { label: "Área", value: "#{number_with_precision(area_text, precision: 0)} m²", icon: "bi-arrows-fullscreen", tone: "blue" } if area_text.to_f.positive? %>
        <% feature_items << { label: "Quartos", value: @habitation.dormitorios_qtd.to_i, icon: "bi-door-closed", tone: "gold" } if @habitation.dormitorios_qtd.to_i.positive? %>
        <% feature_items << { label: "Suítes", value: @habitation.suites_qtd.to_i, icon: "bi-stars", tone: "blue" } if @habitation.suites_qtd.to_i.positive? %>
        <% feature_items << { label: "Vagas", value: @habitation.vagas_qtd.to_i, icon: "bi-car-front", tone: "gold" } if @habitation.vagas_qtd.to_i.positive? %>
        <% if feature_items.any? %>
          <section class="public-habitations-show__features">
            <h2 class="public-habitations-show__section-title mb-4 text-sm font-bold uppercase tracking-[0.22em] text-gray-400">Características</h2>
            <div class="public-habitations-show__feature-grid grid gap-4 md:grid-cols-4">
              <% feature_items.each do |feature| %>
                <div class="public-habitations-show__feature-card flex min-h-[116px] items-center gap-4 rounded-xl border border-gray-100 bg-white p-4 shadow-sm">
                  <div class="public-habitations-show__feature-icon public-habitations-show__feature-icon--<%= feature[:tone] %> flex h-12 w-12 shrink-0 items-center justify-center rounded-xl">
                    <i class="bi <%= feature[:icon] %> text-lg"></i>
                  </div>
                  <div class="min-w-0">
                    <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-gray-400"><%= feature[:label] %></p>
                    <p class="mt-2 text-lg font-extrabold leading-none text-gray-900"><%= feature[:value] %></p>
                  </div>
                </div>
              <% end %>
            </div>
          </section>
        <% end %>

        <section class="public-habitations-show__description">
          <h2 class="public-habitations-show__section-title mb-4 text-sm font-bold uppercase tracking-[0.22em] text-gray-400">Descrição</h2>
          <div class="public-habitations-show__description-card prose prose-gray max-w-none text-gray-600">
            <% description_content = @habitation.display_description %>
            <% if description_content.present? %>
              <%= formatted_habitation_description(description_content) %>
            <% else %>
              <p>Sem descrição disponível.</p>
            <% end %>
          </div>
        </section>

        <%= display_banner('property_detail', container_class: 'w-full my-8') %>

        <% property_features = @habitation.property_features_for_display %>
        <% leisure_features = @habitation.leisure_features_for_display %>
        <% if property_features.any? || leisure_features.any? %>
          <section class="public-habitations-show__amenities space-y-5">
            <h2 class="public-habitations-show__section-title text-sm font-bold uppercase tracking-[0.22em] text-gray-400">Características e Infraestrutura</h2>

            <% if property_features.any? %>
              <div class="public-habitations-show__chip-list flex flex-wrap gap-2">
                <% property_features.each do |feature| %>
                  <span class="public-habitations-show__chip inline-flex items-center gap-2 rounded-full border border-gray-200 bg-white px-3 py-1.5 text-sm text-gray-700">
                    <i class="bi bi-house-check text-golden-one"></i>
                    <%= feature %>
                  </span>
                <% end %>
              </div>
            <% end %>

            <% if leisure_features.any? %>
              <div class="public-habitations-show__chip-list flex flex-wrap gap-2">
                <% leisure_features.each do |feature| %>
                  <span class="public-habitations-show__chip inline-flex items-center gap-2 rounded-full border border-gray-200 bg-white px-3 py-1.5 text-sm text-gray-700">
                    <i class="bi bi-stars text-blue-three"></i>
                    <%= feature %>
                  </span>
                <% end %>
              </div>
            <% end %>
          </section>
        <% end %>
      </main>

      <aside class="public-habitations-show__aside space-y-6">
        <div class="public-habitations-show__desktop-price">
          <%= render "price_card",
              habitation: @habitation,
              title: title,
              has_sale_price: has_sale_price,
              has_rent_price: has_rent_price,
              has_discount: has_discount,
              has_rent_discount: has_rent_discount %>
        </div>

        <% if @shared_broker.present? %>
          <%= render "habitations/shared_broker_card",
              shared_broker: @shared_broker,
              habitation: @habitation,
              share_token: @lead_share_token %>
        <% end %>

        <section class="public-habitations-show__info-card rounded-2xl bg-white p-6 shadow-sm">
          <h3 class="public-habitations-show__section-title text-sm font-bold uppercase tracking-[0.22em] text-gray-400">Informações</h3>
          <div class="mt-4 space-y-3 text-sm">
            <% if @habitation.unique_features.present? %>
              <div>
                <p class="text-gray-500">Característica</p>
                <p class="font-bold text-gray-900"><%= @habitation.unique_features.join(", ") %></p>
              </div>
            <% end %>
            <% if @habitation.delivery_date_visible? %>
              <div>
                <p class="text-gray-500">Previsão de entrega</p>
                <p class="font-bold text-gray-900"><%= l(@habitation.data_entrega, format: :long) %></p>
              </div>
            <% elsif @habitation.data_entrega.present? && @habitation.ready_to_move? %>
              <div>
                <p class="text-gray-500">Situação</p>
                <p class="font-bold text-gray-900">Pronto para morar</p>
              </div>
            <% end %>
          </div>
        </section>

        <% if @public_map.visible? %>
          <% map_place_label = public_property_map_place_label(@habitation) %>
          <section id="localizacao-imovel" class="public-habitations-show__map-card rounded-2xl bg-white p-6 shadow-sm">
            <div class="public-habitations-show__map-heading">
              <div>
                <h3 class="public-habitations-show__section-title text-sm font-bold uppercase tracking-[0.22em] text-gray-400">Localização</h3>
                <p class="public-habitations-show__map-subtitle mt-2 text-sm text-gray-500"><%= @public_map.approximate? ? "Região aproximada do imóvel" : "Localização do imóvel" %></p>
              </div>
              <% if @public_map.external_url.present? %>
                <%= link_to @public_map.external_url, target: "_blank", rel: "noopener noreferrer", class: "public-habitations-show__map-external" do %>
                  <i class="bi bi-box-arrow-up-right"></i>
                  <span>Abrir no Google</span>
                <% end %>
              <% end %>
            </div>

            <div class="public-habitations-show__map-tabs mt-4" role="tablist" aria-label="Visualização da localização">
              <button type="button" class="is-active" role="tab" aria-selected="true" data-public-property-map-target="mapButton" data-action="click->public-property-map#showMap">
                <i class="bi bi-map"></i>Mapa
              </button>
              <% if @public_map.satellite_enabled? %>
                <button type="button" role="tab" aria-selected="false" data-public-property-map-target="satelliteButton" data-action="click->public-property-map#toggleSatellite">
                  <i class="bi bi-globe-americas"></i>Satélite
                </button>
              <% end %>
              <% if @public_map.street_view_enabled? %>
                <button type="button" role="tab" aria-selected="false" data-public-property-map-target="streetViewButton" data-action="click->public-property-map#showStreetView">
                  <i class="bi bi-person-standing"></i>Rua
                </button>
              <% end %>
            </div>

            <div class="public-habitations-show__map-shell mt-3" data-public-property-map-target="shell">
              <div class="public-habitations-show__map"
                   data-public-property-map-target="map"
                   aria-label="<%= @public_map.approximate? ? "Mapa com região aproximada do imóvel" : "Mapa com localização do imóvel" %>"></div>
              <% if @public_map.street_view_enabled? %>
                <div class="public-habitations-show__street-view"
                     data-public-property-map-target="streetView"
                     hidden
                     aria-label="Vista da rua do imóvel"></div>
              <% end %>
            </div>
            <% if map_place_label.present? %>
              <p class="public-habitations-show__map-place mt-3 text-sm font-semibold text-gray-700"><%= map_place_label %></p>
            <% end %>
          </section>
        <% end %>

        <%= display_banner('sidebar', container_class: 'mt-6', force_mobile: true) %>
      </aside>
    </div>

    <% if @related_properties&.any? %>
      <section class="public-habitations-show__related mt-14">
        <h2 class="public-habitations-show__related-title mb-6 text-2xl font-bold text-gray-900">Imóveis Semelhantes</h2>
        <div class="public-habitations-show__related-grid grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          <% @related_properties.each do |property| %>
            <%= render 'shared/tailwind/property_card', property: property %>
          <% end %>
        </div>
      </section>
    <% end %>
  </div>
</div>
