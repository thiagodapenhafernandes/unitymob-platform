<% return unless shared_broker.present? %>

<div class="bg-gradient-to-br from-blue-50 to-white border border-blue-100 rounded-xl p-5 shadow-sm">
  <% attendant_label = habitation.rental_intake? ? "atendente" : "corretor" %>
  <p class="text-xs uppercase tracking-wide text-blue-three font-semibold mb-3">Atendimento com <%= attendant_label %> responsável</p>

  <div class="flex items-center gap-3">
    <div class="w-14 h-14 rounded-full overflow-hidden bg-white border border-blue-100 flex items-center justify-center">
      <% if shared_broker.avatar.attached? %>
        <%= image_tag public_image_url(shared_broker.avatar), class: "w-full h-full object-cover", alt: shared_broker.name %>
      <% else %>
        <i class="bi bi-person text-blue-three text-2xl"></i>
      <% end %>
    </div>

    <div class="min-w-0">
      <p class="font-semibold text-gray-900 truncate"><%= shared_broker.name %></p>
      <% if shared_broker.creci.present? %>
        <p class="text-xs text-gray-500">CRECI <%= shared_broker.creci %></p>
      <% end %>
    </div>
  </div>

  <div class="mt-4">
    <button type="button"
            class="inline-flex w-full items-center justify-center gap-1.5 rounded-lg bg-blue-three px-3 py-2 text-xs font-semibold text-white hover:bg-blue-one"
            data-action="click->lead-capture#open"
            data-property-id="<%= habitation.id %>"
            data-property-code="<%= habitation.codigo %>"
            data-property-title="<%= habitation.display_title %>"
            data-negotiation-type="<%= habitation.whatsapp_negotiation_type %>"
            data-lead-origin="Compartilhamento Corretor"
            data-share-token="<%= share_token %>"
            data-whatsapp-message="Olá, quero falar com <%= shared_broker.name %> sobre o imóvel <%= habitation.display_title %> (Cód: <%= habitation.codigo %>).">
      <i class="bi bi-chat-dots"></i>
      Falar com <%= attendant_label %>
    </button>
  </div>
</div>
