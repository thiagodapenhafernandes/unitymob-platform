<!-- Contato Page - Modern Design -->

<!-- Hero Section -->
<section class="relative h-[400px] flex items-center justify-center bg-cover bg-center" 
         style="background-image: linear-gradient(rgba(30, 64, 175, 0.8), rgba(30, 64, 175, 0.8)), url('<%= asset_path 'hero_05.jpeg' %>');">
  <div class="container-custom relative z-10 text-center text-white">
    <h1 class="text-4xl lg:text-5xl font-bold mb-4" data-aos="fade-up">Entre em Contato</h1>
    <p class="text-xl" data-aos="fade-up" data-aos-delay="100">Estamos prontos para atender você</p>
  </div>
</section>

<!-- Contact Content -->
<section class="py-16 bg-gray-50">
  <div class="container-custom">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      
      <!-- Contact Info Cards -->
      <div class="space-y-6" data-aos="fade-right">
        <h2 class="text-3xl font-bold text-blue-three mb-8">Informações de Contato</h2>
        
        <!-- Address Card -->
        <div class="bg-white p-6 rounded-xl shadow-md hover:shadow-xl transition-shadow">
          <div class="flex items-start gap-4">
            <div class="bg-golden-one/10 p-3 rounded-lg">
              <i class="bi bi-geo-alt text-2xl text-golden-one"></i>
            </div>
            <div>
              <h3 class="text-lg font-bold text-blue-three mb-2">Endereço</h3>
              <p class="text-gray-600"><%= simple_format(@contact_setting.address) %></p>
            </div>
          </div>
        </div>

        <!-- Phone Card -->
        <div class="bg-white p-6 rounded-xl shadow-md hover:shadow-xl transition-shadow">
          <div class="flex items-start gap-4">
            <div class="bg-golden-one/10 p-3 rounded-lg">
              <i class="bi bi-telephone text-2xl text-golden-one"></i>
            </div>
            <div>
              <h3 class="text-lg font-bold text-blue-three mb-2">Telefone</h3>
              <p class="text-gray-600"><%= Phones::Normalizer.display(@contact_setting.phone) %></p>
              <a href="tel:+<%= @contact_setting.phone.to_s.gsub(/\D/, '') %>" class="text-golden-one hover:underline">Ligar agora</a>
            </div>
          </div>
        </div>

        <!-- Email Card -->
        <div class="bg-white p-6 rounded-xl shadow-md hover:shadow-xl transition-shadow">
          <div class="flex items-start gap-4">
            <div class="bg-golden-one/10 p-3 rounded-lg">
              <i class="bi bi-envelope text-2xl text-golden-one"></i>
            </div>
            <div>
              <h3 class="text-lg font-bold text-blue-three mb-2">Email</h3>
              <p class="text-gray-600"><%= @contact_setting.email_primary %></p>
              <a href="mailto:<%= @contact_setting.email_primary %>" class="text-golden-one hover:underline">Enviar email</a>
            </div>
          </div>
        </div>

        <!-- WhatsApp Card -->
        <div class="bg-white p-6 rounded-xl shadow-md hover:shadow-xl transition-shadow">
          <div class="flex items-start gap-4">
            <div class="bg-golden-one/10 p-3 rounded-lg">
              <i class="bi bi-whatsapp text-2xl text-golden-one"></i>
            </div>
            <div>
              <h3 class="text-lg font-bold text-blue-three mb-2">WhatsApp</h3>
              <p class="text-gray-600"><%= Phones::Normalizer.display(@contact_setting.whatsapp_primary) %></p>
              <a href="https://wa.me/<%= @contact_setting.whatsapp_primary.to_s.gsub(/\D/, '') %>" target="_blank" rel="noopener" class="text-golden-one hover:underline">
                Enviar mensagem
              </a>
            </div>
          </div>
        </div>

        <!-- Business Hours -->
        <% if @business_hours.present? %>
        <div class="bg-blue-three text-white p-6 rounded-xl shadow-md">
          <h3 class="text-lg font-bold mb-4 flex items-center gap-2">
            <i class="bi bi-clock"></i>
            Horário de Atendimento
          </h3>
          <div class="space-y-2 text-sm"><%= simple_format(@business_hours) %></div>
        </div>
        <% end %>
      </div>

      <!-- Contact Form -->
      <div data-aos="fade-left">
        <div class="bg-white p-8 rounded-xl shadow-md">
          <h2 class="text-3xl font-bold text-blue-three mb-6">Envie sua Mensagem</h2>
          
          <%= form_with url: contacts_path, method: :post, scope: :contact, local: true, class: "space-y-6" do |f| %>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Nome *</label>
                <%= f.text_field :name, required: true, class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-golden-one focus:border-transparent" %>
              </div>
              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Telefone</label>
                <%= f.telephone_field :phone,
                                      class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-golden-one focus:border-transparent",
                                      autocomplete: "tel",
                                      data: { controller: "phone-input" } %>
              </div>
            </div>

            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Email *</label>
              <%= f.email_field :email, required: true, class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-golden-one focus:border-transparent" %>
            </div>

            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Interesse *</label>
              <%= f.select :interest_intent,
                           [["Vender", "vender"], ["Locar", "locar"], ["Ambos", "ambos"]],
                           { selected: "ambos" },
                           { class: "w-full px-4 py-3 border border-gray-300 rounded-lg bg-white focus:ring-2 focus:ring-golden-one focus:border-transparent" } %>
            </div>

            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Assunto</label>
              <%= f.text_field :subject, class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-golden-one focus:border-transparent" %>
            </div>

            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Mensagem *</label>
              <%= f.text_area :message, rows: 6, required: true, class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-golden-one focus:border-transparent resize-none" %>
            </div>

            <button type="submit"
                    class="w-full bg-golden-one text-blue-three font-bold py-4 px-8 rounded-lg hover:bg-blue-three hover:text-white transition-all duration-300 shadow-md hover:shadow-xl transform hover:-translate-y-0.5">
              <i class="bi bi-send mr-2"></i>
              Enviar Mensagem
            </button>
            <%= render "shared/form_consent_notice" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Map Section (Optional) -->
<section class="h-96 bg-gray-200">
  <iframe 
    src="https://www.google.com/maps?q=<%= ERB::Util.url_encode(@contact_setting.address) %>&amp;output=embed"
    width="100%" 
    height="100%" 
    style="border:0;" 
    allowfullscreen="" 
    loading="lazy">
  </iframe>
</section>
