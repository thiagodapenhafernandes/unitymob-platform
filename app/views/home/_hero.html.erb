<% overlay_color = @home_setting.overlay_color || '#000000' %>
<% overlay_opacity = @home_setting.overlay_opacity || 0.7 %>

<!-- Hero Section - Cinematic Master Edition -->
<section id="hero" class="relative min-h-[75dvh] md:h-[90vh] lg:h-screen flex items-center md:items-center justify-center bg-gray-900 overflow-x-clip"
         data-controller="hero-slider" 
         data-hero-slider-interval-value="10000"
         style="--hero-overlay-start: <%= overlay_color %><%= format('%02x', (overlay_opacity * 255).to_i) %>; 
                --hero-overlay-end: <%= overlay_color %><%= format('%02x', ((overlay_opacity * 0.45) * 255).to_i) %>;">
  
  <!-- Cinematic Slider Container -->
  <div class="hero-slider-container">
    <% (@hero_images.presence || [{ source: asset_path("hero_05.jpeg"), alt: "#{@public_identity.name} - imóveis em destaque" }]).each_with_index do |image, index| %>
      <% desktop_source = public_image_url(image[:source], resize_to_limit: [1920, 1080], format: :webp, representation_proxy: true).presence || image[:source] %>
      <% desktop_source_1440 = public_image_url(image[:source], resize_to_limit: [1440, 810], format: :webp, representation_proxy: true).presence || desktop_source %>
      <% mobile_source_640 = public_image_url(image[:mobile_source] || image[:source], resize_to_limit: [640, 1138], format: :webp, representation_proxy: true).presence || image[:mobile_source] || image[:source] %>
      <% mobile_source_900 = public_image_url(image[:mobile_source] || image[:source], resize_to_limit: [900, 1600], format: :webp, representation_proxy: true).presence || mobile_source_640 %>
      <% placeholder = "data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw==" %>
      <div class="hero-slide <%= 'active' if index == 0 %>" data-hero-slider-target="slide">
        <% if index.zero? %>
          <picture>
            <source media="(max-width: 767px)"
                    srcset="<%= "#{mobile_source_640} 640w, #{mobile_source_900} 900w" %>"
                    sizes="100vw">
            <source media="(min-width: 768px)"
                    srcset="<%= "#{desktop_source_1440} 1440w, #{desktop_source} 1920w" %>"
                    sizes="100vw">
            <%= image_tag(desktop_source,
                          class: "hero-image",
                          alt: image[:alt],
                          width: 1920,
                          height: 1080,
                          sizes: "100vw",
                          fetchpriority: "high",
                          loading: "eager",
                          decoding: "sync") %>
          </picture>
        <% else %>
          <%= image_tag(placeholder,
                        class: "hero-image",
                        alt: image[:alt],
                        width: 1920,
                        height: 1080,
                        sizes: "100vw",
                        fetchpriority: "low",
                        loading: "lazy",
                        decoding: "async",
                        data: {
                          hero_slider_image: true,
                          src: desktop_source,
                          srcset: "#{mobile_source_900} 900w, #{desktop_source} 1920w"
                        }) %>
        <% end %>
      </div>
    <% end %>
  </div>
  
  <!-- Overlay with Premium Gradient -->
  <div class="hero-overlay"></div>
  
  <!-- Content -->
  <div class="container-custom hero-content-wrapper w-full">
    <div class="hero-copy text-center max-w-4xl mx-auto">
      <h1 class="hero-title font-bold text-white tracking-tight px-2 break-words"
          style="--hero-title-configured-size: <%= @home_setting.hero_title_font_size_value %>px;">
        <%= @home_setting.hero_title || "Encontre o imóvel dos seus sonhos" %>
      </h1>
      <p class="hero-subtitle text-white/90 max-w-2xl mx-auto font-medium px-3"
         style="--hero-subtitle-configured-size: <%= @home_setting.hero_subtitle_font_size_value %>px;">
        <%= @home_setting.hero_subtitle.presence || ["As melhores oportunidades", ("em #{@public_identity.primary_city}" if @public_identity.primary_city.present?)].compact.join(" ") %>
      </p>
    </div>

    <!-- Search Form Imobill Style -->
    <div class="relative z-20">
      <%= render 'shared/search_hero_imobill' %>
    </div>
  </div>

  <!-- Bottom Fade to Content (atrás do conteúdo, z baixo pra não cobrir o card) -->
  <div class="absolute bottom-0 left-0 right-0 h-16 md:h-32 bg-gradient-to-t from-gray-900 to-transparent z-[5] pointer-events-none"></div>
</section>
