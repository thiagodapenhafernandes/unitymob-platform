<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    
    <%
      site_name = @layout_setting&.site_name.presence || "Unitymob"
      social_property = defined?(@habitation) ? @habitation : nil
      property_page = social_property.present?
      property_seo_key = "property:#{social_property.codigo.presence || social_property.id}" if property_page
      seo = current_public_seo_setting
      property_seo = seo if property_seo_key.present? && seo&.canonical_key == property_seo_key
      property_seo ||= SeoSetting.for_canonical_key(property_seo_key) if property_seo_key.present?
      seo ||= property_seo if property_seo&.public_applicable? && property_seo.manual_mode?
      seo ||= SeoSetting.for_page(@page_name || 'home') unless property_page
      seo_public = seo&.public_applicable?
      effective_title = (seo_public ? seo.meta_title.presence : nil) || @page_title || "#{site_name} - Encontre seu Imóvel Ideal"
      effective_description = (seo_public ? seo.meta_description.presence : nil) || @page_description || "Os melhores imóveis para venda e locação. Encontre seu imóvel ideal com a #{site_name}."
      effective_keywords = (seo_public ? seo.meta_keywords.presence : nil) || @page_keywords
      effective_robots = seo_public ? seo.robots_content : "index, follow"
      effective_robots = "noindex, follow" if params[:page].to_i >= 3
    %>
    
    <%# Dynamic Metadata %>
    <title><%= effective_title %></title>
    <meta name="description" content="<%= strip_tags(effective_description) %>">
    <% if effective_keywords.present? %>
      <meta name="keywords" content="<%= effective_keywords %>">
    <% end %>
    <meta name="author" content="<%= site_name %>">
    <meta name="robots" content="<%= effective_robots %>">
    
    <%# Resource Hints %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://cdn.jsdelivr.net">
    <% if defined?(@hero_preload_source) && @hero_preload_source.present? %>
      <% hero_preload_source = public_image_url(@hero_preload_source) %>
      <% hero_preload_mobile_source = public_image_url(@hero_preload_mobile_source || @hero_preload_source) %>
      <link rel="preload"
            as="image"
            href="<%= hero_preload_source %>"
            imagesrcset="<%= "#{hero_preload_mobile_source} 900w, #{hero_preload_source} 1920w" %>"
            imagesizes="100vw"
            fetchpriority="high">
    <% end %>
    
    <%# Image Metadata Logic %>
    <% 
      sanitize_utf8 = ->(value) { value.to_s.encode("UTF-8", invalid: :replace, undef: :replace, replace: "").scrub }
      final_image = seo&.social_image_url(base_url: request.base_url, page_image: @page_image) ||
                    @page_image.presence ||
                    "#{request.base_url}/icon.png"
      canonical_url = sanitize_utf8.call(@canonical_url.presence || (seo_public ? seo.public_url(request.base_url) : request.original_url))
      og_title = sanitize_utf8.call((seo_public ? seo.og_title.presence : nil) || effective_title)
      og_description = strip_tags((seo_public ? seo.og_description.presence : nil) || effective_description)
      og_type = social_property.present? ? "product" : "website"
      image_alt = sanitize_utf8.call([og_title, site_name].reject(&:blank?).join(" | "))
      social_price_cents = if social_property.present?
        social_property.valor_venda_cents.to_i.positive? ? social_property.valor_venda_cents : social_property.valor_locacao_cents
      end
      social_price_value = (social_price_cents || 0).to_i
      social_price_amount = social_price_value.positive? ? format("%.2f", social_price_value / 100.0) : nil
      social_modified_at = (seo&.updated_at || social_property&.updated_at)
    %>
    
    <%# Open Graph / Facebook %>
    <meta property="og:type" content="<%= og_type %>">
    <meta property="og:url" content="<%= canonical_url %>">
    <meta property="og:title" content="<%= og_title %>">
    <meta property="og:description" content="<%= og_description %>">
    <meta property="og:site_name" content="<%= site_name %>">
    <meta property="og:locale" content="pt_BR">
    <meta property="og:image" content="<%= final_image %>">
    <meta property="og:image:secure_url" content="<%= final_image.to_s.sub('http://', 'https://') %>">
    <meta property="og:image:alt" content="<%= image_alt %>">
    <% if @page_image_type.present? %>
      <meta property="og:image:type" content="<%= @page_image_type %>">
    <% end %>
    <% if @page_image_width.present? && @page_image_height.present? %>
      <meta property="og:image:width" content="<%= @page_image_width %>">
      <meta property="og:image:height" content="<%= @page_image_height %>">
    <% end %>
    <% if social_modified_at.present? %>
      <meta property="og:updated_time" content="<%= social_modified_at.iso8601 %>">
    <% end %>
    <% if social_property.present? && social_price_amount.present? %>
      <meta property="product:price:amount" content="<%= social_price_amount %>">
      <meta property="product:price:currency" content="BRL">
      <meta property="product:availability" content="in stock">
    <% end %>
    
    <%# Twitter %>
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content="<%= canonical_url %>">
    <meta name="twitter:title" content="<%= og_title %>">
    <meta name="twitter:description" content="<%= og_description %>">
    <meta name="twitter:image" content="<%= final_image %>">
    <meta name="twitter:image:alt" content="<%= image_alt %>">
    
    <link rel="canonical" href="<%= canonical_url %>">
    <% if @layout_setting&.favicon&.attached? %>
      <link rel="icon" href="<%= public_image_url(@layout_setting.favicon) %>">
    <% else %>
      <link rel="icon" href="/icon.png">
    <% end %>
    
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= render "layouts/tracking_head", tracking_setting: @tracking_setting %>
    <%= yield :head %>

    <%# Critical Third Party Styles %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" media="print" onload="this.media='all'">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" media="print" onload="this.media='all'">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0/dist/fancybox/fancybox.css" media="print" onload="this.media='all'">

    <%# Fonts loading with swap %>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600;700&family=Raleway:wght@300;400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    
    <%# Layout Settings (Colors) %>
    <style>
      :root {
        --color-primary: <%= @layout_setting&.primary_color || '#022B3A' %>;
        --color-secondary: <%= @layout_setting&.secondary_color || '#053C5E' %>;
        --color-accent: <%= @layout_setting&.accent_color || '#BFAB25' %>;
        --color-hero-button: <%= @home_setting&.hero_button_color || '#BFAB25' %>;
        --color-hero-button-text: <%= @home_setting&.hero_button_text_color || '#FFFFFF' %>;
      }
    </style>

    <%# Theme Styles %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%
      public_page_stylesheets = []
      if controller_path == "habitations"
        if action_name == "index"
          public_page_stylesheets << "public_habitations_index_refresh"
        elsif action_name == "show"
          public_page_stylesheets << "public_development_show_refresh" if @is_development_page
        end
      end
    %>
    <% public_page_stylesheets.each do |stylesheet| %>
      <%= stylesheet_link_tag stylesheet, "data-turbo-track": "reload" %>
    <% end %>
    <%= stylesheet_link_tag "ax_toast", "data-turbo-track": "reload" %>
    
    <%# JS with Defer %>
    <%= javascript_importmap_tags "public" %>
  </head>

  <% interest_settings = @interest_settings || InterestIntelligence::Settings.new(@layout_setting || LayoutSetting.instance) %>
  <body class="antialiased"
        data-controller="lead-capture public-interest-tracker"
        data-lead-capture-enabled-value="<%= @lead_capture_enabled %>"
        data-lead-capture-phone-settings-value="<%= json_escape(@site_phone_settings.to_json) %>"
        data-lead-capture-share-token-value="<%= @lead_share_token %>"
        data-public-interest-tracker-enabled-value="<%= interest_settings.enabled? %>"
        data-public-interest-tracker-consent-required-value="<%= interest_settings.enabled_value?("requires_public_tracking_consent") %>"
        data-public-interest-tracker-property-id-value="<%= @habitation&.id %>"
        data-public-interest-tracker-property-code-value="<%= @habitation&.codigo %>"
        data-public-interest-tracker-property-category-value="<%= @habitation&.categoria %>"
        data-public-interest-tracker-property-city-value="<%= @habitation&.cidade.presence || @habitation&.read_attribute(:cidade) %>"
        data-public-interest-tracker-property-neighborhood-value="<%= @habitation&.bairro.presence || @habitation&.read_attribute(:bairro) %>"
        data-public-interest-tracker-property-bedrooms-value="<%= @habitation&.dormitorios_qtd %>"
        data-public-interest-tracker-property-parking-spaces-value="<%= @habitation&.vagas_qtd %>"
        data-public-interest-tracker-property-price-cents-value="<%= @habitation&.valor_venda_cents.presence || @habitation&.valor_locacao_cents %>">
    <%= render "layouts/tracking_body", tracking_setting: @tracking_setting %>
    <%= render 'layouts/header' %>
    
    <main role="main">
      <%= render 'shared/flash_messages', toast: true if flash.any? %>

      <%= yield %>
    </main>
    
    <%= render 'layouts/footer' %>
    <%= render "layouts/interest_tracking_consent", settings: interest_settings %>
    
    <%# Performance: Defer non-critical external libraries %>
    <script>
      function loadDeferredAssets() {
        var scripts = [
          'https://unpkg.com/aos@2.3.1/dist/aos.js'
        ];

        scripts.forEach(function(src) {
          if (document.querySelector('script[src="' + src + '"]')) return;

          var s = document.createElement('script');
          s.src = src;
          s.async = true;
          if (src.includes('aos.js')) {
            s.onload = function() { AOS.init({ duration: 800, once: true }); };
          }
          document.body.appendChild(s);
        });
      }

      if (window.addEventListener) window.addEventListener('load', loadDeferredAssets);
      else if (window.attachEvent) window.attachEvent('onload', loadDeferredAssets);
    </script>
    
    <%= render 'shared/code_search_modal' %>
    <%= render 'shared/lead_modal' %>
    <%= render 'shared/lgpd_consent' %>
  </body>
</html>
