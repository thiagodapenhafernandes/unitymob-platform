<% tracking_setting ||= TrackingIntegrationSetting.current %>
<% gtm_container_id = tracking_setting.normalized_google_tag_manager_container_id %>
<% meta_pixel_id = tracking_setting.normalized_meta_pixel_id %>
<% tracking_requires_consent = !lgpd_consent_accepted? %>
<% has_gtm = tracking_setting.google_tag_manager_enabled? && gtm_container_id.present? %>
<% has_meta_pixel = tracking_setting.meta_pixel_enabled? && meta_pixel_id.present? %>

<% if has_gtm || has_meta_pixel %>
  <script>
    (function(w,d){
      var COOKIE_KEY = "salute_lgpd_consent";
      var STORAGE_KEY = "salute_lgpd_consent_v1";
      var ACCEPTED_VALUE = "accepted";
      var loaded = false;

      function consentAccepted() {
        if (!<%= tracking_requires_consent ? "true" : "false" %>) return true;
        if (d.cookie.split(";").some(function(cookie) { return cookie.trim() === COOKIE_KEY + "=" + ACCEPTED_VALUE; })) return true;

        try {
          return w.localStorage.getItem(STORAGE_KEY) === ACCEPTED_VALUE;
        } catch (_error) {
          return false;
        }
      }

      function loadScript(src) {
        if (d.querySelector('script[src="' + src + '"]')) return;

        var script = d.createElement("script");
        script.async = true;
        script.src = src;
        d.head.appendChild(script);
      }

      function loadTracking() {
        if (loaded || !consentAccepted()) return;
        loaded = true;

        <% if has_gtm %>
          w.dataLayer = w.dataLayer || [];
          w.dataLayer.push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
          loadScript("https://www.googletagmanager.com/gtm.js?id=<%= j gtm_container_id %>");
        <% end %>

        <% if has_meta_pixel %>
          if (!w.fbq) {
            var fbq = w.fbq = function() {
              fbq.callMethod ? fbq.callMethod.apply(fbq, arguments) : fbq.queue.push(arguments);
            };
            if (!w._fbq) w._fbq = fbq;
            fbq.push = fbq;
            fbq.loaded = true;
            fbq.version = "2.0";
            fbq.queue = [];
          }
          loadScript("https://connect.facebook.net/en_US/fbevents.js");
          w.fbq("init", "<%= j meta_pixel_id %>");
          w.fbq("track", "PageView");
        <% end %>
      }

      w.SaluteTracking = { load: loadTracking };
      loadTracking();
      w.addEventListener("salute:lgpd-consent-accepted", loadTracking);
    })(window, document);
  </script>
<% end %>
