<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title><%= @layout_setting&.site_name.presence || 'Salute Imóveis' %> - Admin</title>
    <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no,viewport-fit=cover">
    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>
    <%= render 'layouts/no_zoom' %>
    <%= render 'layouts/pwa_meta' %>
    
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- Tom Select -->
    <link href="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet">
    <!-- Trix Editor -->
    <link rel="stylesheet" type="text/css" href="https://unpkg.com/trix@2.0.8/dist/trix.css">
    <!-- Fancybox -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0/dist/fancybox/fancybox.css">
    
    <%= stylesheet_link_tag "admin", media: "all" %>
    <meta name="theme-color" content="#ffffff">

    <!-- Google Fonts: Inter & Outfit -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <%= javascript_importmap_tags %>

    <!-- Global Bootstrap/Turbo Fix -->
    <script>
      document.addEventListener("turbo:load", function() {
        // Simple fix: Close all open dropdowns/collapses if they somehow persisted between visits
        document.querySelectorAll('.dropdown-toggle.show').forEach(el => {
          const dd = bootstrap.Dropdown.getInstance(el);
          if (dd) dd.hide();
        });
        
        document.querySelectorAll('.collapse.show').forEach(el => {
          const cl = bootstrap.Collapse.getInstance(el);
          if (cl) cl.hide();
        });

        // Initialize tooltips if any
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
          return new bootstrap.Tooltip(tooltipTriggerEl)
        })
      });
    </script>
  </head>

  <%
    drawer_catalog_layout = controller_path == "admin/habitations" && action_name == "index"
    body_classes = ["admin-layout"]
    body_classes << "admin-drawer-catalog-layout" if drawer_catalog_layout
    sidebar_offcanvas_classes = ["offcanvas", "offcanvas-start", "admin-sidebar-offcanvas"]
    sidebar_offcanvas_classes << "d-md-none" unless drawer_catalog_layout
  %>
  <body class="<%= body_classes.join(' ') %>">
    <!-- Navbar -->
    <nav class="admin-navbar">
      <button type="button" class="admin-navbar-toggle <%= 'd-md-none' unless drawer_catalog_layout %>" data-bs-toggle="offcanvas" data-bs-target="#adminSidebarOffcanvas" aria-label="Abrir menu">
        <i class="bi bi-list"></i>
      </button>
      <%= link_to((current_admin_user&.admin? ? admin_root_path : field_root_path), class: "admin-navbar-brand") do %>
        <i class="bi bi-speedometer2"></i>
        <span class="admin-navbar-brand-text"><%= @layout_setting&.site_name.presence || 'Salute' %> Admin</span>
      <% end %>
      <div class="admin-navbar-user">
        <span class="admin-navbar-user-name d-none d-sm-inline">
          <i class="bi bi-person-circle"></i> <%= current_admin_user&.name.to_s.split.first || current_admin_user&.email %>
        </span>
        <%= link_to destroy_admin_user_session_path, data: { turbo_method: :delete }, class: "btn btn-sm btn-outline-danger admin-navbar-logout" do %>
          <i class="bi bi-box-arrow-right"></i><span class="d-none d-sm-inline ms-1">Sair</span>
        <% end %>
      </div>
    </nav>

    <!-- Sidebar desktop (>= md) -->
    <aside class="admin-sidebar <%= drawer_catalog_layout ? 'd-none' : 'd-none d-md-block' %>">
      <%= render 'admin/shared/sidebar' %>
    </aside>

    <!-- Sidebar mobile (offcanvas, < md) -->
    <div class="<%= sidebar_offcanvas_classes.join(' ') %>" tabindex="-1" id="adminSidebarOffcanvas">
      <div class="offcanvas-header border-bottom">
        <span class="fw-bold text-primary"><i class="bi bi-speedometer2 me-1"></i>Menu</span>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Fechar"></button>
      </div>
      <div class="offcanvas-body p-0">
        <%= render 'admin/shared/sidebar' %>
      </div>
    </div>

    <!-- Pull-to-refresh indicator -->
    <div id="admin-ptr" class="admin-ptr">
      <div class="admin-ptr-pill">
        <i id="admin-ptr-icon" class="bi bi-arrow-down"></i>
        <span id="admin-ptr-label">Arraste para atualizar</span>
      </div>
    </div>

    <!-- Content -->
    <main class="admin-content">
      <% if impersonating_admin_user? %>
        <div class="alert alert-warning d-flex flex-wrap align-items-center justify-content-between gap-2 shadow-sm mb-3" role="alert">
          <div>
            <i class="bi bi-person-check-fill me-2"></i>
            Você está acessando como <strong><%= current_admin_user.name %></strong>.
            Admin original: <strong><%= impersonation_admin_user.name %></strong>.
          </div>
          <%= button_to admin_impersonation_path,
                method: :delete,
                class: "btn btn-sm btn-dark fw-semibold",
                form_class: "mb-0" do %>
            <i class="bi bi-arrow-counterclockwise me-1"></i> Voltar ao admin
          <% end %>
        </div>
      <% end %>
      <%= render 'shared/flash_messages' if flash.any? %>
      <%= yield %>
    </main>
    
    <%= render 'layouts/pwa_service_worker' %>
    <script>
      (function () {
        const PULL_THRESHOLD = 70;
        const MAX_PULL = 140;
        const indicator = document.getElementById("admin-ptr");
        const icon = document.getElementById("admin-ptr-icon");
        const label = document.getElementById("admin-ptr-label");
        if (!indicator || !window.matchMedia("(max-width: 767.98px)").matches) return;

        let startY = 0;
        let startX = 0;
        let pulling = false;
        let refreshArmed = false;
        let refreshing = false;

        function atTop() {
          return (window.scrollY || window.pageYOffset || 0) <= 0;
        }

        function reset() {
          indicator.style.transform = "translate(-50%, -80px)";
          icon.className = "bi bi-arrow-down";
          icon.style.transform = "rotate(0deg)";
          icon.style.animation = "";
          label.textContent = "Arraste para atualizar";
          refreshArmed = false;
        }

        document.addEventListener("touchstart", function (event) {
          if (refreshing || !atTop() || event.touches.length !== 1) {
            pulling = false;
            return;
          }

          startY = event.touches[0].clientY;
          startX = event.touches[0].clientX;
          pulling = true;
        }, { passive: true });

        document.addEventListener("touchmove", function (event) {
          if (!pulling || refreshing) return;

          const touch = event.touches[0];
          const dy = touch.clientY - startY;
          const dx = Math.abs(touch.clientX - startX);

          if (dx > Math.abs(dy)) {
            pulling = false;
            reset();
            return;
          }

          if (dy <= 0 || !atTop()) {
            reset();
            return;
          }

          const pulled = Math.min(dy, MAX_PULL);
          indicator.style.transform = `translate(-50%, ${pulled - 80}px)`;

          if (pulled >= PULL_THRESHOLD && !refreshArmed) {
            refreshArmed = true;
            icon.style.transform = "rotate(180deg)";
            label.textContent = "Solte para atualizar";
          } else if (pulled < PULL_THRESHOLD && refreshArmed) {
            refreshArmed = false;
            icon.style.transform = "rotate(0deg)";
            label.textContent = "Arraste para atualizar";
          }
        }, { passive: true });

        document.addEventListener("touchend", function () {
          if (!pulling) return;
          pulling = false;

          if (refreshArmed) {
            refreshing = true;
            icon.className = "bi bi-arrow-repeat";
            icon.style.animation = "admin-ptr-spin .8s linear infinite";
            label.textContent = "Atualizando...";
            indicator.style.transform = "translate(-50%, 10px)";
            setTimeout(function () { window.location.reload(); }, 300);
          } else {
            reset();
          }
        }, { passive: true });
      })();
    </script>
  </body>
</html>
