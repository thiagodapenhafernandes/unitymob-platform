<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <%
      account_site_name = @layout_setting&.site_name.presence || 'Salute Imóveis'
      account_admin_area_name = @layout_setting.respond_to?(:admin_area_label) ? @layout_setting.admin_area_label : 'Plataforma'
    %>
    <title><%= current_admin_user&.system_admin? ? 'Unitymob Plataforma' : "#{account_site_name} - #{account_admin_area_name}" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no,viewport-fit=cover">
    <link rel="manifest" href="<%= admin_manifest_path(format: :json) %>">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-title" content="<%= (defined?(LayoutSetting) ? LayoutSetting.instance.site_name.presence : nil) || 'Plataforma' %>">
    <link rel="apple-touch-icon" href="/pwa-icon-192">
    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>
    <%= render 'layouts/no_zoom' %>
    <%= render 'layouts/pwa_meta' %>
    <%
      admin_controller_path = controller_path.to_s
      admin_action_name = action_name.to_s
      admin_rich_text_assets = admin_controller_path == "admin/habitations" && %w[new edit].include?(admin_action_name)
      admin_fancybox_assets = (
        admin_controller_path == "admin/habitations" && %w[new edit show].include?(admin_action_name)
      ) || admin_controller_path == "admin/habitation_media" ||
          admin_controller_path == "admin/whatsapp_inbox" ||
          (admin_controller_path == "admin/leads" && admin_action_name == "show")
    %>
    
    <%# CSS de framework legado removido — substituído pela camada de compatibilidade (admin_compat) + Tailwind admin %>
    <%# Vendors self-hosted (sem CDN de terceiros em runtime) %>
    <!-- Bootstrap Icons -->
    <%= stylesheet_link_tag "vendor/bootstrap-icons", media: "all" %>
    <!-- Tom Select -->
    <%= stylesheet_link_tag "vendor/tom-select.bootstrap5.min", media: "all" %>
    <% if admin_rich_text_assets %>
      <!-- Trix Editor (CSS 2.0.8 self-hosted, mesmo arquivo antes servido pelo unpkg) -->
      <%= stylesheet_link_tag "vendor/trix", media: "all" %>
    <% end %>
    <%# Caminho do CSS do Fancybox para carga sob demanda pelo fancybox_gallery_controller %>
    <meta name="fancybox-css-path" content="<%= stylesheet_path("vendor/fancybox") %>">
    <% if admin_fancybox_assets %>
      <!-- Fancybox -->
      <%= stylesheet_link_tag "vendor/fancybox", media: "all" %>
    <% end %>
    
    <%= stylesheet_link_tag "admin", media: "all" %>
    <%# Camada de compatibilidade de classes legadas (telas ainda não 100% migradas, no visual novo) %>
    <%= stylesheet_link_tag "admin_compat", media: "all" %>
    <%# Novo design system da plataforma interna (Tailwind, prefixo tw-, namespaced .ax-*) %>
    <%= stylesheet_link_tag "admin_tailwind", media: "all" %>
    <%= stylesheet_link_tag "habitations_form_refresh", media: "all" %>
    <%= stylesheet_link_tag "whatsapp_inbox_refresh", media: "all" %>
    <%# Toast compartilhado (mesma identidade em todo o sistema) %>
    <%= stylesheet_link_tag "ax_toast", media: "all" %>
    <%# Tema white-label da plataforma interna, independente dos tokens do site público. %>
    <%
      admin_surface_color = @layout_setting&.respond_to?(:admin_surface_color) ? @layout_setting.admin_surface_color.presence : nil
      admin_header_color = @layout_setting&.respond_to?(:admin_header_color) ? @layout_setting.admin_header_color.presence : nil
      admin_workspace_color = @layout_setting&.respond_to?(:admin_workspace_color) ? @layout_setting.admin_workspace_color.presence : nil
      admin_sidebar_color = @layout_setting&.respond_to?(:admin_sidebar_color) ? @layout_setting.admin_sidebar_color.presence : nil
      admin_ink_color = @layout_setting&.respond_to?(:admin_ink_color) ? @layout_setting.admin_ink_color.presence : nil
    %>
    <style>
      :root {
        --admin-surface: <%= admin_surface_color || LayoutSetting::ADMIN_SURFACE_DEFAULT %>;
        --admin-surface-header: <%= admin_header_color || LayoutSetting::ADMIN_HEADER_DEFAULT %>;
        --admin-workspace-bg: <%= admin_workspace_color || LayoutSetting::ADMIN_WORKSPACE_DEFAULT %>;
        --admin-sidebar-bg: <%= admin_sidebar_color || LayoutSetting::ADMIN_SIDEBAR_DEFAULT %>;
        --admin-primary: <%= @layout_setting&.admin_primary_color.presence || LayoutSetting::ADMIN_PRIMARY_DEFAULT %>;
        --admin-ink: <%= admin_ink_color || LayoutSetting::ADMIN_INK_DEFAULT %>;
        --admin-primary-fg: #ffffff;
      }

      .fancybox__container {
        --fancybox-zIndex: 5000;
        z-index: 5000 !important;
      }

      .habitation-media-page-body {
        display: block;
        height: 100%;
        min-height: 0;
        overflow-y: auto;
        overflow-x: hidden;
        overscroll-behavior: contain;
        scroll-padding-bottom: 96px;
      }

      .habitation-media-page-body .habitation-media-module-form {
        display: grid !important;
        grid-template-rows: auto minmax(0, 1fr) auto;
        gap: 8px;
        min-height: 100%;
        padding-bottom: 8px;
      }

      .habitation-media-page-body .habitation-media-module-form > .ax-form-workspace {
        min-height: 0;
        overflow: visible;
      }

      .habitation-media-page-body .habitation-media-module-form > .habitation-action-bar {
        grid-column: auto;
        grid-row: auto;
        margin: 0 !important;
        border-width: 1px !important;
        border-radius: 8px;
        box-shadow: none !important;
      }

      .habitation-media-page-body .ax-media-toolbar {
        align-items: flex-start;
        min-height: 32px;
      }

      .habitation-media-page-body .ax-media-toolbar__title {
        line-height: 1.15;
      }

      body.ax-app .habitation-form-ui .ax-media-grid__item {
        display: flex !important;
        flex-direction: column !important;
        gap: 4px !important;
        min-width: 0;
      }

      body.ax-app .habitation-form-ui .ax-media-grid {
        transition: gap .16s ease, padding .16s ease !important;
      }

      body.ax-app .habitation-form-ui .ax-media-grid.is-sorting {
        gap: 16px 10px !important;
        padding-block: 6px !important;
      }

      body.ax-app .habitation-form-ui .media-gallery-scroll {
        overscroll-behavior: contain !important;
        scroll-padding-block: 152px !important;
      }

      body.ax-app .habitation-form-ui .media-gallery-scroll.is-sorting {
        scroll-behavior: auto !important;
      }

      body.ax-app .habitation-form-ui .ax-media-tile__link {
        cursor: zoom-in !important;
      }

      body.ax-app .habitation-form-ui .media-photo-tile > .media-photo-overlay {
        justify-content: flex-start !important;
        background: linear-gradient(180deg, rgba(15, 23, 42, .24) 0%, rgba(15, 23, 42, 0) 46%) !important;
      }

      body.ax-app .habitation-form-ui .ax-media-tile__footer {
        display: flex !important;
        align-items: center !important;
        justify-content: space-between !important;
        gap: 3px !important;
        min-height: 28px !important;
        padding: 0 2px !important;
      }

      body.ax-app .habitation-form-ui .ax-media-tile__footer-slot {
        display: flex !important;
        align-items: center !important;
        min-width: 0 !important;
      }

      body.ax-app .habitation-form-ui .ax-media-tile__footer-slot--left {
        justify-content: flex-start !important;
      }

      body.ax-app .habitation-form-ui .ax-media-tile__footer-slot--right {
        justify-content: flex-end !important;
      }

      body.ax-app .habitation-form-ui .ax-media-action-group {
        display: inline-flex !important;
        align-items: center !important;
        gap: 3px !important;
      }

      body.ax-app .habitation-form-ui .ax-media-tile__footer .ax-media-action {
        flex: 0 0 auto !important;
        width: 26px !important;
        min-width: 26px !important;
        min-height: 26px !important;
        padding: 0 !important;
      }

      body.ax-app .habitation-form-ui .ax-media-tile__footer .media-photo-action-button {
        height: 26px !important;
      }

      body.ax-app .habitation-form-ui .sortable-chosen {
        z-index: 4 !important;
      }

      body.ax-app .habitation-form-ui .sortable-ghost {
        opacity: 1 !important;
      }

      body.ax-app .habitation-form-ui .sortable-ghost .ax-media-tile__frame {
        border: 2px dashed color-mix(in srgb, var(--admin-primary, #365f8f) 68%, #fff) !important;
        background: linear-gradient(135deg, rgba(54, 95, 143, .08), rgba(54, 95, 143, .02)) !important;
        box-shadow: inset 0 0 0 999px rgba(238, 243, 248, .72), 0 0 0 4px rgba(54, 95, 143, .10) !important;
      }

      body.ax-app .ax-media-sortable-fallback {
        z-index: 2600 !important;
        opacity: .96 !important;
        pointer-events: none !important;
        transform: rotate(.6deg) scale(.985);
        box-shadow: 0 18px 38px rgba(15, 23, 42, .20);
      }

      body.ax-app .ax-media-sortable-fallback .ax-media-tile__footer {
        opacity: .62 !important;
      }
    </style>
    <script>
      try {
        if (window.localStorage.getItem("ax-sidebar-compact") === "1") {
          document.documentElement.classList.add("ax-sidebar-compact-preload");
        }
        if (window.localStorage.getItem("admin-habitations-inspector-collapsed") === "1") {
          document.documentElement.classList.add("ax-inspector-collapsed-preload");
        }
        if (window.localStorage.getItem("admin-habitation-form-editor-collapsed") === "1") {
          document.documentElement.classList.add("ax-habitation-editor-collapsed-preload");
        }
        if (window.localStorage.getItem("admin-webhook-settings-aside-collapsed") === "1") {
          document.documentElement.classList.add("ax-webhook-settings-aside-collapsed-preload");
        }
      } catch (_) {}

    </script>
    <meta name="theme-color" content="#ffffff">

    <!-- Fontes Inter & Outfit self-hosted (antes Google Fonts) -->
    <%= stylesheet_link_tag "vendor/admin-fonts", media: "all" %>
    <%# JS de framework legado removido — comportamento data-* legado tratado em application.js %>
    <%= javascript_importmap_tags %>
  </head>

  <% builder_layout = false %>
  <% habitations_workspace = (controller_name == 'habitations' && %w[index edit new].include?(action_name)) || controller_name == 'habitation_media' %>
  <% habitation_form_workspace = controller_name == 'habitations' && %w[edit new].include?(action_name) %>
  <% habitation_editor_workspace = (controller_name == 'habitations' && %w[edit new].include?(action_name)) || controller_name == 'habitation_media' %>
  <% distribution_rule_editor_workspace = controller_name == 'distribution_rules' && %w[new edit].include?(action_name) %>
  <% webhook_settings_workspace = controller_name == 'webhook_settings' && action_name == 'index' %>
  <% whatsapp_workspace = controller_name == 'whatsapp_inbox' %>
  <% whatsapp_focus_workspace = whatsapp_workspace && params[:workspace].to_s == 'focus' %>
  <% admin_metrics = admin_page_render_metrics %>
  <body class="ax-app admin-layout <%= 'ax-builder-layout' if builder_layout %> <%= 'ax-habitations-workspace' if habitations_workspace %> <%= 'ax-habitation-form-workspace' if habitation_form_workspace %> <%= 'ax-habitation-editor-workspace' if habitation_editor_workspace %> <%= 'ax-distribution-rule-editor-workspace' if distribution_rule_editor_workspace %> <%= 'ax-webhook-settings-workspace' if webhook_settings_workspace %> <%= 'ax-whatsapp-workspace' if whatsapp_workspace %> <%= 'ax-whatsapp-focus-workspace' if whatsapp_focus_workspace %>"
        data-controller="ax-drawer admin-navigation"
        data-admin-render-ms="<%= admin_metrics[:duration_ms] %>"
        data-admin-render-page="<%= admin_metrics[:page] %>">
    <% unless whatsapp_focus_workspace %>
      <%# ===== Navbar (novo shell Tailwind) ===== %>
      <nav class="ax-navbar">
        <button type="button" class="ax-navbar__toggle" data-action="ax-drawer#toggle" aria-label="Abrir menu">
          <i class="bi bi-list"></i>
        </button>
        <% brand_path = current_admin_user&.system_admin? ? admin_system_path : (current_admin_user&.tenant_owner? ? admin_root_path : field_root_path) %>
        <%= link_to(brand_path, class: "ax-navbar__brand") do %>
          <span class="ax-navbar__brand-mark"><i class="bi bi-buildings"></i></span>
          <span class="ax-navbar__brand-text"><% if current_admin_user&.system_admin? %>Unitymob <span>Plataforma</span><% else %><%= account_site_name %> <span><%= account_admin_area_name %></span><% end %></span>
        <% end %>

        <%= render "admin/shared/context_items" %>

        <div class="ax-navbar__spacer"></div>

        <div class="ax-navbar__user" data-controller="ax-dropdown">
          <button type="button" class="ax-navbar__user-trigger" data-action="ax-dropdown#toggle" data-ax-dropdown-target="trigger" aria-expanded="false" aria-label="Menu do usuário">
            <span class="ax-navbar__avatar"><i class="bi bi-person"></i></span>
            <span class="tw-hidden sm:tw-inline"><%= current_admin_user&.name.presence || current_admin_user&.email %></span>
            <i class="bi bi-chevron-down tw-text-xs tw-text-ink-faint"></i>
          </button>
          <div class="ax-menu" data-ax-dropdown-target="menu" hidden style="right:0; left:auto;">
            <div class="tw-px-2.5 tw-py-1.5 tw-text-xs tw-text-ink-muted tw-truncate"><%= current_admin_user&.notification_email %></div>
            <%# Multi-conta: troca sem relogin (só fora de impersonação e com 2+ contas) %>
            <%# Troca de contas: recurso de ADMIN DE CONTAS — só aparece quando a
                identidade primária é Admin da Conta (tenant_owner) na conta natal. %>
            <% if current_admin_user && !current_admin_user.system_admin? && session[:impersonator_admin_user_id].blank? &&
                  (current_admin_user.login_identity.tenant_owner? rescue false) %>
              <% accounts = current_admin_user.switchable_accounts rescue [] %>
              <% if accounts.size > 1 %>
                <div class="ax-menu__sep"></div>
                <div class="tw-px-2.5 tw-py-1 tw-text-[10px] tw-font-extrabold tw-uppercase tw-tracking-wide tw-text-ink-muted">Contas</div>
                <% accounts.each do |entry| %>
                  <% is_current = entry[:admin_user].id == current_admin_user.id %>
                  <% if is_current %>
                    <div class="ax-menu__item" style="cursor:default;opacity:.7">
                      <i class="bi bi-check2"></i><span><%= entry[:tenant].name %></span>
                    </div>
                  <% else %>
                    <%= button_to admin_account_switch_path(tenant_id: entry[:tenant].id), method: :post,
                          class: "ax-menu__item", form: { class: "tw-block tw-w-full", data: { turbo: false } } do %>
                      <i class="bi bi-arrow-left-right"></i><span><%= entry[:tenant].name %></span>
                    <% end %>
                  <% end %>
                <% end %>
              <% end %>
            <% end %>
            <div class="ax-menu__sep"></div>
            <%= link_to admin_two_factor_settings_path, class: "ax-menu__item" do %>
              <i class="bi bi-shield-lock"></i><span>Verificação em duas etapas</span>
            <% end %>
            <div class="ax-menu__sep"></div>
            <%= link_to destroy_admin_user_session_path, data: { turbo_method: :delete }, class: "ax-menu__item ax-menu__item--danger" do %>
              <i class="bi bi-box-arrow-right"></i><span>Sair</span>
            <% end %>
          </div>
        </div>
      </nav>

      <div class="ax-sidebar-contextbar">
        <span class="ax-contextbar__title"><i class="bi bi-layout-sidebar"></i><span>Explorer</span></span>
        <div class="ax-contextbar__tools">
          <button type="button" class="ax-contextbar__tool ax-contextbar__tool--collapse" data-action="ax-drawer#toggleResponsive" aria-label="Menu lateral" title="Menu lateral">
            <i class="bi bi-arrow-bar-left"></i>
          </button>
        </div>
      </div>

      <% unless habitations_workspace || distribution_rule_editor_workspace || webhook_settings_workspace %>
        <div class="ax-contextbar">
          <div class="ax-contextbar__main">
            <nav class="ax-breadcrumb" aria-label="Contexto atual">
              <%= admin_contextbar_navigation %>
            </nav>

            <div class="ax-contextbar__actions">
              <%= admin_contextbar_actions %>
            </div>
          </div>
        </div>
      <% end %>

      <%# Backdrop do drawer (mobile) %>
      <div class="ax-drawer-backdrop lg:tw-hidden" data-ax-drawer-target="backdrop" hidden data-action="click->ax-drawer#close"></div>

      <%# ===== Sidebar (desktop fixa / mobile drawer) ===== %>
      <aside class="ax-sidebar" data-ax-drawer-target="panel">
        <%= render 'admin/shared/sidebar' %>
      </aside>
    <% end %>

    <% unless whatsapp_focus_workspace %>
      <!-- Pull-to-refresh indicator -->
      <div id="admin-ptr" class="admin-ptr">
        <div class="admin-ptr-pill">
          <i id="admin-ptr-icon" class="bi bi-arrow-down"></i>
          <span id="admin-ptr-label">Arraste para atualizar</span>
        </div>
      </div>
    <% end %>

    <!-- Content -->
    <main class="ax-main">
      <% if respond_to?(:impersonating_admin_user?) && impersonating_admin_user? %>
        <div class="alert alert-warning d-flex flex-wrap align-items-center justify-content-between gap-2 shadow-sm mb-3" role="alert">
          <div>
            <i class="bi bi-person-check-fill me-2"></i>
            Você está acessando como <strong><%= current_admin_user.name %></strong>.
            Admin original: <strong><%= impersonation_admin_user.name %></strong>.
          </div>
          <%= button_to admin_impersonation_path,
                method: :delete,
                class: "btn btn-sm btn-dark fw-semibold",
                form_class: "mb-0" do %>
            <i class="bi bi-arrow-counterclockwise me-1"></i> Voltar ao admin
          <% end %>
        </div>
      <% end %>
      <%= render 'shared/flash_messages', toast: true if flash.any? %>
      <%= yield %>
    </main>

    <div id="adminNavigationPreloader"
         class="ax-admin-preloader"
         data-admin-navigation-target="overlay"
         data-turbo-permanent
         hidden
         aria-live="polite"
         aria-busy="true">
      <div class="ax-admin-preloader__panel" role="status">
        <span class="ax-admin-preloader__spinner" aria-hidden="true"></span>
        <strong data-admin-navigation-target="title">Carregando página...</strong>
        <span data-admin-navigation-target="detail">Preparando workspace administrativo</span>
      </div>
    </div>

    <%= render "admin/habitations/media/modal_shell" %>
    
    <div id="admin-offline-banner" hidden
         style="position: fixed; top: 0; left: 0; right: 0; z-index: 4090; padding: 8px 14px; background: #b54708; color: #fff; font-size: 12.5px; font-weight: 600; text-align: center;">
      <i class="bi bi-wifi-off"></i> Sem conexão — suas ações podem não ser salvas até a internet voltar.
    </div>
    <script>
      (function () {
        var banner = document.getElementById("admin-offline-banner");
        function sync() { banner.hidden = navigator.onLine; }
        window.addEventListener("online", sync);
        window.addEventListener("offline", sync);
        sync();
      })();
    </script>
    <%= render 'layouts/pwa_service_worker' %>
    <%= render 'layouts/admin_push_subscriptions' if current_admin_user %>
    <script>
      (function () {
        const PULL_THRESHOLD = 70;
        const MAX_PULL = 140;
        const indicator = document.getElementById("admin-ptr");
        const icon = document.getElementById("admin-ptr-icon");
        const label = document.getElementById("admin-ptr-label");
        if (!indicator || !window.matchMedia("(max-width: 767.98px)").matches) return;

        let startY = 0;
        let startX = 0;
        let pulling = false;
        let refreshArmed = false;
        let refreshing = false;

        function atTop() {
          return (window.scrollY || window.pageYOffset || 0) <= 0;
        }

        function reset() {
          indicator.style.transform = "translate(-50%, -80px)";
          icon.className = "bi bi-arrow-down";
          icon.style.transform = "rotate(0deg)";
          icon.style.animation = "";
          label.textContent = "Arraste para atualizar";
          refreshArmed = false;
        }

        document.addEventListener("touchstart", function (event) {
          if (refreshing || !atTop() || event.touches.length !== 1) {
            pulling = false;
            return;
          }

          startY = event.touches[0].clientY;
          startX = event.touches[0].clientX;
          pulling = true;
        }, { passive: true });

        document.addEventListener("touchmove", function (event) {
          if (!pulling || refreshing) return;

          const touch = event.touches[0];
          const dy = touch.clientY - startY;
          const dx = Math.abs(touch.clientX - startX);

          if (dx > Math.abs(dy)) {
            pulling = false;
            reset();
            return;
          }

          if (dy <= 0 || !atTop()) {
            reset();
            return;
          }

          const pulled = Math.min(dy, MAX_PULL);
          indicator.style.transform = `translate(-50%, ${pulled - 80}px)`;

          if (pulled >= PULL_THRESHOLD && !refreshArmed) {
            refreshArmed = true;
            icon.style.transform = "rotate(180deg)";
            label.textContent = "Solte para atualizar";
          } else if (pulled < PULL_THRESHOLD && refreshArmed) {
            refreshArmed = false;
            icon.style.transform = "rotate(0deg)";
            label.textContent = "Arraste para atualizar";
          }
        }, { passive: true });

        document.addEventListener("touchend", function () {
          if (!pulling) return;
          pulling = false;

          if (refreshArmed) {
            refreshing = true;
            icon.className = "bi bi-arrow-repeat";
            icon.style.animation = "admin-ptr-spin .8s linear infinite";
            label.textContent = "Atualizando...";
            indicator.style.transform = "translate(-50%, 10px)";
            setTimeout(function () { window.location.reload(); }, 300);
          } else {
            reset();
          }
        }, { passive: true });
      })();
    </script>
  </body>
</html>
