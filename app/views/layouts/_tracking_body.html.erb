<% tracking_setting ||= TrackingIntegrationSetting.current %>
<% gtm_container_id = tracking_setting.normalized_google_tag_manager_container_id %>
<% meta_pixel_id = tracking_setting.normalized_meta_pixel_id %>

<% if tracking_setting.google_tag_manager_enabled? && gtm_container_id.present? %>
  <noscript>
    <iframe src="https://www.googletagmanager.com/ns.html?id=<%= gtm_container_id %>"
            height="0"
            width="0"
            style="display:none;visibility:hidden"></iframe>
  </noscript>
<% end %>

<% if tracking_setting.meta_pixel_enabled? && meta_pixel_id.present? %>
  <noscript>
    <img height="1"
         width="1"
         style="display:none"
         src="https://www.facebook.com/tr?id=<%= meta_pixel_id %>&ev=PageView&noscript=1"
         alt="">
  </noscript>
<% end %>
