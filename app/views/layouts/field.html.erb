<!DOCTYPE html>
<html lang="pt-BR" data-field-theme="<%= current_admin_user&.effective_admin_theme_mode || AdminUser::ADMIN_THEME_MODE_DEFAULT %>">
  <head>
    <% field_layout_setting = defined?(LayoutSetting) ? LayoutSetting.instance : nil %>
    <% field_primary_color = field_layout_setting&.admin_primary_color.presence || '#365F8F' %>
    <% field_icon_version = field_layout_setting&.updated_at.to_i %>
    <% field_theme_mode = current_admin_user&.effective_admin_theme_mode || AdminUser::ADMIN_THEME_MODE_DEFAULT %>
    <% field_theme_color = field_theme_mode == "dark" ? LayoutSetting::ADMIN_DARK_THEME[:header] : field_primary_color %>
    <title>Salute Imóveis — Campo</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover">
    <meta name="theme-color" content="<%= field_theme_color %>">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-title" content="Salute Campo">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= render 'layouts/no_zoom' %>

    <link rel="manifest" href="<%= field_manifest_path(format: :json) %>">
    <link rel="apple-touch-icon" href="/pwa-icon-192?v=<%= field_icon_version %>">
    <link rel="icon" type="image/png" sizes="192x192" href="/pwa-icon-192?v=<%= field_icon_version %>">
    <link rel="icon" type="image/png" sizes="512x512" href="/pwa-icon-512?v=<%= field_icon_version %>">

    <%# Bootstrap e ícones self-hosted (antes jsdelivr) %>
    <%= stylesheet_link_tag "vendor/bootstrap.min" %>
    <%= stylesheet_link_tag "vendor/bootstrap-icons" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "ax_toast", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "field_theme", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      :root { --field-primary: <%= field_primary_color %>; }
    </style>

    <script>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", function () {
          navigator.serviceWorker.register("/field-service-worker.js", { scope: "/", updateViaCache: "none" })
            .then(function (reg) {
              console.log("[field SW] registered, scope:", reg.scope);
              window.__fieldSWReg = reg;
              reg.update().catch(function (err) { console.warn("[field SW] update check failed:", err); });
              // IMPORTANTE: nunca pedir permissão no load — o iOS só mostra o prompt
              // a partir de um gesto do usuário. No load apenas renovamos se já concedido.
              if (pushSupported() && Notification.permission === "granted") {
                subscribeToPush(reg);
              } else {
                maybePromptForPush();
              }
            })
            .catch(function (err) { console.warn("[field SW] registration failed:", err); });
        });
      }

      function pushSupported() {
        return "serviceWorker" in navigator && "PushManager" in window && "Notification" in window;
      }

      // iOS só entrega Web Push em PWA instalado na tela inicial (standalone).
      function isStandalone() {
        return window.matchMedia("(display-mode: standalone)").matches || window.navigator.standalone === true;
      }

      // Mostra um banner com botão "Ativar notificações" quando a permissão ainda
      // não foi decidida. O clique no botão é o gesto exigido pelo iOS.
      function maybePromptForPush() {
        if (!pushSupported() || Notification.permission !== "default") return;
        if (document.getElementById("field-push-banner")) return;

        const banner = document.createElement("div");
        banner.id = "field-push-banner";
        banner.className = "field-push-banner";
        banner.innerHTML =
          '<span class="field-push-banner__copy">Ative as notificações para receber novos leads na hora.</span>' +
          '<button type="button" id="field-push-enable" class="field-push-banner__enable">Ativar</button>' +
          '<button type="button" id="field-push-dismiss" class="field-push-banner__dismiss" aria-label="Dispensar">&times;</button>';
        document.body.appendChild(banner);

        document.getElementById("field-push-enable").addEventListener("click", enablePush);
        document.getElementById("field-push-dismiss").addEventListener("click", function () { banner.remove(); });
      }

      // Pede permissão a partir do toque do usuário e assina (fluxo válido no iOS).
      async function enablePush() {
        if (!pushSupported()) return;
        try {
          const permission = await Notification.requestPermission();
          const banner = document.getElementById("field-push-banner");
          if (banner) banner.remove();
          if (permission !== "granted") {
            if (permission === "denied") {
              alert("Notificações bloqueadas. Ative em Ajustes do iPhone › Notificações para este app.");
            }
            return;
          }
          const reg = window.__fieldSWReg || await navigator.serviceWorker.ready;
          await subscribeToPush(reg);
        } catch (e) {
          console.warn("[push] enable failed:", e);
        }
      }

      // Assina o push (reutiliza a subscription existente). Só age com permissão concedida.
      async function subscribeToPush(registration) {
        if (!pushSupported() || Notification.permission !== "granted") return;

        try {
          // Busca a VAPID public key do servidor
          const keyResp = await fetch("/field/push_subscriptions/vapid_key", { credentials: "same-origin" });
          if (!keyResp.ok) return;
          const { public_key } = await keyResp.json();
          if (!public_key) {
            console.warn("[push] VAPID public key ausente no servidor (reinicie a app com VAPID_PUBLIC_KEY).");
            return;
          }

          let existing = await registration.pushManager.getSubscription();
          const oldEndpoint = existing && existing.endpoint;
          if (existing && !subscriptionUsesServerKey(existing, public_key)) {
            console.warn("[push] subscription usa VAPID antigo; renovando inscrição.");
            await existing.unsubscribe();
            existing = null;
          }

          const sub = existing || await registration.pushManager.subscribe({
            userVisibleOnly: true,
            applicationServerKey: urlBase64ToUint8Array(public_key)
          });

          try {
            if ("periodicSync" in registration) {
              await registration.periodicSync.register("push-subscription-refresh", { minInterval: 12 * 60 * 60 * 1000 });
            }
          } catch (_e) { /* sem suporte: renovação segue pelos outros gatilhos */ }

          const csrfToken = document.querySelector("[name=csrf-token]")?.content;
          await fetch("/field/push_subscriptions", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "X-CSRF-Token": csrfToken || "",
              "Accept": "application/json"
            },
            credentials: "same-origin",
            body: JSON.stringify({ subscription: sub.toJSON(), old_endpoint: oldEndpoint })
          });
        } catch (e) {
          console.warn("[push] subscribe failed:", e);
        }
      }

      function subscriptionUsesServerKey(subscription, publicKey) {
        try {
          const currentKey = subscription.options && subscription.options.applicationServerKey;
          if (!currentKey) return true;

          const serverKey = urlBase64ToUint8Array(publicKey);
          const current = new Uint8Array(currentKey);
          if (current.length !== serverKey.length) return false;

          return current.every((value, index) => value === serverKey[index]);
        } catch (e) {
          console.warn("[push] falha ao comparar VAPID da subscription", e);
          return true;
        }
      }

      function urlBase64ToUint8Array(base64) {
        const padding = "=".repeat((4 - base64.length % 4) % 4);
        const base = (base64 + padding).replace(/-/g, "+").replace(/_/g, "/");
        const raw = atob(base);
        return Uint8Array.from(raw, c => c.charCodeAt(0));
      }
    </script>

    <script type="module">
      // FingerprintJS open-source — hash estável por dispositivo/browser.
      // Usado como sinal de antifraude (detecção de fingerprint duplicado).
      // Self-hosted via importmap (vendor/javascript/@fingerprintjs--fingerprintjs.js).
      import FingerprintJS from "@fingerprintjs/fingerprintjs";
      (async function () {
        try {
          const fp = await FingerprintJS.load();
          const result = await fp.get();
          window.__fieldFingerprint = result.visitorId;
        } catch (e) {
          console.warn("[field fp] failed:", e);
        }
      })();
    </script>

    <style>
      html, body {
        background: #f8f9fa;
        min-height: 100vh;
        min-height: 100dvh;
        /* O /field não tem navbar fixo — então nada de "testa" de 54px.
           Reserva apenas o status bar / notch quando rodando como PWA
           standalone (iOS); no navegador o inset é 0 e o conteúdo sobe. */
        padding-top: env(safe-area-inset-top, 0px);
      }
      .field-layout {
        max-width: 480px;
        margin: 0 auto;
        padding: 0.75rem 1rem 5rem;
      }
      .field-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        padding: 1.25rem;
      }
      .field-status-banner {
        border-radius: 16px;
        padding: 1.5rem;
        margin-bottom: 1rem;
        text-align: center;
      }
      .status-ok    { background: #d1e7dd; color: #0a3622; }
      .status-warn  { background: #fff3cd; color: #664d03; }
      .status-error { background: #f8d7da; color: #58151c; }
      .status-info  { background: #cff4fc; color: #055160; }
      .status-neutral { background: #e9ecef; color: #495057; }
      .big-action-btn {
        width: 100%;
        padding: 1.25rem;
        font-size: 1.1rem;
        font-weight: 600;
        border-radius: 12px;
      }
    </style>
  </head>
  <body>
    <%= render 'shared/flash_messages', toast: true if flash.any? %>

    <div id="field-offline-banner" class="field-offline-banner">
      <i class="bi bi-wifi-off"></i> Você está offline — pings ficarão em fila.
    </div>

    <!-- Modal de instalação específico da PWA Field. -->
    <div id="field-install-overlay" class="field-install-overlay">
      <div class="field-install-card">
        <div class="field-install-header">
          <div class="field-install-icon">
            <i class="bi bi-phone"></i>
          </div>
          <h3>Instale o app Salute Campo</h3>
          <p>Experiência mais rápida, notificações e acesso offline.</p>
        </div>

        <div id="field-install-android" class="field-install-section">
          <ul>
            <li>Abre como app, sem barra de endereço</li>
            <li>GPS em background funciona melhor</li>
            <li>Pings continuam quando app fica escondido</li>
          </ul>
          <button id="field-install-btn" class="field-install-btn-primary">
            <i class="bi bi-download"></i> Instalar agora
          </button>
          <ol id="field-install-android-manual" class="field-install-android-manual">
            <li>Toque em <i class="bi bi-three-dots-vertical"></i> (menu do navegador)</li>
            <li>Escolha <strong>"Instalar app"</strong> ou <strong>"Adicionar à tela inicial"</strong></li>
            <li>Confirme em "Instalar"</li>
          </ol>
        </div>

        <div id="field-install-ios" class="field-install-section">
          <ol>
            <li>Toque em <i class="bi bi-box-arrow-up"></i> <strong>Compartilhar</strong> na barra do navegador</li>
            <li>Escolha <strong>"Adicionar à Tela de Início"</strong></li>
            <li>Confirme em "Adicionar"</li>
          </ol>
        </div>

        <div id="field-install-fallback" class="field-install-section">
          <p>Abra no Chrome (Android) ou Safari (iPhone) e use a opção "Instalar app" ou "Adicionar à Tela de Início" do navegador.</p>
        </div>

        <button id="field-install-dismiss" class="field-install-btn-link">
          Continuar no navegador por enquanto
        </button>
      </div>
    </div>

    <style>
      .field-push-banner {
        position: fixed;
        right: 12px;
        bottom: 12px;
        left: 12px;
        z-index: 9999;
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px;
        border-radius: 12px;
        background: #0f172a;
        color: #fff;
        box-shadow: 0 8px 30px rgba(0, 0, 0, .25);
        font-size: 14px;
      }
      .field-push-banner__copy { flex: 1; line-height: 1.3; }
      .field-push-banner__enable,
      .field-push-banner__dismiss { border: 0; cursor: pointer; }
      .field-push-banner__enable {
        padding: 8px 12px;
        border-radius: 8px;
        background: #22c55e;
        color: #04210f;
        font-weight: 700;
      }
      .field-push-banner__dismiss {
        padding: 4px;
        background: transparent;
        color: #94a3b8;
        font-size: 18px;
        line-height: 1;
      }
      .field-offline-banner {
        display: none;
        padding: .5rem 1rem;
        border-bottom: 1px solid #ffe69c;
        background: #fff3cd;
        color: #664d03;
        font-size: .875rem;
        text-align: center;
      }
      .field-install-overlay {
        position: fixed;
        inset: 0;
        z-index: 1060;
        display: none;
        background: rgba(15, 23, 42, .75);
        backdrop-filter: blur(4px);
      }
      .field-install-android-manual { display: none; }
      .field-ptr {
        position: fixed;
        top: env(safe-area-inset-top, 0px);
        left: 50%;
        z-index: 1030;
        transform: translate(-50%, -80px);
        transition: transform .2s ease;
        pointer-events: none;
      }
      .field-ptr__pill {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .5rem 1rem;
        border: 1px solid #e5e7eb;
        border-radius: 999px;
        background: #fff;
        color: #0f172a;
        box-shadow: 0 4px 12px rgba(0, 0, 0, .08);
        font-size: .85rem;
      }
      .field-ptr__icon { transition: transform .2s; }
      .field-install-card {
        position: absolute;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 16px 48px rgba(0,0,0,.25);
        padding: 1.5rem;
        max-width: 420px;
        width: 92%;
        max-height: 90vh;
        overflow-y: auto;
      }
      .field-install-header { text-align: center; margin-bottom: 1rem; }
      .field-install-icon {
        width: 64px; height: 64px;
        border-radius: 14px;
        background: color-mix(in srgb, var(--field-primary) 12%, transparent);
        color: var(--field-primary);
        font-size: 2rem;
        display: inline-flex;
        align-items: center; justify-content: center;
        margin-bottom: .75rem;
      }
      .field-install-header h3 { font-size: 1.25rem; font-weight: 700; margin: 0 0 .25rem; color: #0f172a; }
      .field-install-header p { font-size: .875rem; color: #64748b; margin: 0; }
      .field-install-section { display: none; }
      .field-install-section.active { display: block; }
      .field-install-section ul, .field-install-section ol {
        font-size: .875rem; color: #64748b;
        padding-left: 1.25rem; margin: 0 0 1rem;
      }
      .field-install-section li { margin-bottom: .25rem; }
      .field-install-section p { font-size: .875rem; color: #64748b; margin: 0 0 1rem; }
      .field-install-btn-primary {
        width: 100%;
        background: var(--field-primary); color: #fff;
        border: none; border-radius: 10px;
        padding: .875rem 1rem;
        font-size: 1rem; font-weight: 600;
        cursor: pointer;
        margin-bottom: .5rem;
      }
      .field-install-btn-primary:active { background: color-mix(in srgb, var(--field-primary) 82%, #000); }
      .field-install-btn-link {
        display: block;
        width: 100%;
        background: none; border: none;
        color: #64748b; font-size: .875rem;
        padding: .75rem;
        cursor: pointer;
      }
    </style>

    <!-- Pull-to-refresh indicator -->
    <div id="field-ptr" class="field-ptr">
      <div class="field-ptr__pill">
        <i id="field-ptr-icon" class="bi bi-arrow-down field-ptr__icon"></i>
        <span id="field-ptr-label">Arraste para atualizar</span>
      </div>
    </div>

    <main class="field-layout">
      <%= yield %>
    </main>

    <% field_ai_setting = current_admin_user && current_tenant ? PropertySetting.instance(tenant: current_tenant) : nil %>
    <% if field_ai_setting&.ai_property_search_enabled? && field_ai_setting.voice_property_search_enabled? && field_ai_setting.ai_property_search_available_to?(current_admin_user) && controller_name != "property_searches" %>
      <%= link_to field_property_search_path(voice: "1"),
            class: "field-ai-search-fab",
            aria: { label: "Buscar imóveis por voz" },
            title: "Buscar imóveis por voz" do %>
        <i class="bi bi-mic-fill" aria-hidden="true"></i>
      <% end %>
    <% end %>

    <script>
      (function () {
        const DISMISS_KEY = "field_install_dismissed_until";
        const overlay   = document.getElementById("field-install-overlay");
        const androidBox = document.getElementById("field-install-android");
        const iosBox    = document.getElementById("field-install-ios");
        const fallback  = document.getElementById("field-install-fallback");
        const installBtn = document.getElementById("field-install-btn");
        const dismissBtn = document.getElementById("field-install-dismiss");

        function isStandalone() {
          return window.matchMedia("(display-mode: standalone)").matches
              || window.navigator.standalone === true;
        }

        function isIos() {
          // iPadOS moderno se anuncia como "Macintosh" — o toque entrega
          return (/iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream)
              || (/Macintosh/.test(navigator.userAgent) && navigator.maxTouchPoints > 1);
        }

        function isAndroid() {
          return /Android/i.test(navigator.userAgent);
        }

        function shouldShow() {
          if (isStandalone()) return false;
          if (!navigator.onLine) return false;  // offline: não faz sentido
          const until = parseInt(localStorage.getItem(DISMISS_KEY) || "0", 10);
          if (until && Date.now() < until) return false;
          return true;
        }

        function showOverlay(mode) {
          if (!shouldShow()) return;
          androidBox.classList.remove("active");
          iosBox.classList.remove("active");
          fallback.classList.remove("active");
          if (mode === "android" || mode === "android-manual") {
            androidBox.classList.add("active");
            const manual = mode === "android-manual";
            const manualSteps = document.getElementById("field-install-android-manual");
            if (installBtn) installBtn.style.display = manual ? "none" : "";
            if (manualSteps) manualSteps.style.display = manual ? "block" : "none";
          } else if (mode === "ios") {
            iosBox.classList.add("active");
          } else {
            fallback.classList.add("active");
          }
          overlay.style.display = "block";
        }

        function hideOverlay() {
          overlay.style.display = "none";
        }

        let deferredPrompt;
        window.addEventListener("beforeinstallprompt", function (e) {
          e.preventDefault();
          deferredPrompt = e;
          // so incomoda em celular/tablet — no desktop o app de campo nao faz sentido
          if (isAndroid() && shouldShow()) showOverlay("android");
        });

        if (shouldShow()) {
          if (isIos()) {
            setTimeout(() => showOverlay("ios"), 800);
          } else if (isAndroid()) {
            // Chrome dispara beforeinstallprompt (instala em 1 toque); navegadores
            // sem o evento (Samsung Internet, Firefox...) recebem o passo a passo
            setTimeout(() => { if (!deferredPrompt) showOverlay("android-manual"); }, 2500);
          }
        }

        if (installBtn) {
          installBtn.addEventListener("click", function () {
            if (!deferredPrompt) return;
            deferredPrompt.prompt();
            deferredPrompt.userChoice.finally(function () {
              deferredPrompt = null;
              hideOverlay();
            });
          });
        }

        if (dismissBtn) {
          dismissBtn.addEventListener("click", function () {
            localStorage.setItem(DISMISS_KEY, (Date.now() + 7 * 24 * 60 * 60 * 1000).toString());
            hideOverlay();
          });
        }

        // Indicador offline
        function toggleOffline() {
          const banner = document.getElementById("field-offline-banner");
          if (!banner) return;
          if (navigator.onLine) banner.style.display = "none";
          else banner.style.display = "block";
        }
        window.addEventListener("online", toggleOffline);
        window.addEventListener("offline", toggleOffline);
        toggleOffline();
      })();

      // Pull-to-refresh — arrastar pra baixo no topo recarrega a página
      (function () {
        const PULL_THRESHOLD = 70;      // px até marcar como "pode soltar"
        const MAX_PULL = 140;            // limite visual
        const indicator = document.getElementById("field-ptr");
        const icon      = document.getElementById("field-ptr-icon");
        const label     = document.getElementById("field-ptr-label");
        if (!indicator) return;

        let startY = 0;
        let pulling = false;
        let refreshArmed = false;
        let refreshing = false;

        function atTop() {
          return (window.scrollY || window.pageYOffset || 0) <= 0;
        }

        function show(y) {
          // y em pixels de translate (começa de -80)
          indicator.style.transform = `translate(-50%, ${y - 80}px)`;
        }

        function reset() {
          indicator.style.transform = "translate(-50%, -80px)";
          icon.style.transform = "rotate(0deg)";
          label.textContent = "Arraste para atualizar";
          refreshArmed = false;
        }

        document.addEventListener("touchstart", (e) => {
          if (refreshing) return;
          if (!atTop()) { pulling = false; return; }
          startY = e.touches[0].clientY;
          pulling = true;
        }, { passive: true });

        document.addEventListener("touchmove", (e) => {
          if (!pulling || refreshing) return;
          const dy = e.touches[0].clientY - startY;
          if (dy <= 0) { reset(); return; }
          if (!atTop()) { pulling = false; reset(); return; }

          const pulled = Math.min(dy, MAX_PULL);
          show(pulled);

          if (pulled >= PULL_THRESHOLD && !refreshArmed) {
            refreshArmed = true;
            icon.style.transform = "rotate(180deg)";
            label.textContent = "Solte para atualizar";
          } else if (pulled < PULL_THRESHOLD && refreshArmed) {
            refreshArmed = false;
            icon.style.transform = "rotate(0deg)";
            label.textContent = "Arraste para atualizar";
          }
        }, { passive: true });

        document.addEventListener("touchend", () => {
          if (!pulling) return;
          pulling = false;

          if (refreshArmed) {
            refreshing = true;
            label.textContent = "Atualizando…";
            icon.className = "bi bi-arrow-repeat";
            icon.style.animation = "field-ptr-spin .8s linear infinite";
            // fixa o indicador visível
            indicator.style.transform = "translate(-50%, 10px)";
            setTimeout(() => window.location.reload(), 300);
          } else {
            reset();
          }
        }, { passive: true });
      })();
    </script>

    <style>
      @keyframes field-ptr-spin { from { transform: rotate(0); } to { transform: rotate(360deg); } }
    </style>
  </body>
</html>
