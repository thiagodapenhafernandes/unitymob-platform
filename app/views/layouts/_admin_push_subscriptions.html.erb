<%# Inscreve o PWA admin no Web Push em Android/mobile e iOS instalado.
    No Safari iOS (não instalado) o push nem existe — orienta a instalar. %>
<script>
  (function () {
    const ua = navigator.userAgent;
    const isAndroid = /Android/i.test(ua);
    const isIosDevice = /iPad|iPhone|iPod/.test(ua) || (/Macintosh/.test(ua) && navigator.maxTouchPoints > 1);
    const isStandalone = window.matchMedia("(display-mode: standalone)").matches || window.navigator.standalone === true;

    // iOS no navegador: sem PushManager fora do app instalado. Instalação e
    // push no celular vivem no /field (o login mobile já aterrissa lá).
    if (isIosDevice && !isStandalone) return;

    if (!("serviceWorker" in navigator) || !("PushManager" in window) || !("Notification" in window)) return;
    // Android mobile OU iOS com o PWA instalado (Web Push iOS exige app na tela de início)
    if (!(isAndroid && window.matchMedia("(max-width: 767.98px)").matches) && !(isIosDevice && isStandalone)) return;

    const bannerId = "admin-push-banner";

    window.addEventListener("load", function () {
      navigator.serviceWorker.register("/field-service-worker.js", { scope: "/field/", updateViaCache: "none" })
        .then(function (registration) {
          if (Notification.permission === "granted") {
            subscribeToLeadPush(registration);
          } else if (Notification.permission === "default") {
            showEnableBanner(registration);
          }
        })
        .catch(function (error) { console.warn("[admin push] service worker register failed:", error); });
    });

    function showEnableBanner(registration) {
      if (document.getElementById(bannerId)) return;

      const banner = document.createElement("div");
      banner.id = bannerId;
      banner.className = "ax-push-permission-banner";
      banner.innerHTML =
        '<span class="ax-push-permission-banner__copy">Ative notificações para receber novos leads neste aparelho.</span>' +
        '<button type="button" id="admin-push-enable" class="ax-push-permission-banner__enable">Ativar</button>' +
        '<button type="button" id="admin-push-dismiss" class="ax-push-permission-banner__dismiss" aria-label="Dispensar">&times;</button>';
      document.body.appendChild(banner);

      document.getElementById("admin-push-enable").addEventListener("click", async function () {
        try {
          const permission = await Notification.requestPermission();
          banner.remove();
          if (permission === "granted") await subscribeToLeadPush(registration);
        } catch (error) {
          console.warn("[admin push] permission failed:", error);
        }
      });
      document.getElementById("admin-push-dismiss").addEventListener("click", function () { banner.remove(); });
    }

    async function subscribeToLeadPush(registration) {
      try {
        const keyResp = await fetch("/field/push_subscriptions/vapid_key", {
          credentials: "same-origin",
          headers: { "Accept": "application/json" }
        });
        if (!keyResp.ok) return;

        const data = await keyResp.json();
        if (!data.public_key) return;

        let existing = await registration.pushManager.getSubscription();
        const oldEndpoint = existing && existing.endpoint;

        if (existing && !subscriptionUsesServerKey(existing, data.public_key)) {
          await existing.unsubscribe();
          existing = null;
        }

        const subscription = existing || await registration.pushManager.subscribe({
          userVisibleOnly: true,
          applicationServerKey: urlBase64ToUint8Array(data.public_key)
        });

        try {
          if ("periodicSync" in registration) {
            await registration.periodicSync.register("push-subscription-refresh", { minInterval: 12 * 60 * 60 * 1000 });
          }
        } catch (_e) { /* sem suporte/permissão: renovação fica pelos outros gatilhos */ }

        const csrfToken = document.querySelector("[name=csrf-token]")?.content;
        await fetch("/field/push_subscriptions", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "X-CSRF-Token": csrfToken || "",
            "Accept": "application/json"
          },
          credentials: "same-origin",
          body: JSON.stringify({ subscription: subscription.toJSON(), old_endpoint: oldEndpoint, source: "admin_android" })
        });
      } catch (error) {
        console.warn("[admin push] subscribe failed:", error);
      }
    }

    function subscriptionUsesServerKey(subscription, publicKey) {
      try {
        const currentKey = subscription.options && subscription.options.applicationServerKey;
        if (!currentKey) return true;

        const serverKey = urlBase64ToUint8Array(publicKey);
        const current = new Uint8Array(currentKey);
        if (current.length !== serverKey.length) return false;

        return current.every(function (value, index) { return value === serverKey[index]; });
      } catch (error) {
        console.warn("[admin push] falha ao comparar VAPID da subscription", error);
        return true;
      }
    }

    function urlBase64ToUint8Array(base64) {
      const padding = "=".repeat((4 - base64.length % 4) % 4);
      const base = (base64 + padding).replace(/-/g, "+").replace(/_/g, "/");
      const raw = atob(base);
      return Uint8Array.from(raw, function (char) { return char.charCodeAt(0); });
    }
  })();
</script>
